#------------- Vieille Brioude 01/03 au 30/04 = dévalaison
#Attention on travaille sur les smolts mais s_juv2ad indicé t sur les retours d'adultes.
#Les adultes sont issus du retour des juvéniles produit en t-3,t-4 et t-5 pour 1/3 chaque.
#Les smolts ont une année de plus par rapport à l'année de production, d'où pour une année t de retour il faut considérer les Q des année t-2, t-3 et t-4 à 1/3 chaque
data_Q<-read.csv(file=file.path(dossier_externe, "Data/co-variables environnement/Q_Vieille-Brioude_1919-2020.csv"),sep=";",dec=",")
#on reformate le champ date 
data_Q$date<-as.Date(data_Q$Jour,"%d/%m/%Y")
data_Q[is.na(data_Q$Q),]

data_Q_mars_avril<-data_Q[between(month(data_Q$date),3 ,4),]
data_Q_mars_avril$year<-year(data_Q_mars_avril$date)
mean_data_Q_MA<-data_Q_mars_avril%>%group_by(year)%>%summarise(meanMA=mean(Q,na.rm=TRUE))
running.mean<- function(x, n = 3){stats::filter(x, rep(1 / n, n), sides = 1)}
#calculer la moyenne pondérée avec poids identique (1/3) revient à calculer une moyenne glissante sur fenêtre 3 ans
#plus facile de faire comme ça sinon il faut trouver comment se décaler sur les plages d'années avec moyenne pondérée
mean_indic_adult<-running.mean(mean_data_Q_MA,3)
#Il faut changer les années en face de chaque moyenne pondérée car la première valeur correspond aux juvéniles à l'origine des adultes de retour en 1979
year<-seq(1975,2020,1)
mean_indic_adult<-cbind(year,as.vector(mean_indic_adult[55:100,2])) #commence à 55 car 1ere année retour adulte=1975 qui sont issus des juv 1971 à 1973 centré sur 1972 (t=55) et finit à 44 car dernière année pour les retours adultes 2020=2018 c-à-d période 2016-2018 qui est centrée sur 2017 soit t=100


#------------- Montjean sur Loire
data_Q2<-read.csv(file=file.path(dossier_externe, "Data/co-variables environnement/Q_Montjean_1863-2020_V3.csv"),sep=";",dec=",")
#on reformate le champ date 
data_Q2$date<-as.Date(data_Q2$Jour,"%d/%m/%Y")
data_Q2$date[is.na(data_Q2$date)]<-as.Date(data_Q2$Jour[is.na(data_Q2$date)],"%Y-%m-%d") #des date sont formatées dans un autre format
nrow(data_Q2[is.na(data_Q2$Q),]) #28 jour avec des débit en NA uniquement sur 2021
data_Q2$year<-year(data_Q2$date)
data_Q2$month<-month(data_Q2$date)
