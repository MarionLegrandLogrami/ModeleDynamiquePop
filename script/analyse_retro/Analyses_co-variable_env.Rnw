<<date_entree_SAT,echo=FALSE, eval=FALSE,results=hide >>=
	sat<-read.csv(file="C:/Users/utilisateur/Documents/Tableau de Bord/PROJETS/ModeleDynamiquePopSaumon/Data/CaptureSAT_Loire.csv",sep=";")
	#on reformate le champ date 
	#Sys.setlocale('LC_TIME', "French_France")
	Sys.setlocale("LC_TIME", "English_United States")
	sat$date2<-as.Date(sat$date,"%d-%b-%y")
	sat$year<-year(sat$date2)
	sat$month<-month(sat$date2)
	colnames(sat)[2]<-"riv"
	sat<-sat[!(sat$riv=="ARROUX"),]
	
	sat_yr_month<-sat%>%group_by(riv,year,month)%>%summarise(count=n())
	
	p<-ggplot(data=sat_yr_month,aes(x=as.factor(month),y=count,fill=as.factor(year)))+
			geom_bar(stat="identity",position="dodge")+
			facet_wrap(~riv,ncol=1)+
			xlab("Mois")+
			scale_fill_discrete(name=iconv("Année","UTF8"))+
			theme(legend.position="bottom")
	
	png(file="C:/Users/utilisateur/workspace/ModeleDynamiquePop/data/CaptureSAT_1987-1993.png",height=600,width=800)
	print(p)
	dev.off()
@

<<passage_stacomi,echo=FALSE, eval=FALSE,results=hide>>=
	
stacomi<-sqldf("Select  s.sta_nom,dc.dic_code,op.ope_date_debut,t.tax_nom_commun,st.std_libelle,l.lot_effectif, CASE WHEN car_par_code='C001' THEN car_valeur_quantitatif ELSE NULL END as taille
				From logrami.t_station_sta s
				left join logrami.t_ouvrage_ouv o on (s.sta_code=o.ouv_sta_code)
				left join logrami.t_dispositiffranchissement_dif df on (df.dif_ouv_identifiant=o.ouv_identifiant)
				left join logrami.t_dispositifcomptage_dic dc on (dc.dic_dif_identifiant=df.dif_dis_identifiant)
				left join logrami.t_operation_ope op on (op.ope_dic_identifiant = dc.dic_dis_identifiant)
				left join logrami.t_lot_lot l on (l.lot_ope_identifiant = op.ope_identifiant)
				left join logrami.tj_caracteristiquelot_car c on (c.car_lot_identifiant=l.lot_identifiant and c.car_par_code='C001')
				JOIN ref.tr_taxon_tax t ON (t.tax_code::text = l.lot_tax_code::text)
				JOIN ref.tr_stadedeveloppement_std st on (st.std_code=l.lot_std_code)
				where l.lot_lot_identifiant is null and l.lot_tax_code='2220' and st.std_libelle='Adulte' and (sta_nom like'Vichy' OR sta_nom like 'Langeac')
				order by 1,2,3,4,5")

#verif effectif
as.data.frame(stacomi%>%group_by(sta_nom,year(ope_date_debut))%>%summarise(sum=sum(lot_effectif,na.rm=TRUE)))
stacomi$year<-year(stacomi$ope_date_debut)
stacomi$month<-month(stacomi$ope_date_debut)
stacomi$jj<-yday(stacomi$ope_date_debut)
stacomi_yr_month<-stacomi%>%group_by(sta_nom,year,month)%>%summarise(sum=sum(lot_effectif,na.rm=TRUE))
p<-ggplot(stacomi_yr_month, aes(x=as.factor(month),y=sum,fill=as.factor(year)))+
		geom_bar(stat="identity",position="dodge")+
			facet_wrap(~sta_nom,ncol=1,scale="free_y")+
			xlab("Mois")+
			ylab("Effectifs")+
			scale_fill_discrete(name=iconv("Année","UTF8"))+
			theme(legend.position="bottom")

	png(file="C:/Users/utilisateur/workspace/ModeleDynamiquePop/data/Passage_SAT_stacomi.png",height=600,width=800)
	print(p)
	dev.off()

stacomi_jj<-stacomi%>%group_by(sta_nom,jj)%>%summarise(sum=sum(lot_effectif,na.rm=TRUE))
p<-ggplot(stacomi, aes(x=sta_nom,y=jj))+
		geom_boxplot()+
		xlab("Station")+
		ylab("Jour Julien")+
		geom_segment(x=0,xend=2.4,y=60,yend=60,linetype="dashed")+
		geom_text(y=60,x=2.5,label="Mars",size=3)+
		geom_segment(x=0,xend=2.4,y=91,yend=91,linetype="dashed")+
		geom_text(y=91,x=2.5,label="Avril",size=3)+
		geom_segment(x=0,xend=2.4,y=121,yend=121,linetype="dashed")+
		geom_text(y=121,x=2.5,label="Mai",size=3)+
		geom_segment(x=0,xend=2.4,y=274,yend=274,linetype="dashed")+
		geom_text(y=274,x=2.5,label="Octobre",size=3)+
		geom_segment(x=0,xend=2.4,y=305,yend=305,linetype="dashed")+
		geom_text(y=305,x=2.5,label="Novembre",size=3)

png(file="C:/Users/utilisateur/workspace/ModeleDynamiquePop/data/Passage_SAT_stacomi_boxplot.png",height=600,width=800)
print(p)
dev.off()
@


<<data_Q,echo=FALSE, eval=FALSE,results=hide >>=

###Les débits sont maintenant rentrés dans la base bd_envir et mis à jour tous les jours. On peut donc aller les récupérer directement !
con_bd_envir <- DBI::dbConnect(drv = Postgres(),
		host = "intranet.logrami.fr",
		dbname = "bd_envir",
		user  = userserver,
		password  = passwordserver)

vb<-dbGetQuery(con_bd_envir,
		"select sta_nom,date(mes_date_debut) as date_debut, extract(year from mes_date_debut) as year,round(mes_valeur::numeric,1)
				from public.t_station_sta
				left join public.t_stationmatos_stm on sta_id =stm_sta_id
				left join public.t_mesure_mes on mes_stm_id=stm_id
				where stm_mat_code=2 and sta_nom='Vieille-Brioude'
				")

## Au printemps
#On filtre sur les mois de mars à juin et on calcule la moyenne pour chaque année
#q_vb_mont<-vb%>%filter(between(month(date_debut),3,5),between(year,1975,(1974+T)))%>%group_by(year)%>%summarise(meanMAM=mean(round,na.rm=TRUE))
q_vb_mont_printemps<-vb%>%filter(between(month(date_debut),3,6),between(year,1975,(1974+T)))%>%group_by(year)%>%summarise(meanMAM=mean(round,na.rm=TRUE))

## A l'automne : septembre-novembre
q_vb_mont_automne<-vb%>%filter(between(month(date_debut),9,11),between(year,1975,(1974+T)))%>%group_by(year)%>%summarise(meanMAM=mean(round,na.rm=TRUE))

paste0(q_vb_mont_printemps$meanMAM,collapse=",")
paste0(q_vb_mont_automne$meanMAM,collapse=",")

## A l'hiver : décembre + janvier/février t+1


#------------ Lempdes sur Alagnon -------------#
q_Lempdes_mont<-dbGetQuery(con_bd_envir,
		"select sta_nom,date(mes_date_debut) as date_debut, extract(year from mes_date_debut) as year,round(mes_valeur::numeric,1)
				from public.t_station_sta
				left join public.t_stationmatos_stm on sta_id =stm_sta_id
				left join public.t_mesure_mes on mes_stm_id=stm_id
				where stm_mat_code=2 and sta_nom='Lempdes sur Alagnon'
				")
#Attention année 1979 à 1981 à estimer d'après Joursac
#----- Joursac sur l'Alagnon pour régression linéaire avec Lempdes pour combler les 3 années manquantes sur Lempdes -----#
#----- A Joursac les données sont complètes pour les années 1979, 1980 et 1981 -----#
q_J_mont<-dbGetQuery(con_bd_envir,
		"select sta_nom,date(mes_date_debut) as date_debut, extract(year from mes_date_debut) as year,round(mes_valeur::numeric,1)
				from public.t_station_sta
				left join public.t_stationmatos_stm on sta_id =stm_sta_id
				left join public.t_mesure_mes on mes_stm_id=stm_id
				where stm_mat_code=2 and sta_nom='Joursac'
				")

q_L_mont<-rbind(q_Lempdes_mont,q_J_mont)
q_L_mont<-reshape(q_L_mont, #the data set to reshape
		idvar = "date_debut", #variable(s) used as the unique identifier for unstacking
		timevar = "sta_nom", #variable(s) to unstack by where each category becomes a column per variable in v.names
		v.names = c("round"), #variables to be unstacked into columns
		direction = "wide") #whether to make the data long (stacked) or wide (unstacked)
colnames(q_L_mont)<-c("date_debut","year","Q_Lempdes","Q_Joursac")

##Estimation de la relation entre les 2 station
mod1<-lm(log(Q_Lempdes)~log(Q_Joursac),data=q_L_mont)
summary(mod1)
#plot(mod1)
#plot(log(Q_pont_seuges)~log(Q_amont_pont),data=q_P_mont)


start = as.Date("1979-01-01")
end = as.Date("1981-12-31")
#au printemps
newdata<-data.frame(date=seq(from = start, to = end, by = 1))
#newdata<-newdata[between(month(newdata$date),4,6), ]
newdata<-as.data.frame(newdata)
newdata<-merge(newdata,q_L_mont[,c("date_debut","Q_Joursac")],by.x="date",by.y="date_debut",all.x=TRUE)
newdata$pred<-predict(mod1, newdata = newdata)
#le modèle était log-transformé, on retransforme pour avoir les Q en échelle naturelle
newdata$pred_nat<-exp(newdata$pred)

#on ajoute ces données estimées au jeu de données
add_data<-data.frame(sta_nom=rep("Joursac",nrow(newdata)),date_debut=newdata$date,year=year(newdata$date),round=newdata$pred_nat)

titi<-rbind(q_Lempdes_mont,add_data)

Q_Lempdes<-arrange(titi,date_debut)
q_l_mont_printemps<-Q_Lempdes%>%filter(between(month(date_debut),3,6),between(year,1975,(1974+T)))%>%group_by(year)%>%summarise(meanL=mean(round,na.rm=TRUE))

paste0(q_l_mont_printemps$meanL,collapse=",")

#automne
q_l_mont_automne<-q_L_mont%>%filter(between(month(date_debut),9,11),between(year,1975,(1974+T)))%>%group_by(year)%>%summarise(mean=mean(round,na.rm=TRUE))


paste0(q_l_mont_automne$mean,collapse=",")


#------------ Prades -------------#
#2 stations une "amont du pont" 1968-2008 et l'autre "pont de seuges" 2003-2022
#On utilise  la station amont pont entre 2003 et 2008 pour la calibration et en estime les Q à pont de seuges sur l'historique

q_P_mont1<-dbGetQuery(con_bd_envir,
		"select sta_nom,date(mes_date_debut) as date_debut, extract(year from mes_date_debut) as year,round(mes_valeur::numeric,1)
				from public.t_station_sta
				left join public.t_stationmatos_stm on sta_id =stm_sta_id
				left join public.t_mesure_mes on mes_stm_id=stm_id
				where stm_mat_code=2 and sta_nom='Prades - amont du pont'
				")

q_P_mont2<-dbGetQuery(con_bd_envir,
		"select sta_nom,date(mes_date_debut) as date_debut, extract(year from mes_date_debut) as year,round(mes_valeur::numeric,1)
				from public.t_station_sta
				left join public.t_stationmatos_stm on sta_id =stm_sta_id
				left join public.t_mesure_mes on mes_stm_id=stm_id
				where stm_mat_code=2 and sta_nom='Prades - pont amont Seuges'
				")
q_P_mont<-rbind(q_P_mont1,q_P_mont2)
q_P_mont<-reshape(q_P_mont, #the data set to reshape
		idvar = "date_debut", #variable(s) used as the unique identifier for unstacking
		timevar = "sta_nom", #variable(s) to unstack by where each category becomes a column per variable in v.names
		v.names = c("round"), #variables to be unstacked into columns
		direction = "wide") #whether to make the data long (stacked) or wide (unstacked)
colnames(q_P_mont)<-c("date_debut","year","Q_amont_pont","Q_pont_seuges")

##Estimation de la relation entre les 2 station
mod1<-lm(log(Q_pont_seuges)~log(Q_amont_pont),data=q_P_mont)
summary(mod1)
plot(mod1)
plot(log(Q_pont_seuges)~log(Q_amont_pont),data=q_P_mont)


start = as.Date("1975-01-01")
end = as.Date("2002-12-31")
#au printemps
newdata<-data.frame(date=seq(from = start, to = end, by = 1))
#newdata<-newdata[between(month(newdata$date),4,6), ]
newdata<-as.data.frame(newdata)
newdata<-merge(newdata,q_P_mont[,c("date_debut","Q_amont_pont")],by.x="date",by.y="date_debut",all.x=TRUE)
newdata$pred<-predict(mod1, newdata = newdata)
#le modèle était log-transformé, on retransforme pour avoir les Q en échelle naturelle
newdata$pred_nat<-exp(newdata$pred)

#on ajoute ces données estimées au jeu de données
add_data<-data.frame(sta_nom=rep("Prades - pont amont Seuges",nrow(newdata)),date_debut=newdata$date,year=year(newdata$date),round=newdata$pred_nat)

titi<-rbind(q_P_mont2,add_data)

Q_prades<-arrange(titi,date_debut)

q_p_mont_printemps<-Q_prades%>%filter(between(month(date_debut),3,6),between(year,1975,(1974+T)))%>%group_by(year)%>%summarise(mean=mean(round,na.rm=TRUE))
q_p_mont_automne<-Q_prades%>%filter(between(month(date_debut),9,11),between(year,1975,(1974+T)))%>%group_by(year)%>%summarise(mean=mean(round,na.rm=TRUE))

paste0(q_p_mont_printemps$mean,collapse=",")
paste0(q_p_mont_automne$mean,collapse=",")

