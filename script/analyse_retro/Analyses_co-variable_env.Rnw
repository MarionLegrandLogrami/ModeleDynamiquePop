#---- Données pour expliquer répartition adultes en amont de Poutès ---------#

#D'après Quentin, 2 solutions : soit prendre les Q de Prades qui représentent assez bien les Q pour le secteur amont Poutès
#Soit on essaie de reconstituer les Q passant à Poutès en sommant St Haon (Allier) et St Bonnet de Montauroux (Chapeauroux)
#On choisit de prendre les Q de Prades
#Soucis :
# 	+ Prades a fonctionné entre 1968 et 1970. Puis interruption jusqu'à décembre 2002
#	+ Concernant Prades à partir de 1975 seulement 2 années manquantes (quand on regarde les Q entre septembre et novembre : 2001 et 2002)
#	+ 4 années pour les Q au printemps (avril-juin) : 1975/1983/2001/2002
#Pour 2001/2002, ces débits existent pour St Haon. On regarde si on peut caler une relation entre Prades et St Haon pour estimer ces 2 années
## ATTENTION : ces Q servent pour la répartition en amont de Poutès, donc on n'a pas besoin de données avant 1986...
data_Q_prades_st_haon<-read.csv(file=file.path(dossier_externe, "Data/co-variables environnement/Q_Prades_St_Haon.csv"),sep=";",dec=",")
#on reformate le champ date 
data_Q_prades_st_haon$date<-str_c(data_Q_prades_st_haon$annee,"-",data_Q_prades_st_haon$mois,"-",data_Q_prades_st_haon$jour)
data_Q_prades_st_haon$date<-as.Date(data_Q_prades_st_haon$date,"%Y-%m-%d")

#On ne garde que les débits sur septembre-novembre
data_Q_prades_st_haon_sept_nov<-data_Q_prades_st_haon[between(month(data_Q_prades_st_haon$date),9 ,11),]
#On ne garde que les débits sur avril_juin
data_Q_prades_st_haon_avr_juin<-data_Q_prades_st_haon[between(month(data_Q_prades_st_haon$date),4 ,6),]

#il me faut les Q des 2 stations sur 2 colonnes différentes
data_Q_prades_st_haon_sept_nov<-reshape(data_Q_prades_st_haon_sept_nov, #the data set to reshape
        idvar = "date", #variable(s) used as the unique identifier for unstacking
        timevar = "station", #variable(s) to unstack by where each category becomes a column per variable in v.names
        v.names = c("Q"), #variables to be unstacked into columns
        direction = "wide") #whether to make the data long (stacked) or wide (unstacked)
              
colnames(data_Q_prades_st_haon_sept_nov)[5:6]<-c("Q_Prades","Q_StHaon")
data_Q_prades_st_haon_sept_nov$Q_Prades<-as.numeric(data_Q_prades_st_haon_sept_nov$Q_Prades)
data_Q_prades_st_haon_sept_nov$Q_StHaon<-as.numeric(data_Q_prades_st_haon_sept_nov$Q_StHaon)

ggplot(data_Q_prades_st_haon_sept_nov, aes(x=Q_Prades, y=Q_StHaon)) +
		geom_point() +
		geom_smooth(method=lm , color="red", fill="#69b3a2", se=TRUE) +
		theme_bw()
# au printemps
data_Q_prades_st_haon_avr_juin<-reshape(data_Q_prades_st_haon_avr_juin, #the data set to reshape
		idvar = "date", #variable(s) used as the unique identifier for unstacking
		timevar = "station", #variable(s) to unstack by where each category becomes a column per variable in v.names
		v.names = c("Q"), #variables to be unstacked into columns
		direction = "wide") #whether to make the data long (stacked) or wide (unstacked)

colnames(data_Q_prades_st_haon_avr_juin)[5:6]<-c("Q_Prades","Q_StHaon")
data_Q_prades_st_haon_avr_juin$Q_Prades<-as.numeric(data_Q_prades_st_haon_avr_juin$Q_Prades)
data_Q_prades_st_haon_avr_juin$Q_StHaon<-as.numeric(data_Q_prades_st_haon_avr_juin$Q_StHaon)

ggplot(data_Q_prades_st_haon_avr_juin, aes(x=Q_Prades, y=Q_StHaon)) +
		geom_point() +
		geom_smooth(method=lm , color="red", fill="#69b3a2", se=TRUE) +
		theme_bw()

#les résidus ne sont pas normalement distribués. On essaie de log transformer

mod1<-lm(log(Q_Prades)~log(Q_StHaon),data=data_Q_prades_st_haon_sept_nov)
summary(mod1)
#plot(mod1)
#ça a une meilleure tête

#Les 2 années à estimer sont 2001 et 2002
start = as.Date("2001-09-01")
end = as.Date("2001-11-30")
start2 = as.Date("2002-09-01")
end2 = as.Date("2002-11-30")

newdata<-data.frame(date=c(seq(from = start, to = end, by = 1),seq(from = start2, to = end2, by = 1)))
newdata<-as.data.frame(newdata)
newdata<-merge(newdata,data_Q_prades_st_haon_sept_nov[,c("date","Q_StHaon")],by.x="date",by.y="date",all.x=TRUE)
newdata$Q_StHaon<-log(newdata$Q_StHaon)
newdata$pred<-predict(mod1, newdata = newdata)
#le modèle était log-transformé, on retransforme pour avoir les Q en échelle naturelle
newdata$pred_nat<-exp(newdata$pred)

#on construit un jeu complet pour les Q_prades
Q_prades<-data_Q_prades_st_haon_sept_nov[,c("date","Q_Prades")]
Q_prades<-Q_prades[!(is.na(Q_prades$Q_Prades)),]
#on ajoute ces données estimées au jeu de données Q_Prades
add_data<-data.frame(date=newdata$date,Q_Prades=newdata$pred_nat)

titi<-rbind(Q_prades,add_data)

Q_prades2<-arrange(titi,date)
Q_prades2$year<-year(Q_prades2$date)
Q_prades_yr<-Q_prades2%>%group_by(year)%>%summarise(mean=mean(Q_Prades))
Q_prades_yr$mean #pour copier/coller dans openbugs

mean(Q_prades_yr$mean)
sd(Q_prades_yr$mean)

