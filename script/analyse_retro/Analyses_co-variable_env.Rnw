L_Q_L_mont_A_cr<-(log(Q_L_mont_A)-mean(log(Q_L_mont_A)))/sd(log(Q_L_mont_A))
L_Q_L_mont_P_cr<-(log(Q_L_mont_P)-mean(log(Q_L_mont_P)))/sd(log(Q_L_mont_P))
L_Q_P_mont_A_cr<-(log(Q_P_mont_A)-mean(log(Q_P_mont_A)))/sd(log(Q_P_mont_A))
L_Q_P_mont_P_cr<-(log(Q_P_mont_P)-mean(log(Q_P_mont_P)))/sd(log(Q_P_mont_P))
L_Q_VB_mont_A_cr<-(log(Q_VB_mont_A)-mean(log(Q_VB_mont_A)))/sd(log(Q_VB_mont_A))
L_Q_VB_mont_P_cr<-(log(Q_VB_mont_P)-mean(log(Q_VB_mont_P)))/sd(log(Q_VB_mont_P))

L_Q_L_mont_A_cr<-data.frame(sta=rep("Lempdes-sur-Alagnon",48),saison=rep("Automne",48),year=1975:2022,Q=L_Q_L_mont_A_cr)
L_Q_L_mont_P_cr<-data.frame(sta=rep("Lempdes-sur-Alagnon",48),saison=rep("Printemps",48),year=1975:2022,Q=L_Q_L_mont_P_cr)
L_Q_VB_mont_A_cr<-data.frame(sta=rep("Vieille-Brioude",48),saison=rep("Automne",48),year=1975:2022,Q=L_Q_VB_mont_A_cr)
L_Q_VB_mont_P_cr<-data.frame(sta=rep("Vieille-Brioude",48),saison=rep("Printemps",48),year=1975:2022,Q=L_Q_VB_mont_P_cr)
L_Q_P_mont_A_cr<-data.frame(sta=rep("Prades",48),saison=rep("Automne",48),year=1975:2022,Q=L_Q_P_mont_A_cr)
L_Q_P_mont_P_cr<-data.frame(sta=rep("Prades",48),saison=rep("Printemps",48),year=1975:2022,Q=L_Q_P_mont_P_cr)


q_rep<-rbind(L_Q_L_mont_A_cr,L_Q_L_mont_P_cr,L_Q_P_mont_A_cr,L_Q_P_mont_P_cr,L_Q_VB_mont_A_cr,L_Q_VB_mont_P_cr)
q_rep$saison <- factor(q_rep$saison, levels=c('Printemps', 'Automne'))
q_rep$sta <- factor(q_rep$sta, levels=c('Lempdes-sur-Alagnon', 'Vieille-Brioude','Prades'))
library(ggplot2)
g<-ggplot(data=q_rep)+
		geom_line(aes(x=year,y=Q,col=sta),size=1)+
		geom_hline(yintercept=0)+
		facet_grid(sta~saison)+
		ylab("Débit log-transformé et centré-réduit")+
		theme_bw()

ggsave(file=here::here("img/2023_05/Q_log_cr_used_in_model.png"),g)

#en débit naturel
Q_L_mont_A<-data.frame(sta=rep("Lempdes-sur-Alagnon",48),saison=rep("Automne",48),year=1975:2022,Q=Q_L_mont_A)
Q_L_mont_P<-data.frame(sta=rep("Lempdes-sur-Alagnon",48),saison=rep("Printemps",48),year=1975:2022,Q=Q_L_mont_P)
Q_VB_mont_A<-data.frame(sta=rep("Vieille-Brioude",48),saison=rep("Automne",48),year=1975:2022,Q=Q_VB_mont_A)
Q_VB_mont_P<-data.frame(sta=rep("Vieille-Brioude",48),saison=rep("Printemps",48),year=1975:2022,Q=Q_VB_mont_P)
Q_P_mont_A<-data.frame(sta=rep("Prades",48),saison=rep("Automne",48),year=1975:2022,Q=Q_P_mont_A)
Q_P_mont_P<-data.frame(sta=rep("Prades",48),saison=rep("Printemps",48),year=1975:2022,Q=Q_P_mont_P)


q_rep_nat<-rbind(Q_L_mont_A,Q_L_mont_P,Q_P_mont_A,Q_P_mont_P,Q_VB_mont_A,Q_VB_mont_P)
q_rep_nat$saison <- factor(q_rep_nat$saison, levels=c('Printemps', 'Automne'))
q_rep_nat$sta <- factor(q_rep_nat$sta, levels=c('Lempdes-sur-Alagnon', 'Vieille-Brioude','Prades'))
g_nat<-ggplot(data=q_rep_nat)+
		geom_line(aes(x=year,y=Q,col=sta),size=1)+
		#geom_hline(yintercept=0)+
		facet_grid(sta~saison,scales="free_y")+
		ylab("Débit m3/s")+
		theme_bw()

ggsave(file=here::here("img/2023_05/Q_naturel_used_in_model.png"),g_nat)

#Q influence survie

L_Q_VB_deval_cr<-(log(Q_VB_deval)-mean(log(Q_VB_deval)))/sd(log(Q_VB_deval))
L_Q_MSL_deval_cr<-(log(Q_MSL_deval)-mean(log(Q_MSL_deval)))/sd(log(Q_MSL_deval))
L_Q_MSL_mont_cr<-(log(Q_MSL_mont)-mean(log(Q_MSL_mont)))/sd(log(Q_MSL_mont))

L_Q_VB_deval_cr<-data.frame(sta=rep("Vieille-Brioude",48),migration=rep("Dévalaison",48),year=1975:2022,Q=L_Q_VB_deval_cr)
L_Q_MSL_deval_cr<-data.frame(sta=rep("Montjean-sur-Loire",48),migration=rep("Dévalaison",48),year=1975:2022,Q=L_Q_MSL_deval_cr)
L_Q_MSL_mont_cr<-data.frame(sta=rep("Montjean-sur-Loire",48),migration=rep("Montaison",48),year=1975:2022,Q=L_Q_MSL_mont_cr)

q_rep_surv<-rbind(L_Q_VB_deval_cr,L_Q_MSL_deval_cr,L_Q_MSL_mont_cr)
q_rep_surv$migration <- factor(q_rep_surv$migration, levels=c('Montaison', 'Dévalaison'))
q_rep_surv$sta <- factor(q_rep_surv$sta, levels=c('Montjean-sur-Loire','Vieille-Brioude'))

g_surv<-ggplot(data=q_rep_surv)+
		geom_line(aes(x=year,y=Q,col=sta),size=1)+
		geom_hline(yintercept=0)+
		facet_grid(sta~migration)+
		ylab("Débit log-transformé et centré-réduit")+
		theme_bw()

ggsave(file=here::here("img/2023_05/Q_surv_log_cr_used_in_model.png"),g_surv)

#débit naturel
Q_VB_deval<-data.frame(sta=rep("Vieille-Brioude",48),migration=rep("Dévalaison",48),year=1975:2022,Q=Q_VB_deval)
Q_MSL_deval<-data.frame(sta=rep("Montjean-sur-Loire",48),migration=rep("Dévalaison",48),year=1975:2022,Q=Q_MSL_deval)
Q_MSL_mont<-data.frame(sta=rep("Montjean-sur-Loire",48),migration=rep("Montaison",48),year=1975:2022,Q=Q_MSL_mont)

q_rep_surv<-rbind(Q_VB_deval,Q_MSL_deval,Q_MSL_mont)
q_rep_surv$migration <- factor(q_rep_surv$migration, levels=c('Montaison', 'Dévalaison'))
q_rep_surv$sta <- factor(q_rep_surv$sta, levels=c('Montjean-sur-Loire','Vieille-Brioude'))
q_rep_surv$mean<-NA
q_rep_surv$mean[q_rep_surv$sta=="Montjean-sur-Loire"&q_rep_surv$migration=="Montaison"]<-mean(q_rep_surv$Q[q_rep_surv$sta=="Montjean-sur-Loire"&q_rep_surv$migration=="Montaison"])
q_rep_surv$mean[q_rep_surv$sta=="Montjean-sur-Loire"&q_rep_surv$migration=="Dévalaison"]<-mean(q_rep_surv$Q[q_rep_surv$sta=="Montjean-sur-Loire"&q_rep_surv$migration=="Dévalaison"])
q_rep_surv$mean[q_rep_surv$sta!="Montjean-sur-Loire"]<-mean(q_rep_surv$Q[q_rep_surv$sta!="Montjean-sur-Loire"])

g_surv<-ggplot(data=q_rep_surv)+
		geom_line(aes(x=year,y=Q,col=sta),size=1)+
		geom_hline(aes(yintercept = mean))+
		facet_grid(sta~migration,scales="free_y")+
		ylab("Débit m3/s")+
		theme_bw()

ggsave(file=here::here("img/2023_05/Q_surv_naturel_used_in_model.png"),g_surv)

@

