#Code modifié le 2025-02-19
data_Q2_mont_yr <- data_Q2 %>% 
                filter((month(date) == 12 & day(date) >= 15) | 
                       (month(date) %in% c(1, 2)) | 
                       (month(date) == 3 & day(date) <= 15)) %>%
                mutate(annee_hydro = ifelse(month(date) == 12, year(date) + 1, year(date))) %>%
                filter(annee_hydro <= 1974 + T) %>%
                group_by (annee_hydro) %>%
			          summarise(mean=mean(round,na.rm=TRUE))
data_Q2_mont_yr_model<-as.data.frame(data_Q2_mont_yr[between(data_Q2_mont_yr$year,1970,2020),])
data_Q2_mont_yr_model$mean[6:51] #pour copier/coller dans openbugs

	
	#....Dévalaison : 15 mars - 15 mai
data_Q2_deval<-data_Q2[data_Q2$month==4,] #on sélectionne sur les mois complets
unique(data_Q2_deval$month)
#on ajoute les mois tronqués
data_Q2_mars<-data_Q2[data_Q2$month==3 & day(data_Q2$date)>=15,]
data_Q2_mai<-data_Q2[data_Q2$month==5 & day(data_Q2$date)<=15,]
#On assemble les 3 jeux de données
data_Q2_deval<-rbind(data_Q2_mars,data_Q2_deval,data_Q2_mai)
data_Q2_deval_yr<-data_Q2_deval%>%group_by(year)%>%summarise(mean=mean(Q))
data_Q2_deval_yr_model<-as.data.frame(data_Q2_deval_yr[between(data_Q2_deval_yr$year,1970,2020),])
# data_Q2_deval_yr_model$mean #pour copier/coller dans openbugs

running.mean<- function(x, n = 3){stats::filter(x, rep(1 / n, n), sides = 1)}
#calculer la moyenne pondérée avec poids identique (1/3) revient à calculer une moyenne glissante sur fenêtre 3 ans
#plus facile de faire comme ça sinon il faut trouver comment se décaler sur les plages d'années avec moyenne pondérée
mean_indic_adult_MSL<-running.mean(data_Q2_deval_yr_model,3)
#Il faut changer les années en face de chaque moyenne pondérée car la première valeur correspond aux juvéniles à l'origine des adultes de retour en 1979
year<-seq((min(data_Q2_deval_yr_model$year)+4),2020,1)
mean_indic_adult_MSL<-cbind(year,as.vector(mean_indic_adult_MSL[3:48,2])) #commence à 3 car avant NA et finit à 48 car dernière année pour les retours adultes 2020=2018 c-à-d période 2016-2018 qui est centrée sur 2017 soit t=48
mean_indic_adult_MSL[,2]

#---------------------
# Figure évolution Q
#---------------------
data_Q2_mont_yr_model$ind<-1
data_Q2_deval_yr_model$ind<-2
data_MSL<-rbind(data_Q2_mont_yr_model,data_Q2_deval_yr_model)
data_MSL$ind<-as.factor(data_MSL$ind)
p<-ggplot(data=data_MSL,aes(x=year,y=mean,color=ind))+
		geom_line(size=1)+
		scale_color_discrete(name = "Série de données", labels = c("Q montaison (15/12 - 15/03)", "Q dévalaison (15/03 - 15/05)"))+
		ylab("Débit moyen sur la période (m3/s)")+
		theme_bw()+
		theme(legend.position="bottom",
				axis.text=element_text(size=12),
				axis.title=element_text(size=14,face="bold"))

png(file=here::here("data/co-variables_env/Mean_Q_Montjean_1970-2018.png"),height=600,width=800)
print(p)
dev.off()


#------------- Lempdes Alagnon 01/03 au 31/05 = montaison
data_Q<-read.csv(file=file.path(dossier_externe, "Data/co-variables environnement/Q_Lempdes_1967-2021.csv"),sep=";",dec=",")
#on reformate le champ date 
data_Q$date<-as.Date(data_Q$Jour,"%d/%m/%Y")
data_Q[is.na(data_Q$Q),]# plusieurs NA mais sur les moois de septembre, décembre,août et juillet + en 2021
data_Q$year<-year(data_Q$date)
data_Q$month<-month(data_Q$date)
#On ne garde les Q que jusqu'en 2018 et à partir de 1975
data_Q<-data_Q[between(data_Q$year,1975,2020),]

data_Q_avril_juin<-data_Q[between(month(data_Q$date),4 ,6),]
#Pour débit à l'automne on garde entre septembre et novembre
data_Q_sept_nov<-data_Q[between(month(data_Q$date),9 ,11),]

data_Q_lempdes_yr<-data_Q_avril_juin%>%group_by(year)%>%summarise(mean=mean(Q))
seq<-data.frame(year=seq(1979,1981,1),mean=rep(NA,3))
data_Q_lempdes_yr<-rbind(data_Q_lempdes_yr,seq)
data_Q_lempdes_yr<-arrange(data_Q_lempdes_yr,year)
data_Q_lempdes_yr$mean #pour copier/coller dans openbugs
mean(data_Q_lempdes_yr$mean,na.rm=TRUE)#13.89604
sd(data_Q_lempdes_yr$mean,na.rm=TRUE)#7.175608

### Il manque les années 1979,1980 et 1981 (1978 et 1982 sont complètes)

#----- Joursac sur l'Alagnon pour régression linéaire avec Lempdes pour combler les 3 années manquantes sur Lempdes -----#
#----- A Joursac les données sont complètes pour les années 1979, 1980 et 1981 -----#
data_Q_joursac<-read.csv(file=file.path(dossier_externe, "Data/co-variables environnement/Q_Joursac_1975_2018.csv"),sep=";",dec=",")
#on reformate le champ date 
data_Q_joursac$date<-as.Date(data_Q_joursac$Jour,"%d/%m/%Y")
data_Q_joursac[is.na(data_Q_joursac$Q),]# plusieurs NA en 1999 et 2001
data_Q_joursac$year<-year(data_Q_joursac$date)
data_Q_joursac$month<-month(data_Q_joursac$date)
#On ne garde les Q que jusqu'en 2018 et à partir de 1975
data_Q_joursac<-data_Q_joursac[between(data_Q_joursac$year,1975,2018),]
#On ne garde que les débits sur avril-juin
data_Q_joursac<-data_Q_joursac[between(month(data_Q_joursac$date),4 ,6),]
#Pour la relation à l'automne : on ne garde que les débits entre septembre et novembre
data_Q_joursac_A<-data_Q_joursac[between(month(data_Q_joursac$date),9 ,11),]


#-- pour faire la régression il faut récupérer dans un même tableau les débits des 2 stations.

data_Q_L_J<-merge(data_Q_avril_juin[,c("date","Q")],data_Q_joursac[,c("date","Q")],by.x="date",by.y="date")
colnames(data_Q_L_J)<-c("date","Q_L","Q_J")
#on ajoute les jours juliens
#data_Q_L_J$jj<-yday(data_Q_L_J$date)
data_Q_L_J_automne<-merge(data_Q_sept_nov[,c("date","Q")],data_Q_joursac_A[,c("date","Q")],by.x="date",by.y="date")
colnames(data_Q_L_J_automne)<-c("date","Q_L","Q_J")

ggplot(data_Q_L_J_automne, aes(x=Q_L, y=Q_J)) +
  geom_point() +
  geom_smooth(method=lm , color="red", fill="#69b3a2", se=TRUE) +
  theme_bw()

mod<-lm(data=data_Q_L_J,Q_L~Q_J)
summary(mod)
plot(mod)

#les résidus ne sont pas normalement distribués. On essaie de log transformer

mod1<-lm(log(Q_L)~log(Q_J),data=data_Q_L_J)
summary(mod1)
plot(mod1)

#à l'automne
mod2<-lm(log(Q_L)~log(Q_J),data=data_Q_L_J_automne)
summary(mod2)
plot(mod2)
#ça a une meilleure tête

start = as.Date("1979-01-01")
end = as.Date("1981-12-31")
#au printemps
newdata<-data.frame(date=seq(from = start, to = end, by = 1))
newdata<-newdata[between(month(newdata$date),3,6), ]
newdata<-as.data.frame(newdata)
newdata<-merge(newdata,data_Q_joursac[,c("date","Q")],by.x="newdata",by.y="date",all.x=TRUE)
newdata$Q_J<-log(newdata$Q)
newdata<-newdata[,c("newdata","Q_J")]
colnames(newdata)<-c("date","Q_J")
newdata$pred<-predict(mod1, newdata = newdata)
#le modèle était log-transformé, on retransforme pour avoir les Q en échelle naturelle
newdata$pred_nat<-exp(newdata$pred)

#A l'automne
newdata<-data.frame(date=seq(from = start, to = end, by = 1))
newdata<-newdata[between(month(newdata$date),9,11), ]
newdata<-as.data.frame(newdata)
newdata<-merge(newdata,data_Q_joursac_A[,c("date","Q")],by.x="newdata",by.y="date",all.x=TRUE)
newdata$Q_J_A<-log(newdata$Q)
newdata<-newdata[,c("newdata","Q_J")]
colnames(newdata)<-c("date","Q_J")
newdata$pred<-predict(mod2, newdata = newdata)
#le modèle était log-transformé, on retransforme pour avoir les Q en échelle naturelle
newdata$pred_nat<-exp(newdata$pred)

#on ajoute ces données estimées au jeu de données Q_Lempdes
add_data<-data.frame(nomCoursEau=rep("L'Alagnon",nrow(newdata)),codeStation=rep("K2593010",nrow(newdata)),nomStation=rep("Lempdes",nrow(newdata)),Jour=rep(NA,nrow(newdata)),Q=newdata$pred_nat,V=rep(NA,nrow(newdata)),date=newdata$date,year=year(newdata$date),month=month(newdata$date))

titi<-rbind(data_Q_avril_juin,add_data)

