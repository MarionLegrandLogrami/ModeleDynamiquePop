ids<-factor(c(str_c("1.",seq(1,(T-5),1)),str_c("2.",seq(1,(T-5),1))))
values<-data.frame(id=ids,values=c(rep("red",(T-5)),rep("green",(T-5))))
positions<-data.frame(id=rep(ids,each=4),
		x=rep(c(rbind(seq(4,(T-2),1),seq(3,(T-3),1),seq(3,(T-3),1),seq(4,(T-2),1))),2),
		y=c(c(rbind(0,0,running.mean(mean_niveau_pop_50_50,5)[!is.na(running.mean(mean_niveau_pop_50_50,5))][1:(length(x_mob)-1)],running.mean(mean_niveau_pop_50_50,5)[!is.na(running.mean(mean_niveau_pop_50_50,5))][2:(length(x_mob))])),
			c(rbind(running.mean(mean_niveau_pop_50_50,5)[!is.na(running.mean(mean_niveau_pop_50_50,5))][2:(length(x_mob))],running.mean(mean_niveau_pop_50_50,5)[!is.na(running.mean(mean_niveau_pop_50_50,5))][1:(length(x_mob)-1)],rep(max(running.mean(data_vichy_all,5),na.rm=TRUE),(length(x_mob)-1)),rep(max(running.mean(data_vichy_all,5),na.rm=TRUE),(length(x_mob)-1)))))
