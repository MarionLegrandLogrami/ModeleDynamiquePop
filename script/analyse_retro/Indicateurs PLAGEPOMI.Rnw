#################################
## Diagnostic conservation
#################################
library(coda)
library(ggplot2)
library(stringr)
#load("C:/Users/marion.legrand/workspace/ModeleDynamiquePop/2017_08_29_Projection_InteractionReciproqueMatriceVC_Maj2016_ContinuiteEcologique_2017_12_12.RData")
load("C:/Users/marion.legrand/workspace/ModeleDynamiquePop/2019_12_12_Projection_InteractionReciproqueMatriceVC_Maj2018_ContinuiteEcologique_2020_01_03.RData")

surf=c(rep(c(846021,70845,250441,0),11),rep(c(846021,70845,250441,301101),12),rep(c(846021,70845,250441,383049),6),rep(c(846021,356519,250441,383049),(T-8)))
S_juv_JP<-matrix(surf,nrow=4)
S_juv_JP<-rbind(S_juv_JP,colSums(S_juv_JP)) #Créé une 5eme ligne qui correspond à la somme par année des surfaces sur l'ensemble des secteurs

Rmax=read.coda("RmaxCODAchain1.txt","RmaxCODAindex.txt")
nu_d=read.coda("nu_dCODAchain1.txt","nu_dCODAindex.txt")

##A partir de T+1 on utilise les projections simulées dans SimulationContinuiteEcologique_4zones
d_wild_moy_V=d_moy_vichy
d_wild_moy_A=d_moy_alagnon
d_wild_moy_L=d_moy_langeac
d_wild_moy_P=d_moy_poutes
##Comme on calcule le diagnostic sur 10ans (proba d'être en dessous X années sur 10) il faut aussi qu'on récupère les données pour T-9 à T
bugs_d_wild_moy_V=read.coda("dmoywild_VCODAchain1.txt","dmoywild_VCODAindex.txt")
bugs_d_wild_moy_A=read.coda("dmoywild_ACODAchain1.txt","dmoywild_ACODAindex.txt")
bugs_d_wild_moy_L=read.coda("dmoywild_LCODAchain1.txt","dmoywild_LCODAindex.txt")
bugs_d_wild_moy_P=read.coda("dmoywild_PCODAchain1.txt","dmoywild_PCODAindex.txt")

DC_tot_wild_tot=array(rep(NA,(T+20)*5000),dim=c(5000,(T+20))) #en considérant toutes les surfaces même si elles ne sont pas accessibles
#DC_tot_wild=array(rep(0,T*5000),dim=c(5000,T))	#en considérant les surfaces accessibles uniquement (change au fil des années
##Pour décliner par secteur
DC_tot_wild_V=array(NA,dim=c(5000,(T+20)))
DC_tot_wild_A=array(NA,dim=c(5000,(T+20)))
DC_tot_wild_L=array(NA,dim=c(5000,(T+20)))
DC_tot_wild_P=array(NA,dim=c(5000,(T+20)))

#Attention dans le calcul de la part de juv produite sur la part de la capacité d'accueil, il faut prendre en compte
#pour Rmax que les secteurs ne produisent pas à équivalence
Rmax_ponder_V<-array(0,dim=c(10000,(T+20)))
Rmax_ponder_A<-array(0,dim=c(10000,(T+20)))
Rmax_ponder_L<-array(0,dim=c(10000,(T+20)))
Rmax_ponder_P<-array(0,dim=c(10000,(T+20)))
Rmax_ponder<-array(0,dim=c(10000,(T+20)))
for (t in (T-9):(T+20)){
	for (i in 1:10000){
		Rmax_ponder_V[i,t]<-Rmax[i]*exp(nu_d[i,1])*S_juv_JP[1,(t)]
		Rmax_ponder_A[i,t]<-Rmax[i]*exp(nu_d[i,2])*S_juv_JP[2,(t)]
		Rmax_ponder_L[i,t]<-Rmax[i]*exp(nu_d[i,3])*S_juv_JP[3,(t)]
		Rmax_ponder_P[i,t]<-Rmax[i]*exp(nu_d[i,4])*S_juv_JP[4,(t)]
		Rmax_ponder[i,t]<-Rmax_ponder_V[i,t]+Rmax_ponder_A[i,t]+Rmax_ponder_L[i,t]+Rmax_ponder_P[i,t]
	}
}

##Comme on calcule le diagnostic sur 10ans (proba d'être en dessous X années sur 10) il faut aussi qu'on récupère les données pour T-9 à T
for (t in (T-9):T){
	for (i in 1:5000){
		#On fait l'analyse en considérant l'ensemble des habitats favorables qu'ils soient accessibles ou non
		DC_tot_wild_tot[i,t]<-((bugs_d_wild_moy_V[i,t-1]*S_juv_JP[1,(t)]+bugs_d_wild_moy_A[i,t-1]*S_juv_JP[2,(t)]+bugs_d_wild_moy_L[i,t-1]*S_juv_JP[3,(t)]+bugs_d_wild_moy_P[i,t-12]*S_juv_JP[4,(t)])*100)/Rmax_ponder[i,t] #(Rmax[i]*S_juv_JP_tot[5])
		#On fait l'analyse en regardant année après années les surfaces favorables effectivement accessibles
		#DC_tot[i,t]<-((d_wild_moy_V[i,t-1]*S_juv_JP[1,t]+d_wild_moy_A[i,t-1]*S_juv_JP[2,t]+d_wild_moy_L[i,t-1]*S_juv_JP[3,t]+d_wild_moy_P[i,t-12]*S_juv_JP[4,t])*100)/(Rmax[i]*S_juv_JP[5,t])
		
		##Par secteur
		DC_tot_wild_V[i,t]<-bugs_d_wild_moy_V[i,t-1]*S_juv_JP[1,(t)]*100/Rmax_ponder_V[i,t]
		DC_tot_wild_A[i,t]<-bugs_d_wild_moy_A[i,t-1]*S_juv_JP[2,(t)]*100/Rmax_ponder_A[i,t]
		DC_tot_wild_L[i,t]<-bugs_d_wild_moy_L[i,t-1]*S_juv_JP[3,(t)]*100/Rmax_ponder_L[i,t]
		DC_tot_wild_P[i,t]<-bugs_d_wild_moy_P[i,t-12]*S_juv_JP[4,(t)]*100/Rmax_ponder_P[i,t]
	}
}


for (t in (T+1):(T+20)){
	for (i in 1:5000){
		#On fait l'analyse en considérant l'ensemble des habitats favorables qu'ils soient accessibles ou non
		DC_tot_wild_tot[i,t]<-((d_wild_moy_V[i,t]*S_juv_JP[1,(t)]+d_wild_moy_A[i,t]*S_juv_JP[2,(t)]+d_wild_moy_L[i,t]*S_juv_JP[3,(t)]+d_wild_moy_P[i,t]*S_juv_JP[4,(t)])*100)/Rmax_ponder[i,t] #(Rmax[i]*S_juv_JP_tot[5])
		#On fait l'analyse en regardant année après années les surfaces favorables effectivement accessibles
		#DC_tot[i,t]<-((d_wild_moy_V[i,t-1]*S_juv_JP[1,t]+d_wild_moy_A[i,t-1]*S_juv_JP[2,t]+d_wild_moy_L[i,t-1]*S_juv_JP[3,t]+d_wild_moy_P[i,t-12]*S_juv_JP[4,t])*100)/(Rmax[i]*S_juv_JP[5,t])
		
		##Par secteur
		DC_tot_wild_V[i,t]<-d_wild_moy_V[i,t]*S_juv_JP[1,(t)]*100/Rmax_ponder_V[i,t]
		DC_tot_wild_A[i,t]<-d_wild_moy_A[i,t]*S_juv_JP[2,(t)]*100/Rmax_ponder_A[i,t]
		DC_tot_wild_L[i,t]<-d_wild_moy_L[i,t]*S_juv_JP[3,(t)]*100/Rmax_ponder_L[i,t]
		DC_tot_wild_P[i,t]<-d_wild_moy_P[i,t]*S_juv_JP[4,(t)]*100/Rmax_ponder_P[i,t]
	}
}

#============================
# Cible intermédiaire
#============================
#-----------------------
# Pour DC_tot_wild_tot
#-----------------------
### 25% Rmax pris comme référence pour cible intermédiaire

w_upper_tot_25_Rmax_ce=array(0,dim=c(5000,(T+20)))

for (t in (T-9):(T+20)){
	
	for (i in 1:5000){
		if(DC_tot_wild_tot[i,t] > 25){w_upper_tot_25_Rmax_ce[i,t]=1}
	}
}

p_w_upper_tot_25_Rmax_ce=rep(0,(T+20))

for (t in (T-9):(T+20)){
	p_w_upper_tot_25_Rmax_ce[t]=mean(w_upper_tot_25_Rmax_ce[,t])
}
##########################################################################################
# On calcule le nbr de fois qu'on passe en dessous (risque de ne pas atteindre le seuil)
##########################################################################################

#On récupère les 0 et 1 en fonction des objectifs de Rmax. on prend 10 années mobiles et on regarde si on atteint nos objectifs de risque par ex 25% de risque signifie qu'on 
#ne doit pas avoir plus de 3 années sur 10 en dessous de l'objectif 25% Rmax
risk_10_Rmax_25_ce<-array(NA,dim=c(5000,(T+20)))
risk_20_Rmax_25_ce<-array(NA,dim=c(5000,(T+20)))
risk_30_Rmax_25_ce<-array(NA,dim=c(5000,(T+20)))

for(t in (T+1):(T+20)){
	for (i in 1:5000){
		#Risque 10% : il ne faut pas plus de 1 année en dessous de l'objectif pour le remplir
		risk_10_Rmax_25_ce[i,t]<-ifelse(length(which(w_upper_tot_25_Rmax_ce[i,(t-9):t]==0))<=1,1,0)
		#Risque 20% : il ne faut pas plus de 2 années en dessous de l'objectif pour le remplir
		risk_20_Rmax_25_ce[i,t]<-ifelse(length(which(w_upper_tot_25_Rmax_ce[i,(t-9):t]==0))<=2,1,0)
		#Risque 30% : il ne faut pas plus de 3 années en dessous de l'objectif pour le remplir
		risk_30_Rmax_25_ce[i,t]<-ifelse(length(which(w_upper_tot_25_Rmax_ce[i,(t-9):t]==0))<=3,1,0)		
	}
}
mean_risk_10_Rmax_25_ce<-NA
mean_risk_20_Rmax_25_ce<-NA
mean_risk_30_Rmax_25_ce<-NA

for (t in (T+1):(T+20)){
	mean_risk_10_Rmax_25_ce[t]<-mean(risk_10_Rmax_25_ce[,t])
	mean_risk_20_Rmax_25_ce[t]<-mean(risk_20_Rmax_25_ce[,t])
	mean_risk_30_Rmax_25_ce[t]<-mean(risk_30_Rmax_25_ce[,t])
}


x_diag=seq((T+1-5),(T+20-5),1)
rects <- data.frame(ystart = seq(0,0.75,0.25), yend = seq(0.25,1,0.25), 
		col = c("red","orange","yellow","green"))
graph_diagnostic_ce<-ggplot()+
		geom_rect(data=rects, aes(xmin=(T+1-5), xmax=(T+20-5), ymin=ystart,ymax=yend), fill=rects$col, alpha =0.5) +
		geom_line(aes(x_diag,mean_risk_10_Rmax_25_ce[(T+1):(T+20)],colour="1"),size=1)+
		geom_line(aes(x_diag,mean_risk_20_Rmax_25_ce[(T+1):(T+20)],colour="2"),size=1)+
		geom_line(aes(x_diag,mean_risk_30_Rmax_25_ce[(T+1):(T+20)],colour="3"),size=1)+
		geom_hline(yintercept = 0.5,linetype="dashed",size=2)+
		geom_hline(yintercept = 0.75, linetype="dashed", size=1)+
		geom_hline(yintercept = 0.25, linetype="dashed", size=1)+
		xlab("Année") + 
		ylab("Probabilité d'assurer la conservation selon le diagnostique choisi \n")+
		ggtitle("Diagnostic de conservation de la population sauvage pour 25% Rmax \n(fenêtre glissante sur 10 ans)")+
		scale_x_continuous(breaks=c((T+1-5),(T+7-5),(T+12-5),(T+17-5),(T+20-5)), labels=c((1974+T+1),(1974+T+7),(1974+T+12),(1974+T+17),(1974+T+20)))+
		scale_y_continuous(breaks=seq(0,1,0.2), labels=seq(0,1,0.2))+
		scale_colour_manual("", breaks = c("1", "2", "3"),values = c("black", "gray50", "gray80"),labels=c("Risque 10%", "Risque 20%", "Risque 30%")) +
		theme()+
  	theme_bw()+
		#theme_bw(base_size=22)+
		theme(plot.title = element_text(hjust = 0.5),legend.position="bottom")


mean(mean_risk_10_Rmax_25_ce[(T+1):(T+20)][16:20])
mean(mean_risk_20_Rmax_25_ce[(T+1):(T+20)][16:20])
mean(mean_risk_30_Rmax_25_ce[(T+1):(T+20)][16:20])

