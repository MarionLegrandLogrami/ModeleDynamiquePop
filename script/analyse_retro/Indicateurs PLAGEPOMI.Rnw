################
# CIBLE ULTIME
################

S_juv_JP<-keep_good_surf(surf_2021=TRUE)
S_juv_JP_tot<-S_juv_JP[,T]

#------------------------------------------------------------------
# Pop sauvage uniquement + 50% Rmax + 50% survie historique 
#------------------------------------------------------------------
Juv_Rmax_50_V=array(0,dim=c(10000,T))
Juv_Rmax_50_A=array(0,dim=c(10000,T))
Juv_Rmax_50_L=array(0,dim=c(10000,T))
Juv_Rmax_50_P=array(0,dim=c(10000,T))
Juv_Rmax_50=array(0,dim=c(10000,T))

for (t in 1:T){
	for (i in 1:10000){
		Juv_Rmax_50_V[i,t]<-0.50*Rmax[i]*exp(bugs_nu_d[i,1])*S_juv_JP[1,t] #multiplie par nu_d pour tenir compte de la différence de production de juvéniles des différentes zones
		Juv_Rmax_50_A[i,t]<-0.50*Rmax[i]*exp(bugs_nu_d[i,2])*S_juv_JP[2,t] #multiplie par nu_d pour tenir compte de la différence de production de juvéniles des différentes zones
		Juv_Rmax_50_L[i,t]<-0.50*Rmax[i]*exp(bugs_nu_d[i,3])*S_juv_JP[3,t] #multiplie par nu_d pour tenir compte de la différence de production de juvéniles des différentes zones
		Juv_Rmax_50_P[i,t]<-0.50*Rmax[i]*exp(bugs_nu_d[i,4])*S_juv_JP[4,t] #multiplie par nu_d pour tenir compte de la différence de production de juvéniles des différentes zones
		Juv_Rmax_50[i,t]<-Juv_Rmax_50_V[i,t]+Juv_Rmax_50_A[i,t]+Juv_Rmax_50_L[i,t]+Juv_Rmax_50_P[i,t] #mean=319547.8
	}
}

niveau_pop_50_actu<-array(0,dim=c(10000,T))
niveau_pop_50_50<-array(0,dim=c(10000,T))

for (t in 1:T){
	for (i in 1:10000){
		# Scénario 50% Rmax et survie actuelle
		niveau_pop_50_actu[i,t]<- exp(log(bugs_s_juv2ad[i]*Juv_Rmax_50[i,t]))#au passage je reviens en échelle naturelle
		# Scénario 50% Rmax et retour à 50% du niveau de survie historique
		niveau_pop_50_50[i,t]<- exp(log(bugs_s_juv2ad[i]*Juv_Rmax_50[i,t]) + level_s_fake_50)#au passage je reviens en échelle naturelle
	}
}

mean_niveau_pop_50_50<-apply(niveau_pop_50_50,MARGIN=2,FUN=mean)

#=============================================================================================
# Pour comparer on recalcule le pool de juvéniles sauvage à l'origine des retours d'adultes
#=============================================================================================
bugs_dmoy_wild_V=read.coda("dmoywild_VCODAchain1.txt","dmoywild_VCODAindex.txt")
bugs_dmoy_wild_A=read.coda("dmoywild_ACODAchain1.txt","dmoywild_ACODAindex.txt")
bugs_dmoy_wild_L=read.coda("dmoywild_LCODAchain1.txt","dmoywild_LCODAindex.txt")
bugs_dmoy_wild_P=read.coda("dmoywild_PCODAchain1.txt","dmoywild_PCODAindex.txt")
bugs_juv_wild_vichy=array(0,dim=c(5000,T))
bugs_juv_wild_alagnon=array(0,dim=c(5000,T))
bugs_juv_wild_langeac=array(0,dim=c(5000,T))
bugs_juv_wild_poutes=array(0,dim=c(5000,T))
bugs_juv_wild_vichy_tot=array(0,dim=c(5000,T))
bugs_juv_wild_alagnon_tot=array(0,dim=c(5000,T))
bugs_juv_wild_langeac_tot=array(0,dim=c(5000,T))
bugs_juv_wild_poutes_tot=array(0,dim=c(5000,T))
bugs_juv_wild_system=array(0,dim=c(5000,T))
bugs_juv_wild_system_surv_actu=array(0,dim=c(5000,T))

#On recalcule les juvéniles sauvages à partir des densités de juvéniles sauvages du modèle et en multipliant par les surfaces
for(t in 1:(T-1)){
	for (i in 1:5000){ 
		bugs_juv_wild_vichy[i,t+1]=bugs_dmoy_wild_V[i,t]*S_juv_JP[1,t+1]
		bugs_juv_wild_alagnon[i,t+1]=bugs_dmoy_wild_A[i,t]*S_juv_JP[2,t+1]
		bugs_juv_wild_langeac[i,t+1]=bugs_dmoy_wild_L[i,t]*S_juv_JP[3,t+1]
	}
}
for(t in 12:(T-1)){
	for (i in 1:5000){ 
		bugs_juv_wild_poutes[i,t+1]=bugs_dmoy_wild_P[i,t-11]*S_juv_JP[4,t+1]
	}
}

for (t in 7:15){
	for (i in 1:5000){ 
		bugs_juv_wild_vichy_tot[i,t] = (1/3) * bugs_juv_wild_vichy[i,t-3] + (1/3) * bugs_juv_wild_vichy[i,t-4] + (1/3) * bugs_juv_wild_vichy[i,t-5] 
		bugs_juv_wild_alagnon_tot[i,t] = (1/3) * bugs_juv_wild_alagnon[i,t-3] + (1/3) * bugs_juv_wild_alagnon[i,t-4] + (1/3) * bugs_juv_wild_alagnon[i,t-5] 
		bugs_juv_wild_langeac_tot[i,t] = (1/3) * bugs_juv_wild_langeac[i,t-3] + (1/3) * bugs_juv_wild_langeac[i,t-4] + (1/3) * bugs_juv_wild_langeac[i,t-5] 
		
		bugs_juv_wild_system[i,t] <- bugs_juv_wild_vichy_tot[i,t]+bugs_juv_wild_alagnon_tot[i,t]+bugs_juv_wild_langeac_tot[i,t]
	}
}	

for (t in 16:T){
	for (i in 1:5000){ 
		bugs_juv_wild_vichy_tot[i,t] = (1/3) * bugs_juv_wild_vichy[i,t-3] + (1/3) * bugs_juv_wild_vichy[i,t-4] + (1/3) * bugs_juv_wild_vichy[i,t-5] 
		bugs_juv_wild_alagnon_tot[i,t] = (1/3) * bugs_juv_wild_alagnon[i,t-3] + (1/3) * bugs_juv_wild_alagnon[i,t-4] + (1/3) * bugs_juv_wild_alagnon[i,t-5] 
		bugs_juv_wild_langeac_tot[i,t] = (1/3) * bugs_juv_wild_langeac[i,t-3] + (1/3) * bugs_juv_wild_langeac[i,t-4] + (1/3) * bugs_juv_wild_langeac[i,t-5] 
		bugs_juv_wild_poutes_tot[i,t] = (1/3) * bugs_juv_wild_poutes[i,t-3] +(1/3) * bugs_juv_wild_poutes[i,t-4] + (1/3) * bugs_juv_wild_poutes[i,t-5] 
				
		bugs_juv_wild_system[i,t] <- bugs_juv_wild_vichy_tot[i,t]+bugs_juv_wild_alagnon_tot[i,t]+bugs_juv_wild_langeac_tot[i,t] +bugs_juv_wild_poutes_tot[i,t]	
	}
}

#On leur applique la survie actuelle
for (t in 7:7){
	for (i in 1:5000){ 
		bugs_juv_wild_system_surv_actu[i,t] <- exp(log(bugs_s_juv2ad[i]*bugs_juv_wild_system[i,t])+ bugs_level_s[i]+bugs_res_vichy[i,t-6])
		
	}
}

for (t in 8:T){
	for (i in 1:5000){
		bugs_juv_wild_system_surv_actu[i,t] <- exp(log(bugs_s_juv2ad[i]*bugs_juv_wild_system[i,t])+ bugs_level_s[i] * bugs_I_surv[i,t-7]+bugs_res_vichy[i,t-6])
	}
}

mean_bugs_juv_wild_system_surv_actu<-apply(bugs_juv_wild_system_surv_actu,MARGIN=2,mean)

