#========================================================================
# Probabilité d'observer tx renouvellement >=1 en moyenne mobile 5 ans
#========================================================================
#on regarde probabilité d'être égale ou supérieur au point de référence = au moins à 1 en tx de renouv (ou à 0 en échelle log)
upper_renew_rate_actu=array(0,dim=c(5000,T))

for (t in 7:(T-6)){ #Décalage de 6 ans car pour calculer tx renouv des adultes de 2010 il nous faut les retours des années 2014+2015+2016 (à T=42 dernière année =2016) + on ne commence qu'à la 7eme année car avant tirage à blanc
	for (i in 1:5000){
		if(renew_rate_coef[i,t] >= 0){upper_renew_rate_actu[i,t]=1} # valeur en lor on prend donc >= à 0
	} 
}

p_upper_renew_rate_actu=rep(0,T)

for (t in 7:(T-6)){
	p_upper_renew_rate_actu[t]=mean(upper_renew_rate_actu[,t])
}

#On réduit sur les années où on a le calcul
p_upper_renew_rate_actu<-p_upper_renew_rate_actu[7:(T-6)]
#library(igraph) #fonctionrunning.mean() qui calcule moyenne mobile (glissante) sur un pas de temps donné
running.mean<- function(x, n = 5){stats::filter(x, rep(1 / n, n), sides = 2)}
x_mob_renew_rate=seq(11,(T-6),1)

rects <- data.frame(ystart = seq(0,0.75,0.25), yend = seq(0.25,1,0.25), 
		col = c("red","orange","yellow","green"))
graph_tx_ren_proba<-ggplot()+ 
		geom_rect(data=rects, aes(xmin=min(x_mob_renew_rate), xmax=max(x_mob_renew_rate), ymin=ystart,ymax=yend), fill=rects$col, alpha =0.5) +
		geom_line(aes(x_mob_renew_rate,running.mean(p_upper_renew_rate_actu,5)),size=1)+
		#scale_x_continuous(breaks=c(8,16.7,25.5,34.1), labels=c((1975+7+5),1990,2000,(2016-6)))+
		scale_x_continuous(breaks=c(11,16,21,26,31,36), labels=c(1985,(1974+7+5+4),1995,2000,2005,2010))+
		geom_hline(yintercept = 0.5,linetype="dashed",size=2)+
		geom_hline(yintercept = 0.75, linetype="dashed", size=1)+
		geom_hline(yintercept = 0.25, linetype="dashed", size=1)+
		xlab(iconv("Année","UTF8")) + 
		ylab(iconv("Probabilité","UTF8"))+
		ggtitle(iconv("\nProbabilité d'observer un taux de renouvellement >=1 \npour la population totale (sauvage + élevage) \n(moyenne mobile 5 ans) ","UTF8"))+
		labs(fill = "")+
		theme_bw()+
