@

<<Simulation_CE,echo=FALSE, eval=FALSE, results=hide>>=

#=====================
# Taux renouvellement
#=====================
#-----------------------
#Population sauvage
#-----------------------
s_juv2ad=read.coda("s_juv2adCODAchain1.txt","s_juv2adCODAindex.txt")
level_s=read.coda("simulation/level_sCODAchain1.txt","simulation/level_sCODAindex.txt") 
I_surv=read.coda("simulation/I_survCODAchain1.txt","simulation/I_survCODAindex.txt")
res_vichy=read.coda("simulation/res_vichyCODAchain1.txt","simulation/res_vichyCODAindex.txt")
d_wild_moy_vichy=read.coda("dmoywild_VCODAchain1.txt","dmoywild_VCODAindex.txt")
d_wild_moy_alagnon=read.coda("dmoywild_ACODAchain1.txt","dmoywild_ACODAindex.txt")
d_wild_moy_langeac=read.coda("dmoywild_LCODAchain1.txt","dmoywild_LCODAindex.txt")
d_wild_moy_poutes=read.coda("dmoywild_PCODAchain1.txt","dmoywild_PCODAindex.txt")
N_vichy=read.coda("N_vichyCODAchain1.txt","N_vichyCODAindex.txt")

juv_wild_vichy<-array(rep(0,T*5000),dim=c(5000,T+1))
juv_wild_alagnon<-array(rep(0,T*5000),dim=c(5000,T+1))
juv_wild_langeac<-array(rep(0,T*5000),dim=c(5000,T+1))
juv_wild_poutes<-array(rep(0,T*5000),dim=c(5000,T+1))
juv_wild_tot_V<-array(rep(0,T*5000),dim=c(5000,T+1))
juv_wild_tot_A<-array(rep(0,T*5000),dim=c(5000,T+1))
juv_wild_tot_L<-array(rep(0,T*5000),dim=c(5000,T+1))
juv_wild_tot_P<-array(rep(0,T*5000),dim=c(5000,T+1))
juv_wild_tot_system<-array(rep(0,T*5000),dim=c(5000,T+1))
N_wild_vichy<-array(rep(0,T*5000),dim=c(5000,T))
coef_juv_1<-array(rep(0,T*5000),dim=c(5000,T+20))
coef_juv_2<-array(rep(0,T*5000),dim=c(5000,T+20))
coef_juv_3<-array(rep(0,T*5000),dim=c(5000,T+20))
renew_rate_w=array(0,dim=c(5000,T+1))
renew_rate_w_q=array(NA,dim=c((T),5))		
renew_rate_w_coef=array(0,dim=c(5000,T+1))
renew_rate_w_coef_q=array(NA,dim=c((T),5))
renew_rate=array(NA,dim=c(5000,T+20-5))
renew_rate_q=array(NA,dim=c((T+20-5),5))

surf=c(rep(c(846021,70845,250441,0),11),rep(c(846021,70845,250441,301101),12),rep(c(846021,70845,250441,383049),6),rep(c(846021,356519,250441,383049),(T-8)))
S_juv_JP<-matrix(surf,nrow=4)	

#On calcule les juvéniles SAUVAGES uniquement de chaque année sur chaque secteur
for (t in 1:T){
	for (i in 1:5000){
		juv_wild_vichy[i,t+1]=d_wild_moy_vichy[i,t]*S_juv_JP[1,t+1] #d_wild_moy commence à 2 d'où l'indice t et non t+1
		juv_wild_alagnon[i,t+1]=d_wild_moy_alagnon[i,t]*S_juv_JP[2,t+1] #d_wild_moy commence à 2 d'où l'indice t et non t+1
		juv_wild_langeac[i,t+1]=d_wild_moy_langeac[i,t]*S_juv_JP[3,t+1] #d_wild_moy commence à 2 d'où l'indice t et non t+1
	}
}

for (t in 12:T){
	for (i in 1:5000){
		juv_wild_poutes[i,t+1]=d_wild_moy_poutes[i,t-11]*S_juv_JP[4,t+1] #d_wild_moy commence à 13 d'où l'indice t et non t+1
		
	}
}

#On calcule les juvéniles SAUVAGES uniquement à l'origine des retours d'adultes
for (t in 7:T){
	for (i in 1:5000){
		juv_wild_tot_V[i,t] <- (1/3) * juv_wild_vichy[i,t-3] + (1/3) * juv_wild_vichy[i,t-4] + (1/3) * juv_wild_vichy[i,t-5]
		juv_wild_tot_A[i,t] <- (1/3) * juv_wild_alagnon[i,t-3] + (1/3) * juv_wild_alagnon[i,t-4] + (1/3) * juv_wild_alagnon[i,t-5] 
		juv_wild_tot_L[i,t] <- (1/3) * juv_wild_langeac[i,t-3] + (1/3) * juv_wild_langeac[i,t-4] + (1/3) * juv_wild_langeac[i,t-5] 
	}
}

for (t in 16:16){
	for (i in 1:5000){
		juv_wild_tot_P[i,t] <- (1/3) * juv_wild_poutes[i,t-3] 
	}
}	
for (t in 17:17){
	for (i in 1:5000){
		juv_wild_tot_P[i,t] <- (1/3) * juv_wild_poutes[i,t-3] + (1/3) * juv_wild_poutes[i,t-4]
	}
}	
for (t in 18:T){
	for (i in 1:5000){
		juv_wild_tot_P[i,t] <- (1/3) * juv_wild_poutes[i,t-3] + (1/3) * juv_wild_poutes[i,t-4] + (1/3) * juv_wild_poutes[i,t-5]
	}
}

for (t in 7:15){
	for (i in 1:5000){
		juv_wild_tot_system[i,t] <- juv_wild_tot_V[i,t]+ juv_wild_tot_A[i,t] +juv_wild_tot_L[i,t] 
	}
}
for (t in 16:T){
	for (i in 1:5000){
		juv_wild_tot_system[i,t] <- juv_wild_tot_V[i,t]+ juv_wild_tot_A[i,t] +juv_wild_tot_L[i,t]  + juv_wild_tot_P[i,t]
	}
}	


#On calcule les adultes sauvages à Vichy
for (t in 7:7){
	for (i in 1:5000){
		N_wild_vichy[i,t]<-exp(log(juv_wild_tot_system[i,t])+log(s_juv2ad[i])+ level_s[i] * 1+res_vichy[i,t-6])
		#exp(log(juv_wild_tot_system[i,t]*s_juv2ad[i] * exp(level_s[i] * 1)) + res_vichy[i,t-6])
	}
}


for (t in 8:T){
	for (i in 1:5000){
		N_wild_vichy[i,t]<-exp(log(juv_wild_tot_system[i,t])+log(s_juv2ad[i])+ level_s[i] * I_surv[i,t-7]+res_vichy[i,t-6])
		#N_wild_vichy[i,t]<-exp(log(juv_wild_tot_system[i,t]*s_juv2ad[i] * exp(level_s[i] * I_surv[i,t-7])) + res_vichy[i,t-6])
	}
}


#On fait les quantiles de N_wild_vichy
N_wild_vichy_q<-array(NA,dim=c((T),5))
for (t in 1:T){
	N_wild_vichy_q[t,]=quantile(N_wild_vichy[,t],probs=c(0.025,0.25,0.5,0.75,0.975),names=FALSE)
}

load("C:/Users/marion.legrand/workspace/ModeleDynamiquePop/2019_12_12_Projection_InteractionReciproqueMatriceVC_Maj2018_ContinuiteEcologique_2020_01_03.RData")
#REPONSE à une question d'Etienne - quelle mortalité faut-il compenser pour obtenir un taux de renouvellement au moins égal à 1
#Méthode empirique réalisé dans le script de projection à 20 ans dans le scénario de CE qui nous a permis d'établir qu'en compensant 37% de mortalité
#on obtient un tx de renouvellement = à 1 une fois que la montaison est traitée
#load("C:/Users/marion.legrand/workspace/ModeleDynamiquePop/2019_12_12_Projection_InteractionReciproqueMatriceVC_Maj2018_ContinuiteEcologique_TEST_ameliorationSurv_2020_01_09.RData")

#A partir de T on a juv_vichy. On rassemble les 2 jeux de données mais en prenant les bugs_ uniquement jusqu'à T-1 (=41)
juv_vichy<-cbind(juv_wild_vichy[,1:(T-1)],juv_vichy[,T:(T+27)])
juv_alagnon<-cbind(juv_wild_alagnon[,1:(T-1)],juv_alagnon[,T:(T+27)])
juv_langeac<-cbind(juv_wild_langeac[,1:(T-1)],juv_langeac[,T:(T+27)])
juv_poutes<-cbind(juv_wild_poutes[,1:(T-1)],juv_poutes[,T:(T+27)])

bugs2jags(str_c(datawd,"data.txt"),"data_4zones_Interaction_2019.12.12.R")
source("data_4zones_Interaction_2019.12.12.R")
data_vichy<-N[,1]
##On calcul sur la fin de la période rétrospective
for(t in (T-9):(T)){#
	for (i in 1:5000){ 
		###### Partie Taux Renouvellement ############
		#on calcule le coef pondérateur des juvéniles
		coef_juv_1[i,t]<-(juv_vichy[i,t-4]+juv_alagnon[i,t-4]+juv_langeac[i,t-4]+juv_poutes[i,t-4])/((juv_vichy[i,t-4]+juv_alagnon[i,t-4]+juv_langeac[i,t-4]+juv_poutes[i,t-4])+(juv_vichy[i,t-5]+juv_alagnon[i,t-5]+juv_langeac[i,t-5]+juv_poutes[i,t-5])+(juv_vichy[i,t-6]+juv_alagnon[i,t-6]+juv_langeac[i,t-6]+juv_poutes[i,t-6]))
		coef_juv_2[i,t]<-(juv_vichy[i,t-4]+juv_alagnon[i,t-4]+juv_langeac[i,t-4]+juv_poutes[i,t-4])/((juv_vichy[i,t-3]+juv_alagnon[i,t-3]+juv_langeac[i,t-3]+juv_poutes[i,t-3])+(juv_vichy[i,t-4]+juv_alagnon[i,t-4]+juv_langeac[i,t-4]+juv_poutes[i,t-4])+(juv_vichy[i,t-5]+juv_alagnon[i,t-5]+juv_langeac[i,t-5]+juv_poutes[i,t-5]))
		coef_juv_3[i,t]<-(juv_vichy[i,t-4]+juv_alagnon[i,t-4]+juv_langeac[i,t-4]+juv_poutes[i,t-4])/((juv_vichy[i,t-2]+juv_alagnon[i,t-2]+juv_langeac[i,t-2]+juv_poutes[i,t-2])+(juv_vichy[i,t-3]+juv_alagnon[i,t-3]+juv_langeac[i,t-3]+juv_poutes[i,t-3])+(juv_vichy[i,t-4]+juv_alagnon[i,t-4]+juv_langeac[i,t-4]+juv_poutes[i,t-4]))
	}
}

for(t in (T+1):(T+20)){#
	for (i in 1:5000){ 
		###### Partie Taux Renouvellement ############
		#on calcule le coef pondérateur des juvéniles
		coef_juv_1[i,t]<-(juv_vichy[i,t-4]+juv_alagnon[i,t-4]+juv_langeac[i,t-4]+juv_poutes[i,t-4])/((juv_vichy[i,t-4]+juv_alagnon[i,t-4]+juv_langeac[i,t-4]+juv_poutes[i,t-4])+(juv_vichy[i,t-5]+juv_alagnon[i,t-5]+juv_langeac[i,t-5]+juv_poutes[i,t-5])+(juv_vichy[i,t-6]+juv_alagnon[i,t-6]+juv_langeac[i,t-6]+juv_poutes[i,t-6]))
		coef_juv_2[i,t]<-(juv_vichy[i,t-4]+juv_alagnon[i,t-4]+juv_langeac[i,t-4]+juv_poutes[i,t-4])/((juv_vichy[i,t-3]+juv_alagnon[i,t-3]+juv_langeac[i,t-3]+juv_poutes[i,t-3])+(juv_vichy[i,t-4]+juv_alagnon[i,t-4]+juv_langeac[i,t-4]+juv_poutes[i,t-4])+(juv_vichy[i,t-5]+juv_alagnon[i,t-5]+juv_langeac[i,t-5]+juv_poutes[i,t-5]))
		coef_juv_3[i,t]<-(juv_vichy[i,t-4]+juv_alagnon[i,t-4]+juv_langeac[i,t-4]+juv_poutes[i,t-4])/((juv_vichy[i,t-2]+juv_alagnon[i,t-2]+juv_langeac[i,t-2]+juv_poutes[i,t-2])+(juv_vichy[i,t-3]+juv_alagnon[i,t-3]+juv_langeac[i,t-3]+juv_poutes[i,t-3])+(juv_vichy[i,t-4]+juv_alagnon[i,t-4]+juv_langeac[i,t-4]+juv_poutes[i,t-4]))
	}
}


for(t in (T-9):(T-1)){
	for (i in 1:5000){ 
		###### Partie Taux Renouvellement ############
		#on calcule le coef pondérateur des juvéniles
		renew_rate[i,t-5]<-log((coef_juv_1[i,t]*N_wild_vichy[i,t-1]+coef_juv_2[i,t]*N_wild_vichy[i,t]+coef_juv_3[i,t]*N_wild_vichy[i,t+1])/data_vichy[t-5])
	}
}
for(t in T:T){
	for (i in 1:5000){ 
		###### Partie Taux Renouvellement ############
		#on calcule le coef pondérateur des juvéniles
		renew_rate[i,t-5]<-log((coef_juv_1[i,t]*N_wild_vichy[i,t-1]+coef_juv_2[i,t]*N_wild_vichy[i,t]+coef_juv_3[i,t]*N_vichy[i,t+1])/data_vichy[t-5])
	}
}

for(t in (T+1):(T+1)){
	for (i in 1:5000){ 
		###### Partie Taux Renouvellement ############
		#on calcule le coef pondérateur des juvéniles
		renew_rate[i,t-5]<-log((coef_juv_1[i,t]*N_wild_vichy[i,t-1]+coef_juv_2[i,t]*N_vichy[i,t]+coef_juv_3[i,t]*N_vichy[i,t+1])/data_vichy[t-5])
	}
}
for(t in (T+2):(T+5)){
	for (i in 1:5000){ 
		###### Partie Taux Renouvellement ############
		#on calcule le coef pondérateur des juvéniles
		renew_rate[i,t-5]<-log((coef_juv_1[i,t]*N_vichy[i,t-1]+coef_juv_2[i,t]*N_vichy[i,t]+coef_juv_3[i,t]*N_vichy[i,t+1])/data_vichy[t-5])
	}
}
for(t in (T+6):(T+20)){
	for (i in 1:5000){ 
		###### Partie Taux Renouvellement ############
		#on calcule le coef pondérateur des juvéniles
		renew_rate[i,t-5]<-log((coef_juv_1[i,t]*N_vichy[i,t-1]+coef_juv_2[i,t]*N_vichy[i,t]+coef_juv_3[i,t]*N_vichy[i,t+1])/N_vichy[i,t-5])
	}
}

for (t in (T-5):(T+20)){
	renew_rate_q[t-5,]=quantile(renew_rate[,t-5],probs=c(0.025,0.25,0.5,0.75,0.975),names=FALSE)
}

#========================================
# En moyenne mobile simple - echelle log
#========================================
#library(igraph)#fonction running.mean() qui calcule moyenne mobile (glissante) sur un pas de temps donné
running.mean<- function(x, n = 5){stats::filter(x, rep(1 / n, n), sides = 2)}
library(dplyr)
library(ggplot2)
data<-stack(as.data.frame(renew_rate[,(T+1-4-6):(T+20-6)]))
#On fait la moyenne des médianes
median_data<-tapply(exp(data[,1]),data[,2],median) ##ATTENTION ICI on PREND MEDIANE pour faire moyenne mobile des médianes sur 5 ans

x_tx_moyMob=seq(1,(ncol(renew_rate[,(T+1-4-6):(T+20-4-6)])),1)
rect_2_col <- data.frame(ystart = c(0,1), yend = c(1,2),col = c("red","green"))
graph_tx_ren_ce_wild<-ggplot()+
		geom_rect(data=rect_2_col, aes(xmin=1, xmax=20, ymin=ystart,ymax=yend), fill=rect_2_col$col, alpha =0.5) +
		geom_line(aes(x_tx_moyMob,running.mean(median_data,5)[!is.na(running.mean(median_data,5))]),size=1)+
		#geom_boxplot(aes(x,exp(data$values),group=data$ind,fill=med_val),outlier.shape = NA)+
		scale_y_continuous(trans="log10")+
		annotation_logticks(sides="l")  +
		scale_x_continuous(breaks=c(1,3,8,13,18,20), labels=c((1974+T+1-6),(1974+T+3-6),(1974+T+8-6),(1974+T+13-6),(1974+T+18-6),(1974+T+20-6)))+
		scale_fill_manual(values=col)+
		#geom_hline(yintercept=1,color = "black") +
		xlab("Année") + 
		ylab("Tx de renouvellement")+
		ggtitle("Tx de renouvellement de la population sauvage \n(moyenne mobile 5 ans)")+
		labs(fill = "")+
		theme_bw()+
    #theme_bw(base_size=22)+ #pour sauvegarde png
		theme(plot.title = element_text(hjust = 0.5),legend.position="bottom")

#pour voir moyenne des 5 dernières années
mean(running.mean(median_data,5)[!is.na(running.mean(median_data,5))][16:20]) #0.8879985


