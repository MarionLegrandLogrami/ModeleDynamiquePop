detach("package:dplyr", unload=TRUE)
library(plyr)
datapoly <- join(values, positions) #on utilise join et non merge car sinon tri sur les id et on a 1.1 puis 1.10 au lieu d'avoir 1.1 puis 1.2

graph_niveau_pop_ce<-ggplot()+
		geom_polygon(data=datapoly, aes(x=x, y=y, group=id),fill=datapoly$values, alpha =0.5) +
		#geom_line(aes(x_mob,running.mean(mean_N_vichy_50_actu,5)),size=0.5)+
		geom_line(aes(x_mob,running.mean(mean_N_vichy_ce,5)[!is.na(running.mean(mean_N_vichy_ce,5))]),size=1)+ #poissons estimés
		#geom_line(aes(x_mob[23:38],running.mean(median_N_vichy_ce,5)[23:38]),size=1)+ #poissons observés
		xlab("Année") + 
		ylab("Adultes estimés à Vichy")+
		ggtitle("Adultes estimés à Vichy par rapport au nombre de géniteurs \nque produirait la quantité de juvéniles correspondant à 50% de Rmax \n(moyenne mobile 5 ans)")+
		scale_x_continuous(limits = c((T+1-2), (T+20-2)),breaks=c((T+1-2),(T+4-2),(T+9-2),(T+14-2),(T+20-2)), labels=c((1974+T+1),(1974+T+4),(1974+T+9),(1974+T+14),(1974+T+20)))+
		theme(legend.position="none")+
    theme_bw()+
		#theme_bw(base_size=22)+
		theme(plot.title = element_text(hjust = 0.5)) 

