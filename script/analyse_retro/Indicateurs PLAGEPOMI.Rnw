#library(igraph)
running.mean<- function(x, n = 5){stats::filter(x, rep(1 / n, n), sides = 2)}
library(dplyr)
data<-stack(as.data.frame(renew_rate_w_coef[,7:(T-6)]))
#On fait la moyenne des médianes
mean_data<-tapply(exp(data[,1]),data[,2],mean)
#x_tx_moyMob=seq(1,(ncol(renew_rate_w_coef[,7:(T-6)])-4),1)
x_tx_moyMob=seq(1,(ncol(renew_rate_w_coef[,7:(T-6)])-4),1)
