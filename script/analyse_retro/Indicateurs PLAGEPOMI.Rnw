<<Rmax,echo=FALSE, eval=FALSE, results=hide>>
#calcul à quoi correspond Rmax
Juv_Rmax_V=array(0,dim=c(10000,T))
Juv_Rmax_A=array(0,dim=c(10000,T))
Juv_Rmax_L=array(0,dim=c(10000,T))
Juv_Rmax_P=array(0,dim=c(10000,T))
Juv_Rmax=array(0,dim=c(10000,T))
for (t in 1:T){
	for (i in 1:10000){
		Juv_Rmax_V[i,t]<-Rmax[i]*exp(bugs_nu_d[i,1])*S_juv_JP[1,t] #multiplie par nu_d pour tenir compte de la différence de production de juvéniles des différentes zones
		Juv_Rmax_A[i,t]<-Rmax[i]*exp(bugs_nu_d[i,2])*S_juv_JP[2,t] #multiplie par nu_d pour tenir compte de la différence de production de juvéniles des différentes zones
		Juv_Rmax_L[i,t]<-Rmax[i]*exp(bugs_nu_d[i,3])*S_juv_JP[3,t] #multiplie par nu_d pour tenir compte de la différence de production de juvéniles des différentes zones
		Juv_Rmax_P[i,t]<-Rmax[i]*exp(bugs_nu_d[i,4])*S_juv_JP[4,t] #multiplie par nu_d pour tenir compte de la différence de production de juvéniles des différentes zones
		Juv_Rmax[i,t]<-Juv_Rmax_V[i,t]+Juv_Rmax_A[i,t]+Juv_Rmax_L[i,t]+Juv_Rmax_P[i,t] #mean=213031.8
	}
}
mean(Juv_Rmax) #=407554

##50% Rmax
