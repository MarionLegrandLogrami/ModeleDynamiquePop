Juv_Rmax_100_A=array(0,dim=c(10000,T))
Juv_Rmax_100_L=array(0,dim=c(10000,T))
Juv_Rmax_100_P=array(0,dim=c(10000,T))
Juv_Rmax_100=array(0,dim=c(10000,T))

