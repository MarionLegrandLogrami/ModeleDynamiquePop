)


detach("package:dplyr", unload=TRUE)
library(plyr)
datapoly <- join(values, positions) #on utilise join et non merge car sinon tri sur les id et on a 1.1 puis 1.10 au lieu d'avoir 1.1 puis 1.2

graph_niveau_pop_CU<-ggplot()+
		geom_polygon(data=datapoly, aes(x=x, y=y, group=id),fill=datapoly$values, alpha =0.5) +
		geom_line(aes(x_mob[1:23],running.mean(data_vichy_all,5)[!is.na(running.mean(data_vichy_all,5))][1:23]),size=1,linetype = "dashed")+ #poissons estimés
		geom_line(aes(x_mob[23:(length(x_mob))],running.mean(data_vichy_all,5)[!is.na(running.mean(data_vichy_all,5))][23:(length(x_mob))]),size=1)+ #poissons observés
		xlab("Année") + 
		ylab("Adultes estimés issus de juvéniles sauvages")+
		ggtitle("Adultes issus de juvéniles sauvages à Vichy par rapport au nombre d'adultes \nque produirait la quantité de juvéniles correspondant à 50% de Rmax et dans \nle cas d'un retour à 50% de la survie historique (moyenne mobile 5 ans)")+
		scale_x_continuous(breaks=c(4,14,24,34,(T-2)), labels=c(1980,1990,2000,2010,(1974+T)))+
		theme(legend.position="none")+
    theme_bw()+
		#theme_bw(base_size=22)+ #pour sauvegarde png
		theme(plot.title = element_text(hjust = 0.5)) 


