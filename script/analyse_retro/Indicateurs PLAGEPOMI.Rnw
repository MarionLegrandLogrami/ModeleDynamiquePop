	for (i in 1:5000){ 
		###### Partie Taux Renouvellement ############
		#on calcule le coef pondérateur des juvéniles
		renew_rate[i,t-5]<-log((coef_juv_1[i,t]*N_wild_vichy[i,t-1]+coef_juv_2[i,t]*N_wild_vichy[i,t]+coef_juv_3[i,t]*N_vichy[i,t+1])/data_vichy[t-5])
	}
}

for(t in (T+1):(T+1)){
	for (i in 1:5000){ 
		###### Partie Taux Renouvellement ############
		#on calcule le coef pondérateur des juvéniles
		renew_rate[i,t-5]<-log((coef_juv_1[i,t]*N_wild_vichy[i,t-1]+coef_juv_2[i,t]*N_vichy[i,t]+coef_juv_3[i,t]*N_vichy[i,t+1])/data_vichy[t-5])
	}
}
for(t in (T+2):(T+5)){
	for (i in 1:5000){ 
		###### Partie Taux Renouvellement ############
		#on calcule le coef pondérateur des juvéniles
		renew_rate[i,t-5]<-log((coef_juv_1[i,t]*N_vichy[i,t-1]+coef_juv_2[i,t]*N_vichy[i,t]+coef_juv_3[i,t]*N_vichy[i,t+1])/data_vichy[t-5])
	}
}
for(t in (T+6):(T+20)){
	for (i in 1:5000){ 
		###### Partie Taux Renouvellement ############
		#on calcule le coef pondérateur des juvéniles
		renew_rate[i,t-5]<-log((coef_juv_1[i,t]*N_vichy[i,t-1]+coef_juv_2[i,t]*N_vichy[i,t]+coef_juv_3[i,t]*N_vichy[i,t+1])/N_vichy[i,t-5])
	}
}

