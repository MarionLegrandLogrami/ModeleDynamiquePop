data_vichy<-N[,1]

for (t in 7:21){
	for (i in 1:5000){
		renew_rate_coef[i,t-5]<-log((coef_juv_tot_1[i,t]*N_vichy[i,t-1]+coef_juv_tot_2[i,t]*N_vichy[i,t]+coef_juv_tot_3[i,t]*N_vichy[i,t+1])/N_vichy[i,t-5])
