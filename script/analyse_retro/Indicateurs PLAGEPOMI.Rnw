## Part sauvage/élevage
##########################

#Dans le scénario CE, on arrête les déversements - tous les juvéniles sont donc sauvages à partir de T+1
#Par contre on fait une moyenne mobile sur 5 ans donc 2017 = moyenne 2013-2017 il faut récupérer les données des années précédentes
surf=c(rep(c(846021,70845,250441,0),11),rep(c(846021,70845,250441,301101),12),rep(c(846021,70845,250441,383049),6),rep(c(846021,356519,250441,383049),(T-8)))
S_juv_JP<-matrix(surf,nrow=4)	
#==============================
# calcul des juvéniles totaux 
#==============================
dmoy_tot_V=read.coda("dmoytot_VCODAchain1.txt","dmoytot_VCODAindex.txt",5001,10000)
dmoy_tot_A=read.coda("dmoytot_ACODAchain1.txt","dmoytot_ACODAindex.txt",5001,10000)
dmoy_tot_L=read.coda("dmoytot_LCODAchain1.txt","dmoytot_LCODAindex.txt",5001,10000)
dmoy_tot_P=read.coda("dmoytot_PCODAchain1.txt","dmoytot_PCODAindex.txt",5001,10000)

juv_tot=array(rep(0,(5000*T)),dim=c(5000,T))#296000
juv_tot_q=array(rep(0,T*5),dim=c(T,5))

for (t in 2:12){
	juv_tot[,t]= dmoy_tot_V[,t-1] * S_juv_JP[1,t] + dmoy_tot_A[,t-1] * S_juv_JP[2,t] + dmoy_tot_L[,t-1] * S_juv_JP[3,t]
}
for (t in 13:T){
	juv_tot[,t]= dmoy_tot_V[,t-1] * S_juv_JP[1,t] + dmoy_tot_A[,t-1] * S_juv_JP[2,t] + dmoy_tot_L[,t-1] *S_juv_JP[3,t] + dmoy_tot_P[,t-12] * S_juv_JP[4,t]	
}

#===============================
# Calcul des juvéniles sauvages
#===============================
dmoy_wild_V=read.coda("dmoywild_VCODAchain1.txt","dmoytot_VCODAindex.txt",5001,10000)
dmoy_wild_A=read.coda("dmoywild_ACODAchain1.txt","dmoytot_ACODAindex.txt",5001,10000)
dmoy_wild_L=read.coda("dmoywild_LCODAchain1.txt","dmoytot_LCODAindex.txt",5001,10000)
dmoy_wild_P=read.coda("dmoywild_PCODAchain1.txt","dmoytot_PCODAindex.txt",5001,10000)

juv_wild_V=array(rep(0,195000),dim=c(5000,T))
juv_wild_A=array(rep(0,195000),dim=c(5000,T))
juv_wild_L=array(rep(0,195000),dim=c(5000,T))
juv_wild_P=array(rep(0,195000),dim=c(5000,T))
juv_wild_tot=array(rep(0,195000),dim=c(5000,T))
juv_wild_tot_q=array(rep(0,T*5),dim=c(T,5))


for (t in 2:12){
	juv_wild_V[,t]<-dmoy_wild_V[,t-1] * S_juv_JP[1,t]
	juv_wild_A[,t]<-dmoy_wild_V[,t-1] * S_juv_JP[2,t]
	juv_wild_L[,t]<-dmoy_wild_L[,t-1] * S_juv_JP[3,t]
}

for (t in 13:T){
	juv_wild_V[,t]<-dmoy_wild_V[,t-1] * S_juv_JP[1,t]
	juv_wild_A[,t]<-dmoy_wild_V[,t-1] * S_juv_JP[2,t]
	juv_wild_L[,t]<-dmoy_wild_L[,t-1] * S_juv_JP[3,t]
	juv_wild_P[,t]<-dmoy_wild_P[,t-12] * S_juv_JP[4,t]
}

for (t in 1:T){
	juv_wild_tot[,t]<-juv_wild_V[,t]+juv_wild_A[,t]+juv_wild_L[,t]+juv_wild_P[,t]
}

#==================
# Calcul du ratio
#==================
ratio_juv_wild<-array(NA,dim=c(5000,T))
mean_ratio_juv_wild<-array(NA,dim=c(1,T))
for (t in 2:T){
	for (i in 1:5000){
		ratio_juv_wild[i,t]<-juv_wild_tot[i,t]/juv_tot[i,t]
	}
}

mean_ratio_juv_wild<-apply(ratio_juv_wild,MARGIN=2,FUN=mean)
#A partir de T+1 100% sauvage
ratio_juv_1<-rep(1,20)
mean_ratio_juv_wild<-c(mean_ratio_juv_wild,ratio_juv_1)
x_juv<-seq(1,T+20,1)
rect_2_col <- data.frame(ystart = c(0,0.5), yend = c(0.5,1),col = c("red","green"))
graph_part_juv_ws<-ggplot()+
		geom_rect(data=rect_2_col, aes(xmin=(T+1-2), xmax=(T+20-2), ymin=ystart,ymax=yend), fill=rect_2_col$col, alpha =0.5) +
		geom_line(aes(x_juv[(T+1-2):(T+20-2)],running.mean(mean_ratio_juv_wild[(T-3):(T+20)],5)[!is.na(running.mean(mean_ratio_juv_wild[(T-3):(T+20)],5))]),size=1)+
		geom_hline(yintercept = 0.5,linetype="dashed",size=2)+
		geom_hline(yintercept = 0.75, linetype="dashed", size=1)+
		geom_hline(yintercept = 0.25, linetype="dashed", size=1)+
		xlab("Année") + 
		ylab("Ratio juvénile sauvage sur juvénile total")+
		ggtitle("Part de juvéniles sauvages dans l'ensemble des juvéniles \n(moyenne mobile 5 ans)")+
		scale_x_continuous(breaks=c((T+1-2),(T+4-2),(T+9-2),(T+14-2),(T+20-2)), labels=c((1974+T+1),(1974+T+4),(1974+T+9),(1974+T+14),(1974+T+20)))+
		theme(legend.position="none")+
		theme_bw()+
    #theme_bw(base_size=22)+ #pour sauvegarde png
		theme(plot.title = element_text(hjust = 0.5)) 

