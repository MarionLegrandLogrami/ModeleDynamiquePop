#Pour les graphs avec les projections
data_proj_p <- data_netcdf %>% filter(between(month(date),3,6),year(date)>=1975,nom_station!='Montjean') %>% 
		group_by (nom_station,year(date),mod_hydro,mod_narratif) %>%
		summarise(qmean=mean(debit,na.rm=TRUE),.groups = "drop")%>%
		rename(year=`year(date)`) %>%
		filter(year<= (1974+T+20))%>%
		group_by(nom_station, mod_hydro, mod_narratif) %>%  # Regrouper uniquement par station, mod_hydro et mod_narratif pour calculer lqmean_cr
		mutate(
				mean_log_qmean = mean(log(qmean), na.rm = TRUE),  # Moyenne log(qmean) sans tenir compte de l'année
				sd_log_qmean = sd(log(qmean), na.rm = TRUE),      # Écart-type log(qmean) sans tenir compte de l'année
				lqmean_cr = (log(qmean) - mean_log_qmean) / sd_log_qmean # Standardisation
		)
#on agrège le jeu de données netcdf par moyenne sur les mois de septembre à novembre (on ne prend pas Montjean qui n'est pas sur ces périodes dans le modèle)
data_proj_a <- data_netcdf %>% filter(between(month(date),9,11),year(date)>=1975,nom_station!='Montjean') %>% 
		group_by (nom_station,year(date),mod_hydro,mod_narratif) %>%
		summarise(qmean=mean(debit,na.rm=TRUE),.groups = "drop")%>%
		rename(year=`year(date)`) %>%
		filter(year<= (1974+T+20))%>%
		group_by(nom_station, mod_hydro, mod_narratif) %>%  # Regrouper uniquement par station, mod_hydro et mod_narratif pour calculer lqmean_cr
		mutate(
				mean_log_qmean = mean(log(qmean), na.rm = TRUE),  # Moyenne log(qmean) sans tenir compte de l'année
				sd_log_qmean = sd(log(qmean), na.rm = TRUE),      # Écart-type log(qmean) sans tenir compte de l'année
				lqmean_cr = (log(qmean) - mean_log_qmean) / sd_log_qmean # Standardisation
		)
#save(data_proj_a,file=str_c(datawd,"data_proj_a.Rdata"))	
#save(data_proj_p,file=str_c(datawd,"data_proj_p.Rdata"))
#--------------------------------------------------
# Graph par mod_hydro
#--------------------------------------------------
for (i in 1:length(noms_stations)){
	
	g_p <- ggplot(data_p %>% filter(nom_station==noms_stations[i]), aes(x = year, y = lqmean_cr, color = mod_hydro, linetype = mod_narratif)) +
			geom_line() + 
			# Ajouter les données observées
			geom_line(data = obs_p_replicated %>% filter(sta_nom==noms_stations[i]), aes(x = year, y = lqmean_cr), color = "black", linetype = "solid", linewidth = 0.7) +
			facet_wrap(~ mod_hydro,ncol = 1) + 
			labs(
					title = str_c("Débits à la station de ",noms_stations[i]," de mars à juin"),
					x = "Annees",
					y = "log(Débit) centré-réduit",
					color = "Modèle Hydrologique",
					linetype = "Modèle Narratif"
			) +
			theme_minimal() +
			theme(axis.text.x = element_text(angle = 45, hjust = 1),
					legend.position = "bottom",
					legend.box = "vertical",  # Force la légende à être verticale (titre au-dessus)
					legend.title = element_text(hjust = 0.5),
					legend.text = element_text(size = 8),  # Réduction de la taille du texte de la légende
					plot.margin = unit(c(1, 1, 1, 1), "cm")) +  # Augmenter la marge si nécessaire)+
			guides(
					color = guide_legend(nrow = 1, order = 1),  # Légende des couleurs sur 2 lignes
					linetype = guide_legend(nrow = 2, order = 2)  # Légende des types de ligne sur 2 lignes
			)
	
	ggsave(str_c(imgwd,str_c("Explore2_",noms_stations[i],"_log_cr_printemps_historique.png")), plot = g_p, width = 10, height = 8, dpi = 300, bg = "white")
	#Automne
	g_a <- ggplot(data_a %>% filter(nom_station==noms_stations[i]), aes(x = year, y = lqmean_cr, color = mod_hydro, linetype = mod_narratif)) +
			geom_line() + 
			# Ajouter les données observées
			geom_line(data = obs_a_replicated %>% filter(sta_nom==noms_stations[i]), aes(x = year, y = lqmean_cr), color = "black", linetype = "solid", linewidth = 0.7) +
