<< analyse_netcdf_fig, echo=FALSE, eval=TRUE,results=hide >>=	

load(file=str_c(datawd,"data_netcdf.RData")) #le jeu de donnée s'appelle data_netcdf 

#========================================================================================================
#on fait une boucle qui fait tous les graphs sur les différentes stations hors Montjean traité à part
#========================================================================================================
# Liste des noms de stations à interroger
noms_stations <- c("Vieille-Brioude", "Prades", "Lempdes")  # Ajoutez d'autres noms de station ici
# Définir les valeurs de mod_hydro (hors CTRIP qu'on a fixé à la main)
mod_hydro_values <- c("EROS", "ORCHIDEE", "SMASH")

#on récupère les coda du modèle pour avoir les données utilisées dans le modèle
obs_lempdes_A <- data.frame(sta_nom=rep('Lempdes',length(Q_L_mont_A)),
						  year=1975:(1974+T),
						  qmean=Q_L_mont_A,
						  mod_hydro=rep('CTRIP',length(Q_L_mont_A)),
						  mod_narratif=rep(NA,length(Q_L_mont_A)))
obs_lempdes_P <- data.frame(sta_nom=rep('Lempdes',length(Q_L_mont_P)),
						  year=1975:(1974+T),
						  qmean=Q_L_mont_P,
						  mod_hydro=rep('CTRIP',length(Q_L_mont_P)),
						  mod_narratif=rep(NA,length(Q_L_mont_P)))		
obs_prades_A <- data.frame(sta_nom=rep('Prades',length(Q_P_mont_A)),
						  year=1975:(1974+T),
						  qmean=Q_P_mont_A,
						  mod_hydro=rep('CTRIP',length(Q_P_mont_A)),
						  mod_narratif=rep(NA,length(Q_P_mont_A)))
obs_prades_P <- data.frame(sta_nom=rep('Prades',length(Q_P_mont_P)),
						  year=1975:(1974+T),
						  qmean=Q_P_mont_P,
						  mod_hydro=rep('CTRIP',length(Q_P_mont_P)),
						  mod_narratif=rep(NA,length(Q_P_mont_P)))	
obs_vb_A <- data.frame(sta_nom=rep('Vieille-Brioude',length(Q_VB_mont_A)),
						  year=1975:(1974+T),
						  qmean=Q_VB_mont_A,
						  mod_hydro=rep('CTRIP',length(Q_VB_mont_A)),
						  mod_narratif=rep(NA,length(Q_VB_mont_A)))
obs_vb_P <- data.frame(sta_nom=rep('Vieille-Brioude',length(Q_VB_mont_P)),
						  year=1975:(1974+T),
						  qmean=Q_VB_mont_P,
						  mod_hydro=rep('CTRIP',length(Q_VB_mont_P)),
						  mod_narratif=rep(NA,length(Q_VB_mont_P)))	
				  
obs_a <- rbind(obs_lempdes_A,obs_prades_A,obs_vb_A)		
obs_a <- obs_a %>% group_by(sta_nom, mod_hydro, mod_narratif) %>%  # Regrouper uniquement par station, mod_hydro et mod_narratif pour calculer lqmean_cr
		mutate(	mean_log_qmean = mean(log(qmean), na.rm = TRUE),  # Moyenne log(qmean) sans tenir compte de l'année
				sd_log_qmean = sd(log(qmean), na.rm = TRUE),      # Écart-type log(qmean) sans tenir compte de l'année
				lqmean_cr = (log(qmean) - mean_log_qmean) / sd_log_qmean # Standardisation
		)
obs_p <- rbind(obs_lempdes_P,obs_prades_P,obs_vb_P)	
obs_p <- obs_p %>% group_by(sta_nom, mod_hydro, mod_narratif) %>%  # Regrouper uniquement par station, mod_hydro et mod_narratif pour calculer lqmean_cr
		mutate(	mean_log_qmean = mean(log(qmean), na.rm = TRUE),  # Moyenne log(qmean) sans tenir compte de l'année
				sd_log_qmean = sd(log(qmean), na.rm = TRUE),      # Écart-type log(qmean) sans tenir compte de l'année
				lqmean_cr = (log(qmean) - mean_log_qmean) / sd_log_qmean # Standardisation
		)

# Définir les valeurs de mod_hydro (hors CTRIP qu'on a déjà fixé)
mod_hydro_values <- c("EROS", "ORCHIDEE", "SMASH")
mod_narratif_values <- c("MOHC-HadGEM2-ES / CLMcom-CCLM4-8-17", "MOHC-HadGEM2-ES / CNRM-ALADIN63", "CNRM-CERFACS-CNRM-CM5 / CNRM-ALADIN63","ICHEC-EC-EARTH / MOHC-HadREM3-GA7-05")
obs_a_replicated <- obs_a %>%
		# Créer une liste de data frames en fonction de mod_hydro_values
		bind_rows(lapply(mod_hydro_values, function(mod) {
							obs_a %>%
									mutate(mod_hydro = mod)
						}))
obs_a_replicated2 <- obs_a %>%
		# Créer une liste de data frames en fonction de mod_hydro_values
		bind_rows(lapply(mod_narratif_values, function(mod) {
							obs_a %>%
									mutate(mod_narratif = mod)
						})) %>%
		filter(!(is.na(mod_narratif)))

obs_p_replicated <- obs_p %>%
		# Créer une liste de data frames en fonction de mod_hydro_values
		bind_rows(lapply(mod_hydro_values, function(mod) {
							obs_p %>%
									mutate(mod_hydro = mod) 
						}))

obs_p_replicated2 <- obs_p %>%
		# Créer une liste de data frames en fonction de mod_hydro_values
		bind_rows(lapply(mod_narratif_values, function(mod) {
							obs_p %>%
									mutate(mod_narratif = mod)
						})) %>%
		filter(!(is.na(mod_narratif)))


#on agrège le jeu de données netcdf par moyenne sur les mois de mars à juin (on ne prend pas Montjean qui n'est pas sur ces périodes dans le modèle)
data_p <- data_netcdf %>% filter(between(month(date),3,6),year(date)<=1974+T,nom_station!='Montjean') %>% 
			group_by (nom_station,year(date),mod_hydro,mod_narratif) %>%
			summarise(qmean=mean(debit,na.rm=TRUE),.groups = "drop")%>%
			rename(year=`year(date)`) %>%
			filter(year>=1950)%>%
			group_by(nom_station, mod_hydro, mod_narratif) %>%  # Regrouper uniquement par station, mod_hydro et mod_narratif pour calculer lqmean_cr
			mutate(
					mean_log_qmean = mean(log(qmean), na.rm = TRUE),  # Moyenne log(qmean) sans tenir compte de l'année
					sd_log_qmean = sd(log(qmean), na.rm = TRUE),      # Écart-type log(qmean) sans tenir compte de l'année
					lqmean_cr = (log(qmean) - mean_log_qmean) / sd_log_qmean # Standardisation
			) 
#on agrège le jeu de données netcdf par moyenne sur les mois de septembre à novembre (on ne prend pas Montjean qui n'est pas sur ces périodes dans le modèle)
data_a <- data_netcdf %>% filter(between(month(date),9,11),year(date)<=1974+T,nom_station!='Montjean') %>% 
			group_by (nom_station,year(date),mod_hydro,mod_narratif) %>%
			summarise(qmean=mean(debit,na.rm=TRUE),.groups = "drop")%>%
			rename(year=`year(date)`) %>%
			filter(year>=1950) %>%
			group_by(nom_station, mod_hydro, mod_narratif) %>%  # Regrouper uniquement par station, mod_hydro et mod_narratif pour calculer lqmean_cr
			mutate(
					mean_log_qmean = mean(log(qmean), na.rm = TRUE),  # Moyenne log(qmean) sans tenir compte de l'année
					sd_log_qmean = sd(log(qmean), na.rm = TRUE),      # Écart-type log(qmean) sans tenir compte de l'année
					lqmean_cr = (log(qmean) - mean_log_qmean) / sd_log_qmean # Standardisation
			)
