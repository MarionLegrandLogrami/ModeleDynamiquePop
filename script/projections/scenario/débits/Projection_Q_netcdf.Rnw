@

<< analyse_netcdf_Montjean-sur-Loire, echo=FALSE, eval=TRUE,results=hide >>=	

load(file=str_c(datawd,"data_netcdf.RData")) #le jeu de donnée s'appelle data_netcdf 

#=================================================================================
#on fait une boucle qui fait tous les graphs sur les différentes stations
#=================================================================================
# Liste des noms de stations à interroger
noms_stations <- c("Montjean")  # Ajoutez d'autres noms de station ici
# Définir les valeurs de mod_hydro (hors CTRIP qu'on a fixé à la main)
mod_hydro_values <- c("EROS", "ORCHIDEE", "SMASH")

#on récupère les coda du modèle pour avoir les données utilisées dans le modèle
obs_montjean_mont <- data.frame(sta_nom=rep('Montjean',length(Q_MSL_mont)),
						  year=1975:(1974+T),
						  qmean=Q_MSL_mont,
						  mod_hydro=rep('CTRIP',length(Q_MSL_mont)),
						  mod_narratif=rep(NA,length(Q_MSL_mont)))
obs_montjean_deval <- data.frame(sta_nom=rep('Montjean',length(Q_MSL_deval)),
						  year=1975:(1974+T),
						  qmean=Q_MSL_deval,
						  mod_hydro=rep('CTRIP',length(Q_MSL_deval)),
						  mod_narratif=rep(NA,length(Q_MSL_deval)))		
	
obs_montjean_mont <- obs_montjean_mont %>% group_by(sta_nom, mod_hydro, mod_narratif) %>%  # Regrouper uniquement par station, mod_hydro et mod_narratif pour calculer lqmean_cr
		mutate(	mean_log_qmean = mean(log(qmean), na.rm = TRUE),  # Moyenne log(qmean) sans tenir compte de l'année
				sd_log_qmean = sd(log(qmean), na.rm = TRUE),      # Écart-type log(qmean) sans tenir compte de l'année
				lqmean_cr = (log(qmean) - mean_log_qmean) / sd_log_qmean # Standardisation
		)

obs_montjean_deval <- obs_montjean_deval %>% group_by(sta_nom, mod_hydro, mod_narratif) %>%  # Regrouper uniquement par station, mod_hydro et mod_narratif pour calculer lqmean_cr
		mutate(	mean_log_qmean = mean(log(qmean), na.rm = TRUE),  # Moyenne log(qmean) sans tenir compte de l'année
				sd_log_qmean = sd(log(qmean), na.rm = TRUE),      # Écart-type log(qmean) sans tenir compte de l'année
				lqmean_cr = (log(qmean) - mean_log_qmean) / sd_log_qmean # Standardisation
		)

mod_hydro_values <- c("EROS", "ORCHIDEE", "SMASH")
mod_narratif_values <- c("MOHC-HadGEM2-ES / CLMcom-CCLM4-8-17", "MOHC-HadGEM2-ES / CNRM-ALADIN63", "CNRM-CERFACS-CNRM-CM5 / CNRM-ALADIN63","ICHEC-EC-EARTH / MOHC-HadREM3-GA7-05")
obs_montjean_mont_replicated <- obs_montjean_mont %>%
		# Créer une liste de data frames en fonction de mod_hydro_values
		bind_rows(lapply(mod_hydro_values, function(mod) {
							obs_montjean_mont %>%
									mutate(mod_hydro = mod)  # Modifier mod_hydro
						}))
obs_montjean_mont_replicated2 <- obs_montjean_mont %>%
		# Créer une liste de data frames en fonction de mod_narratif_values
		bind_rows(lapply(mod_narratif_values, function(mod) {
							obs_montjean_mont %>%
									mutate(mod_narratif = mod)  # Modifier mod_hydro
						})) %>%
		filter(!(is.na(mod_narratif)))

obs_montjean_deval_replicated <- obs_montjean_deval %>%
		# Créer une liste de data frames en fonction de mod_hydro_values
		bind_rows(lapply(mod_hydro_values, function(mod) {
							obs_montjean_deval %>%
									mutate(mod_hydro = mod)  # Modifier mod_hydro
						}))
obs_montjean_deval_replicated2 <- obs_montjean_deval %>%
		# Créer une liste de data frames en fonction de mod_narratif_values
		bind_rows(lapply(mod_narratif_values, function(mod) {
							obs_montjean_deval %>%
									mutate(mod_narratif = mod)  # Modifier mod_hydro
						})) %>%
		filter(!(is.na(mod_narratif)))

#on aggrège le jeu de données netcdf
  # pour la montaison du 15 décembre au 15 mars
  # pour la dévalaison du 15 mars au 15 mai

data_mont <- data_netcdf %>%
              filter(nom_station == "Montjean",
                     (month(date) == 12 & day(date) >= 15) | 
                     (month(date) %in% c(1, 2)) | 
                     (month(date) == 3 & day(date) <= 15)) %>% 
      mutate(annee_hydro = ifelse(month(date) == 12, year(date) + 1, year(date))) %>%
      filter(annee_hydro <= 1974 + T) %>%
			group_by (nom_station,annee_hydro,mod_hydro,mod_narratif) %>%
			summarise(qmean=mean(debit,na.rm=TRUE),.groups = "drop")%>%
			filter(annee_hydro>=1950) %>%
			group_by(nom_station, mod_hydro, mod_narratif) %>%  
      mutate(
					mean_log_qmean = mean(log(qmean), na.rm = TRUE),  # Moyenne log(qmean) sans tenir compte de l'année
					sd_log_qmean = sd(log(qmean), na.rm = TRUE),      # Écart-type log(qmean) sans tenir compte de l'année
					lqmean_cr = (log(qmean) - mean_log_qmean) / sd_log_qmean # Standardisation
			)

data_deval <- data_netcdf %>%
              filter(nom_station == "Montjean",
                     year(date) <= 1974 + T,
                     (month(date) == 3 & day(date) >= 15) | 
                     (month(date) == 4) | 
                     (month(date) == 5 & day(date) <= 15)) %>% 
      mutate(annee_hydro = year(date)) %>%
			group_by (nom_station,annee_hydro,mod_hydro,mod_narratif) %>%
			summarise(qmean=mean(debit,na.rm=TRUE),.groups = "drop")%>%
			filter(annee_hydro>=1950) %>%
			group_by(nom_station, mod_hydro, mod_narratif) %>%  
      mutate(
					mean_log_qmean = mean(log(qmean), na.rm = TRUE),  # Moyenne log(qmean) sans tenir compte de l'année
					sd_log_qmean = sd(log(qmean), na.rm = TRUE),      # Écart-type log(qmean) sans tenir compte de l'année
					lqmean_cr = (log(qmean) - mean_log_qmean) / sd_log_qmean # Standardisation
			)

