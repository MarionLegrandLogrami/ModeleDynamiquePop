#========================================
# par narratif
#========================================

data_p_all2 <- data_p %>% select (nom_station, year, mod_hydro, mod_narratif,lqmean_cr) %>% 
		mutate(type="pred",
				num_narratif = case_when(mod_narratif=='CNRM-CERFACS-CNRM-CM5 / CNRM-ALADIN63' ~ 1,
						mod_narratif=='ICHEC-EC-EARTH / MOHC-HadREM3-GA7-05' ~ 5,
						mod_narratif=='MOHC-HadGEM2-ES / CNRM-ALADIN63' ~ 6,
						mod_narratif=='MOHC-HadGEM2-ES / CLMcom-CCLM4-8-17' ~ 7)) %>%
		rbind(obs_p_replicated2 %>% mutate(mod_hydro = "obs") %>% rename(nom_station=sta_nom) %>%
								 select (nom_station, year, mod_hydro, mod_narratif,lqmean_cr) %>%
								 mutate(type="pred",
										 num_narratif = case_when(mod_narratif=='CNRM-CERFACS-CNRM-CM5 / CNRM-ALADIN63' ~ 1,
												 mod_narratif=='ICHEC-EC-EARTH / MOHC-HadREM3-GA7-05' ~ 5,
												 mod_narratif=='MOHC-HadGEM2-ES / CNRM-ALADIN63' ~ 6,
												 mod_narratif=='MOHC-HadGEM2-ES / CLMcom-CCLM4-8-17' ~ 7))) %>%
		mutate(
				type_all = case_when(
						is.na(num_narratif) ~ type,  # Pas de num_narratif si NA
						TRUE ~ str_c(type, "_", num_narratif)  # Concaténation complète
				)
		) %>%
		mutate(mod_hydro = factor(mod_hydro, levels = c("obs", "CTRIP", "EROS", "ORCHIDEE", "SMASH"))) %>%
		mutate( mod_hydro = fct_relevel(mod_hydro, "obs", "CTRIP", "EROS", "ORCHIDEE", "SMASH"))

