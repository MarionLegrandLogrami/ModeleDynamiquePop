# Sauvegarde des résultats triés dans un fichier CSV
##On compile res_autumn_mod, res_spring_mod, res_deval_mod et res_mont_mod
res_mod_def <- rbind(res_autumn_mod,res_spring_mod,res_deval_mod,res_mont_mod)
res_mod_def <- res_mod_def %>% arrange(station,saison,mse)
##On compile res_autumn_nar, res_spring_nar, res_deval_nar et res_mont_nar
res_nar_def <- rbind(res_autumn_nar,res_spring_nar,res_deval_nar,res_mont_nar)
res_nar_def <- res_nar_def %>% arrange(station,saison,mse)

write.csv(res_mod_def, file = str_c(tabwd, "QQplot_R2_compar_res_mod.csv"), row.names = FALSE)
write.csv(res_nar_def, file = str_c(tabwd, "QQplot_R2_compar_res_narratif.csv"), row.names = FALSE)




