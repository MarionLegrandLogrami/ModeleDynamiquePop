<< data_netcdf, echo=FALSE, eval=FALSE,results=hide >>=	
#on applique la fonction pour récupérer toutes les données sur les stations d'intérêt sur la période historique et future

data_netcdf <- fnct_netcdf(station=c('K224082001','K233081001','K259301001','M530001010')) #3 477 152
#on vérifie qu'on a bien 4 modèle hydrologique et 4 modèle narratif pour chaque station
tata <- data_netcdf %>%
		group_by(station, nom_station) %>%
		summarise(
				nb_mod_hydro = n_distinct(mod_hydro),   # Nombre de modèles hydrologiques distincts
				nb_num_narratif = n_distinct(num_narratif), # Nombre de numéros narratifs distincts
				date_min = min(date),                   # Date minimale
				date_max = max(date) ,                   # Date maximale
				max_debit=max(debit)
		)
View(tata)
#on sauve data pour ne pas perdre de temps à relancer à chaque fois
save(data_netcdf, file=str_c(datawd,"data_netcdf.RData"))
@

<< test_analyse_netcdf, echo=FALSE, eval=TRUE,results=hide >>=	
load(file=str_c(datawd,"data_netcdf.RData"))

ggplot(data_netcdf, aes(x = date, y = debit, color = mod_narratif, linetype = mod_hydro)) +
		geom_line() + 
		facet_wrap(~ station,ncol = 1,scale="free") + 
		labs(
				title = "Débits par station avec mod_hydro et mod_narratif",
				x = "Date",
				y = "Débit (m3/s)",
				color = "Modèle Narratif",
				linetype = "Modèle Hydrologique"
		) +
		theme_minimal() +
		theme(axis.text.x = element_text(angle = 45, hjust = 1),legend.position = "bottom")
#=====================================================================================================
#on travaille station par station
#on sort un tableau avec pour chaque station, mod_hydro, mod_narratif, le débit moyen au printemps
#=====================================================================================================
T=49
#Vieille-Brioude
netcdf_q_vb_P<-data_netcdf%>%filter(station=='K233081001',between(month(date),3,6),year(date)<=1974+T)%>%
		group_by(year(date),mod_hydro,mod_narratif)%>%summarise(qmean=mean(debit,na.rm=TRUE))%>%
		rename(year=`year(date)`)

#on cherche les données observées
obs_q_vb_P<-dbGetQuery(con_bd_envir,
		"select sta_nom,date(mes_date_debut),round(mes_valeur::numeric,1)
				from public.t_station_sta
				left join public.t_stationmatos_stm on sta_id =stm_sta_id
				left join public.t_mesure_mes on mes_stm_id=stm_id
				where stm_mat_code=2 and sta_nom='Vieille-Brioude'
				")

#On filtre sur les mois de mars à mai et on calcule la moyenne pour chaque année
obs_vb<-obs_q_vb_P%>%filter(between(month(date),3,6),year(date)<=1974+T)%>%
		mutate(mod_hydro='CTRIP',mod_narratif=NA)%>%
		group_by(year(date),mod_hydro,mod_narratif)%>%summarise(qmean=mean(round,na.rm=TRUE))%>%
		rename(year=`year(date)`) %>%
		filter(year>=1950)
#Pour afficher sur le ggplot on doit dupliquer les données observées autant de fois qu'il y a de mod_hydro
#il faut juste sur ces données dupliquer mettre à chaque fois un nouveau mod_hydro pour que ggplot puisse afficher
#les données observées dans le bon facet_wrap
# Définir les valeurs de mod_hydro (hors CTRIP qu'on a déjà fixé)
mod_hydro_values <- c("EROS", "ORCHIDEE", "SMASH")

# Répliquer le jeu de données et changer mod_hydro
obs_vb_replicated <- obs_vb %>%
		# Créer une liste de data frames en fonction de mod_hydro_values
		bind_rows(lapply(mod_hydro_values, function(mod) {
							obs_vb %>%
									mutate(mod_hydro = mod)  # Modifier mod_hydro
						}))


g <- ggplot(netcdf_q_vb_P, aes(x = year, y = qmean, color = mod_hydro, linetype = mod_narratif)) +
		geom_line() + 
		# Ajouter les données observées
		geom_line(data = obs_vb_replicated, aes(x = year, y = qmean), color = "black", linetype = "solid", size = 0.7) +
		facet_wrap(~ mod_hydro,ncol = 1) + 
		labs(
				title = "Débits à la station de Vieille-Brioude de mars à juin",
				x = "Annees",
				y = "Débit (m3/s)",
				color = "Modèle Hydrologique",
				linetype = "Modèle Narratif"
		) +
		theme_minimal() +
		theme(axis.text.x = element_text(angle = 45, hjust = 1),
				legend.position = "bottom",
				legend.box = "vertical",  # Force la légende à être verticale (titre au-dessus)
				legend.title = element_text(hjust = 0.5),
				legend.text = element_text(size = 8),  # Réduction de la taille du texte de la légende
				plot.margin = unit(c(1, 1, 1, 1), "cm")) +  # Augmenter la marge si nécessaire)+
		guides(
				color = guide_legend(nrow = 1, order = 1),  # Légende des couleurs sur 2 lignes
				linetype = guide_legend(nrow = 2, order = 2)  # Légende des types de ligne sur 2 lignes
		)

ggsave(str_c(imgwd,"Explore2_Vieille_brioude_historique.png"), plot = g, width = 10, height = 8, dpi = 300, bg = "white")

