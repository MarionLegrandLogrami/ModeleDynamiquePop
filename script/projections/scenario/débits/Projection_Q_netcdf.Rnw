<< analyse_netcdf_etienne, echo=FALSE, eval=TRUE,results=hide >>=	
# regarder les quantiles des valeurs observés vs prédites (avec des boxplot ou des qqplot) 
# et calculer les coefficients d’autocorrélation d’ordre 1. Cela devrait nous permettre de compléter notre jugement 
# sur la forme des distributions et les patrons temporels associés.	

load(file=str_c(datawd,"data_a.Rdata"))	
load(file=str_c(datawd,"data_p.Rdata"))
load(file=str_c(datawd,"data_mont.Rdata"))	
load(file=str_c(datawd,"data_deval.Rdata"))	
load(file=str_c(datawd,"obs_a_replicated.Rdata"))	
load(file=str_c(datawd,"obs_p_replicated.Rdata"))	
load(file=str_c(datawd,"obs_montjean_mont_replicated.Rdata"))	
load(file=str_c(datawd,"obs_montjean_deval_replicated.Rdata"))	
load(file=str_c(datawd,"obs_a_replicated2.Rdata"))	
load(file=str_c(datawd,"obs_p_replicated2.Rdata"))
load(file=str_c(datawd,"obs_montjean_mont_replicated2.Rdata"))
load(file=str_c(datawd,"obs_montjean_deval_replicated2.Rdata"))

# Liste des noms de stations à interroger
noms_stations <- c("Vieille-Brioude", "Prades", "Lempdes")  # Ajoutez d'autres noms de station ici


#Pour les figures on a besoin de jeu de données rassemblant données observées et prédites
data_p_all <- data_p %>% select (nom_station, year, mod_hydro, mod_narratif,lqmean_cr) %>% 
		mutate(type="pred",
				num_narratif = case_when(mod_narratif=='CNRM-CERFACS-CNRM-CM5 / CNRM-ALADIN63' ~ 1,
						mod_narratif=='ICHEC-EC-EARTH / MOHC-HadREM3-GA7-05' ~ 5,
						mod_narratif=='MOHC-HadGEM2-ES / CNRM-ALADIN63' ~ 6,
						mod_narratif=='MOHC-HadGEM2-ES / CLMcom-CCLM4-8-17' ~ 7)) %>%
		rbind(obs_p_replicated %>% rename(nom_station=sta_nom) %>% select (nom_station, year, mod_hydro, mod_narratif,lqmean_cr) %>% mutate(type="obs",num_narratif=NA)) %>%
		mutate(
				type_all = case_when(
						is.na(num_narratif) ~ type,  # Pas de num_narratif si NA
						TRUE ~ str_c(type, "_", num_narratif)  # Concaténation complète
				)
		)

data_a_all <- data_a %>% select (nom_station, year, mod_hydro, mod_narratif,lqmean_cr) %>% 
		mutate(type="pred",
				num_narratif = case_when(mod_narratif=='CNRM-CERFACS-CNRM-CM5 / CNRM-ALADIN63' ~ 1,
						mod_narratif=='ICHEC-EC-EARTH / MOHC-HadREM3-GA7-05' ~ 5,
						mod_narratif=='MOHC-HadGEM2-ES / CNRM-ALADIN63' ~ 6,
						mod_narratif=='MOHC-HadGEM2-ES / CLMcom-CCLM4-8-17' ~ 7)) %>%
		rbind(obs_a_replicated %>% rename(nom_station=sta_nom) %>% select (nom_station, year, mod_hydro, mod_narratif,lqmean_cr) %>% mutate(type="obs",num_narratif=NA)) %>%
		mutate(
				type_all = case_when(
						is.na(num_narratif) ~ type,  # Pas de num_narratif si NA
						TRUE ~ str_c(type, "_", num_narratif)  # Concaténation complète
				)
		)

data_mont_all <- data_mont %>% select (nom_station, annee_hydro, mod_hydro, mod_narratif,lqmean_cr) %>% 
    rename(year=annee_hydro) %>%
		mutate(type="pred",
				num_narratif = case_when(mod_narratif=='CNRM-CERFACS-CNRM-CM5 / CNRM-ALADIN63' ~ 1,
						mod_narratif=='ICHEC-EC-EARTH / MOHC-HadREM3-GA7-05' ~ 5,
						mod_narratif=='MOHC-HadGEM2-ES / CNRM-ALADIN63' ~ 6,
						mod_narratif=='MOHC-HadGEM2-ES / CLMcom-CCLM4-8-17' ~ 7)) %>%
		rbind(obs_montjean_mont_replicated %>% rename(nom_station=sta_nom) %>% select (nom_station, year, mod_hydro, mod_narratif,lqmean_cr) %>% mutate(type="obs",num_narratif=NA)) %>%
		mutate(
				type_all = case_when(
						is.na(num_narratif) ~ type,  # Pas de num_narratif si NA
						TRUE ~ str_c(type, "_", num_narratif)  # Concaténation complète
				)
		)

data_deval_all <- data_deval %>% select (nom_station, annee_hydro, mod_hydro, mod_narratif,lqmean_cr) %>% 
    rename(year=annee_hydro) %>%
		mutate(type="pred",
				num_narratif = case_when(mod_narratif=='CNRM-CERFACS-CNRM-CM5 / CNRM-ALADIN63' ~ 1,
						mod_narratif=='ICHEC-EC-EARTH / MOHC-HadREM3-GA7-05' ~ 5,
						mod_narratif=='MOHC-HadGEM2-ES / CNRM-ALADIN63' ~ 6,
						mod_narratif=='MOHC-HadGEM2-ES / CLMcom-CCLM4-8-17' ~ 7)) %>%
		rbind(obs_montjean_deval_replicated %>% rename(nom_station=sta_nom) %>% select (nom_station, year, mod_hydro, mod_narratif,lqmean_cr) %>% mutate(type="obs",num_narratif=NA)) %>%
		mutate(
				type_all = case_when(
						is.na(num_narratif) ~ type,  # Pas de num_narratif si NA
						TRUE ~ str_c(type, "_", num_narratif)  # Concaténation complète
				)
		)

#hue_pal()(n = 5) #pour connaitre par défaut les couleurs utilisées dans les graphs

for (i in 1:length(noms_stations)){
	g_p <-ggplot(data_p_all%>% filter(nom_station==noms_stations[i]), aes(x = type_all, y = lqmean_cr, fill = type_all)) +
			geom_boxplot() +
			facet_wrap(~mod_hydro)+
			labs(title = str_c("Débits au printemps à ",noms_stations[i]),
					y = "Values", x = "") +
			theme_minimal() +
			theme(axis.text.x = element_text(angle = 45, hjust = 1),
					legend.position = "bottom",
					legend.box = "vertical",  # Force la légende à être verticale (titre au-dessus)
					legend.title = element_text(hjust = 0.5),
					legend.text = element_text(size = 8),  # Réduction de la taille du texte de la légende
					plot.margin = unit(c(1, 1, 1, 1), "cm")) +  # Augmenter la marge si nécessaire)+
			scale_fill_manual(values = c("obs" = "#F8766D", 
							"pred_1" = "#A3A500", 
							"pred_5" = "#00BF7D",
							"pred_7" = "#E76BF3",
							"pred_6" = "#00B0F6"),
					labels = c("obs" = "valeurs observées",
							"pred_1" = "changements futurs peu marqués", 
							"pred_5" = "fort réchauffement et fort assèchement en été (et en annuel)",
							"pred_7" = "fort réchauffement et forts contrastes saisonniers en précipitations",
							"pred_6" = "réchauffement marqué et augmentation des précipitations")) +
			guides(
					fill = guide_legend(nrow = 5)  # Légende des couleurs sur 2 lignes
			)
	
	ggsave(str_c(imgwd,str_c("Explore2_boxplot_",noms_stations[i],"_printemps.png")), plot = g_p, width = 10, height = 8, dpi = 300, bg = "white")
	
	g_a <- ggplot(data_a_all%>% filter(nom_station==noms_stations[i]), aes(x = type_all, y = lqmean_cr, fill = type_all)) +
			geom_boxplot() +
			facet_wrap(~mod_hydro)+
			labs(title = str_c("Débits à l'automne à ",noms_stations[i]),
					y = "Values", x = "") +
			theme_minimal() +
			theme(axis.text.x = element_text(angle = 45, hjust = 1),
					legend.position = "bottom",
					legend.box = "vertical",  # Force la légende à être verticale (titre au-dessus)
					legend.title = element_text(hjust = 0.5),
					legend.text = element_text(size = 8),  # Réduction de la taille du texte de la légende
					plot.margin = unit(c(1, 1, 1, 1), "cm")) +  # Augmenter la marge si nécessaire)+
			scale_fill_manual(values = c("obs" = "#F8766D", 
							"pred_1" = "#A3A500", 
							"pred_5" = "#00BF7D",
							"pred_7" = "#E76BF3",
							"pred_6" = "#00B0F6"),
					labels = c("obs" = "valeurs observées",
							"pred_1" = "changements futurs peu marqués", 
							"pred_5" = "fort réchauffement et fort assèchement en été (et en annuel)",
							"pred_7" = "fort réchauffement et forts contrastes saisonniers en précipitations",
							"pred_6" = "réchauffement marqué et augmentation des précipitations")) +
			guides(
					fill = guide_legend(nrow = 5)  # Légende des couleurs sur 2 lignes
			)  
	
	ggsave(str_c(imgwd,str_c("Explore2_boxplot_",noms_stations[i],"_automne.png")), plot = g_a, width = 10, height = 8, dpi = 300, bg = "white")
	
	
}

