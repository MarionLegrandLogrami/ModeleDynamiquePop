<< choix_narratif_fix_mod_etienne, echo=FALSE, eval=TRUE,results=hide >>=	

mod <- "EROS" #"SMASH"

#----- Tri sur les narratif ------------
# Création d'un dataframe pour stocker les R²
res_spring_nar_fm <- data.frame(
		station = character(),
		mod_hydro = character(),
		mod_narratif = character(),
		saison= character(),
		mse = numeric(),
		r_squared_diag = numeric(),
		stringsAsFactors = FALSE
)

res_autumn_nar_fm <- data.frame(
		station = character(),
		mod_hydro = character(),
		mod_narratif = character(),
		saison= character(),
		mse = numeric(),
		r_squared_diag = numeric(),
		stringsAsFactors = FALSE
)

##-------- On compare les narratifs ---------------------
# Boucle pour calculer MSE et R² basé sur la diagonale
for (i in 1:length(noms_stations)) {
	for (k in unique(data_p$mod_narratif)) {
		
		obs <- obs_p_replicated %>% filter(sta_nom==noms_stations[i],
						mod_hydro==mod) %>% 
				select(lqmean_cr)  %>% 
				pull()
		
		# Valeurs prédites issues d'Explore2 : on fait la médiane par an, par station et par modèle_hydro
		pred <- data_p %>% filter(nom_station==noms_stations[i],
						mod_hydro==mod,
						mod_narratif==k,
						year %in% seq(1975,2023,1)) %>%
				select(lqmean_cr) %>%
				pull()
		
		# Assurer que obs et pred ont la même taille avec interpolation des quantiles
		common_probs <- seq(0, 1, length.out = 101)
		obs_quantiles <- quantile(obs, probs = common_probs)
		pred_quantiles <- quantile(pred, probs = common_probs)
		
		# Calcul de l'erreur quadratique moyenne
		mse <- mean((pred_quantiles - obs_quantiles)^2)
		
		# Calcul du R² basé sur la bissectrice
		r_squared_diag <- 1 - sum((pred_quantiles - obs_quantiles)^2) / sum((obs_quantiles - mean(obs_quantiles))^2)
		
		# Stocker les résultats
		res_spring_nar_fm <- rbind(res_spring_nar_fm, data.frame(
						station = noms_stations[i], 
						mod_hydro = mod,
						mod_narratif = as.character(k),
						saison= "spring",
						mse = mse,
						r_squared_diag = r_squared_diag
				))
		
	}
}

for (i in 1:length(noms_stations)) {
	for (k in unique(data_a$mod_narratif)) {
		
		obs <- obs_a_replicated %>% filter(sta_nom==noms_stations[i],
						mod_hydro==mod) %>% 
				select(lqmean_cr)  %>% 
				pull()
		
		# Valeurs prédites issues d'Explore2 : on fait la médiane par an, par station et par modèle_hydro
		pred <- data_a %>% filter(nom_station==noms_stations[i],
						mod_hydro==mod,
						mod_narratif==k,
						year %in% seq(1975,2023,1)) %>%
				select(lqmean_cr) %>%
				pull()
		
		# Assurer que obs et pred ont la même taille avec interpolation des quantiles
		common_probs <- seq(0, 1, length.out = 101)
		obs_quantiles <- quantile(obs, probs = common_probs)
		pred_quantiles <- quantile(pred, probs = common_probs)
		
		# Calcul de l'erreur quadratique moyenne
		mse <- mean((pred_quantiles - obs_quantiles)^2)
		
		# Calcul du R² basé sur la bissectrice
		r_squared_diag <- 1 - sum((pred_quantiles - obs_quantiles)^2) / sum((obs_quantiles - mean(obs_quantiles))^2)
		
		# Stocker les résultats
		res_autumn_nar_fm <- rbind(res_autumn_nar_fm, data.frame(
						station = noms_stations[i], 
						mod_hydro = mod,
						mod_narratif = as.character(k),
						saison= "autumn",
						mse = mse,
						r_squared_diag = r_squared_diag
				))
		
	}
}


####---- Pour Montjean-sur-Loire----------
##--- Montaison

# Création d'un dataframe pour stocker les R²
res_mont_nar_fm <- data.frame(
		station = character(),
		mod_hydro = character(),
		mod_narratif = character(),
		saison= character(),
		mse = numeric(),
		r_squared_diag = numeric(),
		stringsAsFactors = FALSE
)

for (k in unique(data_mont$mod_narratif)) {
	
	obs <- obs_montjean_mont_replicated %>% filter(mod_hydro==mod) %>% 
			select(lqmean_cr)  %>% 
			pull()
	
	# Valeurs prédites issues d'Explore2 : on fait la médiane par an, par station et par modèle_hydro
	pred <- data_mont %>% filter(mod_narratif==k,
					mod_hydro==mod,
					annee_hydro %in% seq(1975,2023,1)) %>%
			select(lqmean_cr) %>%
			pull()
	
	# Assurer que obs et pred ont la même taille avec interpolation des quantiles
	common_probs <- seq(0, 1, length.out = 101)
	obs_quantiles <- quantile(obs, probs = common_probs)
	pred_quantiles <- quantile(pred, probs = common_probs)
	
	# Calcul de l'erreur quadratique moyenne
	mse <- mean((pred_quantiles - obs_quantiles)^2)
	
	# Calcul du R² basé sur la bissectrice
	r_squared_diag <- 1 - sum((pred_quantiles - obs_quantiles)^2) / sum((obs_quantiles - mean(obs_quantiles))^2)
	
	# Stocker les résultats
	res_mont_nar_fm <- rbind(res_mont_nar_fm, data.frame(
					station = "Montjean-sur-Loire", 
					mod_hydro = mod,
					mod_narratif = as.character(k),
					saison = "montaison",
					mse = mse,
					r_squared_diag = r_squared_diag
			))
}


##--- Dévalaison------
# Création d'un dataframe pour stocker les R²

res_deval_nar_fm <- data.frame(
		station = character(),
		mod_hydro = character(),
		mod_narratif = character(),
		saison= character(),
		mse = numeric(),
		r_squared_diag = numeric(),
		stringsAsFactors = FALSE
)

for (k in unique(data_deval$mod_narratif)) {
	
	obs <- obs_montjean_deval_replicated %>% filter(mod_hydro==mod) %>% 
			select(lqmean_cr)  %>% 
			pull()
	
	# Valeurs prédites issues d'Explore2 : on fait la médiane par an, par station et par modèle_hydro
	pred <- data_deval %>% filter(mod_narratif==k,
					mod_hydro==mod,
					annee_hydro %in% seq(1975,2023,1)) %>%
			select(lqmean_cr) %>%
			pull()
	
	# Assurer que obs et pred ont la même taille avec interpolation des quantiles
	common_probs <- seq(0, 1, length.out = 101)
	obs_quantiles <- quantile(obs, probs = common_probs)
	pred_quantiles <- quantile(pred, probs = common_probs)
	
	# Calcul de l'erreur quadratique moyenne
	mse <- mean((pred_quantiles - obs_quantiles)^2)
	
	# Calcul du R² basé sur la bissectrice
	r_squared_diag <- 1 - sum((pred_quantiles - obs_quantiles)^2) / sum((obs_quantiles - mean(obs_quantiles))^2)
	
	# Stocker les résultats
	res_deval_nar_fm <- rbind(res_deval_nar_fm, data.frame(
					station = "Montjean-sur-Loire", 
					mod_hydro = mod,
					mod_narratif = as.character(k),
					saison = "devalaison",
					mse = mse,
					r_squared_diag = r_squared_diag
			))
}


# Sauvegarde des résultats triés dans un fichier CSV
##On compile res_autumn_nar_fm, res_spring_nar_fm, res_deval_nar_fm et res_mont_nar_fm
res_nar_def_fm <- rbind(res_autumn_nar_fm,res_spring_nar_fm,res_deval_nar_fm,res_mont_nar_fm)
res_nar_def_fm <- res_nar_def_fm %>% arrange(station,saison,mse)

write.csv(res_nar_def_fm, file = str_c(tabwd, "QQplot_R2_compar_res_narratif_mod_",mod,".csv"), row.names = FALSE)


@



<< autocor_netcdf_etienne, echo=FALSE, eval=TRUE,results=hide >>=	
# regarder les quantiles des valeurs observés vs prédites (avec des boxplot ou des qqplot) 
# et calculer les coefficients d’autocorrélation d’ordre 1. Cela devrait nous permettre de compléter notre jugement 
# sur la forme des distributions et les patrons temporels associés.	

load(file=str_c(datawd,"data_a.Rdata"))	
load(file=str_c(datawd,"data_p.Rdata"))	
load(file=str_c(datawd,"obs_a_replicated.Rdata"))	
load(file=str_c(datawd,"obs_p_replicated.Rdata"))	
load(file=str_c(datawd,"obs_a_replicated2.Rdata"))	
load(file=str_c(datawd,"obs_p_replicated2.Rdata"))
load(file=str_c(datawd,"data_proj_a.Rdata"))	
load(file=str_c(datawd,"data_proj_p.Rdata"))

#########################################
# Autoccorélation
#########################################

# Calculer l'autocorrélation d'ordre 1 pour les observations et les prédictions (au printemps et à l'automne)
acf(obs_p_replicated$lqmean_cr, lag.max = 10, plot = FALSE) #0.016
acf(obs_a_replicated$lqmean_cr, lag.max = 10, plot = FALSE) #0.033
acf(data_p$lqmean_cr, lag.max = 1, plot = FALSE) #0.097
# Calculer l'ACF pour chaque mod_narratif et extraire les valeurs
data_p %>%
		group_by(mod_hydro,mod_narratif) %>%
		summarise(acf_values = list(acf(lqmean_cr, lag.max = 1, plot = FALSE)$acf), 
				.groups = "drop") %>%
		mutate(acf_values = map(acf_values, ~ .x[2])) %>%  
		unnest(cols=acf_values)

acf(data_a$lqmean_cr, lag.max = 1, plot = FALSE) #0.1
data_a %>%
		group_by(mod_hydro,mod_narratif) %>%
		summarise(acf_values = list(acf(lqmean_cr, lag.max = 1, plot = FALSE)$acf), 
				.groups = "drop") %>%
		mutate(acf_values = map(acf_values, ~ .x[2])) %>%  
		unnest(cols=acf_values)
#tab_all <- pivot_wider(data_a_all %>% ungroup() %>% select(nom_station,year,lqmean_cr,mod_hydro,type_all), names_from = type_all, values_from = lqmean_cr)
#
#data_clean <- tab_all %>%
#		drop_na()
#
#cor(data_clean[,4:8], use = "complete.obs")

#================================================================================================================
# Le narratif MOHC-HadGEM2-ES / CLMcom-CCLM4-8-17 est celui qui a la plus forte autocorrélation pour un lag 1.
# On réalise des ggplot avec ce narratif et les valeurs observées
#=================================================================================================================

for (i in 1:length(noms_stations)){
	
	g_p <- ggplot(data_p %>% filter(nom_station==noms_stations[i],mod_narratif == "MOHC-HadGEM2-ES / CLMcom-CCLM4-8-17"), aes(x = year, y = lqmean_cr, color = mod_hydro)) +
			geom_line() + 
			# Ajouter les données observées
			geom_line(data = obs_p_replicated %>% filter(sta_nom==noms_stations[i]), aes(x = year, y = lqmean_cr), color = "black", linetype = "solid", linewidth = 0.5) +
			facet_wrap(~ mod_hydro,ncol = 1) + 
			labs(
					title = str_c("Débits à la station de ",noms_stations[i]," de mars à juin"),
					x = "Annees",
					y = "log(Débit) centré-réduit",
					color = "Modèle Hydrologique"
			) +
			theme_minimal() +
			theme(axis.text.x = element_text(angle = 45, hjust = 1),
					legend.position = "bottom",
					legend.box = "vertical",  # Force la légende à être verticale (titre au-dessus)
					legend.title = element_text(hjust = 0.5),
					legend.text = element_text(size = 8),  # Réduction de la taille du texte de la légende
					plot.margin = unit(c(1, 1, 1, 1), "cm")) +  # Augmenter la marge si nécessaire)+
			guides(
					color = guide_legend(nrow = 1, order = 1)  # Légende des couleurs sur 2 lignes
			)
	
	ggsave(str_c(imgwd,str_c("Explore2_",noms_stations[i],"_log_cr_printemps_histo_narratif_7.png")), plot = g_p, width = 10, height = 8, dpi = 300, bg = "white")
	#Automne
	g_a <- ggplot(data_a %>% filter(nom_station==noms_stations[i],mod_narratif == "MOHC-HadGEM2-ES / CLMcom-CCLM4-8-17"), aes(x = year, y = lqmean_cr, color = mod_hydro)) +
			geom_line() + 
			# Ajouter les données observées
			geom_line(data = obs_a_replicated %>% filter(sta_nom==noms_stations[i]), aes(x = year, y = lqmean_cr), color = "black", linetype = "solid", linewidth = 0.5) +
			facet_wrap(~ mod_hydro,ncol = 1) + 
			labs(
					title = str_c("Débits à la station de ",noms_stations[i]," de septembre à novembre"),
					x = "Annees",
					y = "log(Débit) centré-réduit",
					color = "Modèle Hydrologique"
			) +
			theme_minimal() +
			theme(axis.text.x = element_text(angle = 45, hjust = 1),
					legend.position = "bottom",
					legend.box = "vertical",  # Force la légende à être verticale (titre au-dessus)
					legend.title = element_text(hjust = 0.5),
					legend.text = element_text(size = 8),  # Réduction de la taille du texte de la légende
					plot.margin = unit(c(1, 1, 1, 1), "cm")) +  # Augmenter la marge si nécessaire)+
			guides(
					color = guide_legend(nrow = 1, order = 1)  # Légende des couleurs sur 2 lignes
			)
	
	ggsave(str_c(imgwd,str_c("Explore2_",noms_stations[i],"_log_cr_automne_histo_narratif_7.png")), plot = g_a, width = 10, height = 8, dpi = 300, bg = "white")
	
	
}

