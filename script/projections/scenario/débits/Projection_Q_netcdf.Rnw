labels_facets <- c(
		"pred_1" = "Changement peu marqué",
		"pred_5" = "Fort réchauffement et assèchement",
		"pred_6" = "Réchauffement marqué & augmentation précip.",
		"pred_7" = "Forts réchauffement & contrastes saisonniers"
)

for (i in 1:length(noms_stations)){
	g_p <-ggplot(data_p_all2%>% filter(nom_station==noms_stations[i]), aes(x = mod_hydro, y = lqmean_cr, fill = mod_hydro)) +
			geom_boxplot() +
			facet_wrap(~type_all, labeller = as_labeller(labels_facets)) +
			labs(title = str_c("Débits au printemps à ",noms_stations[i]),
					y = "Values", x = "") +
			theme_minimal() +
			theme(axis.text.x = element_text(angle = 45, hjust = 1),
					legend.position = "bottom",
					legend.box = "vertical",  # Force la légende à être verticale (titre au-dessus)
					legend.title = element_text(hjust = 0.5),
					legend.text = element_text(size = 8),  # Réduction de la taille du texte de la légende
					plot.margin = unit(c(1, 1, 1, 1), "cm")) +  # Augmenter la marge si nécessaire)+
			
			guides(
					fill = "none"  # Légende des couleurs sur 2 lignes
			)
	
	ggsave(str_c(imgwd,str_c("Explore2_boxplot_",noms_stations[i],"_printemps_par_narratif.png")), plot = g_p, width = 10, height = 8, dpi = 300, bg = "white")
	
	g_a <- ggplot(data_a_all2%>% filter(nom_station==noms_stations[i]), aes(x = mod_hydro, y = lqmean_cr, fill = mod_hydro)) +
			geom_boxplot() +
			facet_wrap(~type_all, labeller = as_labeller(labels_facets)) +
			labs(title = str_c("Débits à l'automne à ",noms_stations[i]),
					y = "Values", x = "") +
			theme_minimal() +
			theme(axis.text.x = element_text(angle = 45, hjust = 1),
					legend.position = "bottom",
					legend.box = "vertical",  # Force la légende à être verticale (titre au-dessus)
					legend.title = element_text(hjust = 0.5),
					legend.text = element_text(size = 8),  # Réduction de la taille du texte de la légende
					plot.margin = unit(c(1, 1, 1, 1), "cm")) +  # Augmenter la marge si nécessaire)+
			
			guides(
					fill = "none"  # Légende des couleurs sur 2 lignes
			)
	
	ggsave(str_c(imgwd,str_c("Explore2_boxplot_",noms_stations[i],"_automne_par_narratif.png")), plot = g_a, width = 10, height = 8, dpi = 300, bg = "white")
	
	
}

