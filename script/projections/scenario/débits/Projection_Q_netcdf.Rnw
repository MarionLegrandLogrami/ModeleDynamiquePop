	pred <- data_deval %>% filter(mod_narratif==k,
					annee_hydro %in% seq(1975,2023,1)) %>%
			group_by(mod_narratif,annee_hydro) %>%
			summarize(lqmean_cr_med=median(lqmean_cr)) %>%
			select(lqmean_cr_med) %>%
			pull()
	
	# Assurer que obs et pred ont la même taille avec interpolation des quantiles
	common_probs <- seq(0, 1, length.out = 101)
	obs_quantiles <- quantile(obs, probs = common_probs)
	pred_quantiles <- quantile(pred, probs = common_probs)
	
	# Calcul de l'erreur quadratique moyenne
	mse <- mean((pred_quantiles - obs_quantiles)^2)
	
	# Calcul du R² basé sur la bissectrice
	r_squared_diag <- 1 - sum((pred_quantiles - obs_quantiles)^2) / sum((obs_quantiles - mean(obs_quantiles))^2)
	
	# Stocker les résultats
	res_deval_nar <- rbind(res_deval_nar, data.frame(
					station = "Montjean-sur-Loire", 
