<< choix_mod_narratif_etienne, echo=FALSE, eval=TRUE,results=hide >>=	
#==============================================================================================================================
#------------ On calcule somme des carrés des écarts entre quantiles des valeurs observées et quantiles des valeurs prédites
#==============================================================================================================================

# Création d'un dataframe pour stocker les R²
res_autumn_mod <- data.frame(
		station = character(),
		mod_hydro = character(),
		saison= character(),
		mse = numeric(),
		r_squared_diag = numeric(),
		stringsAsFactors = FALSE
)
##-------- On compare les modèle_hydro ---------------------
# Boucle pour calculer MSE et R² basé sur la diagonale
for (i in 1:length(noms_stations)) {
	for (j in unique(data_a$mod_hydro)) {
				
			obs <- obs_a_replicated %>% filter(sta_nom==noms_stations[i],
							mod_hydro==j) %>%
					select(lqmean_cr)  %>% 
					pull()
			
			# Valeurs prédites issues d'Explore2 : on fait la médiane par an, par station et par modèle_hydro
			pred <- data_a %>% filter(nom_station==noms_stations[i],
							mod_hydro==j,
							year %in% seq(1975,2023,1)) %>%
					group_by(nom_station,mod_hydro,year) %>%
					summarize(lqmean_cr_med=median(lqmean_cr)) %>%
					select(lqmean_cr_med) %>%
					pull()
			
				# Assurer que obs et pred ont la même taille avec interpolation des quantiles
				common_probs <- seq(0, 1, length.out = 101)
				obs_quantiles <- quantile(obs, probs = common_probs)
				pred_quantiles <- quantile(pred, probs = common_probs)
				
				# Calcul de l'erreur quadratique moyenne
				mse <- mean((pred_quantiles - obs_quantiles)^2)
				
				# Calcul du R² basé sur la bissectrice
				r_squared_diag <- 1 - sum((pred_quantiles - obs_quantiles)^2) / sum((obs_quantiles - mean(obs_quantiles))^2)
				
				# Stocker les résultats
		res_autumn_mod <- rbind(res_autumn_mod, data.frame(
								station = noms_stations[i], 
								mod_hydro = as.character(j),
								saison="autumn",
								mse = mse,
								r_squared_diag = r_squared_diag
						))

	}
}

# Trier les résultats par station et par MSE (plus petit = meilleur)
res_autumn_mod_sort <- res_autumn_mod[order(res_autumn_mod$station, res_autumn_mod$mse), ]

#----- Tri sur les narratif ------------
# Création d'un dataframe pour stocker les R²
res_autumn_nar <- data.frame(
		station = character(),
		mod_narratif = character(),
		saison= character(),
		mse = numeric(),
		r_squared_diag = numeric(),
		stringsAsFactors = FALSE
)
##-------- On compare les narratifs ---------------------
# Boucle pour calculer MSE et R² basé sur la diagonale
for (i in 1:length(noms_stations)) {
		for (k in unique(data_a$mod_narratif)) {
		
		obs <- obs_a_replicated %>% filter(sta_nom==noms_stations[i],
						mod_hydro=="CTRIP") %>% #les données sont dupliquées 4 fois pour les 4 modèle. On en prend un au hasard just epour ne pas avoir de doublon
				select(lqmean_cr)  %>% 
				pull()
		
		# Valeurs prédites issues d'Explore2 : on fait la médiane par an, par station et par modèle_hydro
		pred <- data_a %>% filter(nom_station==noms_stations[i],
						mod_narratif==k,
						year %in% seq(1975,2023,1)) %>%
				group_by(nom_station,mod_narratif,year) %>%
				summarize(lqmean_cr_med=median(lqmean_cr)) %>%
				select(lqmean_cr_med) %>%
				pull()
		
		# Assurer que obs et pred ont la même taille avec interpolation des quantiles
		common_probs <- seq(0, 1, length.out = 101)
		obs_quantiles <- quantile(obs, probs = common_probs)
		pred_quantiles <- quantile(pred, probs = common_probs)
		
		# Calcul de l'erreur quadratique moyenne
		mse <- mean((pred_quantiles - obs_quantiles)^2)
		
		# Calcul du R² basé sur la bissectrice
		r_squared_diag <- 1 - sum((pred_quantiles - obs_quantiles)^2) / sum((obs_quantiles - mean(obs_quantiles))^2)
		
		# Stocker les résultats
		res_autumn_nar <- rbind(res_autumn_nar, data.frame(
						station = noms_stations[i], 
						mod_narratif = as.character(k),
						saison = "autumn",
						mse = mse,
						r_squared_diag = r_squared_diag
				))
		
	}
}

# Trier les résultats par station et par MSE (plus petit = meilleur)
res_autumn_nar_sort <- res_autumn_nar[order(res_autumn_nar$station, res_autumn_nar$mse), ]

