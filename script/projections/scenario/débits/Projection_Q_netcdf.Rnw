data_p <- data_p %>% mutate(subtitle = case_when(mod_narratif=="CNRM-CERFACS-CNRM-CM5 / CNRM-ALADIN63" ~ "Changements futurs relativement peu marqués",
												 mod_narratif=="ICHEC-EC-EARTH / MOHC-HadREM3-GA7-05" ~ "Fort réchauffement et fort assèchement en été (et en annuel)",
												 mod_narratif=="MOHC-HadGEM2-ES / CNRM-ALADIN63" ~ "Réchauffement marqué et augmentation des précipitations",
												 mod_narratif=="MOHC-HadGEM2-ES / CLMcom-CCLM4-8-17" ~ "Fort réchauffement et forts contrastes saisonniers en précipitations"))
data_a <- data_a %>% mutate(subtitle = case_when(mod_narratif=="CNRM-CERFACS-CNRM-CM5 / CNRM-ALADIN63" ~ "Changements futurs relativement peu marqués",
												 mod_narratif=="ICHEC-EC-EARTH / MOHC-HadREM3-GA7-05" ~ "Fort réchauffement et fort assèchement en été (et en annuel)",
												 mod_narratif=="MOHC-HadGEM2-ES / CNRM-ALADIN63" ~ "Réchauffement marqué et augmentation des précipitations",
												 mod_narratif=="MOHC-HadGEM2-ES / CLMcom-CCLM4-8-17" ~ "Fort réchauffement et forts contrastes saisonniers en précipitations"))

data_mont <- data_mont %>% mutate(subtitle = case_when(mod_narratif=="CNRM-CERFACS-CNRM-CM5 / CNRM-ALADIN63" ~ "Changements futurs relativement peu marqués",
												 mod_narratif=="ICHEC-EC-EARTH / MOHC-HadREM3-GA7-05" ~ "Fort réchauffement et fort assèchement en été (et en annuel)",
												 mod_narratif=="MOHC-HadGEM2-ES / CNRM-ALADIN63" ~ "Réchauffement marqué et augmentation des précipitations",
												 mod_narratif=="MOHC-HadGEM2-ES / CLMcom-CCLM4-8-17" ~ "Fort réchauffement et forts contrastes saisonniers en précipitations"))
data_deval <- data_deval %>% mutate(subtitle = case_when(mod_narratif=="CNRM-CERFACS-CNRM-CM5 / CNRM-ALADIN63" ~ "Changements futurs relativement peu marqués",
												 mod_narratif=="ICHEC-EC-EARTH / MOHC-HadREM3-GA7-05" ~ "Fort réchauffement et fort assèchement en été (et en annuel)",
												 mod_narratif=="MOHC-HadGEM2-ES / CNRM-ALADIN63" ~ "Réchauffement marqué et augmentation des précipitations",
												 mod_narratif=="MOHC-HadGEM2-ES / CLMcom-CCLM4-8-17" ~ "Fort réchauffement et forts contrastes saisonniers en précipitations"))


								 
col_sub <- c("#00BFC4","#C77CFF","#F8766D","#7CAE00")


for (i in 1: length(noms_stations)){
	for (j in 1 : length(unique(data_p$mod_hydro))){
		for (k in 1 : length(unique(data_p$mod_narratif))){
			png(filename=str_c(imgwd,str_c("Explore2_",noms_stations[i],"_printemps_mod_",unique(data_p$mod_hydro)[j],"_narratif_",k,".png")),width = 800, height = 800)		
			qqplot(obs_p_replicated %>% filter(sta_nom==noms_stations[i],
									mod_hydro==unique(obs_a_replicated$mod_hydro)[j]) %>%
							select(lqmean_cr) %>%
							pull(), 
					data_p %>% filter(nom_station==noms_stations[i],
									mod_hydro==unique(data_p$mod_hydro)[j],
									mod_narratif==unique(data_p$mod_narratif)[k],
									year %in% seq(1975,2023,1)) %>%
							select(lqmean_cr) %>%
							pull(),
					#data_p$lqmean_cr[data_p$nom_station==noms_stations[i] & 
										#data_p$mod_hydro==unique(data_p$mod_hydro)[j] & 
										#data_p$mod_narratif==unique(data_p$mod_narratif)[k]], 
					main=str_c("Log des débits centrés-réduits à ",noms_stations[i]," au printemps"),
					xlab="Quantiles des valeurs observées", 
					ylab="Quantiles des valeurs prédites",
					pch = 16,
					col =  col_sub[k])
			mtext( str_c("modèle ",unique(data_p$mod_hydro)[j]," : ",data_p$subtitle[data_p$nom_station==noms_stations[i] & data_p$mod_narratif==unique(data_p$mod_narratif)[k]]), side = 3, line = 0.5, col = col_sub[k])
			abline(0, 1, col= col_sub[k], lwd=2) 
			dev.off()
		}
	}
}
