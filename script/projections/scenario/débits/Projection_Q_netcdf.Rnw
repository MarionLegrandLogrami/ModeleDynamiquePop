###

fnct_netcdf <- function(station){
	# Lister les dossiers (CTRIP, EROS, ORCHIDEE, SMASH)
	dossiers <- list.files(datawd, full.names = FALSE)
	# Initialiser une liste pour stocker les chemins
	path <- c()
	# Boucler sur chaque dossier et récupérer les chemins des fichiers
	for (dossier in dossiers) {
		# Construire le chemin complet vers le dossier
		chemin_dossier <- file.path(gsub("/+$", "", datawd), dossier)
		
		# Récupérer les fichiers dans ce dossier
		fichiers <- list.files(chemin_dossier, full.names = TRUE)
		fichiers <- sub(paste0(gsub("/+$", "", datawd), "/"), "", fichiers)
		# Ajouter les chemins complets des fichiers à la variable `path`
		path <- c(path, fichiers)
	}
	for (i in 1: length(path)){
		for (j in 1:length(station)){
			data <- nc_open(str_c(datawd,path[i]))
			# Extraire des variables
			sta <- ncvar_get(data, "code")
			debit <- ncvar_get(data,"debit")
			indices_specifiques <- which(sta %in% station[j])
			temps_vals <- ncvar_get(data, "time")
			time_units <- ncatt_get(data, "time", "units")$value
			date_reference <- as.Date(sub("days since ", "", time_units))
			dates <- date_reference + temps_vals
			debit_station <- as.data.frame(debit[indices_specifiques,])
			# Créer un tableau avec les dates et les débits
			tab_data <- data.frame(date = dates,
					station = rep(sta[indices_specifiques], each = ncol(debit_station)),
					debit = as.vector(t(debit_station)),
					mod_hydro = rep(dirname(path[i]), times = ncol(debit_station)),
					mod_narratif = rep(str_c(strsplit(path[i], "_")[[1]][3]," / ",strsplit(path[i], "_")[[1]][6]), times = ncol(debit_station)))
			if(j==1){tab_temp <- tab_data}else{tab_temp <- rbind(tab_temp,tab_data)}
		}
		if(i==1){tab_def <- tab_temp}else{tab_def <- rbind(tab_def,tab_temp)}
	}
	tab_def <- tab_def %>%
			mutate(nom_station = case_when(
							station == "K224082001" ~ "Prades",
							station == "K233081001" ~ "Vieille-Brioude",
							station == "K259301001" ~ "Lempdes",  # Remplacez par le nom approprié
							station == "M530001010" ~ "Montjean",   # Remplacez par le nom approprié
							TRUE ~ "Autre"  # Valeur par défaut si aucune correspondance n'est trouvée
					),
					num_narratif = case_when (
							mod_narratif == "CNRM-CERFACS-CNRM-CM5 / CNRM-ALADIN63" ~ 1,
							mod_narratif == "ICHEC-EC-EARTH / MOHC-HadREM3-GA7-05" ~ 5,
							mod_narratif == "MOHC-HadGEM2-ES / CNRM-ALADIN63" ~ 6,
							mod_narratif == "MOHC-HadGEM2-ES / CLMcom-CCLM4-8-17" ~ 7,
							TRUE ~ NA_real_))
	return(tab_def)
}

