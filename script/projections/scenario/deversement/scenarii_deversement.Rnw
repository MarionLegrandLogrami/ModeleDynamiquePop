ratio_juv_A_q=array(rep(0,(T+20)*5),dim=c((T+20),5))
ratio_juv_L_q=array(rep(0,(T+20)*5),dim=c((T+20),5))
ratio_juv_P_q=array(rep(0,(T+20)*5),dim=c((T+20),5))


for (t in 2:12){
	juv_V[,t]<-bugs_dmoy_tot_V[,t-1] * S_juv_JP[1,t]
	juv_A[,t]<-bugs_dmoy_tot_A[,t-1] * S_juv_JP[2,t]
	juv_L[,t]<-bugs_dmoy_tot_L[,t-1] * S_juv_JP[3,t]
}

