<<Niveau_pop_Rmax,echo=FALSE, eval=FALSE,results=hide>>=
#=======================
# Rmax 25
#=======================

surf=c(rep(c(846021,70845,250441,0),11),rep(c(846021,70845,250441,301101),12),rep(c(846021,70845,250441,383049),6),rep(c(846021,356519,250441,383049),(T-2))) #T-2 pour calculer sur T+27 année
S_juv_JP<-matrix(surf,nrow=4)
S_juv_JP<-rbind(S_juv_JP,colSums(S_juv_JP)) #Créé une 5eme ligne qui correspond à la somme par année des surfaces sur l'ensemble des secteurs

bugs_nu_d=read.coda("nu_dCODAchain1.txt","nu_dCODAindex.txt")
bugs_sigma_vichy=read.coda("sigma_vichyCODAchain1.txt","sigma_vichyCODAindex.txt")
Rmax=read.coda("RmaxCODAchain1.txt","RmaxCODAindex.txt")

Juv_Rmax_25_V=array(0,dim=c(10000,(T+21)))
Juv_Rmax_25_A=array(0,dim=c(10000,(T+21)))
Juv_Rmax_25_L=array(0,dim=c(10000,(T+21)))
Juv_Rmax_25_P=array(0,dim=c(10000,(T+21)))
Juv_Rmax_25=array(0,dim=c(10000,(T+21)))

for (t in (T-3):(T+21)){ #On calcule à partir de 2013 car moyenne mobile sur 5 ans avec pour dernière année 2017 (pour continuer la série du niveau de pop)
	for (i in 1:10000){
		Juv_Rmax_25_V[i,t]<-0.25*Rmax[i]*exp(bugs_nu_d[i,1])*S_juv_JP[1,t] #multiplie par nu_d pour tenir compte de la différence de production de juvéniles des différentes zones
		Juv_Rmax_25_A[i,t]<-0.25*Rmax[i]*exp(bugs_nu_d[i,2])*S_juv_JP[2,t] #multiplie par nu_d pour tenir compte de la différence de production de juvéniles des différentes zones
		Juv_Rmax_25_L[i,t]<-0.25*Rmax[i]*exp(bugs_nu_d[i,3])*S_juv_JP[3,t] #multiplie par nu_d pour tenir compte de la différence de production de juvéniles des différentes zones
		Juv_Rmax_25_P[i,t]<-0.25*Rmax[i]*exp(bugs_nu_d[i,4])*S_juv_JP[4,t] #multiplie par nu_d pour tenir compte de la différence de production de juvéniles des différentes zones
		Juv_Rmax_25[i,t]<-Juv_Rmax_25_V[i,t]+Juv_Rmax_25_A[i,t]+Juv_Rmax_25_L[i,t]+Juv_Rmax_25_P[i,t] #mean=213031.8
	}
}

##On calcule la référence pour comparer ensuite les estimations de géniteurs à Vichy qu'on a dans le scénario de CE
niveau_pop_25_actu<-array(0,dim=c(10000,(T+21)))
N_vichy_25_actu<-array(0,dim=c(10000,(T+21)))

for (t in (T-3):(T+21)){#On calcule à partir de 2013 car moyenne mobile sur 5 ans avec pour dernière année 2017 (pour continuer la série du niveau de pop)
	for (i in 1:10000){
		##Scénario 50% Rmax et survie actuelle
		niveau_pop_25_actu[i,t]<- log(bugs_s_juv2ad[i]*Juv_Rmax_25[i,t])
		N_vichy_25_actu[i,t]<-rlnorm(1,niveau_pop_25_actu[i,t],bugs_sigma_vichy[i])
	}
}

mean_N_vichy_25_actu<-NA

for (t in (T-3):(T+21)){
	mean_N_vichy_25_actu[t]<-mean(N_vichy_25_actu[,t]) # 752
}
mean(mean_N_vichy_25_actu, na.rm=TRUE)	#414

