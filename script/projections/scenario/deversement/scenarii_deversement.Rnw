##========================================
## En moyenne mobile simple - echelle log
##========================================
##library(igraph)
running.mean<- function(x, n = 5){stats::filter(x, rep(1 / n, n), sides = 2)}
library(dplyr)
data<-stack(as.data.frame(renew_rate_final))
##On fait la médiane
median_data<-tapply(exp(data[,1]),data[,2],median)
x_tx_moyMob=seq(1,(ncol(renew_rate_final)-10),1)
rect_2_col <- data.frame(ystart = c(0,1), yend = c(1,2),col = c("red","green"))
graph_tx_ren<-ggplot()+
	geom_rect(data=rect_2_col, aes(xmin=1, xmax=length(x_tx_moyMob), ymin=ystart,ymax=yend), fill=rect_2_col$col, alpha =0.5) +
	geom_line(aes(x_tx_moyMob,running.mean(median_data,5)[3:22]),size=1)+
	#geom_boxplot(aes(x,exp(data$values),group=data$ind,fill=med_val),outlier.shape = NA)+
	scale_y_continuous(trans="log10")+
	annotation_logticks(sides="l")  +
	scale_x_continuous(breaks=c(1,4,9,14,19), labels=c((1974+T-7),(1974+T+4-7),(1974+T+9-7),(1974+T+14-7),(1974+T+19-7)))+
	scale_fill_manual(values=col)+
	#geom_hline(yintercept=1,color = "black") +
	xlab(iconv("Année","UTF8")) +
	ylab(iconv("Tx de renouvellement","UTF8"))+
	ggtitle("Tx de renouvellement de la population totale \n(moyenne mobile 5 ans)")+
	labs(fill = "")+
	theme_bw()+
	theme(plot.title = element_text(hjust = 0.5),legend.position="bottom")

