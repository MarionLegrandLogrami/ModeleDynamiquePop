#)

detach("package:dplyr", unload=TRUE)
library(plyr)
datapoly <- join(values, positions) #on utilise join et non merge car sinon tri sur les id et on a 1.1 puis 1.10 au lieu d'avoir 1.1 puis 1.2

graph_niveau_pop_ws<-ggplot()+
		geom_polygon(data=datapoly, aes(x=x, y=y, group=id),fill=datapoly$values, alpha =0.5) +
		#geom_line(aes(x_mob,running.mean(mean_N_vichy_50_actu,5)),size=0.5)+
		geom_line(aes(x_mob,running.mean(mean_N_vichy_ws,5)[!is.na(running.mean(mean_N_vichy_ws,5))]),size=1)+ #poissons estimés
		xlab(iconv("Année","UTF8")) + 
		ylab(iconv("Adultes estimés à Vichy","UTF8"))+
		ggtitle(iconv("Adultes estimés (en moyenne) à Vichy par rapport au nombre de géniteurs \nque produiraient la quantité de juvéniles correspondant à 50% de Rmax \n(moyenne mobile 5 ans centrée sur l'année indiquée)","UTF8"))+
		scale_x_continuous(limits = c((T+1-2), (T+20-2)),breaks=c((T+1-2),(T+4-2),(T+9-2),(T+14-2),(T+20-2)), labels=c((1974+T+1-2),(1974+T+4-2),(1974+T+9-2),(1974+T+14-2),(1974+T+20-2)))+
		scale_y_continuous(breaks=seq(0,1200,200),labels=seq(0,1200,200))+
		theme(legend.position="none")+
		theme_bw()+
		theme(plot.title = element_text(hjust = 0.5)) 

