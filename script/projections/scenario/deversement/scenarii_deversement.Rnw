<<transport_gen_15_Niv_pop, echo=FALSE, eval=FALSE,results=hide >>=
load(file = "C:/Users/utilisateur/workspace/ModeleDynamiquePop/2019_12_12_Projection_InteractionReciproqueMatriceVC_Maj2018_2020_07_01.RData")

library(coda)
library(boot)

surf=c(rep(c(846021,70845,250441,0),11),rep(c(846021,70845,250441,301101),12),rep(c(846021,70845,250441,383049),6),rep(c(846021,356519,250441,383049),(T-2))) #T-2 pour calculer sur T+27 année
S_juv_JP<-matrix(surf,nrow=4)
S_juv_JP<-rbind(S_juv_JP,colSums(S_juv_JP)) #Créé une 5eme ligne qui correspond à la somme par année des surfaces sur l'ensemble des secteurs

bugs_nu_d=read.coda("nu_dCODAchain1.txt","nu_dCODAindex.txt")
bugs_sigma_vichy=read.coda("sigma_vichyCODAchain1.txt","sigma_vichyCODAindex.txt")
Rmax=read.coda("RmaxCODAchain1.txt","RmaxCODAindex.txt")
#----------------------------------------------
# Niveau pop avec 50% Rmax et survie actuelle
#----------------------------------------------
Juv_Rmax_50_V=array(0,dim=c(10000,(T+21)))
Juv_Rmax_50_A=array(0,dim=c(10000,(T+21)))
Juv_Rmax_50_L=array(0,dim=c(10000,(T+21)))
Juv_Rmax_50_P=array(0,dim=c(10000,(T+21)))
Juv_Rmax_50=array(0,dim=c(10000,(T+21)))

for (t in (T-3):(T+21)){ #On calcule à partir de 2013 car moyenne mobile sur 5 ans avec pour dernière année 2017 (pour continuer la série du niveau de pop)
	for (i in 1:10000){
		Juv_Rmax_50_V[i,t]<-0.50*Rmax[i]*exp(bugs_nu_d[i,1])*S_juv_JP[1,t] #multiplie par nu_d pour tenir compte de la différence de production de juvéniles des différentes zones
		Juv_Rmax_50_A[i,t]<-0.50*Rmax[i]*exp(bugs_nu_d[i,2])*S_juv_JP[2,t] #multiplie par nu_d pour tenir compte de la différence de production de juvéniles des différentes zones
		Juv_Rmax_50_L[i,t]<-0.50*Rmax[i]*exp(bugs_nu_d[i,3])*S_juv_JP[3,t] #multiplie par nu_d pour tenir compte de la différence de production de juvéniles des différentes zones
		Juv_Rmax_50_P[i,t]<-0.50*Rmax[i]*exp(bugs_nu_d[i,4])*S_juv_JP[4,t] #multiplie par nu_d pour tenir compte de la différence de production de juvéniles des différentes zones
		Juv_Rmax_50[i,t]<-Juv_Rmax_50_V[i,t]+Juv_Rmax_50_A[i,t]+Juv_Rmax_50_L[i,t]+Juv_Rmax_50_P[i,t] #mean=213031.8
	}
}

##On calcule la référence pour comparer ensuite les estimations de géniteurs à Vichy qu'on a dans le scénario de CE
niveau_pop_50_actu<-array(0,dim=c(10000,(T+21)))
N_vichy_50_actu<-array(0,dim=c(10000,(T+21)))

for (t in (T-3):(T+21)){#On calcule à partir de 2013 car moyenne mobile sur 5 ans avec pour dernière année 2017 (pour continuer la série du niveau de pop)
	for (i in 1:10000){
		##Scénario 50% Rmax et survie actuelle
		niveau_pop_50_actu[i,t]<- log(bugs_s_juv2ad[i]*Juv_Rmax_50[i,t])
		N_vichy_50_actu[i,t]<-rlnorm(1,niveau_pop_50_actu[i,t],bugs_sigma_vichy[i])
	}
}

mean_N_vichy_50_actu<-NA

for (t in (T-3):(T+21)){
	mean_N_vichy_50_actu[t]<-mean(N_vichy_50_actu[,t]) # 752
}

#On récupère les simulation du nbr d'adulte à Vichy
N_vichy_ws<-stack(as.data.frame(N_vichy[,(T+1):(T+20)]))
#On renomme les "ind" pour avoir numéro année
levels(N_vichy_ws$ind)<-seq((1974+T+1),(1974+T+20),1)
#Il manque quelques années retrospectives on récupère les coda du modèle
#On récupère les données de passage à Vichy
bugs2jags(str_c(datawd,"data.txt"),"data_4zones_Interaction_2017.12.12.R")
source("data_4zones_Interaction_2017.12.12.R")
data_vichy<-N[,1]
#On fait la moyenne des moyennes
#On ajoute les données réelles pour convrir la période 2015-2017
data_vichy_add<-data.frame(values=rep(data_vichy[(T-3):T],each=10000),ind=rep(seq((1974+T-3),(1974+T),1),each=10000))
N_vichy_ws<-rbind(data_vichy_add,N_vichy_ws)
mean_N_vichy_ws<-tapply(N_vichy_ws[,1],N_vichy_ws[,2],mean) ##ATTENTION ICI on PREND MOYENNE pour faire moyenne mobile des médianes sur 5 ans

#===========================
# En moyenne mobile
#==========================
#On cherche à tracer la ref en moyenne mobile
#library(igraph) #fonctionrunning.mean() qui calcule moyenne mobile (glissante) sur un pas de temps donné
running.mean<- function(x, n = 5){stats::filter(x, rep(1 / n, n), sides = 2)}
#x_mob=seq(5,T,1)
x_mob=seq((T+1-2),(T+20-2),1)
#On créé les polygones pour avoir les couleurs vertes et rouge en fonction de l'évolution du niveau de ref (un peu compliqué à faire mais ça marche). Pour mémo polygone attend x1=x_droit / x2=x_gauche / y1=y_gauche / y2=y_droit
#poly_2_col <- data.frame(ystart = c(rep(0,38),running.mean(mean_N_vichy_50_actu,5)), yend = c(running.mean(mean_N_vichy_50_actu,5),rep(max(running.mean(data_vichy_all,5)),38)),col = c(rep("red",38),rep("green",38)))
#poly_2_col <- data.frame(ystart = c(rep(0,20),running.mean(mean_N_vichy_50_actu[(T-3):(T+20)],5)[!is.na(running.mean(mean_N_vichy_50_actu[(T-3):(T+20)]))]), 
#						 yend = c(running.mean(mean_N_vichy_50_actu[(T-3):(T+20)],5)[!is.na(running.mean(mean_N_vichy_50_actu[(T-3):(T+20)]))],rep(max(running.mean(mean_N_vichy_ws,5)),20)[!is.na(running.mean(mean_N_vichy_50_actu))]),col = c(rep("red",20),rep("green",20)))

ids<-factor(c(str_c("1.",seq((T+1-2),(T+20-2),1)),str_c("2.",seq((T+1-2),(T+20-2),1))))
values<-data.frame(id=ids,values=c(rep("red",length(x_mob)),rep("green",length(x_mob))))
positions<-data.frame(id=rep(ids,each=4),
		x=rep(c(rbind(seq((T+1-2),(T+20-2),1),seq((T+1-1),(T+20-1),1),seq((T+1-1),(T+20-1),1),seq((T+1-2),(T+20-2),1)))),
		y=c(c(rbind(
								0,
								0,
								rep(mean(running.mean(mean_N_vichy_50_actu,5)[!is.na(running.mean(mean_N_vichy_50_actu))]),length(x_mob)),
								rep(mean(running.mean(mean_N_vichy_50_actu,5)[!is.na(running.mean(mean_N_vichy_50_actu))]),length(x_mob)))),
				c(rbind(
								rep(mean(running.mean(mean_N_vichy_50_actu,5)[!is.na(running.mean(mean_N_vichy_50_actu))]),length(x_mob)),
								rep(mean(running.mean(mean_N_vichy_50_actu,5)[!is.na(running.mean(mean_N_vichy_50_actu))]),length(x_mob)),
								#On regarde qui est le plus grand du niveau de référence mean_N_vichy_50_actu ou du nbr estimés d'adulte mean_N_vichy_ws
								#Si c'est le niveau de référence on prend cette valeur + la moitié de cette valeur pour éviter de se retrouver avec simplement un trait vert
								if(max(running.mean(mean_N_vichy_50_actu,5)[!is.na(running.mean(mean_N_vichy_50_actu))])<max(running.mean(mean_N_vichy_ws,5),na.rm=TRUE)){
											rep(max(running.mean(mean_N_vichy_ws,5),na.rm=TRUE),(length(x_mob)-1))}else{
											rep(max(running.mean(mean_N_vichy_50_actu,5)[!is.na(running.mean(mean_N_vichy_50_actu))])+max(running.mean(mean_N_vichy_50_actu,5)[!is.na(running.mean(mean_N_vichy_50_actu))])/2,length(x_mob))},
								if(max(running.mean(mean_N_vichy_50_actu,5)[!is.na(running.mean(mean_N_vichy_50_actu))])<max(running.mean(mean_N_vichy_ws,5),na.rm=TRUE)){
											rep(max(running.mean(mean_N_vichy_ws,5),na.rm=TRUE),(length(x_mob)-1))}else{
											rep(max(running.mean(mean_N_vichy_50_actu,5)[!is.na(running.mean(mean_N_vichy_50_actu))])+max(running.mean(mean_N_vichy_50_actu,5)[!is.na(running.mean(mean_N_vichy_50_actu))])/2,length(x_mob))})
				)
#y=c(c(rbind(0,running.mean(mean_N_vichy_50_actu,5))),c(rbind(running.mean(mean_N_vichy_50_actu,5),rep(max(running.mean(data_vichy_all,5)),38))))
		))


