# Probabilité d'être avec un tx de renouvellement > à 1
#--------------------------------------------------------

tx_ren_above_1=array(0,dim=c(5000,64))


for (t in T:(T+20)){
	
	for (i in 1:5000){
		if(exp(renew_rate[i,t-5]) > 1){tx_ren_above_1[i,t-5]=1}  #Attention renew_rate est en log donc il faut bien prendre l'exponentielle de renew_rate pour retrouver une échelle naturelle
	}
}

