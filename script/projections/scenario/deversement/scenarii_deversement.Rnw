		I_juv_moy<-rbind(I_juv_moy,ind_dev)
		
#-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
# Validation Projections - Modèle 2021_06_01, on réécrit les quantités réellement déversées sur 2009-2018 et ensuite on prolonge les quantités 2018 sur les 10 dernières années
#-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
		##---- Scénario0 : On fait pareil que dernière année (2018)
		stock_juv_scenar<-array(c(rep(0,T*4),t(stock_juv[c(35:44),]),rep(c(408288,0,0,0),16)),dim=c(4,(T+26))) 
