##Pour lisser sur 5 ans, il faut récupérer les taux de renouvellement de 
## 1974+(T+1)-8 à 1974+(T+1)-4 --> 1974+(T+1)-4= 1ere année calculée dans les projections donc on récupère jusqu'à 1974+(T+1)-5
#load(file="C:/Users/utilisateur/workspace/ModeleDynamiquePop/renew_rate_coef_tot_2019_12_12.Rdata")
load(file=here::here("renew_rate_coef_tot_2021_09.Rdata"))
##On ne selectionne que les 4 dernières années 
renew_rate_old<-renew_rate_coef[,(T-9):(T-6)]
colnames(renew_rate_old)<-c(str_c("[,",(T-9),"]"),str_c("[,",(T-8),"]"),str_c("[,",(T-7),"]"),str_c("[,",(T-6),"]"))
##On ajoute un colnames à renew_rate
colnames(renew_rate)<-paste0("[,",seq(1,(T+20),1),"]")
##On merge renew_rate_old et renew_rate
renew_rate_final<-cbind(renew_rate_old,renew_rate[,(T-5):(T+20)])

