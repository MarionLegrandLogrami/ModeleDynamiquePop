##---------- fin choix scénarii --------------##
		
		

for (t in T:(T+3)){
	for (i in 1:5000){ 
		bugs_juv_tot_vichy[i,t] = (1/3) * bugs_juv_vichy[i,t-3] + (1/3) * bugs_juv_vichy[i,t-4] + (1/3) * bugs_juv_vichy[i,t-5] 
		bugs_juv_tot_alagnon[i,t] = (1/3) * bugs_juv_alagnon[i,t-3] + (1/3) * bugs_juv_alagnon[i,t-4] + (1/3) * bugs_juv_alagnon[i,t-5] 
		bugs_juv_tot_langeac[i,t] = (1/3) * bugs_juv_langeac[i,t-3] + (1/3) * bugs_juv_langeac[i,t-4] + (1/3) * bugs_juv_langeac[i,t-5] 
		bugs_juv_tot_poutes[i,t] = (1/3) * bugs_juv_poutes[i,t-3] + (1/3) * bugs_juv_poutes[i,t-4] + (1/3) * bugs_juv_poutes[i,t-5]
		bugs_juv_tot_system[i,t] = bugs_juv_tot_vichy[i,t] + bugs_juv_tot_alagnon[i,t] + bugs_juv_tot_langeac[i,t] +bugs_juv_tot_poutes[i,t]
		
		ratio_juv_prod_A[i,t] <- bugs_juv_tot_alagnon[i,t] / (bugs_juv_tot_vichy[i,t]+bugs_juv_tot_alagnon[i,t]+bugs_juv_tot_langeac[i,t]+bugs_juv_tot_poutes[i,t])
		ratio_juv_prod_L[i,t] <- (bugs_juv_tot_langeac[i,t]+bugs_juv_tot_poutes[i,t]) / (bugs_juv_tot_vichy[i,t]+bugs_juv_tot_langeac[i,t]+bugs_juv_tot_poutes[i,t])
		
		ratio_juv_A[i,t]<- bugs_rho_station[i]*(S_juv_JP[2,t]/(S_juv_JP[1,t]+S_juv_JP[2,t]+S_juv_JP[3,t]+S_juv_JP[4,t]))+(1-bugs_rho_station[i])*ratio_juv_prod_A[i,t]
		L_ratio_juv_A[i,t] <- logit(ratio_juv_A[i,t])
		L_mu_p_alagnon[i,t]<-L_ratio_juv_A[i,t]+bugs_adjust_p_A[i]
		L_p_alagnon[i,t]<-rnorm(1,L_mu_p_alagnon[i,t],bugs_sigma_p_alagnon[i]) 
		res_p_alagnon[i,t] <- L_p_alagnon[i,t]-L_mu_p_alagnon[i,t]
		
		ratio_juv_L[i,t]<- bugs_rho_station[i]*((S_juv_JP[3,t]+S_juv_JP[4,t])/(S_juv_JP[1,t]+S_juv_JP[3,t]+S_juv_JP[4,t]))+(1-bugs_rho_station[i])*ratio_juv_prod_L[i,t]
		L_ratio_juv_L[i,t] <- logit(ratio_juv_L[i,t])
		L_mu_p_langeac[i,t]<-L_ratio_juv_L[i,t]+bugs_adjust_p_L[i]
		L_p_langeac[i,t]<-rnorm(1,L_mu_p_langeac[i,t],bugs_sigma_p_langeac[i]) 
		res_p_langeac[i,t] <- L_p_langeac[i,t]-L_mu_p_langeac[i,t]
		
		ratio_juv_prod_P[i,t] <-  bugs_juv_tot_poutes[i,t]/(bugs_juv_tot_langeac[i,t]+bugs_juv_tot_poutes[i,t])#*bugs_rho_poutes[i])
		ratio_juv_P[i,t]<- bugs_rho_station[i]*(S_juv_JP[4,t]/(S_juv_JP[3,t]+S_juv_JP[4,t]))+(1-bugs_rho_station[i])*ratio_juv_prod_P[i,t]
		L_ratio_juv_P[i,t] <- logit(ratio_juv_P[i,t])
		L_mu_p_poutes[i,t]<-L_ratio_juv_P[i,t]+bugs_adjust_p_P[i] 
		L_p_poutes[i,t]<-rnorm(1,L_mu_p_poutes[i,t],bugs_sigma_p_poutes[i]) 
		res_p_poutes[i,t] <- L_p_poutes[i,t]-L_mu_p_poutes[i,t]
		
		L_mu_Vichy_nm[i,t]<- log(bugs_s_juv2ad[i]*bugs_juv_tot_system[i,t]) 
		N_vichy[i,t]<-rlnorm(1,L_mu_Vichy_nm[i,t],bugs_sigma_vichy[i])
		if (N_vichy[i,t]<3) {N_vichy[i,t]=3}
		if (N_vichy[i,t]>30000) {N_vichy[i,t]=30000}
		res_vichy[i,t] <- log(N_vichy[i,t])-L_mu_Vichy_nm[i,t]
		
		p_alagnon[i,t]=inv.logit(L_p_alagnon[i,t])	
		p_langeac[i,t]=inv.logit(L_p_langeac[i,t])	
		p_poutes[i,t]=inv.logit(L_p_poutes[i,t])	
		N_alagnon[i,t]=rbinom(1,ifelse(N_vichy[i,t]-S_stocking_simulation[t-(t-1)]<0,1,round(N_vichy[i,t]-S_stocking_simulation[t-(t-1)],0)),p_alagnon[i,t])
		N_langeac[i,t]=rbinom(1,ifelse(N_vichy[i,t]-N_alagnon[i,t]-S_stocking_simulation[t-(t-1)]<0,1,round(N_vichy[i,t]-N_alagnon[i,t]-S_stocking_simulation[t-(t-1)],0)),p_langeac[i,t])
		N_poutes[i,t]=rbinom(1,round(N_langeac[i,t],0),p_poutes[i,t])
		min_N_langeac[i,t]<-N_poutes[i,t]+1
		if(N_langeac[i,t]<min_N_langeac[i,t]){N_langeac[i,t]=min_N_langeac[i,t]}
		
		S_poutes[i,t]=max(N_poutes[i,t],1)
		S_langeac[i,t]=max(N_langeac[i,t]-N_poutes[i,t],1)
		S_alagnon[i,t]=max(N_alagnon[i,t],1)
		S_vichy[i,t]= max(N_vichy[i,t]-N_alagnon[i,t]-N_langeac[i,t]-S_stocking_simulation[t-(t-1)],1)
		
		#....................................................
		#Ce qu'on faisait dans le scénario sans déversement
#		L_mu_d_wild_vichy[i,t+1]=log( (S_vichy[i,t]/S_juv_JP[1,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_vichy[i,t]/S_juv_JP[1,t]) )) + bugs_nu_d[i,1]
#		L_d_moy_vichy[i,t+1]=rnorm(1,L_mu_d_wild_vichy[i,t+1],bugs_sigma_wild_moy[i])
#		d_moy_vichy[i,t+1]=exp(L_d_moy_vichy[i,t+1])#d_moy_vichy=d_wild_moy_vichy car projection sans repeuplement
#		juv_vichy[i,t+1]=d_moy_vichy[i,t+1]*S_juv_JP[1,t+1]
		
		
		#p_Rmax = proportion d'habitat pour les sauvages
		L_mu_d_wild_temp_vichy[i,t+1]=log((S_vichy[i,t]/S_juv_JP[1,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_vichy[i,t]/S_juv_JP[1,t]))) + bugs_nu_d[i,1]
		if(I_juv_moy[t+1,1]==1){
			L_mu_d_juv_temp_vichy[i,t+1]=log( (stock_juv_scenar[1,t+1]/S_juv_JP[1,t]) / ( bugs_alpha_dd_juv[i]  + bugs_beta_dd[i] * (stock_juv_scenar[1,t+1]/S_juv_JP[1,t]) ) ) + bugs_nu_d[i,1]
			p_Rmax_vichy[i,t+1]= exp(L_mu_d_wild_temp_vichy[i,t+1]) / ( exp(L_mu_d_wild_temp_vichy[i,t+1]) + exp(L_mu_d_juv_temp_vichy[i,t+1]))
		}else{p_Rmax_vichy[i,t+1]=1}
		
		L_mu_d_wild_vichy[i,t+1]=log( (S_vichy[i,t]/S_juv_JP[1,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] / p_Rmax_vichy[i,t+1]* (S_vichy[i,t]/S_juv_JP[1,t]) )) + bugs_nu_d[i,1]
		L_d_moy_vichy[i,t+1]=rnorm(1,L_mu_d_wild_vichy[i,t+1],bugs_sigma_wild_moy[i])
		d_moy_w_vichy[i,t+1]=exp(L_d_moy_vichy[i,t+1])#d_moy_vichy=d_wild_moy_vichy car projection sans repeuplement
		
		beta_temp_vichy[i,t+1] <-  1 / ( 1 + (bugs_a[i]/bugs_Rmax[i])*(S_vichy[i,t]/S_juv_JP[1,t]))
		#Pente de la relation SR des déversés corrigée d'un paramètre beta_temp qui correspond à l'impact des poissons sauvages déjà en place sur les poissons déversés
		alpha_dd_juv_temp_vichy[i,t+1]  <- 1/(bugs_a_juv[i] * beta_temp_vichy[i,t+1])
		if(I_juv_moy[t+1,1]==1){
			L_mu_d_juv_vichy[i,t+1]= log((stock_juv_scenar[1,t+1]/S_juv_JP[1,t]) / (alpha_dd_juv_temp_vichy[i,t+1] + bugs_beta_dd[i] / (1- p_Rmax_vichy[i,t+1]) * (stock_juv_scenar[1,t+1]/S_juv_JP[1,t]))) + bugs_nu_d[i,1]
			L_d_juv_moy_vichy[i,t+1]=rnorm(1,L_mu_d_juv_vichy[i,t+1],bugs_sigma_juv_moy[i])	
			d_moy_juv_vichy[i,t+1]=exp(L_d_juv_moy_vichy[i,t+1])
		}else{d_moy_juv_vichy[i,t+1]=0}
		juv_vichy[i,t+1]=(d_moy_w_vichy[i,t+1]+d_moy_juv_vichy[i,t+1])*S_juv_JP[1,t+1]
		
#		L_mu_d_wild_alagnon[i,t+1]=log( (S_alagnon[i,t]/S_juv_JP[2,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_alagnon[i,t]/S_juv_JP[2,t]) )) + bugs_nu_d[i,2]
#		L_d_moy_alagnon[i,t+1]=rnorm(1,L_mu_d_wild_alagnon[i,t+1],bugs_sigma_wild_moy[i])
#		d_moy_alagnon[i,t+1]=exp(L_d_moy_alagnon[i,t+1])#d_moy_vichy=d_wild_moy_vichy car projection sans repeuplement
#		juv_alagnon[i,t+1]=d_moy_alagnon[i,t+1]*S_juv_JP[2,t+1]
	
		L_mu_d_wild_temp_alagnon[i,t+1]=log((S_alagnon[i,t]/S_juv_JP[2,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_alagnon[i,t]/S_juv_JP[2,t]))) + bugs_nu_d[i,2]
		if(I_juv_moy[t+1,2]==1){
			L_mu_d_juv_temp_alagnon[i,t+1]=log( (stock_juv_scenar[2,t+1]/S_juv_JP[2,t]) / ( bugs_alpha_dd_juv[i]  + bugs_beta_dd[i] * (stock_juv_scenar[2,t+1]/S_juv_JP[2,t]) ) ) + bugs_nu_d[i,2]
			p_Rmax_alagnon[i,t+1]= exp(L_mu_d_wild_temp_alagnon[i,t+1]) / ( exp(L_mu_d_wild_temp_alagnon[i,t+1]) + exp(L_mu_d_juv_temp_alagnon[i,t+1])) 
		}else{p_Rmax_alagnon[i,t+1]=1}
		
		L_mu_d_wild_alagnon[i,t+1]=log( (S_alagnon[i,t]/S_juv_JP[2,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] / p_Rmax_alagnon[i,t+1]* (S_alagnon[i,t]/S_juv_JP[2,t]) )) + bugs_nu_d[i,2]
		L_d_moy_alagnon[i,t+1]=rnorm(1,L_mu_d_wild_alagnon[i,t+1],bugs_sigma_wild_moy[i])
		d_moy_w_alagnon[i,t+1]=exp(L_d_moy_alagnon[i,t+1])#d_moy_vichy=d_wild_moy_vichy car projection sans repeuplement
		
		beta_temp_alagnon[i,t+1] <-  1 / ( 1 + (bugs_a[i]/bugs_Rmax[i])*(S_alagnon[i,t]/S_juv_JP[2,t]))
		#Pente de la relation SR des déversés corrigée d'un paramètre beta_temp qui correspond à l'impact des poissons sauvages déjà en place sur les poissons déversés
		alpha_dd_juv_temp_alagnon[i,t+1]  <- 1/(bugs_a_juv[i] * beta_temp_alagnon[i,t+1])
		if(I_juv_moy[t+1,2]==1){
			L_mu_d_juv_alagnon[i,t+1]= log((stock_juv_scenar[2,t+1]/S_juv_JP[2,t]) / (alpha_dd_juv_temp_alagnon[i,t+1] + bugs_beta_dd[i] / (1- p_Rmax_alagnon[i,t+1]) * (stock_juv_scenar[2,t+1]/S_juv_JP[2,t]))) + bugs_nu_d[i,2]
			L_d_juv_moy_alagnon[i,t+1]=rnorm(1,L_mu_d_juv_alagnon[i,t+1],bugs_sigma_juv_moy[i])
			d_moy_juv_alagnon[i,t+1]=exp(L_d_juv_moy_alagnon[i,t+1])
		}else{d_moy_juv_alagnon[i,t+1]=0}
		juv_alagnon[i,t+1]=(d_moy_w_alagnon[i,t+1]+d_moy_juv_alagnon[i,t+1])*S_juv_JP[2,t+1]
		
#		L_mu_d_wild_langeac[i,t+1]=log( (S_langeac[i,t]/S_juv_JP[3,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_langeac[i,t]/S_juv_JP[3,t]) )) + bugs_nu_d[i,3]
#		L_d_moy_langeac[i,t+1]=rnorm(1,L_mu_d_wild_langeac[i,t+1],bugs_sigma_wild_moy[i])
#		d_moy_langeac[i,t+1]=exp(L_d_moy_langeac[i,t+1])#d_moy_vichy=d_wild_moy_vichy car projection sans repeuplement
#		juv_langeac[i,t+1]=d_moy_langeac[i,t+1]*S_juv_JP[3,t+1]

		L_mu_d_wild_temp_langeac[i,t+1]=log((S_langeac[i,t]/S_juv_JP[3,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_langeac[i,t]/S_juv_JP[3,t]))) + bugs_nu_d[i,3]
		if(I_juv_moy[t+1,3]==1){
			L_mu_d_juv_temp_langeac[i,t+1]=log( (stock_juv_scenar[3,t+1]/S_juv_JP[3,t]) / ( bugs_alpha_dd_juv[i]  + bugs_beta_dd[i] * (stock_juv_scenar[3,t+1]/S_juv_JP[3,t]) ) ) + bugs_nu_d[i,3]
			p_Rmax_langeac[i,t+1]= exp(L_mu_d_wild_temp_langeac[i,t+1]) / ( exp(L_mu_d_wild_temp_langeac[i,t+1]) + exp(L_mu_d_juv_temp_langeac[i,t+1]))
		}else{p_Rmax_langeac[i,t+1]=1}
		
		L_mu_d_wild_langeac[i,t+1]=log( (S_langeac[i,t]/S_juv_JP[3,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] / p_Rmax_langeac[i,t+1]* (S_langeac[i,t]/S_juv_JP[3,t]) )) + bugs_nu_d[i,3]
		L_d_moy_langeac[i,t+1]=rnorm(1,L_mu_d_wild_langeac[i,t+1],bugs_sigma_wild_moy[i])
		d_moy_w_langeac[i,t+1]=exp(L_d_moy_langeac[i,t+1])
		
		beta_temp_langeac[i,t+1] <-  1 / ( 1 + (bugs_a[i]/bugs_Rmax[i])*(S_langeac[i,t]/S_juv_JP[3,t]))
		#Pente de la relation SR des déversés corrigée d'un paramètre beta_temp qui correspond à l'impact des poissons sauvages déjà en place sur les poissons déversés
		alpha_dd_juv_temp_langeac[i,t+1]  <- 1/(bugs_a_juv[i] * beta_temp_langeac[i,t+1])
		if(I_juv_moy[t+1,3]==1){
			L_mu_d_juv_langeac[i,t+1]= log((stock_juv_scenar[3,t+1]/S_juv_JP[3,t]) / (alpha_dd_juv_temp_langeac[i,t+1] + bugs_beta_dd[i] / (1- p_Rmax_langeac[i,t+1]) * (stock_juv_scenar[3,t+1]/S_juv_JP[3,t]))) + bugs_nu_d[i,3]
			L_d_juv_moy_langeac[i,t+1]=rnorm(1,L_mu_d_juv_langeac[i,t+1],bugs_sigma_juv_moy[i])
			d_moy_juv_langeac[i,t+1]=exp(L_d_juv_moy_langeac[i,t+1])
		}else{d_moy_juv_langeac[i,t+1]=0}
		juv_langeac[i,t+1]=(d_moy_w_langeac[i,t+1]+d_moy_juv_langeac[i,t+1])*S_juv_JP[3,t+1]
		
#		L_mu_d_wild_poutes[i,t+1]=log( (S_poutes[i,t]/S_juv_JP[4,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_poutes[i,t]/S_juv_JP[4,t]) )) + bugs_nu_d[i,4]
#		L_d_moy_poutes[i,t+1]=rnorm(1,L_mu_d_wild_poutes[i,t+1],bugs_sigma_wild_moy[i])
#		d_moy_poutes[i,t+1]=exp(L_d_moy_poutes[i,t+1])#d_moy_vichy=d_wild_moy_vichy car projection sans repeuplement
#		juv_poutes[i,t+1]=d_moy_poutes[i,t+1]*S_juv_JP[4,t+1]
		
		L_mu_d_wild_temp_poutes[i,t+1]=log((S_poutes[i,t]/S_juv_JP[4,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_poutes[i,t]/S_juv_JP[4,t]))) + bugs_nu_d[i,4]
		if(I_juv_moy[t+1,4]==1){
			L_mu_d_juv_temp_poutes[i,t+1]=log( (stock_juv_scenar[4,t+1]/S_juv_JP[4,t]) / ( bugs_alpha_dd_juv[i]  + bugs_beta_dd[i] * (stock_juv_scenar[4,t+1]/S_juv_JP[4,t]) ) ) + bugs_nu_d[i,4]
			p_Rmax_poutes[i,t+1]= exp(L_mu_d_wild_temp_poutes[i,t+1]) / ( exp(L_mu_d_wild_temp_poutes[i,t+1]) + exp(L_mu_d_juv_temp_poutes[i,t+1])) 
		}else{p_Rmax_poutes[i,t+1]=1}
		
		L_mu_d_wild_poutes[i,t+1]=log( (S_poutes[i,t]/S_juv_JP[4,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] / p_Rmax_poutes[i,t+1]* (S_poutes[i,t]/S_juv_JP[4,t]) )) + bugs_nu_d[i,4]
		L_d_moy_poutes[i,t+1]=rnorm(1,L_mu_d_wild_poutes[i,t+1],bugs_sigma_wild_moy[i])
		d_moy_w_poutes[i,t+1]=exp(L_d_moy_poutes[i,t+1])
		
		beta_temp_poutes[i,t+1] <-  1 / ( 1 + (bugs_a[i]/bugs_Rmax[i])*(S_poutes[i,t]/S_juv_JP[4,t]))
		#Pente de la relation SR des déversés corrigée d'un paramètre beta_temp qui correspond à l'impact des poissons sauvages déjà en place sur les poissons déversés
		alpha_dd_juv_temp_poutes[i,t+1]  <- 1/(bugs_a_juv[i] * beta_temp_poutes[i,t+1])
		if(I_juv_moy[t+1,4]==1){
			L_mu_d_juv_poutes[i,t+1]= log((stock_juv_scenar[4,t+1]/S_juv_JP[4,t]) / (alpha_dd_juv_temp_poutes[i,t+1] + bugs_beta_dd[i] / (1- p_Rmax_poutes[i,t+1]) * (stock_juv_scenar[4,t+1]/S_juv_JP[4,t]))) + bugs_nu_d[i,4]
			L_d_juv_moy_poutes[i,t+1]=rnorm(1,L_mu_d_juv_poutes[i,t+1],bugs_sigma_juv_moy[i])
			d_moy_juv_poutes[i,t+1]=exp(L_d_juv_moy_poutes[i,t+1])
		}else{d_moy_juv_poutes[i,t+1]=0}
		juv_poutes[i,t+1]=(d_moy_w_poutes[i,t+1]+d_moy_juv_poutes[i,t+1])*S_juv_JP[4,t+1]

		
	}
}

#Les juvéniles t-3 sont maintenant ceux calculés à la fin de la première boucle et non plus ceux issus directement d'openbugs
for (t in (T+4):(T+4)){
	for (i in 1:5000){ 
		bugs_juv_tot_vichy[i,t] = (1/3) * juv_vichy[i,t-3] + (1/3) * bugs_juv_vichy[i,t-4] + (1/3) * bugs_juv_vichy[i,t-5] 
		bugs_juv_tot_alagnon[i,t] = (1/3) * juv_alagnon[i,t-3] + (1/3) * bugs_juv_alagnon[i,t-4] + (1/3) * bugs_juv_alagnon[i,t-5] 
		bugs_juv_tot_langeac[i,t] = (1/3) * juv_langeac[i,t-3] + (1/3) * bugs_juv_langeac[i,t-4] + (1/3) * bugs_juv_langeac[i,t-5] 
		bugs_juv_tot_poutes[i,t] = (1/3) * juv_poutes[i,t-3] + (1/3) * bugs_juv_poutes[i,t-4] + (1/3) * bugs_juv_poutes[i,t-5] 
		bugs_juv_tot_system[i,t] = bugs_juv_tot_vichy[i,t]+bugs_juv_tot_alagnon[i,t]+bugs_juv_tot_langeac[i,t] +bugs_juv_tot_poutes[i,t]#*bugs_rho_poutes[i]
		
		ratio_juv_prod_A[i,t] <- bugs_juv_tot_alagnon[i,t] / (bugs_juv_tot_vichy[i,t]+bugs_juv_tot_alagnon[i,t]+bugs_juv_tot_langeac[i,t]+bugs_juv_tot_poutes[i,t])#*bugs_rho_poutes[i])	
		ratio_juv_prod_L[i,t] <- (bugs_juv_tot_langeac[i,t]+bugs_juv_tot_poutes[i,t]) / (bugs_juv_tot_vichy[i,t]+bugs_juv_tot_langeac[i,t]+bugs_juv_tot_poutes[i,t])#*bugs_rho_poutes[i])	
		#ratio_juv_prod_V[i,t] <- 1-ratio_juv_prod_L[i,t]
		
		ratio_juv_A[i,t]<- bugs_rho_station[i]*(S_juv_JP[2,t]/(S_juv_JP[1,t]+S_juv_JP[2,t]+S_juv_JP[3,t]+S_juv_JP[4,t]))+(1-bugs_rho_station[i])*ratio_juv_prod_A[i,t]
		L_ratio_juv_A[i,t] <- logit(ratio_juv_A[i,t])
		L_mu_p_alagnon[i,t]<-L_ratio_juv_A[i,t]+bugs_adjust_p_A[i]
		L_p_alagnon[i,t]<-rnorm(1,L_mu_p_alagnon[i,t],bugs_sigma_p_alagnon[i]) 
		res_p_alagnon[i,t] <- L_p_alagnon[i,t]-L_mu_p_alagnon[i,t]
		
		ratio_juv_L[i,t]<- bugs_rho_station[i]*((S_juv_JP[3,t]+S_juv_JP[4,t])/(S_juv_JP[1,t]+S_juv_JP[3,t]+S_juv_JP[4,t]))+(1-bugs_rho_station[i])*ratio_juv_prod_L[i,t]
		L_ratio_juv_L[i,t] <- logit(ratio_juv_L[i,t])
		L_mu_p_langeac[i,t]<-L_ratio_juv_L[i,t]+bugs_adjust_p_L[i]
		L_p_langeac[i,t]<-rnorm(1,L_mu_p_langeac[i,t],bugs_sigma_p_langeac[i]) 
		res_p_langeac[i,t] <- L_p_langeac[i,t]-L_mu_p_langeac[i,t]
		
		ratio_juv_prod_P[i,t] <-  bugs_juv_tot_poutes[i,t]/(bugs_juv_tot_langeac[i,t]+bugs_juv_tot_poutes[i,t])#*bugs_rho_poutes[i])
		ratio_juv_P[i,t]<- bugs_rho_station[i]*(S_juv_JP[4,t]/(S_juv_JP[3,t]+S_juv_JP[4,t]))+(1-bugs_rho_station[i])*ratio_juv_prod_P[i,t]
		L_ratio_juv_P[i,t] <- logit(ratio_juv_P[i,t])
		L_mu_p_poutes[i,t]<-L_ratio_juv_P[i,t]+bugs_adjust_p_P[i] 
		L_p_poutes[i,t]<-rnorm(1,L_mu_p_poutes[i,t],bugs_sigma_p_poutes[i]) 
		res_p_poutes[i,t] <- L_p_poutes[i,t]-L_mu_p_poutes[i,t]
		
		L_mu_Vichy_nm[i,t]<- log(bugs_s_juv2ad[i]*bugs_juv_tot_system[i,t]) 
		N_vichy[i,t]<-rlnorm(1,L_mu_Vichy_nm[i,t],bugs_sigma_vichy[i])
		if (N_vichy[i,t]<3) {N_vichy[i,t]=3}
		if (N_vichy[i,t]>30000) {N_vichy[i,t]=30000}#I(3,30000)
		res_vichy[i,t] <- log(N_vichy[i,t])-L_mu_Vichy_nm[i,t]
				
		p_alagnon[i,t]=inv.logit(L_p_alagnon[i,t])	
		p_langeac[i,t]=inv.logit(L_p_langeac[i,t])	
		p_poutes[i,t]=inv.logit(L_p_poutes[i,t])	
		#N_alagnon[i,t]=rbinom(1,round(N_vichy[i,t],0),p_alagnon[i,t])#On prend N_vichy_corrTrans au lieu de N_vichy puisqu'on a prélevé 15% des poissons à Vichy
		#N_langeac[i,t]=rbinom(1,round(N_vichy[i,t]-N_alagnon[i,t],0),p_langeac[i,t])#On prend N_vichy_corrTrans au lieu de N_vichy puisqu'on a prélevé 15% des poissons à VichyN_poutes[i,t]=rbinom(1,round(N_langeac[i,t],0),p_poutes[i,t])
		N_alagnon[i,t]=rbinom(1,ifelse(N_vichy[i,t]-S_stocking_simulation[t-(t-1)]<0,1,round(N_vichy[i,t]-S_stocking_simulation[t-(t-1)],0)),p_alagnon[i,t])
		N_langeac[i,t]=rbinom(1,ifelse(N_vichy[i,t]-N_alagnon[i,t]-S_stocking_simulation[t-(t-1)]<0,1,round(N_vichy[i,t]-N_alagnon[i,t]-S_stocking_simulation[t-(t-1)],0)),p_langeac[i,t])
		N_poutes[i,t]=rbinom(1,round(N_langeac[i,t],0),p_poutes[i,t])
		min_N_langeac[i,t]<-N_poutes[i,t]+1
		if(N_langeac[i,t]<min_N_langeac[i,t]){N_langeac[i,t]=min_N_langeac[i,t]}
		
		S_poutes[i,t]=max(N_poutes[i,t],1)
		S_langeac[i,t]=max(N_langeac[i,t]-N_poutes[i,t],1)
		S_alagnon[i,t]=max(N_alagnon[i,t],1)
		#S_vichy[i,t]= max(N_vichy[i,t]-N_alagnon[i,t]-N_langeac[i,t],1)
		S_vichy[i,t]= max(N_vichy[i,t]-N_alagnon[i,t]-N_langeac[i,t]-S_stocking_simulation[t-(t-1)],1)

		#....................................................
		#Ce qu'on faisait dans le scénario sans déversement
#		L_mu_d_wild_vichy[i,t+1]=log( (S_vichy[i,t]/S_juv_JP[1,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_vichy[i,t]/S_juv_JP[1,t]) )) + bugs_nu_d[i,1]
#		L_d_moy_vichy[i,t+1]=rnorm(1,L_mu_d_wild_vichy[i,t+1],bugs_sigma_wild_moy[i])
#		d_moy_vichy[i,t+1]=exp(L_d_moy_vichy[i,t+1])#d_moy_vichy=d_wild_moy_vichy car projection sans repeuplement
#		juv_vichy[i,t+1]=d_moy_vichy[i,t+1]*S_juv_JP[1,t+1]
		
		
		#p_Rmax = proportion d'habitat pour les sauvages
		L_mu_d_wild_temp_vichy[i,t+1]=log((S_vichy[i,t]/S_juv_JP[1,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_vichy[i,t]/S_juv_JP[1,t]))) + bugs_nu_d[i,1]
		if(I_juv_moy[t+1,1]==1){
			L_mu_d_juv_temp_vichy[i,t+1]=log( (stock_juv_scenar[1,t+1]/S_juv_JP[1,t]) / ( bugs_alpha_dd_juv[i]  + bugs_beta_dd[i] * (stock_juv_scenar[1,t+1]/S_juv_JP[1,t]) ) ) + bugs_nu_d[i,1]
			p_Rmax_vichy[i,t+1]= exp(L_mu_d_wild_temp_vichy[i,t+1]) / ( exp(L_mu_d_wild_temp_vichy[i,t+1]) + exp(L_mu_d_juv_temp_vichy[i,t+1]))
		}else{p_Rmax_vichy[i,t+1]=1}
		
		L_mu_d_wild_vichy[i,t+1]=log( (S_vichy[i,t]/S_juv_JP[1,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] / p_Rmax_vichy[i,t+1]* (S_vichy[i,t]/S_juv_JP[1,t]) )) + bugs_nu_d[i,1]
		L_d_moy_vichy[i,t+1]=rnorm(1,L_mu_d_wild_vichy[i,t+1],bugs_sigma_wild_moy[i])
		d_moy_w_vichy[i,t+1]=exp(L_d_moy_vichy[i,t+1])#d_moy_vichy=d_wild_moy_vichy car projection sans repeuplement
		
		beta_temp_vichy[i,t+1] <-  1 / ( 1 + (bugs_a[i]/bugs_Rmax[i])*(S_vichy[i,t]/S_juv_JP[1,t]))
		#Pente de la relation SR des déversés corrigée d'un paramètre beta_temp qui correspond à l'impact des poissons sauvages déjà en place sur les poissons déversés
		alpha_dd_juv_temp_vichy[i,t+1]  <- 1/(bugs_a_juv[i] * beta_temp_vichy[i,t+1])
		if(I_juv_moy[t+1,1]==1){
			L_mu_d_juv_vichy[i,t+1]= log((stock_juv_scenar[1,t+1]/S_juv_JP[1,t]) / (alpha_dd_juv_temp_vichy[i,t+1] + bugs_beta_dd[i] / (1- p_Rmax_vichy[i,t+1]) * (stock_juv_scenar[1,t+1]/S_juv_JP[1,t]))) + bugs_nu_d[i,1]
			L_d_juv_moy_vichy[i,t+1]=rnorm(1,L_mu_d_juv_vichy[i,t+1],bugs_sigma_juv_moy[i])
			d_moy_juv_vichy[i,t+1]=exp(L_d_juv_moy_vichy[i,t+1])
		}else{d_moy_juv_vichy[i,t+1]=0}
		juv_vichy[i,t+1]=(d_moy_w_vichy[i,t+1]+d_moy_juv_vichy[i,t+1])*S_juv_JP[1,t+1]
		
#		L_mu_d_wild_alagnon[i,t+1]=log( (S_alagnon[i,t]/S_juv_JP[2,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_alagnon[i,t]/S_juv_JP[2,t]) )) + bugs_nu_d[i,2]
#		L_d_moy_alagnon[i,t+1]=rnorm(1,L_mu_d_wild_alagnon[i,t+1],bugs_sigma_wild_moy[i])
#		d_moy_alagnon[i,t+1]=exp(L_d_moy_alagnon[i,t+1])#d_moy_vichy=d_wild_moy_vichy car projection sans repeuplement
#		juv_alagnon[i,t+1]=d_moy_alagnon[i,t+1]*S_juv_JP[2,t+1]
		
		L_mu_d_wild_temp_alagnon[i,t+1]=log((S_alagnon[i,t]/S_juv_JP[2,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_alagnon[i,t]/S_juv_JP[2,t]))) + bugs_nu_d[i,2]
		if(I_juv_moy[t+1,2]==1){
			L_mu_d_juv_temp_alagnon[i,t+1]=log( (stock_juv_scenar[2,t+1]/S_juv_JP[2,t]) / ( bugs_alpha_dd_juv[i]  + bugs_beta_dd[i] * (stock_juv_scenar[2,t+1]/S_juv_JP[2,t]) ) ) + bugs_nu_d[i,2]
			p_Rmax_alagnon[i,t+1]= exp(L_mu_d_wild_temp_alagnon[i,t+1]) / ( exp(L_mu_d_wild_temp_alagnon[i,t+1]) + exp(L_mu_d_juv_temp_alagnon[i,t+1]))  
		}else{p_Rmax_alagnon[i,t+1]=1}
		
		L_mu_d_wild_alagnon[i,t+1]=log( (S_alagnon[i,t]/S_juv_JP[2,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] / p_Rmax_alagnon[i,t+1]* (S_alagnon[i,t]/S_juv_JP[2,t]) )) + bugs_nu_d[i,2]
		L_d_moy_alagnon[i,t+1]=rnorm(1,L_mu_d_wild_alagnon[i,t+1],bugs_sigma_wild_moy[i])
		d_moy_w_alagnon[i,t+1]=exp(L_d_moy_alagnon[i,t+1])#d_moy_vichy=d_wild_moy_vichy car projection sans repeuplement
		
		beta_temp_alagnon[i,t+1] <-  1 / ( 1 + (bugs_a[i]/bugs_Rmax[i])*(S_alagnon[i,t]/S_juv_JP[2,t]))
		#Pente de la relation SR des déversés corrigée d'un paramètre beta_temp qui correspond à l'impact des poissons sauvages déjà en place sur les poissons déversés
		alpha_dd_juv_temp_alagnon[i,t+1]  <- 1/(bugs_a_juv[i] * beta_temp_alagnon[i,t+1])
		if(I_juv_moy[t+1,2]==1){
			L_mu_d_juv_alagnon[i,t+1]= log((stock_juv_scenar[2,t+1]/S_juv_JP[2,t]) / (alpha_dd_juv_temp_alagnon[i,t+1] + bugs_beta_dd[i] / (1- p_Rmax_alagnon[i,t+1]) * (stock_juv_scenar[2,t+1]/S_juv_JP[2,t]))) + bugs_nu_d[i,2]
			L_d_juv_moy_alagnon[i,t+1]=rnorm(1,L_mu_d_juv_alagnon[i,t+1],bugs_sigma_juv_moy[i])
			d_moy_juv_alagnon[i,t+1]=exp(L_d_juv_moy_alagnon[i,t+1])
		}else{d_moy_juv_alagnon[i,t+1]=0}
		juv_alagnon[i,t+1]=(d_moy_w_alagnon[i,t+1]+d_moy_juv_alagnon[i,t+1])*S_juv_JP[2,t+1]
		
#		L_mu_d_wild_langeac[i,t+1]=log( (S_langeac[i,t]/S_juv_JP[3,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_langeac[i,t]/S_juv_JP[3,t]) )) + bugs_nu_d[i,3]
#		L_d_moy_langeac[i,t+1]=rnorm(1,L_mu_d_wild_langeac[i,t+1],bugs_sigma_wild_moy[i])
#		d_moy_langeac[i,t+1]=exp(L_d_moy_langeac[i,t+1])#d_moy_vichy=d_wild_moy_vichy car projection sans repeuplement
#		juv_langeac[i,t+1]=d_moy_langeac[i,t+1]*S_juv_JP[3,t+1]
		
		L_mu_d_wild_temp_langeac[i,t+1]=log((S_langeac[i,t]/S_juv_JP[3,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_langeac[i,t]/S_juv_JP[3,t]))) + bugs_nu_d[i,3]
		if(I_juv_moy[t+1,3]==1){
			L_mu_d_juv_temp_langeac[i,t+1]=log( (stock_juv_scenar[3,t+1]/S_juv_JP[3,t]) / ( bugs_alpha_dd_juv[i]  + bugs_beta_dd[i] * (stock_juv_scenar[3,t+1]/S_juv_JP[3,t]) ) ) + bugs_nu_d[i,3]
			p_Rmax_langeac[i,t+1]= exp(L_mu_d_wild_temp_langeac[i,t+1]) / ( exp(L_mu_d_wild_temp_langeac[i,t+1]) + exp(L_mu_d_juv_temp_langeac[i,t+1]))  
		}else{p_Rmax_langeac[i,t+1]=1}
		
		L_mu_d_wild_langeac[i,t+1]=log( (S_langeac[i,t]/S_juv_JP[3,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] / p_Rmax_langeac[i,t+1]* (S_langeac[i,t]/S_juv_JP[3,t]) )) + bugs_nu_d[i,3]
		L_d_moy_langeac[i,t+1]=rnorm(1,L_mu_d_wild_langeac[i,t+1],bugs_sigma_wild_moy[i])
		d_moy_w_langeac[i,t+1]=exp(L_d_moy_langeac[i,t+1])
		
		beta_temp_langeac[i,t+1] <-  1 / ( 1 + (bugs_a[i]/bugs_Rmax[i])*(S_langeac[i,t]/S_juv_JP[3,t]))
		#Pente de la relation SR des déversés corrigée d'un paramètre beta_temp qui correspond à l'impact des poissons sauvages déjà en place sur les poissons déversés
		alpha_dd_juv_temp_langeac[i,t+1]  <- 1/(bugs_a_juv[i] * beta_temp_langeac[i,t+1])
		if(I_juv_moy[t+1,3]==1){
			L_mu_d_juv_langeac[i,t+1]= log((stock_juv_scenar[3,t+1]/S_juv_JP[3,t]) / (alpha_dd_juv_temp_langeac[i,t+1] + bugs_beta_dd[i] / (1- p_Rmax_langeac[i,t+1]) * (stock_juv_scenar[3,t+1]/S_juv_JP[3,t]))) + bugs_nu_d[i,3]
			L_d_juv_moy_langeac[i,t+1]=rnorm(1,L_mu_d_juv_langeac[i,t+1],bugs_sigma_juv_moy[i])
			d_moy_juv_langeac[i,t+1]=exp(L_d_juv_moy_langeac[i,t+1])
		}else{d_moy_juv_langeac[i,t+1]=0}
		juv_langeac[i,t+1]=(d_moy_w_langeac[i,t+1]+d_moy_juv_langeac[i,t+1])*S_juv_JP[3,t+1]
		
		
#		L_mu_d_wild_poutes[i,t+1]=log( (S_poutes[i,t]/S_juv_JP[4,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_poutes[i,t]/S_juv_JP[4,t]) )) + bugs_nu_d[i,4]
#		L_d_moy_poutes[i,t+1]=rnorm(1,L_mu_d_wild_poutes[i,t+1],bugs_sigma_wild_moy[i])
#		d_moy_poutes[i,t+1]=exp(L_d_moy_poutes[i,t+1])#d_moy_vichy=d_wild_moy_vichy car projection sans repeuplement
#		juv_poutes[i,t+1]=d_moy_poutes[i,t+1]*S_juv_JP[4,t+1]
		
		L_mu_d_wild_temp_poutes[i,t+1]=log((S_poutes[i,t]/S_juv_JP[4,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_poutes[i,t]/S_juv_JP[4,t]))) + bugs_nu_d[i,4]
		if(I_juv_moy[t+1,4]==1){
			L_mu_d_juv_temp_poutes[i,t+1]=log( (stock_juv_scenar[4,t+1]/S_juv_JP[4,t]) / ( bugs_alpha_dd_juv[i]  + bugs_beta_dd[i] * (stock_juv_scenar[4,t+1]/S_juv_JP[4,t]) ) ) + bugs_nu_d[i,4]
			p_Rmax_poutes[i,t+1]= exp(L_mu_d_wild_temp_poutes[i,t+1]) / ( exp(L_mu_d_wild_temp_poutes[i,t+1]) + exp(L_mu_d_juv_temp_poutes[i,t+1]))  
		}else{p_Rmax_poutes[i,t+1]=1}
		
		L_mu_d_wild_poutes[i,t+1]=log( (S_poutes[i,t]/S_juv_JP[4,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] / p_Rmax_poutes[i,t+1]* (S_poutes[i,t]/S_juv_JP[4,t]) )) + bugs_nu_d[i,4]
		L_d_moy_poutes[i,t+1]=rnorm(1,L_mu_d_wild_poutes[i,t+1],bugs_sigma_wild_moy[i])
		d_moy_w_poutes[i,t+1]=exp(L_d_moy_poutes[i,t+1])
		
		beta_temp_poutes[i,t+1] <-  1 / ( 1 + (bugs_a[i]/bugs_Rmax[i])*(S_poutes[i,t]/S_juv_JP[4,t]))
		#Pente de la relation SR des déversés corrigée d'un paramètre beta_temp qui correspond à l'impact des poissons sauvages déjà en place sur les poissons déversés
		alpha_dd_juv_temp_poutes[i,t+1]  <- 1/(bugs_a_juv[i] * beta_temp_poutes[i,t+1])
		if(I_juv_moy[t+1,4]==1){
			L_mu_d_juv_poutes[i,t+1]= log((stock_juv_scenar[4,t+1]/S_juv_JP[4,t]) / (alpha_dd_juv_temp_poutes[i,t+1] + bugs_beta_dd[i] / (1- p_Rmax_poutes[i,t+1]) * (stock_juv_scenar[4,t+1]/S_juv_JP[4,t]))) + bugs_nu_d[i,4]
			L_d_juv_moy_poutes[i,t+1]=rnorm(1,L_mu_d_juv_poutes[i,t+1],bugs_sigma_juv_moy[i])
			d_moy_juv_poutes[i,t+1]=exp(L_d_juv_moy_poutes[i,t+1])
		}else{d_moy_juv_poutes[i,t+1]=0}
		juv_poutes[i,t+1]=(d_moy_w_poutes[i,t+1]+d_moy_juv_poutes[i,t+1])*S_juv_JP[4,t+1]
		
		
	}
}

#Les juvéniles t-3 et t-4 sont maintenant ceux calculés à la fin des boucles précédentes et non plus ceux issus directement d'openbugs
for (t in (T+5):(T+5)){
	for (i in 1:5000){ 
		bugs_juv_tot_vichy[i,t] = (1/3) * juv_vichy[i,t-3] + (1/3) * juv_vichy[i,t-4] + (1/3) * bugs_juv_vichy[i,t-5] 
		bugs_juv_tot_alagnon[i,t] = (1/3) * juv_alagnon[i,t-3] + (1/3) * juv_alagnon[i,t-4] + (1/3) * bugs_juv_alagnon[i,t-5] 
		bugs_juv_tot_langeac[i,t] = (1/3) * juv_langeac[i,t-3] + (1/3) * juv_langeac[i,t-4] + (1/3) * bugs_juv_langeac[i,t-5] 
		bugs_juv_tot_poutes[i,t] = (1/3) * juv_poutes[i,t-3] + (1/3) * juv_poutes[i,t-4] + (1/3) * bugs_juv_poutes[i,t-5] 
		bugs_juv_tot_system[i,t] = bugs_juv_tot_vichy[i,t]+bugs_juv_tot_alagnon[i,t]+bugs_juv_tot_langeac[i,t] +bugs_juv_tot_poutes[i,t]#*bugs_rho_poutes[i]
		
		ratio_juv_prod_A[i,t] <- bugs_juv_tot_alagnon[i,t] / (bugs_juv_tot_vichy[i,t]+bugs_juv_tot_alagnon[i,t]+bugs_juv_tot_langeac[i,t]+bugs_juv_tot_poutes[i,t])#*bugs_rho_poutes[i])	
		ratio_juv_prod_L[i,t] <- (bugs_juv_tot_langeac[i,t]+bugs_juv_tot_poutes[i,t]) / (bugs_juv_tot_vichy[i,t]+bugs_juv_tot_langeac[i,t]+bugs_juv_tot_poutes[i,t])#*bugs_rho_poutes[i])	
		#ratio_juv_prod_V[i,t] <- 1-ratio_juv_prod_L[i,t]
		
		ratio_juv_A[i,t]<- bugs_rho_station[i]*(S_juv_JP[2,t]/(S_juv_JP[1,t]+S_juv_JP[2,t]+S_juv_JP[3,t]+S_juv_JP[4,t]))+(1-bugs_rho_station[i])*ratio_juv_prod_A[i,t]
		L_ratio_juv_A[i,t] <- logit(ratio_juv_A[i,t])
		L_mu_p_alagnon[i,t]<-L_ratio_juv_A[i,t]+bugs_adjust_p_A[i]
		L_p_alagnon[i,t]<-rnorm(1,L_mu_p_alagnon[i,t],bugs_sigma_p_alagnon[i]) 
		res_p_alagnon[i,t] <- L_p_alagnon[i,t]-L_mu_p_alagnon[i,t]
		
		ratio_juv_L[i,t]<- bugs_rho_station[i]*((S_juv_JP[3,t]+S_juv_JP[4,t])/(S_juv_JP[1,t]+S_juv_JP[3,t]+S_juv_JP[4,t]))+(1-bugs_rho_station[i])*ratio_juv_prod_L[i,t]
		L_ratio_juv_L[i,t] <- logit(ratio_juv_L[i,t])
		L_mu_p_langeac[i,t]<-L_ratio_juv_L[i,t]+bugs_adjust_p_L[i]
		L_p_langeac[i,t]<-rnorm(1,L_mu_p_langeac[i,t],bugs_sigma_p_langeac[i]) 
		res_p_langeac[i,t] <- L_p_langeac[i,t]-L_mu_p_langeac[i,t]
		
		ratio_juv_prod_P[i,t] <-  bugs_juv_tot_poutes[i,t]/(bugs_juv_tot_langeac[i,t]+bugs_juv_tot_poutes[i,t])#*bugs_rho_poutes[i])
		ratio_juv_P[i,t]<- bugs_rho_station[i]*(S_juv_JP[4,t]/(S_juv_JP[3,t]+S_juv_JP[4,t]))+(1-bugs_rho_station[i])*ratio_juv_prod_P[i,t]
		L_ratio_juv_P[i,t] <- logit(ratio_juv_P[i,t])
		L_mu_p_poutes[i,t]<-L_ratio_juv_P[i,t]+bugs_adjust_p_P[i] 
		L_p_poutes[i,t]<-rnorm(1,L_mu_p_poutes[i,t],bugs_sigma_p_poutes[i]) 
		res_p_poutes[i,t] <- L_p_poutes[i,t]-L_mu_p_poutes[i,t]
		
		L_mu_Vichy_nm[i,t]<- log(bugs_s_juv2ad[i]*bugs_juv_tot_system[i,t]) 
		N_vichy[i,t]<-rlnorm(1,L_mu_Vichy_nm[i,t],bugs_sigma_vichy[i])
		if (N_vichy[i,t]<3) {N_vichy[i,t]=3}
		if (N_vichy[i,t]>30000) {N_vichy[i,t]=30000}#I(3,30000)
		res_vichy[i,t] <- log(N_vichy[i,t])-L_mu_Vichy_nm[i,t]
		
		p_alagnon[i,t]=inv.logit(L_p_alagnon[i,t])	
		p_langeac[i,t]=inv.logit(L_p_langeac[i,t])	
		p_poutes[i,t]=inv.logit(L_p_poutes[i,t])	
		#N_alagnon[i,t]=rbinom(1,round(N_vichy[i,t],0),p_alagnon[i,t])#On prend N_vichy_corrTrans au lieu de N_vichy puisqu'on a prélevé 15% des poissons à Vichy
		#N_langeac[i,t]=rbinom(1,round(N_vichy[i,t]-N_alagnon[i,t],0),p_langeac[i,t])#On prend N_vichy_corrTrans au lieu de N_vichy puisqu'on a prélevé 15% des poissons à Vichy
		N_alagnon[i,t]=rbinom(1,ifelse(N_vichy[i,t]-S_stocking_simulation[t-(t-1)]<0,1,round(N_vichy[i,t]-S_stocking_simulation[t-(t-1)],0)),p_alagnon[i,t])
		N_langeac[i,t]=rbinom(1,ifelse(N_vichy[i,t]-N_alagnon[i,t]-S_stocking_simulation[t-(t-1)]<0,1,round(N_vichy[i,t]-N_alagnon[i,t]-S_stocking_simulation[t-(t-1)],0)),p_langeac[i,t])
		N_poutes[i,t]=rbinom(1,round(N_langeac[i,t],0),p_poutes[i,t])
		min_N_langeac[i,t]<-N_poutes[i,t]+1
		if(N_langeac[i,t]<min_N_langeac[i,t]){N_langeac[i,t]=min_N_langeac[i,t]}
				
		S_poutes[i,t]=max(N_poutes[i,t],1)
		S_langeac[i,t]=max(N_langeac[i,t]-N_poutes[i,t],1)
		S_alagnon[i,t]=max(N_alagnon[i,t],1)
		#S_vichy[i,t]= max(N_vichy[i,t]-N_alagnon[i,t]-N_langeac[i,t],1)
		S_vichy[i,t]= max(N_vichy[i,t]-N_alagnon[i,t]-N_langeac[i,t]-S_stocking_simulation[t-(t-1)],1)
		
				#....................................................
		#Ce qu'on faisait dans le scénario sans déversement
#		L_mu_d_wild_vichy[i,t+1]=log( (S_vichy[i,t]/S_juv_JP[1,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_vichy[i,t]/S_juv_JP[1,t]) )) + bugs_nu_d[i,1]
#		L_d_moy_vichy[i,t+1]=rnorm(1,L_mu_d_wild_vichy[i,t+1],bugs_sigma_wild_moy[i])
#		d_moy_vichy[i,t+1]=exp(L_d_moy_vichy[i,t+1])#d_moy_vichy=d_wild_moy_vichy car projection sans repeuplement
#		juv_vichy[i,t+1]=d_moy_vichy[i,t+1]*S_juv_JP[1,t+1]
		
		
		#p_Rmax = proportion d'habitat pour les sauvages
		L_mu_d_wild_temp_vichy[i,t+1]=log((S_vichy[i,t]/S_juv_JP[1,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_vichy[i,t]/S_juv_JP[1,t]))) + bugs_nu_d[i,1]
		if(I_juv_moy[t+1,1]==1){
			L_mu_d_juv_temp_vichy[i,t+1]=log( (stock_juv_scenar[1,t+1]/S_juv_JP[1,t]) / ( bugs_alpha_dd_juv[i]  + bugs_beta_dd[i] * (stock_juv_scenar[1,t+1]/S_juv_JP[1,t]) ) ) + bugs_nu_d[i,1]
			p_Rmax_vichy[i,t+1]= exp(L_mu_d_wild_temp_vichy[i,t+1]) / ( exp(L_mu_d_wild_temp_vichy[i,t+1]) + exp(L_mu_d_juv_temp_vichy[i,t+1]))  
		}else{p_Rmax_vichy[i,t+1]=1}
		
		L_mu_d_wild_vichy[i,t+1]=log( (S_vichy[i,t]/S_juv_JP[1,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] / p_Rmax_vichy[i,t+1]* (S_vichy[i,t]/S_juv_JP[1,t]) )) + bugs_nu_d[i,1]
		L_d_moy_vichy[i,t+1]=rnorm(1,L_mu_d_wild_vichy[i,t+1],bugs_sigma_wild_moy[i])
		d_moy_w_vichy[i,t+1]=exp(L_d_moy_vichy[i,t+1])#d_moy_vichy=d_wild_moy_vichy car projection sans repeuplement
		
		beta_temp_vichy[i,t+1] <-  1 / ( 1 + (bugs_a[i]/bugs_Rmax[i])*(S_vichy[i,t]/S_juv_JP[1,t]))
		#Pente de la relation SR des déversés corrigée d'un paramètre beta_temp qui correspond à l'impact des poissons sauvages déjà en place sur les poissons déversés
		alpha_dd_juv_temp_vichy[i,t+1]  <- 1/(bugs_a_juv[i] * beta_temp_vichy[i,t+1])
		if(I_juv_moy[t+1,1]==1){
			L_mu_d_juv_vichy[i,t+1]= log((stock_juv_scenar[1,t+1]/S_juv_JP[1,t]) / (alpha_dd_juv_temp_vichy[i,t+1] + bugs_beta_dd[i] / (1- p_Rmax_vichy[i,t+1]) * (stock_juv_scenar[1,t+1]/S_juv_JP[1,t]))) + bugs_nu_d[i,1]
			L_d_juv_moy_vichy[i,t+1]=rnorm(1,L_mu_d_juv_vichy[i,t+1],bugs_sigma_juv_moy[i])
			d_moy_juv_vichy[i,t+1]=exp(L_d_juv_moy_vichy[i,t+1])
		}else{d_moy_juv_vichy[i,t+1]=0}
		juv_vichy[i,t+1]=(d_moy_w_vichy[i,t+1]+d_moy_juv_vichy[i,t+1])*S_juv_JP[1,t+1]
		
#		L_mu_d_wild_alagnon[i,t+1]=log( (S_alagnon[i,t]/S_juv_JP[2,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_alagnon[i,t]/S_juv_JP[2,t]) )) + bugs_nu_d[i,2]
#		L_d_moy_alagnon[i,t+1]=rnorm(1,L_mu_d_wild_alagnon[i,t+1],bugs_sigma_wild_moy[i])
#		d_moy_alagnon[i,t+1]=exp(L_d_moy_alagnon[i,t+1])#d_moy_vichy=d_wild_moy_vichy car projection sans repeuplement
#		juv_alagnon[i,t+1]=d_moy_alagnon[i,t+1]*S_juv_JP[2,t+1]
	
		L_mu_d_wild_temp_alagnon[i,t+1]=log((S_alagnon[i,t]/S_juv_JP[2,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_alagnon[i,t]/S_juv_JP[2,t]))) + bugs_nu_d[i,2]
		if(I_juv_moy[t+1,2]==1){
			L_mu_d_juv_temp_alagnon[i,t+1]=log( (stock_juv_scenar[2,t+1]/S_juv_JP[2,t]) / ( bugs_alpha_dd_juv[i]  + bugs_beta_dd[i] * (stock_juv_scenar[2,t+1]/S_juv_JP[2,t]) ) ) + bugs_nu_d[i,2]
			p_Rmax_alagnon[i,t+1]= exp(L_mu_d_wild_temp_alagnon[i,t+1]) / ( exp(L_mu_d_wild_temp_alagnon[i,t+1]) + exp(L_mu_d_juv_temp_alagnon[i,t+1]))  
		}else{p_Rmax_alagnon[i,t+1]=1}
		
		L_mu_d_wild_alagnon[i,t+1]=log( (S_alagnon[i,t]/S_juv_JP[2,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] / p_Rmax_alagnon[i,t+1]* (S_alagnon[i,t]/S_juv_JP[2,t]) )) + bugs_nu_d[i,2]
		L_d_moy_alagnon[i,t+1]=rnorm(1,L_mu_d_wild_alagnon[i,t+1],bugs_sigma_wild_moy[i])
		d_moy_w_alagnon[i,t+1]=exp(L_d_moy_alagnon[i,t+1])#d_moy_vichy=d_wild_moy_vichy car projection sans repeuplement
		
		beta_temp_alagnon[i,t+1] <-  1 / ( 1 + (bugs_a[i]/bugs_Rmax[i])*(S_alagnon[i,t]/S_juv_JP[2,t]))
		#Pente de la relation SR des déversés corrigée d'un paramètre beta_temp qui correspond à l'impact des poissons sauvages déjà en place sur les poissons déversés
		alpha_dd_juv_temp_alagnon[i,t+1]  <- 1/(bugs_a_juv[i] * beta_temp_alagnon[i,t+1])
		if(I_juv_moy[t+1,2]==1){
			L_mu_d_juv_alagnon[i,t+1]= log((stock_juv_scenar[2,t+1]/S_juv_JP[2,t]) / (alpha_dd_juv_temp_alagnon[i,t+1] + bugs_beta_dd[i] / (1- p_Rmax_alagnon[i,t+1]) * (stock_juv_scenar[2,t+1]/S_juv_JP[2,t]))) + bugs_nu_d[i,2]
			L_d_juv_moy_alagnon[i,t+1]=rnorm(1,L_mu_d_juv_alagnon[i,t+1],bugs_sigma_juv_moy[i])
			d_moy_juv_alagnon[i,t+1]=exp(L_d_juv_moy_alagnon[i,t+1])
		}else{d_moy_juv_alagnon[i,t+1]=0}
		juv_alagnon[i,t+1]=(d_moy_w_alagnon[i,t+1]+d_moy_juv_alagnon[i,t+1])*S_juv_JP[2,t+1]
		
#		L_mu_d_wild_langeac[i,t+1]=log( (S_langeac[i,t]/S_juv_JP[3,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_langeac[i,t]/S_juv_JP[3,t]) )) + bugs_nu_d[i,3]
#		L_d_moy_langeac[i,t+1]=rnorm(1,L_mu_d_wild_langeac[i,t+1],bugs_sigma_wild_moy[i])
#		d_moy_langeac[i,t+1]=exp(L_d_moy_langeac[i,t+1])#d_moy_vichy=d_wild_moy_vichy car projection sans repeuplement
#		juv_langeac[i,t+1]=d_moy_langeac[i,t+1]*S_juv_JP[3,t+1]

		L_mu_d_wild_temp_langeac[i,t+1]=log((S_langeac[i,t]/S_juv_JP[3,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_langeac[i,t]/S_juv_JP[3,t]))) + bugs_nu_d[i,3]
		if(I_juv_moy[t+1,3]==1){
			L_mu_d_juv_temp_langeac[i,t+1]=log( (stock_juv_scenar[3,t+1]/S_juv_JP[3,t]) / ( bugs_alpha_dd_juv[i]  + bugs_beta_dd[i] * (stock_juv_scenar[3,t+1]/S_juv_JP[3,t]) ) ) + bugs_nu_d[i,3]
			p_Rmax_langeac[i,t+1]= exp(L_mu_d_wild_temp_langeac[i,t+1]) / ( exp(L_mu_d_wild_temp_langeac[i,t+1]) + exp(L_mu_d_juv_temp_langeac[i,t+1]))  	
		}else{p_Rmax_langeac[i,t+1]=1}
		
		L_mu_d_wild_langeac[i,t+1]=log( (S_langeac[i,t]/S_juv_JP[3,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] / p_Rmax_langeac[i,t+1]* (S_langeac[i,t]/S_juv_JP[3,t]) )) + bugs_nu_d[i,3]
		L_d_moy_langeac[i,t+1]=rnorm(1,L_mu_d_wild_langeac[i,t+1],bugs_sigma_wild_moy[i])
		d_moy_w_langeac[i,t+1]=exp(L_d_moy_langeac[i,t+1])
		
		beta_temp_langeac[i,t+1] <-  1 / ( 1 + (bugs_a[i]/bugs_Rmax[i])*(S_langeac[i,t]/S_juv_JP[3,t]))
		#Pente de la relation SR des déversés corrigée d'un paramètre beta_temp qui correspond à l'impact des poissons sauvages déjà en place sur les poissons déversés
		alpha_dd_juv_temp_langeac[i,t+1]  <- 1/(bugs_a_juv[i] * beta_temp_langeac[i,t+1])
		if(I_juv_moy[t+1,3]==1){
			L_mu_d_juv_langeac[i,t+1]= log((stock_juv_scenar[3,t+1]/S_juv_JP[3,t]) / (alpha_dd_juv_temp_langeac[i,t+1] + bugs_beta_dd[i] / (1- p_Rmax_langeac[i,t+1]) * (stock_juv_scenar[3,t+1]/S_juv_JP[3,t]))) + bugs_nu_d[i,3]
			L_d_juv_moy_langeac[i,t+1]=rnorm(1,L_mu_d_juv_langeac[i,t+1],bugs_sigma_juv_moy[i])
			d_moy_juv_langeac[i,t+1]=exp(L_d_juv_moy_langeac[i,t+1])
		}else{d_moy_juv_langeac[i,t+1]=0}
		juv_langeac[i,t+1]=(d_moy_w_langeac[i,t+1]+d_moy_juv_langeac[i,t+1])*S_juv_JP[3,t+1]

		
#		L_mu_d_wild_poutes[i,t+1]=log( (S_poutes[i,t]/S_juv_JP[4,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_poutes[i,t]/S_juv_JP[4,t]) )) + bugs_nu_d[i,4]
#		L_d_moy_poutes[i,t+1]=rnorm(1,L_mu_d_wild_poutes[i,t+1],bugs_sigma_wild_moy[i])
#		d_moy_poutes[i,t+1]=exp(L_d_moy_poutes[i,t+1])#d_moy_vichy=d_wild_moy_vichy car projection sans repeuplement
#		juv_poutes[i,t+1]=d_moy_poutes[i,t+1]*S_juv_JP[4,t+1]
		
		L_mu_d_wild_temp_poutes[i,t+1]=log((S_poutes[i,t]/S_juv_JP[4,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_poutes[i,t]/S_juv_JP[4,t]))) + bugs_nu_d[i,4]
		if(I_juv_moy[t+1,4]==1){
			L_mu_d_juv_temp_poutes[i,t+1]=log( (stock_juv_scenar[4,t+1]/S_juv_JP[4,t]) / ( bugs_alpha_dd_juv[i]  + bugs_beta_dd[i] * (stock_juv_scenar[4,t+1]/S_juv_JP[4,t]) ) ) + bugs_nu_d[i,4]
			p_Rmax_poutes[i,t+1]= exp(L_mu_d_wild_temp_poutes[i,t+1]) / ( exp(L_mu_d_wild_temp_poutes[i,t+1]) + exp(L_mu_d_juv_temp_poutes[i,t+1]))  
		}else{p_Rmax_poutes[i,t+1]=1}
		
		L_mu_d_wild_poutes[i,t+1]=log( (S_poutes[i,t]/S_juv_JP[4,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] / p_Rmax_poutes[i,t+1]* (S_poutes[i,t]/S_juv_JP[4,t]) )) + bugs_nu_d[i,4]
		L_d_moy_poutes[i,t+1]=rnorm(1,L_mu_d_wild_poutes[i,t+1],bugs_sigma_wild_moy[i])
		d_moy_w_poutes[i,t+1]=exp(L_d_moy_poutes[i,t+1])
		
		beta_temp_poutes[i,t+1] <-  1 / ( 1 + (bugs_a[i]/bugs_Rmax[i])*(S_poutes[i,t]/S_juv_JP[4,t]))
		#Pente de la relation SR des déversés corrigée d'un paramètre beta_temp qui correspond à l'impact des poissons sauvages déjà en place sur les poissons déversés
		alpha_dd_juv_temp_poutes[i,t+1]  <- 1/(bugs_a_juv[i] * beta_temp_poutes[i,t+1])
		if(I_juv_moy[t+1,4]==1){
			L_mu_d_juv_poutes[i,t+1]= log((stock_juv_scenar[4,t+1]/S_juv_JP[4,t]) / (alpha_dd_juv_temp_poutes[i,t+1] + bugs_beta_dd[i] / (1- p_Rmax_poutes[i,t+1]) * (stock_juv_scenar[4,t+1]/S_juv_JP[4,t]))) + bugs_nu_d[i,4]
			L_d_juv_moy_poutes[i,t+1]=rnorm(1,L_mu_d_juv_poutes[i,t+1],bugs_sigma_juv_moy[i])
			d_moy_juv_poutes[i,t+1]=exp(L_d_juv_moy_poutes[i,t+1])
		}else{d_moy_juv_poutes[i,t+1]=0}
		juv_poutes[i,t+1]=(d_moy_w_poutes[i,t+1]+d_moy_juv_poutes[i,t+1])*S_juv_JP[4,t+1]

		
	}
}

#Les juvéniles t-3 et t-4 t-5 sont maintenant ceux calculés à la fin des boucles précédentes et non plus ceux issus directement d'openbugs
#On va jusqu'à T+21 pour pouvoir calculer renew_rate sur 20 ans (sinon manque une année car on a besoin de faire N_vichy[T+21]
for (t in (T+6):(T+25)){
	for (i in 1:5000){ 
		#Les juvéniles qui donnent les adultes de retour
		juv_tot_vichy[i,t] = (1/3) * juv_vichy[i,t-3] + (1/3) * juv_vichy[i,t-4] + (1/3) * juv_vichy[i,t-5] 
		juv_tot_alagnon[i,t] = (1/3) * juv_alagnon[i,t-3] + (1/3) * juv_alagnon[i,t-4] + (1/3) * juv_alagnon[i,t-5] 
		juv_tot_langeac[i,t] = (1/3) * juv_langeac[i,t-3] + (1/3) * juv_langeac[i,t-4] + (1/3) * juv_langeac[i,t-5] 
		juv_tot_poutes[i,t] = (1/3) * juv_poutes[i,t-3] + (1/3) * juv_poutes[i,t-4] + (1/3) * juv_poutes[i,t-5] 
		juv_tot_system[i,t] = juv_tot_vichy[i,t]+juv_tot_alagnon[i,t]+juv_tot_langeac[i,t] +juv_tot_poutes[i,t]#*bugs_rho_poutes[i]
		
		ratio_juv_prod_A[i,t] <- juv_tot_alagnon[i,t] / (juv_tot_vichy[i,t]+juv_tot_alagnon[i,t]+juv_tot_langeac[i,t]+juv_tot_poutes[i,t])#*bugs_rho_poutes[i])	
		ratio_juv_prod_L[i,t] <- (juv_tot_langeac[i,t]+juv_tot_poutes[i,t]) / (juv_tot_vichy[i,t]+juv_tot_langeac[i,t]+juv_tot_poutes[i,t])#*bugs_rho_poutes[i])	
		#ratio_juv_prod_V[i,t] <- 1-ratio_juv_prod_L[i,t]
		
		ratio_juv_A[i,t]<- bugs_rho_station[i]*(S_juv_JP[2,t]/(S_juv_JP[1,t]+S_juv_JP[2,t]+S_juv_JP[3,t]+S_juv_JP[4,t]))+(1-bugs_rho_station[i])*ratio_juv_prod_A[i,t]
		L_ratio_juv_A[i,t] <- logit(ratio_juv_A[i,t])
		L_mu_p_alagnon[i,t]<-L_ratio_juv_A[i,t]+bugs_adjust_p_A[i]
		L_p_alagnon[i,t]<-rnorm(1,L_mu_p_alagnon[i,t],bugs_sigma_p_alagnon[i]) 
		res_p_alagnon[i,t] <- L_p_alagnon[i,t]-L_mu_p_alagnon[i,t]
		
		ratio_juv_L[i,t]<- bugs_rho_station[i]*((S_juv_JP[3,t]+S_juv_JP[4,t])/(S_juv_JP[1,t]+S_juv_JP[3,t]+S_juv_JP[4,t]))+(1-bugs_rho_station[i])*ratio_juv_prod_L[i,t]
		L_ratio_juv_L[i,t] <- logit(ratio_juv_L[i,t])
		L_mu_p_langeac[i,t]<-L_ratio_juv_L[i,t]+bugs_adjust_p_L[i]
		L_p_langeac[i,t]<-rnorm(1,L_mu_p_langeac[i,t],bugs_sigma_p_langeac[i]) 
		res_p_langeac[i,t] <- L_p_langeac[i,t]-L_mu_p_langeac[i,t]
		
		ratio_juv_prod_P[i,t] <-  juv_tot_poutes[i,t]/(juv_tot_langeac[i,t]+juv_tot_poutes[i,t])#*bugs_rho_poutes[i])
		ratio_juv_P[i,t]<- bugs_rho_station[i]*(S_juv_JP[4,t]/(S_juv_JP[3,t]+S_juv_JP[4,t]))+(1-bugs_rho_station[i])*ratio_juv_prod_P[i,t]
		L_ratio_juv_P[i,t] <- logit(ratio_juv_P[i,t])
		L_mu_p_poutes[i,t]<-L_ratio_juv_P[i,t]+bugs_adjust_p_P[i] 
		L_p_poutes[i,t]<-rnorm(1,L_mu_p_poutes[i,t],bugs_sigma_p_poutes[i]) 
		res_p_poutes[i,t] <- L_p_poutes[i,t]-L_mu_p_poutes[i,t]
		
		L_mu_Vichy_nm[i,t]<- log(bugs_s_juv2ad[i]*juv_tot_system[i,t]) 
		N_vichy[i,t]<-rlnorm(1,L_mu_Vichy_nm[i,t],bugs_sigma_vichy[i])
		if (N_vichy[i,t]<3) {N_vichy[i,t]=3}
		if (N_vichy[i,t]>30000) {N_vichy[i,t]=30000}#I(3,30000)
		res_vichy[i,t] <- log(N_vichy[i,t])-L_mu_Vichy_nm[i,t]
		
		p_alagnon[i,t]=inv.logit(L_p_alagnon[i,t])	
		p_langeac[i,t]=inv.logit(L_p_langeac[i,t])	
		p_poutes[i,t]=inv.logit(L_p_poutes[i,t])	
		#N_alagnon[i,t]=rbinom(1,round(N_vichy[i,t],0),p_alagnon[i,t])#On prend N_vichy_corrTrans au lieu de N_vichy puisqu'on a prélevé 15% des poissons à Vichy
		#N_langeac[i,t]=rbinom(1,round(N_vichy[i,t]-N_alagnon[i,t],0),p_langeac[i,t])#On prend N_vichy_corrTrans au lieu de N_vichy puisqu'on a prélevé 15% des poissons à VichyN_poutes[i,t]=rbinom(1,round(N_langeac[i,t],0),p_poutes[i,t])
		N_alagnon[i,t]=rbinom(1,ifelse(N_vichy[i,t]-S_stocking_simulation[t-(t-1)]<0,1,round(N_vichy[i,t]-S_stocking_simulation[t-(t-1)],0)),p_alagnon[i,t])
		N_langeac[i,t]=rbinom(1,ifelse(N_vichy[i,t]-N_alagnon[i,t]-S_stocking_simulation[t-(t-1)]<0,1,round(N_vichy[i,t]-N_alagnon[i,t]-S_stocking_simulation[t-(t-1)],0)),p_langeac[i,t])
		N_poutes[i,t]=rbinom(1,round(N_langeac[i,t],0),p_poutes[i,t])
		min_N_langeac[i,t]<-N_poutes[i,t]+1
		if(N_langeac[i,t]<min_N_langeac[i,t]){N_langeac[i,t]=min_N_langeac[i,t]}
		
		S_poutes[i,t]=max(N_poutes[i,t],1)
		S_langeac[i,t]=max(N_langeac[i,t]-N_poutes[i,t],1)
		S_alagnon[i,t]=max(N_alagnon[i,t],1)
		#S_vichy[i,t]= max(N_vichy[i,t]-N_alagnon[i,t]-N_langeac[i,t],1)
		S_vichy[i,t]= max(N_vichy[i,t]-N_alagnon[i,t]-N_langeac[i,t]-S_stocking_simulation[t-(t-1)],1)
		
		#....................................................
		#Ce qu'on faisait dans le scénario sans déversement
#		L_mu_d_wild_vichy[i,t+1]=log( (S_vichy[i,t]/S_juv_JP[1,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_vichy[i,t]/S_juv_JP[1,t]) )) + bugs_nu_d[i,1]
#		L_d_moy_vichy[i,t+1]=rnorm(1,L_mu_d_wild_vichy[i,t+1],bugs_sigma_wild_moy[i])
#		d_moy_vichy[i,t+1]=exp(L_d_moy_vichy[i,t+1])#d_moy_vichy=d_wild_moy_vichy car projection sans repeuplement
#		juv_vichy[i,t+1]=d_moy_vichy[i,t+1]*S_juv_JP[1,t+1]
		
		
		#p_Rmax = proportion d'habitat pour les sauvages
		L_mu_d_wild_temp_vichy[i,t+1]=log((S_vichy[i,t]/S_juv_JP[1,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_vichy[i,t]/S_juv_JP[1,t]))) + bugs_nu_d[i,1]
		if(I_juv_moy[t+1,1]==1){
			L_mu_d_juv_temp_vichy[i,t+1]=log( (stock_juv_scenar[1,t+1]/S_juv_JP[1,t]) / ( bugs_alpha_dd_juv[i]  + bugs_beta_dd[i] * (stock_juv_scenar[1,t+1]/S_juv_JP[1,t]) ) ) + bugs_nu_d[i,1]
			p_Rmax_vichy[i,t+1]= exp(L_mu_d_wild_temp_vichy[i,t+1]) / ( exp(L_mu_d_wild_temp_vichy[i,t+1]) + exp(L_mu_d_juv_temp_vichy[i,t+1]))  
		}else{p_Rmax_vichy[i,t+1]=1}
		
		L_mu_d_wild_vichy[i,t+1]=log( (S_vichy[i,t]/S_juv_JP[1,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] / p_Rmax_vichy[i,t+1]* (S_vichy[i,t]/S_juv_JP[1,t]) )) + bugs_nu_d[i,1]
		L_d_moy_vichy[i,t+1]=rnorm(1,L_mu_d_wild_vichy[i,t+1],bugs_sigma_wild_moy[i])
		d_moy_w_vichy[i,t+1]=exp(L_d_moy_vichy[i,t+1])#d_moy_vichy=d_wild_moy_vichy car projection sans repeuplement
		
		beta_temp_vichy[i,t+1] <-  1 / ( 1 + (bugs_a[i]/bugs_Rmax[i])*(S_vichy[i,t]/S_juv_JP[1,t]))
		#Pente de la relation SR des déversés corrigée d'un paramètre beta_temp qui correspond à l'impact des poissons sauvages déjà en place sur les poissons déversés
		alpha_dd_juv_temp_vichy[i,t+1]  <- 1/(bugs_a_juv[i] * beta_temp_vichy[i,t+1])
		if(I_juv_moy[t+1,1]==1){
			L_mu_d_juv_vichy[i,t+1]= log((stock_juv_scenar[1,t+1]/S_juv_JP[1,t]) / (alpha_dd_juv_temp_vichy[i,t+1] + bugs_beta_dd[i] / (1- p_Rmax_vichy[i,t+1]) * (stock_juv_scenar[1,t+1]/S_juv_JP[1,t]))) + bugs_nu_d[i,1]
			L_d_juv_moy_vichy[i,t+1]=rnorm(1,L_mu_d_juv_vichy[i,t+1],bugs_sigma_juv_moy[i])
			d_moy_juv_vichy[i,t+1]=exp(L_d_juv_moy_vichy[i,t+1])
		}else{d_moy_juv_vichy[i,t+1]=0}
		juv_vichy[i,t+1]=(d_moy_w_vichy[i,t+1]+d_moy_juv_vichy[i,t+1])*S_juv_JP[1,t+1]
		
#		L_mu_d_wild_alagnon[i,t+1]=log( (S_alagnon[i,t]/S_juv_JP[2,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_alagnon[i,t]/S_juv_JP[2,t]) )) + bugs_nu_d[i,2]
#		L_d_moy_alagnon[i,t+1]=rnorm(1,L_mu_d_wild_alagnon[i,t+1],bugs_sigma_wild_moy[i])
#		d_moy_alagnon[i,t+1]=exp(L_d_moy_alagnon[i,t+1])#d_moy_vichy=d_wild_moy_vichy car projection sans repeuplement
#		juv_alagnon[i,t+1]=d_moy_alagnon[i,t+1]*S_juv_JP[2,t+1]
	
		L_mu_d_wild_temp_alagnon[i,t+1]=log((S_alagnon[i,t]/S_juv_JP[2,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_alagnon[i,t]/S_juv_JP[2,t]))) + bugs_nu_d[i,2]
		if(I_juv_moy[t+1,2]==1){
			L_mu_d_juv_temp_alagnon[i,t+1]=log( (stock_juv_scenar[2,t+1]/S_juv_JP[2,t]) / ( bugs_alpha_dd_juv[i]  + bugs_beta_dd[i] * (stock_juv_scenar[2,t+1]/S_juv_JP[2,t]) ) ) + bugs_nu_d[i,2]
			p_Rmax_alagnon[i,t+1]= exp(L_mu_d_wild_temp_alagnon[i,t+1]) / ( exp(L_mu_d_wild_temp_alagnon[i,t+1]) + exp(L_mu_d_juv_temp_alagnon[i,t+1]))  
		}else{p_Rmax_alagnon[i,t+1]=1}
		
		L_mu_d_wild_alagnon[i,t+1]=log( (S_alagnon[i,t]/S_juv_JP[2,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] / p_Rmax_alagnon[i,t+1]* (S_alagnon[i,t]/S_juv_JP[2,t]) )) + bugs_nu_d[i,2]
		L_d_moy_alagnon[i,t+1]=rnorm(1,L_mu_d_wild_alagnon[i,t+1],bugs_sigma_wild_moy[i])
		d_moy_w_alagnon[i,t+1]=exp(L_d_moy_alagnon[i,t+1])#d_moy_vichy=d_wild_moy_vichy car projection sans repeuplement
		
		beta_temp_alagnon[i,t+1] <-  1 / ( 1 + (bugs_a[i]/bugs_Rmax[i])*(S_alagnon[i,t]/S_juv_JP[2,t]))
		#Pente de la relation SR des déversés corrigée d'un paramètre beta_temp qui correspond à l'impact des poissons sauvages déjà en place sur les poissons déversés
		alpha_dd_juv_temp_alagnon[i,t+1]  <- 1/(bugs_a_juv[i] * beta_temp_alagnon[i,t+1])
		if(I_juv_moy[t+1,2]==1){
			L_mu_d_juv_alagnon[i,t+1]= log((stock_juv_scenar[2,t+1]/S_juv_JP[2,t]) / (alpha_dd_juv_temp_alagnon[i,t+1] + bugs_beta_dd[i] / (1- p_Rmax_alagnon[i,t+1]) * (stock_juv_scenar[2,t+1]/S_juv_JP[2,t]))) + bugs_nu_d[i,2]
			L_d_juv_moy_alagnon[i,t+1]=rnorm(1,L_mu_d_juv_alagnon[i,t+1],bugs_sigma_juv_moy[i])
			d_moy_juv_alagnon[i,t+1]=exp(L_d_juv_moy_alagnon[i,t+1])
		}else{d_moy_juv_alagnon[i,t+1]=0}
		juv_alagnon[i,t+1]=(d_moy_w_alagnon[i,t+1]+d_moy_juv_alagnon[i,t+1])*S_juv_JP[2,t+1]
		
#		L_mu_d_wild_langeac[i,t+1]=log( (S_langeac[i,t]/S_juv_JP[3,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_langeac[i,t]/S_juv_JP[3,t]) )) + bugs_nu_d[i,3]
#		L_d_moy_langeac[i,t+1]=rnorm(1,L_mu_d_wild_langeac[i,t+1],bugs_sigma_wild_moy[i])
#		d_moy_langeac[i,t+1]=exp(L_d_moy_langeac[i,t+1])#d_moy_vichy=d_wild_moy_vichy car projection sans repeuplement
#		juv_langeac[i,t+1]=d_moy_langeac[i,t+1]*S_juv_JP[3,t+1]

		L_mu_d_wild_temp_langeac[i,t+1]=log((S_langeac[i,t]/S_juv_JP[3,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_langeac[i,t]/S_juv_JP[3,t]))) + bugs_nu_d[i,3]
		if(I_juv_moy[t+1,3]==1){
			L_mu_d_juv_temp_langeac[i,t+1]=log( (stock_juv_scenar[3,t+1]/S_juv_JP[3,t]) / ( bugs_alpha_dd_juv[i]  + bugs_beta_dd[i] * (stock_juv_scenar[3,t+1]/S_juv_JP[3,t]) ) ) + bugs_nu_d[i,3]
			p_Rmax_langeac[i,t+1]= exp(L_mu_d_wild_temp_langeac[i,t+1]) / ( exp(L_mu_d_wild_temp_langeac[i,t+1]) + exp(L_mu_d_juv_temp_langeac[i,t+1]))  
		}else{p_Rmax_langeac[i,t+1]=1}
		
		L_mu_d_wild_langeac[i,t+1]=log( (S_langeac[i,t]/S_juv_JP[3,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] / p_Rmax_langeac[i,t+1]* (S_langeac[i,t]/S_juv_JP[3,t]) )) + bugs_nu_d[i,3]
		L_d_moy_langeac[i,t+1]=rnorm(1,L_mu_d_wild_langeac[i,t+1],bugs_sigma_wild_moy[i])
		d_moy_w_langeac[i,t+1]=exp(L_d_moy_langeac[i,t+1])
		
		beta_temp_langeac[i,t+1] <-  1 / ( 1 + (bugs_a[i]/bugs_Rmax[i])*(S_langeac[i,t]/S_juv_JP[3,t]))
		#Pente de la relation SR des déversés corrigée d'un paramètre beta_temp qui correspond à l'impact des poissons sauvages déjà en place sur les poissons déversés
		alpha_dd_juv_temp_langeac[i,t+1]  <- 1/(bugs_a_juv[i] * beta_temp_langeac[i,t+1])
		if(I_juv_moy[t+1,3]==1){
			L_mu_d_juv_langeac[i,t+1]= log((stock_juv_scenar[3,t+1]/S_juv_JP[3,t]) / (alpha_dd_juv_temp_langeac[i,t+1] + bugs_beta_dd[i] / (1- p_Rmax_langeac[i,t+1]) * (stock_juv_scenar[3,t+1]/S_juv_JP[3,t]))) + bugs_nu_d[i,3]
			L_d_juv_moy_langeac[i,t+1]=rnorm(1,L_mu_d_juv_langeac[i,t+1],bugs_sigma_juv_moy[i])
			d_moy_juv_langeac[i,t+1]=exp(L_d_juv_moy_langeac[i,t+1])
		}else{d_moy_juv_langeac[i,t+1]=0}
		juv_langeac[i,t+1]=(d_moy_w_langeac[i,t+1]+d_moy_juv_langeac[i,t+1])*S_juv_JP[3,t+1]

		
#		L_mu_d_wild_poutes[i,t+1]=log( (S_poutes[i,t]/S_juv_JP[4,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_poutes[i,t]/S_juv_JP[4,t]) )) + bugs_nu_d[i,4]
#		L_d_moy_poutes[i,t+1]=rnorm(1,L_mu_d_wild_poutes[i,t+1],bugs_sigma_wild_moy[i])
#		d_moy_poutes[i,t+1]=exp(L_d_moy_poutes[i,t+1])#d_moy_vichy=d_wild_moy_vichy car projection sans repeuplement
#		juv_poutes[i,t+1]=d_moy_poutes[i,t+1]*S_juv_JP[4,t+1]
		
		L_mu_d_wild_temp_poutes[i,t+1]=log((S_poutes[i,t]/S_juv_JP[4,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] * (S_poutes[i,t]/S_juv_JP[4,t]))) + bugs_nu_d[i,4]
		if(I_juv_moy[t+1,4]==1){
			L_mu_d_juv_temp_poutes[i,t+1]=log( (stock_juv_scenar[4,t+1]/S_juv_JP[4,t]) / ( bugs_alpha_dd_juv[i]  + bugs_beta_dd[i] * (stock_juv_scenar[4,t+1]/S_juv_JP[4,t]) ) ) + bugs_nu_d[i,4]
			p_Rmax_poutes[i,t+1]= exp(L_mu_d_wild_temp_poutes[i,t+1]) / ( exp(L_mu_d_wild_temp_poutes[i,t+1]) + exp(L_mu_d_juv_temp_poutes[i,t+1]))  
		}else{p_Rmax_poutes[i,t+1]=1}
		
		L_mu_d_wild_poutes[i,t+1]=log( (S_poutes[i,t]/S_juv_JP[4,t]) / (bugs_alpha_dd[i] + bugs_beta_dd[i] / p_Rmax_poutes[i,t+1]* (S_poutes[i,t]/S_juv_JP[4,t]) )) + bugs_nu_d[i,4]
		L_d_moy_poutes[i,t+1]=rnorm(1,L_mu_d_wild_poutes[i,t+1],bugs_sigma_wild_moy[i])
		d_moy_w_poutes[i,t+1]=exp(L_d_moy_poutes[i,t+1])
		
		beta_temp_poutes[i,t+1] <-  1 / ( 1 + (bugs_a[i]/bugs_Rmax[i])*(S_poutes[i,t]/S_juv_JP[4,t]))
		#Pente de la relation SR des déversés corrigée d'un paramètre beta_temp qui correspond à l'impact des poissons sauvages déjà en place sur les poissons déversés
		alpha_dd_juv_temp_poutes[i,t+1]  <- 1/(bugs_a_juv[i] * beta_temp_poutes[i,t+1])
		if(I_juv_moy[t+1,4]==1){
			L_mu_d_juv_poutes[i,t+1]= log((stock_juv_scenar[4,t+1]/S_juv_JP[4,t]) / (alpha_dd_juv_temp_poutes[i,t+1] + bugs_beta_dd[i] / (1- p_Rmax_poutes[i,t+1]) * (stock_juv_scenar[4,t+1]/S_juv_JP[4,t]))) + bugs_nu_d[i,4]
			L_d_juv_moy_poutes[i,t+1]=rnorm(1,L_mu_d_juv_poutes[i,t+1],bugs_sigma_juv_moy[i])
			d_moy_juv_poutes[i,t+1]=exp(L_d_juv_moy_poutes[i,t+1])
		}else{d_moy_juv_poutes[i,t+1]=0}
		juv_poutes[i,t+1]=(d_moy_w_poutes[i,t+1]+d_moy_juv_poutes[i,t+1])*S_juv_JP[4,t+1]

		
	}
}
