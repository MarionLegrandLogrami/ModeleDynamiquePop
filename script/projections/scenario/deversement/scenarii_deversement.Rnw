for(t in T:T){
	for (i in 1:5000){ 
		#Partie Taux Renouvellement
		#on calcule le coef pondérateur des juvéniles
		renew_rate[i,t-5]<-log((coef_juv_1[i,t]*data_vichy[t-1]+coef_juv_2[i,t]*data_vichy[t]+coef_juv_3[i,t]*N_vichy[i,t+1])/data_vichy[t-5])
	}
}
for(t in (T+1):(T+1)){
	for (i in 1:5000){ 
		#Partie Taux Renouvellement
		#on calcule le coef pondérateur des juvéniles
		renew_rate[i,t-5]<-log((coef_juv_1[i,t]*data_vichy[t-1]+coef_juv_2[i,t]*N_vichy[i,t]+coef_juv_3[i,t]*N_vichy[i,t+1])/data_vichy[t-5])
	}
}
for(t in (T+2):(T+5)){
	for (i in 1:5000){ 
		#Partie Taux Renouvellement
		#on calcule le coef pondérateur des juvéniles
		renew_rate[i,t-5]<-log((coef_juv_1[i,t]*N_vichy[i,t-1]+coef_juv_2[i,t]*N_vichy[i,t]+coef_juv_3[i,t]*N_vichy[i,t+1])/data_vichy[t-5])
	}
}
for(t in (T+6):(T+25)){
	for (i in 1:5000){ 
		#Partie Taux Renouvellement
		#on calcule le coef pondérateur des juvéniles
		renew_rate[i,t-5]<-log((coef_juv_1[i,t]*N_vichy[i,t-1]+coef_juv_2[i,t]*N_vichy[i,t]+coef_juv_3[i,t]*N_vichy[i,t+1])/N_vichy[i,t-5])
	}
}

for (t in (T+1):(T+20)){
	renew_rate_q[t,]=quantile(renew_rate[,t],probs=c(0.025,0.25,0.5,0.75,0.975),names=FALSE)
}

#Pour lisser sur 5 ans, il faut récupérer les taux de renouvellement de 
# 1974+(T+1)-8 à 1974+(T+1)-4 --> 1974+(T+1)-4= 1ere année calculée dans les projections donc on récupère jusqu'à 1974+(T+1)-5
#load(file=here::here("renew_rate_coef_tot_2019_12_12.Rdata"))
load(file=here::here("renew_rate_coef_tot_2021_09.Rdata"))

#On fusionne les jeux de données renew_rate et renew_rate_coef pour reconstituer toute la série
renew_rate_final<-cbind(renew_rate_coef[,1:(T-6)],renew_rate[,(T-5):(T+20)])


#--- Sortie et enregistrement du graph
source(here::here("script/fonctions/fct_graph.R"))
draw_indic_tx_ren(tx_renouv=renew_rate_final,simulation=TRUE,scenario="Transport 15% géniteurs Amont Poutès",typ_pop = "Totale",png=TRUE,pngName="TauxRenouvellementPopTotale_transportGeniteur_15_2022_05_06")



