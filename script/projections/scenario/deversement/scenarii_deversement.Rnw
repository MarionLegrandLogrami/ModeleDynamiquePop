load(file = "C:/Users/utilisateur/workspace/ModeleDynamiquePop/2019_12_12_Projection_InteractionReciproqueMatriceVC_Maj2018_scenar_dev_2021_03_17.RData")
#Simulation quantité divisée par 2 par rapport à 2018
load(file ="C:/Users/utilisateur/workspace/ModeleDynamiquePop/2019_12_12_Projection_InteractionReciproqueMatriceVC_Maj2018_scenar_dev_half2018_2021_03_17.RData")
#Simulation double 2018
load(file = "C:/Users/utilisateur/workspace/ModeleDynamiquePop/2019_12_12_Projection_InteractionReciproqueMatriceVC_Maj2018_scenar_dev_double2018_2021_03_17.RData")
#Simulation quantité 2018 en amont de Poutès
load(file = "C:/Users/utilisateur/workspace/ModeleDynamiquePop/2019_12_12_Projection_InteractionReciproqueMatriceVC_Maj2018_scenar_dev_2018_AmontPoutes_2021_03_17.RData")
#Simulation quantité 2018 sur Alagnon
load(file = "C:/Users/utilisateur/workspace/ModeleDynamiquePop/2019_12_12_Projection_InteractionReciproqueMatriceVC_Maj2018_scenar_dev_2018_Alagnon_2021_03_17.RData")
#Simulation quantité 2018 Langeac-Poutès
load(file = "C:/Users/utilisateur/workspace/ModeleDynamiquePop/2019_12_12_Projection_InteractionReciproqueMatriceVC_Maj2018_scenar_dev_2018_Langeac_2021_03_17.RData")

surf=c(rep(c(846021,70845,250441,0),11),rep(c(846021,70845,250441,301101),12),rep(c(846021,70845,250441,383049),6),rep(c(846021,356519,250441,383049),(T-8)))
S_juv_JP<-matrix(surf,nrow=4)	
#==============================
# calcul des juvéniles totaux 
#==============================

#On récupère de bugs les juvéniles produits car on veut faire une figure avec l'ensemble :
bugs_dmoy_tot_V=read.coda("dmoytot_VCODAchain1.txt","dmoytot_VCODAindex.txt",5001,10000)
bugs_dmoy_tot_A=read.coda("dmoytot_ACODAchain1.txt","dmoytot_ACODAindex.txt",5001,10000)
bugs_dmoy_tot_L=read.coda("dmoytot_LCODAchain1.txt","dmoytot_LCODAindex.txt",5001,10000)
bugs_dmoy_tot_P=read.coda("dmoytot_PCODAchain1.txt","dmoytot_PCODAindex.txt",5001,10000)


juv_tot=array(rep(0,(5000*(T+20))),dim=c(5000,(T+20)))#296000
juv_tot_q=array(rep(0,20*5),dim=c(20,5))

for (t in 2:12){
	juv_tot[,t]= bugs_dmoy_tot_V[,t-1] * S_juv_JP[1,t] + bugs_dmoy_tot_A[,t-1] * S_juv_JP[2,t] + bugs_dmoy_tot_L[,t-1] * S_juv_JP[3,t]
}
for (t in 13:(T)){ #ATTENTION on ne prend pas jusqu'à T+1 même si l'année exite car dans openbugs on calcule les juv de la dernière année en ne considérant que les juv sauvages (hypothèse d'arrêt des déversements)
	juv_tot[,t]= bugs_dmoy_tot_V[,t-1] * S_juv_JP[1,t] + bugs_dmoy_tot_A[,t-1] * S_juv_JP[2,t] + bugs_dmoy_tot_L[,t-1] *S_juv_JP[3,t] + bugs_dmoy_tot_P[,t-12] * S_juv_JP[4,t]	
}


for (t in (T+1):(T+20)){
	for (i in 1:5000){
		juv_tot[i,t]= juv_vichy[i,t]+juv_alagnon[i,t]+juv_langeac[i,t]+juv_poutes[i,t]
	}
}


#===============================
# Calcul des juvéniles sauvages
#===============================

juv_wild_V=array(0,dim=c(5000,(T+20)))
juv_wild_A=array(0,dim=c(5000,(T+20)))
juv_wild_L=array(0,dim=c(5000,(T+20)))
juv_wild_P=array(0,dim=c(5000,(T+20)))
juv_wild_tot=array(0,dim=c(5000,(T+20)))

#On récupère les données de bugs
bugs_dmoy_wild_V=read.coda("dmoywild_VCODAchain1.txt","dmoytot_VCODAindex.txt",5001,10000)
bugs_dmoy_wild_A=read.coda("dmoywild_ACODAchain1.txt","dmoytot_ACODAindex.txt",5001,10000)
bugs_dmoy_wild_L=read.coda("dmoywild_LCODAchain1.txt","dmoytot_LCODAindex.txt",5001,10000)
bugs_dmoy_wild_P=read.coda("dmoywild_PCODAchain1.txt","dmoytot_PCODAindex.txt",5001,10000)

for (t in 2:12){
	juv_wild_V[,t]<-bugs_dmoy_wild_V[,t-1] * S_juv_JP[1,t]
	juv_wild_A[,t]<-bugs_dmoy_wild_A[,t-1] * S_juv_JP[2,t]
	juv_wild_L[,t]<-bugs_dmoy_wild_L[,t-1] * S_juv_JP[3,t]
	juv_wild_tot[,t]<-juv_wild_V[,t]+juv_wild_A[,t]+juv_wild_L[,t]
}

for (t in 13:T){ #ATTENTION on ne prend pas jusqu'à T+1 même si l'année exite car dans openbugs on calcule les juv de la dernière année en ne considérant que les juv sauvages (hypothèse d'arrêt des déversements)
	juv_wild_V[,t]<-bugs_dmoy_wild_V[,t-1] * S_juv_JP[1,t]
	juv_wild_A[,t]<-bugs_dmoy_wild_A[,t-1] * S_juv_JP[2,t]
	juv_wild_L[,t]<-bugs_dmoy_wild_L[,t-1] * S_juv_JP[3,t]
	juv_wild_P[,t]<-bugs_dmoy_wild_P[,t-12] * S_juv_JP[4,t]
	juv_wild_tot[,t]<-juv_wild_V[,t]+juv_wild_A[,t]+juv_wild_L[,t]+juv_wild_P[,t]
}

for (t in (T+1):(T+20)){
	juv_wild_V[,t]<-d_moy_w_vichy[,t] * S_juv_JP[1,t]
	juv_wild_A[,t]<-d_moy_w_alagnon[,t] * S_juv_JP[2,t]
	juv_wild_L[,t]<-d_moy_w_langeac[,t] * S_juv_JP[3,t]
	juv_wild_P[,t]<-d_moy_w_poutes[,t] * S_juv_JP[4,t]
	juv_wild_tot[,t]<-juv_wild_V[,t]+juv_wild_A[,t]+juv_wild_L[,t]+juv_wild_P[,t]
}

#==================
# Calcul du ratio
#==================
ratio_juv_wild<-array(NA,dim=c(5000,(T+20)))
mean_ratio_juv_wild<-array(NA,dim=c(1,(T+20)))
for (t in 2:(T+20)){
	for (i in 1:5000){
		ratio_juv_wild[i,t]<-juv_wild_tot[i,t]/juv_tot[i,t]
	}
}

#==================================
# En moyenne mobile de la moyenne
#==================================
running.mean<- function(x, n = 5){stats::filter(x, rep(1 / n, n), sides = 2)}
median_ratio_juv_wild<-apply(ratio_juv_wild,MARGIN=2,FUN=median)
x_juv_INT<-seq(4,(T+20-2),1)
rect_2_col_INT <- data.frame(ystart = c(0,0.5), yend = c(0.5,1),col = c("red","green"))
graph_part_juv<-ggplot()+
					geom_rect(data=rect_2_col_INT, aes(xmin=4, xmax=(T+20-2), ymin=ystart,ymax=yend), fill=rect_2_col_INT$col, alpha =0.5) +
					geom_line(aes(x_juv_INT,running.mean(median_ratio_juv_wild,5)[!is.na(running.mean(median_ratio_juv_wild,5))]),size=1)+
					geom_hline(yintercept = 0.5,linetype="dashed",size=2)+
					geom_hline(yintercept = 0.75, linetype="dashed", size=1)+
					geom_hline(yintercept = 0.25, linetype="dashed", size=1)+
					xlab(iconv("Année","UTF8")) + 
					ylab(iconv("Ratio juvénile sauvage sur juvénile total","UTF8"))+
					ggtitle(iconv("Part de juvéniles sauvages dans l'ensemble des juvéniles \n(moyenne mobile 5 ans centrée sur l'année indiquée)","UTF8"))+
					scale_x_continuous(breaks=c(1,6,16,26,36,46,56,(T+20-2)), labels=c(1975,1980,1990,2000,2010,2020,2030,(1974+T+20-2)))+
					geom_vline(xintercept = (T-2),linetype="dotted")+
					theme(legend.position="none")+
					theme_bw()+
					theme(plot.title = element_text(hjust = 0.5)) 
			
