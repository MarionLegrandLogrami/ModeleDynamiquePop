###Les exports de tableaux réalisés comprennent autant d'onglet que de scénario, on compile tout ça dans un même onglet et on réenregistre
concat_export_tab(tab="scenarii_dev_mean_data")
concat_export_tab(tab="scenarii_dev_running_mean_2022_07")

## on trace une figure avec les différents scénarii

data_concat<-read_excel(path=str_c(tabwd,"scenarii_dev_running_mean_2022_07_concat.xlsx"),col_name=TRUE)
data_concat$annee<-rep(seq(1,(T+20-6-10),1),length(unique(data_concat$scenar)))
#data_concat$type_scenar<-as.factor(rep(1:2,each=50*length(unique(data_concat$scenar))/2))
##SANS enregistrer
rect_2_col <- data.frame(ystart = c(0,1), yend = c(1,1.5), col = c("red","green"))
 #On affiche toujours sur les graphs la 1ere et dernière année et entre on affiche les années finissant par 0 ou 5 sauf si moins de 2 ans d'écarts
Tyear_def<-T+20
seqx <- data.frame(breaks=seq(1,(Tyear_def-16),1),label=seq(1985,(1974+Tyear_def-6),1))
  seqx_debut <- seqx[1,]
  seqx_fin <- seqx[nrow(seqx),]
  seqx_milieu <- seqx[seqx$label%%5==0,]
  seqx_milieu <- seqx_milieu[seqx_milieu$label-seqx_debut$label>2 & seqx_fin$label-seqx_milieu$label>2,]
  seqx <- rbind(seqx_debut,seqx_milieu,seqx_fin)
  xintercept <- T-16#if(simulation==TRUE){Tyear_def}else{}

png(filename =here::here("img/Simulation/2021_09/Scenar0-11_2022_07_05.png") ,width=1000,height=800)
ggplot()+
  geom_rect(data=rect_2_col, aes(xmin=1, xmax=(T+4), ymin=ystart,ymax=yend), fill=rect_2_col$col, alpha =0.5) +
  geom_line(data=data_concat,aes(x=annee,y=running_mean,group=scenar))+
   scale_y_continuous(trans="log10",limits=c(0.1,1.5)) +
          annotation_logticks(sides="l") +
          scale_x_continuous(breaks=seqx$breaks, labels=seqx$label) +
   # scale_color_manual(values=c('#000000','#3F63B5'))+
          xlab("Année de reproduction") + 
          ylab("Tx de renouvellement") +
          ggtitle(str_c("Tx de renouvellement de la population sauvage"," \n(moyenne mobile 5 ans)")) +
          labs(fill = "") +
          geom_vline(aes(xintercept=xintercept), linetype="dotted",size=0.8) +
          annotate(geom="text", x=xintercept/2, y=1.2, label="Rétrospectif",fontface =2,size=6) +
          annotate(geom="text", x=xintercept+(seqx_fin$breaks-xintercept)/2, y=1.2, label="Simulation",fontface =2,size=6)+

          theme_bw() +
          theme(plot.title = element_text(hjust = 0.5),plot.subtitle = element_text(hjust = 0.5),legend.position="bottom",text = element_text(size = 20))
  
dev.off()
  
data_concat[data_concat$année==2034,]
write.xlsx(x=data_concat[data_concat$année==2034,],file=str_c(datawd,"resu_fig_scenarii_dev_0-11_2022_07_05.xlsx"))

#on restreint aux scénarios 0 à 6 et 11
scenarios<- c(str_c("scenario",0:6),"scenario11")
data_concat_0_6_11<-data_concat[data_concat$scenar %in% scenarios,]

png(filename =here::here("img/Simulation/2021_09/Scenar0-6-11_2022_07_05.png") ,width=1000,height=800)
ggplot()+
  geom_rect(data=rect_2_col, aes(xmin=1, xmax=(T+4), ymin=ystart,ymax=yend), fill=rect_2_col$col, alpha =0.5) +
  geom_line(data=data_concat_0_6_11,aes(x=annee,y=running_mean,group=scenar))+
   scale_y_continuous(trans="log10",limits=c(0.1,1.5)) +
          annotation_logticks(sides="l") +
          scale_x_continuous(breaks=seqx$breaks, labels=seqx$label) +
   # scale_color_manual(values=c('#000000','#3F63B5'))+
          xlab("Année de reproduction") + 
          ylab("Tx de renouvellement") +
          ggtitle(str_c("Tx de renouvellement de la population sauvage"," \n(moyenne mobile 5 ans)")) +
          labs(fill = "") +
          geom_vline(aes(xintercept=xintercept), linetype="dotted",size=0.8) +
          annotate(geom="text", x=xintercept/2, y=1.2, label="Rétrospectif",fontface =2,size=6) +
          annotate(geom="text", x=xintercept+(seqx_fin$breaks-xintercept)/2, y=1.2, label="Simulation",fontface =2,size=6)+

          theme_bw() +
          theme(plot.title = element_text(hjust = 0.5),plot.subtitle = element_text(hjust = 0.5),legend.position="bottom",text = element_text(size = 20))
  
dev.off()

data_concat_0_6_11[data_concat_0_6_11$année==2034,]
write.xlsx(x=data_concat_0_6_11[data_concat_0_6_11$année==2034,],file=str_c(imgwd,"resu_fig_scenarii_dev_0-6-11_2022_07_05.xlsx"))


