#--------------------- Graphique répartition spatiale des juvéniles sauvages RATIO ------------------------------#

bugs_dmoy_wild_V=read.coda("dmoywild_VCODAchain1.txt","dmoywild_VCODAindex.txt",5001,10000)
bugs_dmoy_wild_A=read.coda("dmoywild_VCODAchain1.txt","dmoywild_VCODAindex.txt",5001,10000)
bugs_dmoy_wild_L=read.coda("dmoywild_LCODAchain1.txt","dmoywild_LCODAindex.txt",5001,10000)
bugs_dmoy_wild_P=read.coda("dmoywild_PCODAchain1.txt","dmoywild_PCODAindex.txt",5001,10000)


juv_wild_V=array(rep(0,195000),dim=c(5000,(T+20)))
juv_wild_A=array(rep(0,195000),dim=c(5000,(T+20)))
juv_wild_L=array(rep(0,195000),dim=c(5000,(T+20)))
juv_wild_P=array(rep(0,195000),dim=c(5000,(T+20)))
juv_wild_tot=array(rep(0,195000),dim=c(5000,(T+20)))
juv_wild_tot_q=array(rep(0,(T+20)*5),dim=c((T+20),5))


for (t in 2:12){
	juv_wild_V[,t]<-bugs_dmoy_wild_V[,t-1] * S_juv_JP[1,t]
	juv_wild_A[,t]<-bugs_dmoy_wild_A[,t-1] * S_juv_JP[2,t]
	juv_wild_L[,t]<-bugs_dmoy_wild_L[,t-1] * S_juv_JP[3,t]
}

for (t in 13:T){
	juv_wild_V[,t]<-bugs_dmoy_wild_V[,t-1] * S_juv_JP[1,t]
	juv_wild_A[,t]<-bugs_dmoy_wild_A[,t-1] * S_juv_JP[2,t]
	juv_wild_L[,t]<-bugs_dmoy_wild_L[,t-1] * S_juv_JP[3,t]
	juv_wild_P[,t]<-bugs_dmoy_wild_P[,t-12] * S_juv_JP[4,t]
}

for (t in (T+1):(T+20)){
	juv_wild_V[,t]<-d_moy_w_vichy[,t] * S_juv_JP[1,t]
	juv_wild_A[,t]<-d_moy_w_alagnon[,t] * S_juv_JP[2,t]
	juv_wild_L[,t]<-d_moy_w_langeac[,t] * S_juv_JP[3,t]
	juv_wild_P[,t]<-d_moy_w_poutes[,t] * S_juv_JP[4,t]
}

for (t in 1:(T+20)){
	juv_wild_tot[,t]<-juv_wild_V[,t]+juv_wild_A[,t]+juv_wild_L[,t]+juv_wild_P[,t]
}

for (t in 1:(T+20)){
	juv_wild_tot_q[t,]=quantile(juv_wild_tot[,t],probs=c(0.05,0.25,0.5,0.75,0.95),names=FALSE)
}

##Ratio par secteurs
ratio_juv_wild_V=array(0,c(5000,(T+20)))
ratio_juv_wild_A=array(0,c(5000,(T+20)))
ratio_juv_wild_L=array(0,c(5000,(T+20)))
ratio_juv_wild_P=array(0,c(5000,(T+20)))

ratio_juv_wild_V_q=array(rep(0,(T+20)*5),dim=c((T+20),5))
ratio_juv_wild_A_q=array(rep(0,(T+20)*5),dim=c((T+20),5))
ratio_juv_wild_L_q=array(rep(0,(T+20)*5),dim=c((T+20),5))
ratio_juv_wild_P_q=array(rep(0,(T+20)*5),dim=c((T+20),5))


for (t in 2:(T+20)){
	ratio_juv_wild_V[,t]=juv_wild_V[,t]/juv_wild_tot[,t]
	ratio_juv_wild_A[,t]=juv_wild_A[,t]/juv_wild_tot[,t]
	ratio_juv_wild_L[,t]=juv_wild_L[,t]/juv_wild_tot[,t]
	ratio_juv_wild_P[,t]=juv_wild_P[,t]/juv_wild_tot[,t]
}

for (t in 1:(T+20)){
	ratio_juv_wild_V_q[t,]=quantile(ratio_juv_wild_V[,t],probs=c(0.05,0.25,0.5,0.75,0.95),names=FALSE)
	ratio_juv_wild_A_q[t,]=quantile(ratio_juv_wild_A[,t],probs=c(0.05,0.25,0.5,0.75,0.95),names=FALSE)
	ratio_juv_wild_L_q[t,]=quantile(ratio_juv_wild_L[,t],probs=c(0.05,0.25,0.5,0.75,0.95),names=FALSE)
	ratio_juv_wild_P_q[t,]=quantile(ratio_juv_wild_P[,t],probs=c(0.05,0.25,0.5,0.75,0.95),names=FALSE)
}

