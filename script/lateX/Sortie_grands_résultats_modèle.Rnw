\subsection{Production en juvéniles sur le secteur Langeac-Poutès}

<< production_juv_LP, echo=FALSE, eval=TRUE,results=hide >>=
dmoy_tot_L=read.coda(str_c(datawd,"dmoytot_LCODAchain1.txt"),str_c(datawd,"dmoytot_LCODAindex.txt"))

juv_tot_L=array(rep(0,10000*T),dim=c(10000,T))#296000
juv_tot_L_q=array(rep(0,T*5),dim=c(T,5))

for (t in 2:T){
	juv_tot_L[,t]= dmoy_tot_L[,t-1] * S_juv_JP[3,t]
}

for (i in 1:T){
	juv_tot_L_q[i,]=quantile(juv_tot_L[,i],probs=c(0.05,0.25,0.5,0.75,0.95),names=FALSE)
}

png(file=str_c(imgwd,"production_juveniles_Langeac_Poutes.png"),width=800,height=800)
par(mar = c(5, 4, 4, 5) + 0.1) #on augmente la marge à droite pour qu'on puisse lire en entier le chiffre moyen de production
plot(1,1,type="n",axes=FALSE,xlim=c(0.5,T+0.5),xlab="Années",ylim=c(0,200000),ylab="")

# trace l'axe des ordonnées
axis(2,at = c(0,50000,100000,150000,200000),
		labels=c(
				expression(0),
				expression(paste(50," x ", 10^3)),
				expression(paste(100," x ", 10^3)),
				expression(paste(150," x ", 10^3)),
				expression(paste(200," x ", 10^3))),
		cex.axis = 0.8,las = 1,col = "grey55")
# trace l'axe des abscisses
lab1=c(1975,1980,1990,2000,1974+T)
axis(1,at = c(1,6,16,26,T),
		labels=lab1,
		cex.axis = 0.9,las = 1,col = "grey55")

for(i in 2:T){
	#whiskers
	#95%
	segments(i-0.15,juv_tot_L_q[i,5],i+0.15,juv_tot_L_q[i,5])
	segments(i,juv_tot_L_q[i,4],i,juv_tot_L_q[i,5])
	#5%
	segments(i-0.15,juv_tot_L_q[i,1],i+0.15,juv_tot_L_q[i,1])
	segments(i,juv_tot_L_q[i,2],i,juv_tot_L_q[i,1])
	#boxplot
	polygon(c(i-0.3,i+0.3,i+0.3,i-0.3),c(juv_tot_L_q[i,2],juv_tot_L_q[i,2],juv_tot_L_q[i,4],juv_tot_L_q[i,4]),col="grey85")
	#median
	segments(i-0.3,juv_tot_L_q[i,3],i+0.3,juv_tot_L_q[i,3])
}
segments(x0=0,y0=mean(juv_tot_L),y1=mean(juv_tot_L),x1=T+1,col="red")
mtext(round(mean(juv_tot_L),0),side=4,line=0,at=mean(juv_tot_L),cex = 0.8,col="red",las=1)

dev.off()

#on crée le tableau avec les valeurs
tabl <- as.data.frame(juv_tot_L_q)
colnames(tabl) <- c("2.5%","25%","50%","75%","97.5%")
rownames(tabl) <- 1975:(1974+T)
tabl <- tabl[-1,]

tabl[] <- lapply(tabl, function(x) as.integer(round(x))) #on arrondit pour avoir des nombres entiers de poissons


# Capturer la table en LaTeX dans une variable
tab <- xtable(x = tabl, label = "prod_juv_L", caption = "Production totale de juveniles (sauvages + elevage) sur le secteur Langeac-Poutes")

# Convertir en chaîne LaTeX
