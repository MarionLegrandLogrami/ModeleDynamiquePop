}
for (t in 12:44){
	for (i in 1:10000){
		adulte_poutes[i,t]<-N[t,4]
	}
}
for (t in 45:T){
	for (i in 1:10000){
		adulte_poutes[i,t]<-N_poutes[i,(t-44)]
	}
}


