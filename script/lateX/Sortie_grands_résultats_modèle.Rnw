	segments(i-0.3,N_alagnon_q[i,3],i+0.3,N_alagnon_q[i,3])
}


segments(x0=0,y0=mean(mean_res),y1=mean(mean_res),x1=T+1,col="red")
mtext(round(mean(mean_res),3),side=4,line=0,at=mean(mean_res),cex = 0.8,col="red",las=1)
