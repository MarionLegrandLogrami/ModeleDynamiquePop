<< init, echo=FALSE, eval=TRUE,results=hide >>=
#datawd<-here::here("data/CODA/2024_06/Hierarchisation_variance + comptage_Langeac + MAJ data 2023/")
#imgwd<-here::here("img/2024_06/Hierarchisation_variance + comptage_Langeac + MAJ data 2023/")
#tabwd<-here::here("tab/2024_06/Hierarchisation_variance + comptage_Langeac + MAJ data 2023/")

datawd<-here::here("data/CODA/2025_07/")
imgwd<-here::here("img/2025_07/")
tabwd<-here::here("tab/2025_07/")

#quand on lance sous eclipse le setwd n'est pas défini (va sur C:/WINDOWS/system32)
#ça met la zone quand on lance la fonction bugs2jags. On définit le setwd au niveau
#du datawd pour qu'il enregistre le data_model.R au bon endroit
setwd(here::here("data/CODA/2025_07/"))

library(coda)
library(boot)
library(stringr)
require(xtable)
library(dplyr)
library(knitr)
library(kableExtra)

#pour les anciens modèles (avant maj données 2021-2022
#surf=c(rep(c(846021,70845,250441,0),11),rep(c(846021,70845,250441,301101),12),rep(c(846021,70845,250441,383049),6),rep(c(846021,356519,250441,383049),(T-8)))

bugs2jags(str_c(datawd,"data.txt"),"data_model.R")
source("data_model.R")
S_juv_JP<-t(S_juv_JP)	

@

\section{Production en juvéniles}
<< production_juveniles, echo=FALSE, eval=TRUE,results=hide >>=

dmoy_tot_V=read.coda(str_c(datawd,"dmoytot_VCODAchain1.txt"),str_c(datawd,"dmoytot_VCODAindex.txt"))
dmoy_tot_A=read.coda(str_c(datawd,"dmoytot_ACODAchain1.txt"),str_c(datawd,"dmoytot_ACODAindex.txt"))
dmoy_tot_L=read.coda(str_c(datawd,"dmoytot_LCODAchain1.txt"),str_c(datawd,"dmoytot_LCODAindex.txt"))
dmoy_tot_P=read.coda(str_c(datawd,"dmoytot_PCODAchain1.txt"),str_c(datawd,"dmoytot_PCODAindex.txt"))

juv_tot=array(rep(0,(10000*T)),dim=c(10000,T))#296000
juv_tot_q=array(rep(0,T*5),dim=c(T,5))

for (t in 2:12){
	juv_tot[,t]= dmoy_tot_V[,t-1] * S_juv_JP[1,t] + dmoy_tot_A[,t-1] * S_juv_JP[2,t] + dmoy_tot_L[,t-1] * S_juv_JP[3,t]
}
for (t in 13:T){
	juv_tot[,t]= dmoy_tot_V[,t-1] * S_juv_JP[1,t] + dmoy_tot_A[,t-1] * S_juv_JP[2,t] + dmoy_tot_L[,t-1] *S_juv_JP[3,t] + dmoy_tot_P[,t-12] * S_juv_JP[4,t]	
}

for (i in 1:T){
	juv_tot_q[i,]=quantile(juv_tot[,i],probs=c(0.05,0.25,0.5,0.75,0.95),names=FALSE)
}


max(juv_tot_q)#487582.5
mean(juv_tot_q[,3])#170850.1
mean(juv_tot_q[(T-4):T,3])#204350.9
mean(juv_tot)#178155.5
mean(juv_tot[,(T-4):T])#207356.5

png(file=str_c(imgwd,"production_juveniles.png"),width=800,height=800)
par(mar = c(5, 4, 4, 5) + 0.1) #on augmente la marge à droite pour qu'on puisse lire en entier le chiffre moyen de production
plot(1,1,type="n",axes=FALSE,xlim=c(0.5,T+0.5),xlab="Années",ylim=c(0,500000),ylab="")

# trace l'axe des ordonnées
axis(2,at = c(0,100000,200000,300000,400000,500000),
		labels=c(
				expression(0),
				expression(paste(100," x ", 10^3)),
				expression(paste(200," x ", 10^3)),
				expression(paste(300," x ", 10^3)),
				expression(paste(400," x ", 10^3)),
				expression(paste(500," x ", 10^3))),
		cex.axis = 0.8,las = 1,col = "grey55")
# trace l'axe des abscisses
lab1=c(1975,1980,1990,2000,1974+T)
axis(1,at = c(1,6,16,26,T),
		labels=lab1,
		cex.axis = 0.9,las = 1,col = "grey55")

for(i in 2:T){
	#whiskers
	#95%
	segments(i-0.15,juv_tot_q[i,5],i+0.15,juv_tot_q[i,5])
	segments(i,juv_tot_q[i,4],i,juv_tot_q[i,5])
	#5%
	segments(i-0.15,juv_tot_q[i,1],i+0.15,juv_tot_q[i,1])
	segments(i,juv_tot_q[i,2],i,juv_tot_q[i,1])
	#boxplot
	polygon(c(i-0.3,i+0.3,i+0.3,i-0.3),c(juv_tot_q[i,2],juv_tot_q[i,2],juv_tot_q[i,4],juv_tot_q[i,4]),col="grey85")
	#median
	segments(i-0.3,juv_tot_q[i,3],i+0.3,juv_tot_q[i,3])
}
segments(x0=0,y0=mean(juv_tot),y1=mean(juv_tot),x1=T+1,col="red")
mtext(round(mean(juv_tot),0),side=4,line=0,at=mean(juv_tot),cex = 0.8,col="red",las=1)

dev.off()

#on crée le tableau avec les valeurs
tabl <- as.data.frame(juv_tot_q)
colnames(tabl) <- c("2.5%","25%","50%","75%","97.5%")
rownames(tabl) <- 1975:(1974+T)
tabl <- tabl[-1,]

tabl[] <- lapply(tabl, function(x) as.integer(round(x))) #on arrondit pour avoir des nombres entiers de poissons


# Capturer la table en LaTeX dans une variable
tab <- xtable(x = tabl, label = "prod_juv", caption = "Production totale de juveniles (sauvages + elevage)")

# Convertir en chaîne LaTeX
table_latex <- print(tab, include.rownames = TRUE, print.results = FALSE)

# Remplacer les valeurs de la colonne "50%" par la version en gras. Attention comme il y a un rowname la colonne du milieu devient la 4eme
table_latex <- gsub("([0-9\\.]+) & ([0-9\\.]+) & ([0-9\\.]+) & ([0-9\\.]+)",
		"\\1 & \\2 & \\3 & \\\\textbf{\\4} ", 
		table_latex)

# Sauvegarder dans un fichier
writeLines(table_latex, con = str_c(tabwd, "prod_juv.tex"))
@

\begin{figure}[ht]
     \includegraphics[width=0.9\textwidth]{\Sexpr{imgwd}production_juveniles.png}
     \caption{Production totale en juvéniles 0+ (sauvages + déversés) sur l'ensemble des secteurs du modèle}
     \label{prod_juv_tot} 
\end{figure}

\input{\Sexpr{tabwd}prod_juv.tex}

\clearpage

\subsection{Production en juvéniles sur le secteur Vichy-Langeac}

<< production_juv_VL, echo=FALSE, eval=TRUE,results=hide >>=
dmoy_tot_V=read.coda(str_c(datawd,"dmoytot_VCODAchain1.txt"),str_c(datawd,"dmoytot_VCODAindex.txt"))

juv_tot_V=array(rep(0,10000*T),dim=c(10000,T))#296000
juv_tot_V_q=array(rep(0,T*5),dim=c(T,5))

for (t in 2:T){
	juv_tot_V[,t]= dmoy_tot_V[,t-1] * S_juv_JP[1,t]
}

for (i in 1:T){
	juv_tot_V_q[i,]=quantile(juv_tot_V[,i],probs=c(0.05,0.25,0.5,0.75,0.95),names=FALSE)
}

png(file=str_c(imgwd,"production_juveniles_Vichy_Langeac.png"),width=800,height=800)
par(mar = c(5, 4, 4, 5) + 0.1) #on augmente la marge à droite pour qu'on puisse lire en entier le chiffre moyen de production
plot(1,1,type="n",axes=FALSE,xlim=c(0.5,T+0.5),xlab="Années",ylim=c(0,350000),ylab="")

# trace l'axe des ordonnées
axis(2,at = c(0,100000,200000,300000),
		labels=c(
				expression(0),
				expression(paste(100," x ", 10^3)),
				expression(paste(200," x ", 10^3)),
				expression(paste(300," x ", 10^3))),
		cex.axis = 0.8,las = 1,col = "grey55")
# trace l'axe des abscisses
lab1=c(1975,1980,1990,2000,1974+T)
axis(1,at = c(1,6,16,26,T),
		labels=lab1,
		cex.axis = 0.9,las = 1,col = "grey55")

for(i in 2:T){
	#whiskers
	#95%
	segments(i-0.15,juv_tot_V_q[i,5],i+0.15,juv_tot_V_q[i,5])
	segments(i,juv_tot_V_q[i,4],i,juv_tot_V_q[i,5])
	#5%
	segments(i-0.15,juv_tot_V_q[i,1],i+0.15,juv_tot_V_q[i,1])
	segments(i,juv_tot_V_q[i,2],i,juv_tot_V_q[i,1])
	#boxplot
	polygon(c(i-0.3,i+0.3,i+0.3,i-0.3),c(juv_tot_V_q[i,2],juv_tot_V_q[i,2],juv_tot_V_q[i,4],juv_tot_V_q[i,4]),col="grey85")
	#median
	segments(i-0.3,juv_tot_V_q[i,3],i+0.3,juv_tot_V_q[i,3])
}
segments(x0=0,y0=mean(juv_tot_V),y1=mean(juv_tot_V),x1=T+1,col="red")
mtext(round(mean(juv_tot_V),0),side=4,line=0,at=mean(juv_tot_V),cex = 0.8,col="red",las=1)

dev.off()

#on crée le tableau avec les valeurs
tabl <- as.data.frame(juv_tot_V_q)
colnames(tabl) <- c("2.5%","25%","50%","75%","97.5%")
rownames(tabl) <- 1975:(1974+T)
tabl <- tabl[-1,]

tabl[] <- lapply(tabl, function(x) as.integer(round(x))) #on arrondit pour avoir des nombres entiers de poissons


# Capturer la table en LaTeX dans une variable
tab <- xtable(x = tabl, label = "prod_juv_V", caption = "Production totale de juveniles (sauvages + elevage) sur le secteur Vichy-Langeac")

# Convertir en chaîne LaTeX
table_latex <- print(tab, include.rownames = TRUE, print.results = FALSE)

# Remplacer les valeurs de la colonne "50%" par la version en gras. Attention comme il y a un rowname la colonne du milieu devient la 4eme
table_latex <- gsub("([0-9\\.]+) & ([0-9\\.]+) & ([0-9\\.]+) & ([0-9\\.]+)",
		"\\1 & \\2 & \\3 & \\\\textbf{\\4} ", 
		table_latex)

# Sauvegarder dans un fichier
writeLines(table_latex, con = str_c(tabwd, "prod_juv_V.tex"))
@

\begin{figure}[ht]
     \includegraphics[width=\textwidth]{\Sexpr{imgwd}production_juveniles_Vichy_Langeac.png}
     \caption{Production totale en juvéniles 0+ (sauvages + déversés) sur le
     secteur Vichy-Langeac}
     \label{prod_juv_V_tot} 
