\subsection{Production en juvéniles - statistiques}
<< production_juv_stat, echo=FALSE, eval=TRUE,results=hide >>=
#moyenne série +/- ET : sur ensemble secteur d'étude et par secteur
#médiane série : sur ensemble secteur d'étude et par secteur
#moyenne 5 dernières années +/- ET : sur ensemble secteur d'étude et par secteur
#tendance par rapport aux 5 dernières années (--> tx variation) : sur ensemble secteur d'étude et par secteur
#ratio de chacun des secteurs sur l'ensemble de la série
#ratio de chacun des secteurs sur les 5 dernières années
#ratio de chacun des secteurs la dernière année

dmoy_tot_V=read.coda(str_c(datawd,"dmoytot_VCODAchain1.txt"),str_c(datawd,"dmoytot_VCODAindex.txt"))
dmoy_tot_A=read.coda(str_c(datawd,"dmoytot_ACODAchain1.txt"),str_c(datawd,"dmoytot_ACODAindex.txt"))
dmoy_tot_L=read.coda(str_c(datawd,"dmoytot_LCODAchain1.txt"),str_c(datawd,"dmoytot_LCODAindex.txt"))
dmoy_tot_P=read.coda(str_c(datawd,"dmoytot_PCODAchain1.txt"),str_c(datawd,"dmoytot_PCODAindex.txt"))

juv_tot=array(rep(0,(10000*T)),dim=c(10000,T))#296000
juv_tot_q=array(rep(0,T*5),dim=c(T,5))

for (t in 2:12){
	juv_tot[,t]= dmoy_tot_V[,t-1] * S_juv_JP[1,t] + dmoy_tot_A[,t-1] * S_juv_JP[2,t] + dmoy_tot_L[,t-1] * S_juv_JP[3,t]
}
for (t in 13:T){
	juv_tot[,t]= dmoy_tot_V[,t-1] * S_juv_JP[1,t] + dmoy_tot_A[,t-1] * S_juv_JP[2,t] + dmoy_tot_L[,t-1] *S_juv_JP[3,t] + dmoy_tot_P[,t-12] * S_juv_JP[4,t]	
}

ratio_juv_V=array(0,c(10000,T))
ratio_juv_A=array(0,c(10000,T))
ratio_juv_L=array(0,c(10000,T))
ratio_juv_P=array(0,c(10000,T))
for (t in 2:T){
	ratio_juv_V[,t]=juv_tot_V[,t]/juv_tot[,t]
	ratio_juv_A[,t]=juv_tot_A[,t]/juv_tot[,t]
	ratio_juv_L[,t]=juv_tot_L[,t]/juv_tot[,t]
	ratio_juv_P[,t]=juv_tot_P[,t]/juv_tot[,t]
}

tableau <- data.frame(moyenne_serie=c(round(mean(juv_tot_V),0),
								   round(mean(juv_tot_A),0),
								   round(mean(juv_tot_L),0),
								   round(mean(juv_tot_P),0),
								   round(mean(juv_tot),0)),
					ET_serie=c(round(sd(juv_tot_V),0),
							   round(sd(juv_tot_A),0),
							   round(sd(juv_tot_L),0),
							   round(sd(juv_tot_P),0),
							   round(sd(juv_tot),0)),
					moyenne_5yr=c(round(mean(juv_tot_V[,(T-5):(T-1)]),0),
								  round(mean(juv_tot_A[,(T-5):(T-1)]),0),
								  round(mean(juv_tot_L[,(T-5):(T-1)]),0),
								  round(mean(juv_tot_P[,(T-5):(T-1)]),0),
								  round(mean(juv_tot[,(T-5):(T-1)]),0)),
				    ET_5yr=c(round(sd(juv_tot_V[,(T-5):(T-1)]),0),
							 round(sd(juv_tot_A[,(T-5):(T-1)]),0),
							 round(sd(juv_tot_L[,(T-5):(T-1)]),0),
							 round(sd(juv_tot_P[,(T-5):(T-1)]),0),
							 round(sd(juv_tot[,(T-5):(T-1)]),0)),
					year=c(round(mean(juv_tot_V[,T]),0),
							round(mean(juv_tot_A[,T]),0),
							round(mean(juv_tot_L[,T]),0),
							round(mean(juv_tot_P[,T]),0),
							round(mean(juv_tot[,T]),0)),
					year_sd=c(round(sd(juv_tot_V[,T]),0),
							round(sd(juv_tot_A[,T]),0),
							round(sd(juv_tot_L[,T]),0),
							round(sd(juv_tot_P[,T]),0),
							round(sd(juv_tot[,T]),0)),
					tx_variation_5yr=c(paste(round((mean(juv_tot_V[,T])-mean(juv_tot_V[,(T-5):(T-1)]))/mean(juv_tot_V[,(T-5):(T-1)]) *100,0), "%", sep=" "), #(Valeur d'arrivée - Valeur de départ)/valeur de départ *100
										paste(round((mean(juv_tot_A[,T])-mean(juv_tot_A[,(T-5):(T-1)]))/mean(juv_tot_A[,(T-5):(T-1)]) *100,0), "%", sep=" "),
										paste(round((mean(juv_tot_L[,T])-mean(juv_tot_L[,(T-5):(T-1)]))/mean(juv_tot_L[,(T-5):(T-1)]) *100,0), "%", sep=" "),
										paste(round((mean(juv_tot_P[,T])-mean(juv_tot_P[,(T-5):(T-1)]))/mean(juv_tot_P[,(T-5):(T-1)]) *100,0), "%", sep=" "),
										paste(round((mean(juv_tot[,T])-mean(juv_tot[,(T-5):(T-1)]))/mean(juv_tot[,(T-5):(T-1)]) *100,0), "%", sep=" ")))
tableau2 <- data.frame(
					ratio_serie=c(round(mean(ratio_juv_V),2),
								  round(mean(ratio_juv_A),2),
								  round(mean(ratio_juv_L),2),
								  round(mean(ratio_juv_P),2)),
					ratio_5yr=c(round(mean(ratio_juv_V[,(T-5):(T-1)]),2),
								  round(mean(ratio_juv_A[,(T-5):(T-1)]),2),
								  round(mean(ratio_juv_L[,(T-5):(T-1)]),2),
								  round(mean(ratio_juv_P[,(T-5):(T-1)]),2)),
					ratio_year=c(round(mean(ratio_juv_V[,T]),2),
								  round(mean(ratio_juv_A[,T]),2),
								  round(mean(ratio_juv_L[,T]),2),
								  round(mean(ratio_juv_P[,T]),2))				 
			)	
			
colnames(tableau) <- c(paste0("moy_1976_", (1974+T)),
					   "sd_serie",
					   paste0("moy_",(1974+T-5),"_", (1974+T-1)),
					   "sd_5yrs",
					   paste0("moy_",(1974+T)),
					   "sd",
					   "Tx_var_5yr")
			   
colnames(tableau2) <- c(paste0("ratio_1976_", (1974+T)),
					   paste0("ratio_",(1974+T-5),"_", (1974+T-1)),
					   paste0("ratio_",(1974+T))
					   )
rownames(tableau) <- c("Vichy-Langeac","Alagnon","Langeac-Poutes","amont Poutes","Tous les secteurs")
rownames(tableau2) <- c("Vichy-Langeac","Alagnon","Langeac-Poutes","amont Poutes")


# Capturer la table en LaTeX dans une variable
tab <- xtable(x = tableau, label = "prod_juv_stat", caption = "Chiffres cle sur la production en juveniles. Le Tx\\_var\\_5yr correspond au taux de variation entre l'annee la plus recente et la moyenne des 5 annees passees",digits = c(0, 0, 0, 0, 0, 0, 0, 0))
tab2 <- xtable(x = tableau2, label = "prod_juv_stat2", caption = "Ratio de la production en juveniles par secteur")

# Convertir en chaîne LaTeX
o<-print(tab, file = str_c(tabwd,"prod_juv_stat.tex"), 
		table.placement = "htbp",
		caption.placement = "top",
		NA.string = "",
		include.rownames=TRUE
)
o2<-print(tab2, file = str_c(tabwd,"prod_juv_stat2.tex"), 
