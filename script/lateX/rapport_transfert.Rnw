par(mfrow=c(2,1),mar=c(4,5.5,2,1.5))
#Graphe densite dependence juvenile sauvage
plot(1,1,type="n",axes=FALSE,xlim=c(0,0.0025),xlab=expression(paste(S," ",(g?niteurs.m^-2))),ylim=c(0,0.35),ylab=expression(paste(d^sauvage," (0+",.m^-2,")")),main="relation de densit? d?pendance des 0+ sauvages",cex.main=1.5,cex.lab=1.2)
# trace l'axe des ordonn?es
