# trace l'axe des abscisses
axis(1,at = c(1,6,16,26,36,T),
		labels=c(1975,1980,1990,2000,2010,(1974+T)),
		cex.axis = 0.9,las = 1,col = "grey55")

for(i in 12:28){
	#whiskers
	#95%
	segments(i-0.15,N_langeac_count_q[i-11,5],i+0.15,N_langeac_count_q[i-11,5])
	segments(i,N_langeac_count_q[i-11,4],i,N_langeac_count_q[i-11,5])
