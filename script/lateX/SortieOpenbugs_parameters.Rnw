# trace l'axe des abscisses
lab1=c(1975,1980,1990,2000,2010,1974+T)
axis(1,at = c(1,6,16,26,36,T),
		labels=lab1,
		cex.axis = 0.9,las = 1,col = "grey55")


for(i in 1:T){
	#whiskers
	#95%
	segments(i-0.15,adulte_langeac_q[(i),5],i+0.15,adulte_langeac_q[(i),5])
	segments(i,adulte_langeac_q[(i),4],i,adulte_langeac_q[(i),5])
	#5%
	segments(i-0.15,adulte_langeac_q[(i),1],i+0.15,adulte_langeac_q[(i),1])
	segments(i,adulte_langeac_q[(i),2],i,adulte_langeac_q[(i),1])
	#boxplot
	polygon(c(i-0.3,i+0.3,i+0.3,i-0.3),c(adulte_langeac_q[(i),2],adulte_langeac_q[(i),2],adulte_langeac_q[(i),4],adulte_langeac_q[(i),4]),col="green")
	#mean
	segments(i-0.3,mean_res[(i),],i+0.3,mean_res[(i),])
}

