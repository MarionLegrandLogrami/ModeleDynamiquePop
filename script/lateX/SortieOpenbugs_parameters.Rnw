	polygon(c(i-0.3,i+0.3,i+0.3,i-0.3),c(N_langeac_obs_q[i,2],N_langeac_obs_q[i,2],N_langeac_obs_q[i,4],N_langeac_obs_q[i,4]),col="green")
	#mean
	segments(i-0.3,mean_res[i,],i+0.3,mean_res[i,])
}

points(x=c(seq(30,34,1),seq(42,T,1)),N_langeac_obs[c(30:34,42:T)],pch=16)


