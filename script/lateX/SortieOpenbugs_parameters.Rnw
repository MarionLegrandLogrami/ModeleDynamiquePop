\clearpage
\section{Survie du juvénile à l'adulte}

%========================
\subsection{s\_juv2ad}
%=================================================================================
<< s_juv2ad, echo=FALSE, eval=TRUE,results=hide >>=
s_juv2ad <- read_param_coda("s_juv2ad", datawd)
q <- param_quantiles(s_juv2ad)

mean_res_periode2 <- mean(s_juv2ad[, (T-6-30):(T-6)]) #période 2 commence après effondrement survie=1991

# NB : custom_plot() trace toujours la médiane dans la boîte (segment central),
# ce qui correspond ici à l'intention d'origine (moyenne écartée car tirée par
# quelques valeurs extrêmes)
boxplot_years_png(imgwd, "s_juv2ad",
                   data = q$quantiles, years = 1:(T-6), year_origin = 1980,
                   ylab_txt = "s_juv2ad", ylim_range = c(0, 0.03), y_at = seq(0, 0.03, by = 0.005),
                   col_box = "green",
                   mean_line = mean_res_periode2, mean_line_range = c(12, T-6))
@

\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}s_juv2ad.png}%{a_juv.png}
     \caption{s\_juv2ad : la mediane est representée}
     \label{s_juv2ad} 
\end{figure}

s\_juv2ad représente le taux de transition entre le juvénile 0+ et l'adulte.

\clearpage

%=================================================================
\subsection{Influence des débits sur la survie juvénile-adulte}
%=================================================================
%========================
\subsubsection{m\_surv}
%=================================================================================
<< m_surv, echo=FALSE, eval=TRUE,results=hide >>=
m_surv <- read_param_coda("m_surv", datawd)
report_param(m_surv, imgwd, tabwd, "m_surv")
@

\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}m_surv.png}%{a_juv.png}
     \caption{m\_surv}
     \label{m_surv} 
\end{figure}

\input{\Sexpr{tabwd}m_surv.tex}
m\_surv représente la survie moyenne. Il est utiliser dans la relation qui lie la survie du juvénile à l'adulte aux débits.

\clearpage

%=================================================================================
\subsubsection{beta\_Q\_VB\_deval}
%=================================================================================
<< beta_Q_VB_deval, echo=FALSE, eval=TRUE,results=hide >>=
beta_Q_VB_deval <- read_param_coda("beta_Q_VB_deval", datawd)
report_param(beta_Q_VB_deval, imgwd, tabwd, "beta_Q_VB_deval", digits = c(0,4,4,4,4,4,4,4))
@

\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}beta_Q_VB_deval.png}
     \caption{beta\_Q\_VB\_deval}
     \label{beta_Q_VB_deval} 
\end{figure}

\input{\Sexpr{tabwd}beta_Q_VB_deval.tex}

beta\_Q\_VB\_deval représente le coefficient directeur de la droite modélisant l'influence des débits sur la survie. Les débits sont pris à Vieille-Brioude lors de la dévalaison (mars-avril).

\clearpage

%=================================================================================
\subsubsection{beta\_Q\_MSL\_mont}
%=================================================================================
<< beta_Q_MSL_mont, echo=FALSE, eval=TRUE,results=hide >>=
beta_Q_MSL_mont <- read_param_coda("beta_Q_MSL_mont", datawd)
report_param(beta_Q_MSL_mont, imgwd, tabwd, "beta_Q_MSL_mont", digits = c(0,4,4,4,4,4,4,4))
@

\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}beta_Q_MSL_mont.png}
     \caption{beta\_Q\_MSL\_mont}
     \label{beta_Q_MSL_mont} 
\end{figure}

\input{\Sexpr{tabwd}beta_Q_MSL_mont.tex}

beta\_Q\_MSL\_mont représente le coefficient directeur de la droite modélisant l'influence des débits sur la survie. Les débits sont pris à Montjean-sur-Loire lors de la montaison (du 15/12 au 15/03).

\clearpage

%=================================================================================
\subsubsection{beta\_Q\_MSL\_deval}
%=================================================================================
<< beta_Q_MSL_deval, echo=FALSE, eval=TRUE,results=hide >>=
beta_Q_MSL_deval <- read_param_coda("beta_Q_MSL_deval", datawd)
report_param(beta_Q_MSL_deval, imgwd, tabwd, "beta_Q_MSL_deval", digits = c(0,4,4,4,4,4,4,4))
@

\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}beta_Q_MSL_deval.png}
     \caption{beta\_Q\_MSL\_deval}
     \label{beta_Q_MSL_deval} 
\end{figure}

\input{\Sexpr{tabwd}beta_Q_MSL_deval.tex}

beta\_Q\_MSL\_deval représente le coefficient directeur de la droite modélisant l'influence des débits sur la survie. Les débits sont pris à Montjean-sur-Loire lors de la dévalaison (du 15/03 au 15/05).

\clearpage


%=================================================================================
\subsubsection{corrplot\_paramètre\_débit}
%=================================================================================

<< corrplot_debit, echo=FALSE, eval=TRUE,results=hide >>=
# beta_Q_MSL_mont / beta_Q_MSL_deval / beta_Q_VB_deval déjà chargés plus haut dans ce document
sigma_vichy <- read_param_coda("sigma_vichy", datawd)

Q_surv <- data.frame(beta_Q_MSL_mont = beta_Q_MSL_mont, beta_Q_MSL_deval = beta_Q_MSL_deval,
                      beta_Q_VB_deval = beta_Q_VB_deval, sigma_vichy = sigma_vichy)

corrplot_png(Q_surv, imgwd, "corr_Q_surv")
@


\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}corr_Q_surv.png}%{a_juv.png}
    % \caption{corr\_Q\_survie : débits utilisés dans le modèle linéaire expliquant le taux de transition 0\ensuremath{+}/adulte par les débits (Montjean-sur Loire à la dévalaison, Montjean-sur Loire à la montaison et Vieille-Brioude à la dévalaison)}
     \label{corr_Q_surv} 
\end{figure}


\clearpage


\subsubsection{Représentation des séries de débits utilisées dans le modèle}
<<plot_Q_surv, echo=FALSE, eval=TRUE,results=hide >>=

bugs2jags(str_c(datawd,"data.txt"),"data_model.R")
source("data_model.R")

Q_MSL_deval <- data.frame(sta=rep("Q Montjean-sur-Loire dévalaison",length(Q_MSL_deval)),year=1975:(1974+T),Q=Q_MSL_deval)
Q_MSL_mont <- data.frame(sta=rep("Q Montjean-sur-Loire montaison",length(Q_MSL_mont)),year=1975:(1974+T),Q=Q_MSL_mont)
Q_VB_deval <- data.frame(sta=rep("Q Vieille-Brioude dévalaison",length(Q_VB_deval)),year=1975:(1974+T),Q=Q_VB_deval)

Q_surv_serie_bugs<-rbind(Q_MSL_deval,Q_MSL_mont,Q_VB_deval)

Q_surv_serie_bugs$sta <- factor(Q_surv_serie_bugs$sta, levels = c("Q Montjean-sur-Loire montaison", "Q Montjean-sur-Loire dévalaison","Q Vieille-Brioude dévalaison"))

plot_Q_surv <- ggplot(data=Q_surv_serie_bugs,aes(x=year,y=Q))+
		geom_line()+
		facet_wrap(~ sta, scales="free_y",ncol=1)+
		theme(strip.text = element_text(face = "bold"))
ggsave(str_c(imgwd,"plot_Q_surv.png"), plot_Q_surv, dpi = 300, width = 3, height = 5)	
@


\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}plot_Q_surv.png}
     %\caption{représentation des séries de débits utilisées dans le modèle pour
    % expliquer le taux de transition 0\ensuremath{+}/adulte}
     \label{serie\_Q\_surv}
\end{figure}

\clearpage

\subsubsection{corrplot\_série\_débit}
<<corrplot_Q_surv, echo=FALSE, eval=TRUE,results=hide>>=

