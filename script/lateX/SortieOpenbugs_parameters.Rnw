	polygon(c(i-0.3,i+0.3,i+0.3,i-0.3),c(N_langeac_obs_q[(i-5),2],N_langeac_obs_q[(i-5),2],N_langeac_obs_q[(i-5),4],N_langeac_obs_q[(i-5),4]),col="green")
	#mean
	segments(i-0.3,mean_res[(i-5),],i+0.3,mean_res[(i-5),])
}

