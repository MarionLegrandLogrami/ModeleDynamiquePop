%=================================================================================
\subsection{p\_comptage\_langeac}
%=================================================================================
<< p_comptage_langeac, echo=FALSE, eval=TRUE,results=hide >>=
p_comptage_L=read.coda(str_c(datawd,"p_comptage_LCODAchain1.txt"),str_c(datawd,"p_comptage_LCODAindex.txt"))

sum=summary(p_comptage_L, probs=seq(0,1,0.1))
p_comptage_L_q<-sum$quantiles
mean_res<-cbind(sum$statistics[,"Mean"])


png(filename=str_c(imgwd,"p_comptage_L.png"),width=800,height=800)

plot(1,1,type="n",axes=FALSE,xlim=c(0,T),xlab="Years",ylim=c(0.70,1),ylab="p_comptage_L")

# trace l'axe des ordonnées
axis(2,at = seq(0.70,1,by=0.1),labels=seq(0.70,1,by=0.1),cex.axis = 0.9,las = 1,col = "grey55")
# trace l'axe des abscisses
lab1=c(1975,1980,1990,2000,2010,1974+T)
axis(1,at = c(1,6,16,26,36,T),
		labels=lab1,
		cex.axis = 0.9,las = 1,col = "grey55")

for(i in 1:29){
	#whiskers
	#95%
	segments(i-0.15,p_comptage_L_q[i,5],i+0.15,p_comptage_L_q[i,5])
	segments(i,p_comptage_L_q[i,4],i,p_comptage_L_q[i,5])
	#5%
	segments(i-0.15,p_comptage_L_q[i,1],i+0.15,p_comptage_L_q[i,1])
	segments(i,p_comptage_L_q[i,2],i,p_comptage_L_q[i,1])
	#boxplot
	polygon(c(i-0.3,i+0.3,i+0.3,i-0.3),c(p_comptage_L_q[i,2],p_comptage_L_q[i,2],p_comptage_L_q[i,4],p_comptage_L_q[i,4]),col="gray")
	#mean
	segments(i-0.3,mean_res[i,],i+0.3,mean_res[i,])
}

for(i in 30:34){
	#whiskers
	#95%
	segments(i-0.15,p_comptage_L_q[i,5],i+0.15,p_comptage_L_q[i,5])
	segments(i,p_comptage_L_q[i,4],i,p_comptage_L_q[i,5])
	#5%
	segments(i-0.15,p_comptage_L_q[i,1],i+0.15,p_comptage_L_q[i,1])
	segments(i,p_comptage_L_q[i,2],i,p_comptage_L_q[i,1])
	#boxplot
	polygon(c(i-0.3,i+0.3,i+0.3,i-0.3),c(p_comptage_L_q[i,2],p_comptage_L_q[i,2],p_comptage_L_q[i,4],p_comptage_L_q[i,4]),col="green")
	#mean
	segments(i-0.3,mean_res[i,],i+0.3,mean_res[i,])
}

for(i in 35:41){
	#whiskers
	#95%
	segments(i-0.15,p_comptage_L_q[i,5],i+0.15,p_comptage_L_q[i,5])
	segments(i,p_comptage_L_q[i,4],i,p_comptage_L_q[i,5])
	#5%
	segments(i-0.15,p_comptage_L_q[i,1],i+0.15,p_comptage_L_q[i,1])
	segments(i,p_comptage_L_q[i,2],i,p_comptage_L_q[i,1])
	#boxplot
	polygon(c(i-0.3,i+0.3,i+0.3,i-0.3),c(p_comptage_L_q[i,2],p_comptage_L_q[i,2],p_comptage_L_q[i,4],p_comptage_L_q[i,4]),col="gray")
	#mean
	segments(i-0.3,mean_res[i,],i+0.3,mean_res[i,])
}
for(i in 42:T){
	#whiskers
	#95%
	segments(i-0.15,p_comptage_L_q[i,5],i+0.15,p_comptage_L_q[i,5])
	segments(i,p_comptage_L_q[i,4],i,p_comptage_L_q[i,5])
	#5%
	segments(i-0.15,p_comptage_L_q[i,1],i+0.15,p_comptage_L_q[i,1])
	segments(i,p_comptage_L_q[i,2],i,p_comptage_L_q[i,1])
	#boxplot
	polygon(c(i-0.3,i+0.3,i+0.3,i-0.3),c(p_comptage_L_q[i,2],p_comptage_L_q[i,2],p_comptage_L_q[i,4],p_comptage_L_q[i,4]),col="green")
	#mean
	segments(i-0.3,mean_res[i,],i+0.3,mean_res[i,])
}
segments(x0=0,y0=mean(mean_res),y1=mean(mean_res),x1=T+1,col="red")
mtext(round(mean(mean_res),5),side=4,line=0,at=mean(mean_res),cex = 0.8,col="red",las=1)

dev.off()
@

\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}p_comptage_L.png}%{a_juv.png}
     \caption{p\_comptage\_L : les boxplots verts représentent les probabilités
     d'être comptés pour les années où la station de Langeac est en
     fonctionnement. En dehors de ces années, les boxplots sont gris}
     \label{p_comptage_L} 
