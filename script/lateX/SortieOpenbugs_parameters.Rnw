\clearpage
\section{Survie du juvénile à l'adulte}

%========================
\subsection{s\_juv2ad}
%=================================================================================
<< s_juv2ad, echo=FALSE, eval=TRUE,results=hide >>=
s_juv2ad=read.coda(str_c(datawd,"s_juv2adCODAchain1.txt"),str_c(datawd,"s_juv2adCODAindex.txt"))
sum=summary(s_juv2ad, probs=seq(0,1,0.1))
s_juv2ad_q<-sum$quantiles
mean_res<-cbind(sum$statistics[,"Mean"])

mean_res_periode2<-mean(s_juv2ad[,(T-6-30):(T-6)]) #période 2 commence après effondrement survie=1991


png(filename=str_c(imgwd,"s_juv2ad.png"),width=800,height=800)
plot(1,1,type="n",axes=FALSE,xlim=c(0,(T-6)),xlab="Years",ylim=c(0,0.03),ylab="s_juv2ad")

# trace l'axe des ordonnées
axis(2,at = seq(0,0.03,by=0.005),labels=seq(0,0.03,by=0.005),cex.axis = 0.9,las = 1,col = "grey55")
# trace l'axe des abscisses
lab1=c(1981,1990,2000,2010,1974+T)
axis(1,at = c(1,10,20,30,(T-6)),
		labels=lab1,
		cex.axis = 0.9,las = 1,col = "grey55")

for(i in 1:(T-6)){
	#whiskers
	#95%
	segments(i-0.15,s_juv2ad_q[i,5],i+0.15,s_juv2ad_q[i,5])
	segments(i,s_juv2ad_q[i,4],i,s_juv2ad_q[i,5])
	#5%
	segments(i-0.15,s_juv2ad_q[i,1],i+0.15,s_juv2ad_q[i,1])
	segments(i,s_juv2ad_q[i,2],i,s_juv2ad_q[i,1])
	#boxplot
	polygon(c(i-0.3,i+0.3,i+0.3,i-0.3),c(s_juv2ad_q[i,2],s_juv2ad_q[i,2],s_juv2ad_q[i,4],s_juv2ad_q[i,4]),col="green")
	#mean
	#segments(i-0.3,mean_res[i,],i+0.3,mean_res[i,])
	#median car il y a des valeurs extrêmes qui tirent la moyenne
	segments(i-0.3,s_juv2ad_q[i,3],i+0.3,s_juv2ad_q[i,3])
}


#segments(x0=0,y0=mean(mean_res),y1=mean(mean_res),x1=(T-6),col="red")
segments(x0=12,y0=mean_res_periode2,y1=mean_res_periode2,x1=(T-6),col="red")
mtext(round(mean_res_periode2,5),side=4,line=0,at=mean_res_periode2,cex = 0.8,col="red",las=1)
dev.off()

@

\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}s_juv2ad.png}%{a_juv.png}
     \caption{s\_juv2ad : la mediane est representée}
     \label{s_juv2ad} 
\end{figure}

s\_juv2ad représente le taux de transition entre le juvénile 0+ et l'adulte.

\clearpage

%=================================================================
\subsection{Influence des débits sur la survie juvénile-adulte}
%=================================================================
%========================
\subsubsection{m\_surv}
%=================================================================================
<< m_surv, echo=FALSE, eval=TRUE,results=hide >>=
m_surv=read.coda(str_c(datawd,"m_survCODAchain1.txt"),str_c(datawd,"m_survCODAindex.txt"))
png(filename=str_c(imgwd,"m_surv.png"),width=800,height=800)
par(mfrow = c(2, 1))
plot(m_surv,density=FALSE,auto.layout=FALSE)
plot(m_surv,trace=FALSE,auto.layout=FALSE)
dev.off()

sum=summary(m_surv, probs=seq(0,1,0.1))

tabl<-sum$quantiles
tabl["Mean"]<-sum$statistics["Mean"]
tabl["SD"]<-sum$statistics["SD"]
tabl=rbind(tabl) #pour en faire une table

tab<-xtable(x=tabl,label="m_surv",caption="Statistiques de m\\_surv")#,align=c("L",rep("C",5)))

o<-print(tab, file = str_c(tabwd,"m_surv.tex"), 
		table.placement = "htbp",
		caption.placement = "top",
		NA.string = "",
		include.rownames=FALSE
		)

@

\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}m_surv.png}%{a_juv.png}
     \caption{m\_surv}
     \label{m_surv} 
\end{figure}

\input{\Sexpr{tabwd}m_surv.tex}
m\_surv représente la survie moyenne. Il est utiliser dans la relation qui lie la survie du juvénile à l'adulte aux débits.

\clearpage

%=================================================================================
\subsubsection{beta\_Q\_VB\_deval}
%=================================================================================
<< beta_Q_VB_deval, echo=FALSE, eval=TRUE,results=hide >>=
beta_Q_VB_deval=read.coda(str_c(datawd,"beta_Q_VB_devalCODAchain1.txt"),str_c(datawd,"beta_Q_VB_devalCODAindex.txt"))
png(filename=str_c(imgwd,"beta_Q_VB_deval.png"),width=800,height=800)
par(mfrow = c(2, 1))
plot(beta_Q_VB_deval,density=FALSE,auto.layout=FALSE)
plot(beta_Q_VB_deval,trace=FALSE,auto.layout=FALSE)
dev.off()

sum=summary(beta_Q_VB_deval, probs=seq(0,1,0.1))

beta_Q_VB_deval_q<-sum$quantiles
#mean_res<-cbind(sum$statistics[,"Mean"])
mean_res<-sum$statistics["Mean"]

tabl<-sum$quantiles
tabl["Mean"]<-sum$statistics["Mean"]
tabl["SD"]<-sum$statistics["SD"]
tabl=rbind(tabl) #pour en faire une table

tab<-xtable(x=tabl,label="beta_Q_VB_deval",caption="Statistiques de beta\\_Q\\_VB\\_deval",digits=c(0,4,4,4,4,4,4,4))#,align=c("L",rep("C",5)))

o<-print(tab, file = str_c(tabwd,"beta_Q_VB_deval.tex"),
		table.placement = "htbp",
		caption.placement = "top",
		NA.string = "",
		include.rownames=FALSE
		)

@

\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}beta_Q_VB_deval.png}
     \caption{beta\_Q\_VB\_deval}
     \label{beta_Q_VB_deval} 
\end{figure}

\input{\Sexpr{tabwd}beta_Q_VB_deval.tex}

beta\_Q\_VB\_deval représente le coefficient directeur de la droite modélisant l'influence des débits sur la survie. Les débits sont pris à Vieille-Brioude lors de la dévalaison (mars-avril).

\clearpage

