%====================================
\subsection{d\_juv\_moy}
%====================================

d\_juv\_moy représente la densité de juvéniles déversés à l'échelle des secteurs. Il est décliné à l'échelle des 4 secteurs du modèle.

%------------------------------------
\subsubsection{d\_juv\_moy\_Vichy}
%------------------------------------
<< d_juv_moy_V, echo=FALSE, eval=TRUE,results=hide >>=
d_juv_moy_V=read.coda(str_c(datawd,"stocking_juv_VCODAchain1.txt"),str_c(datawd,"stocking_juv_VCODAindex.txt"))

#On a besoin de récupérer les données depuis Openbugs concernant les I_juv_moy
#pour ne pas les réécrire à la main et risquer de faire des erreurs

library(coda) 
bugs2jags(str_c(datawd,"data.txt"),"data_covariable_2019_12_12.R")
source("data_covariable_2019_12_12.R")
head(I_juv_moy) #éa marche !! :D

sum=summary(d_juv_moy_V, probs=seq(0,1,0.1))
d_juv_moy_V_q<-sum$quantiles
#Add column to sort
d_juv_moy_V_q<-cbind(2:T,d_juv_moy_V_q)
#On ne conserve que les lignes quand il y a déversement car sinon = à un tirage
#à blanc
d_juv_moy_V_q_dev<-d_juv_moy_V_q[I_juv_moy[2:T,1]==1,]

#On récupére les lignes quand I_juv_moy=0 et on met des NA partout
d_juv_moy_V_q_ss_dev<-d_juv_moy_V_q[I_juv_moy[2:T,1]==0,]
len<-length(I_juv_moy[2:T,1][I_juv_moy[2:T,1]==0]) #pour calculer le nbr de 0 dans I_juv_moy pour vichy
d_juv_moy_V_q_ss_dev_2<-matrix(rep(NA,len*5),nrow=len,ncol=5)
d_juv_moy_V_q_ss_dev_2<-cbind(c(2:5,7:10,12:17,19:20,31),d_juv_moy_V_q_ss_dev_2)
dimnames(d_juv_moy_V_q_ss_dev_2)<-dimnames(d_juv_moy_V_q_ss_dev)


#On fusionne les 2 et on créé un vecteur d'ordre pour remettre les années de d_juv_moy_V_q_2 dans le bon ordre
d_juv_moy_V_q_2<-rbind(d_juv_moy_V_q_dev,d_juv_moy_V_q_ss_dev_2)
#ord<-c(seq(25,28,by=1),1,seq(29,32,by=1),2,seq(33,38,by=1),3,39,40,seq(4,13,by=1),41,seq(14,24,by=1))
#ord<-c(seq((14+T-32+1),(14+T-32+1+3),by=1),1,seq(28,31,by=1),2,seq(32,37,by=1),3,38,39,seq(4,13,by=1),40,seq(14,(14+T-32),by=1))

d_juv_moy_V_q<-d_juv_moy_V_q_2[order(d_juv_moy_V_q_2[,1]),2:6]

#On calcule les moyennes pour les années sans dev et on met NA partout
mean_res_na<-cbind(sum$statistics[I_juv_moy[2:T,1]==0,"Mean"])
mean_res_na[,1]<-NA
mean_res<-cbind(sum$statistics[I_juv_moy[2:T,1]==1,"Mean"])
#On ajoute une colonne avec le numéro de ligne récupéré en expression réguliére
mean_res_na<-cbind(as.numeric(gsub("[^0-9]","",gsub(",[0-9]","",row.names(mean_res_na)))),mean_res_na)
mean_res<-cbind(as.numeric(gsub("[^0-9]","",gsub(",[0-9]","",row.names(mean_res)))),mean_res)
#On fusionne les années avec et sans dev
mean_res<-rbind(mean_res,mean_res_na)
mean_res<-as.matrix(mean_res[order(mean_res[,1]),2])


png(filename=str_c(imgwd,"d_juv_moy_V.png"),width=800,height=800)

plot(1,1,type="n",axes=FALSE,xlim=c(0,T),xlab="Years",ylim=c(0,0.3),ylab="d_juv_moy_V")

# trace l'axe des ordonnées
axis(2,at = seq(0,0.3,by=0.05),labels=c(0,0.05,0.1,0.15,0.2,0.25,0.3),cex.axis =
0.9,las = 1,col = "grey55") # trace l'axe des abscisses
lab1=c(1976,1980,1990,2000,2010,1974+T)
axis(1,at = c(1,5,15,25,35,(T-1)),
		labels=lab1,
		cex.axis = 0.9,las = 1,col = "grey55")

for(i in 1:(T-1)){
	#whiskers
	#95%
	segments(i-0.15,d_juv_moy_V_q[i,5],i+0.15,d_juv_moy_V_q[i,5])
	segments(i,d_juv_moy_V_q[i,4],i,d_juv_moy_V_q[i,5])
	#5%
	segments(i-0.15,d_juv_moy_V_q[i,1],i+0.15,d_juv_moy_V_q[i,1])
	segments(i,d_juv_moy_V_q[i,2],i,d_juv_moy_V_q[i,1])
	#boxplot
	polygon(c(i-0.3,i+0.3,i+0.3,i-0.3),c(d_juv_moy_V_q[i,2],d_juv_moy_V_q[i,2],d_juv_moy_V_q[i,4],d_juv_moy_V_q[i,4]),col="green")
	#mean
	segments(i-0.3,mean_res[i,],i+0.3,mean_res[i,])
}

segments(x0=0,y0=mean(mean_res,na.rm=TRUE),y1=mean(mean_res,na.rm=TRUE),x1=T,col="red")
mtext(round(mean(mean_res,na.rm=TRUE),5),side=4,line=0,at=mean(mean_res,na.rm=TRUE),cex
= 0.8,col="red",las=1) 

dev.off()
@

\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}d_juv_moy_V.png}%{a_juv.png}
     \caption{d\_juv\_moy\_V}
     \label{d_juv_moy_V} 
\end{figure}

\clearpage

