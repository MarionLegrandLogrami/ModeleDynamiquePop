%====================================
%\section{sigma\_p\_comptage}
%====================================
<< sigma_p_comptage, echo=FALSE, eval=FALSE,results=hide >>=
tau_p_comptage <- read_param_coda("tau_p_comptage", datawd)
sigma_p_comptage <- sqrt(1 / tau_p_comptage)
dimnames(sigma_p_comptage)[[2]] <- "sigma_p_comptage" #comme on le recalcule à partir de tau_p_comptage il gardait ce nom sur le graph

report_param(sigma_p_comptage, imgwd, tabwd, "sigma_p_comptage",
             caption = "Statistiques de sigma\\_p\\comptage")
@

