}
colnames(res_wild_moy_L_std)<-colnames(res_wild_moy_L)
res_wild_moy_L_std<-as.mcmc(res_wild_moy_L_std)

sum=summary(res_wild_moy_L_std, probs=seq(0,1,0.1))
res_wild_moy_L_std_q<-sum$quantiles
mean_res<-cbind(sum$statistics[,"Mean"])


png(filename=str_c(imgwd,"res_wild_moy_L_std.png"),width=800,height=800)

plot(1,1,type="n",axes=FALSE,xlim=c(0,T),xlab="Years",ylim=c(-3,3),ylab="res_wild_moy_L_std")

# trace l'axe des ordonnées
axis(2,at = seq(-3,3,by=0.5),labels=TRUE,cex.axis = 0.9,las = 1,col = "grey55")
# trace l'axe des abscisses
lab1=c(1976,1980,1990,2000,2010,1974+T)
axis(1,at = c(1,5,15,25,35,(T-1)),
		labels=lab1,
		cex.axis = 0.9,las = 1,col = "grey55")

for(i in 1:(T-1)){
	#whiskers
	#95%
	segments(i-0.15,res_wild_moy_L_std_q[i,5],i+0.15,res_wild_moy_L_std_q[i,5])
	segments(i,res_wild_moy_L_std_q[i,4],i,res_wild_moy_L_std_q[i,5])
	#5%
	segments(i-0.15,res_wild_moy_L_std_q[i,1],i+0.15,res_wild_moy_L_std_q[i,1])
	segments(i,res_wild_moy_L_std_q[i,2],i,res_wild_moy_L_std_q[i,1])
	#boxplot
	polygon(c(i-0.3,i+0.3,i+0.3,i-0.3),c(res_wild_moy_L_std_q[i,2],res_wild_moy_L_std_q[i,2],res_wild_moy_L_std_q[i,4],res_wild_moy_L_std_q[i,4]),col="green")
	#mean
	segments(i-0.3,mean_res[i,],i+0.3,mean_res[i,])
}

segments(x0=0,y0=mean(mean_res),y1=mean(mean_res),x1=T,col="red")
mtext(round(mean(mean_res),5),side=4,line=0,at=mean(mean_res),cex = 0.8,col="red",las=1)
dev.off()
@

