	#mean
	segments(i-0.3,mean_res[i-17,],i+0.3,mean_res[i-17,])
}

for(i in 42:T){
	points(x=i,y=min_L[i],pch=16)
}

segments(x0=0,y0=mean(mean_res),y1=mean(mean_res),x1=T,col="red")
