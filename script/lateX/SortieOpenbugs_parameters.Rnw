%====================================
\subsection{res\_wild\_moy}
%====================================

res\_wild\_moy représente les résidus de la densité de juvénile sauvage à l'échelle de chacun des secteurs du modèle.

%------------------------------------
\subsubsection{res\_wild\_moy\_Vichy\_standardisé}
%------------------------------------
<< res_wild_moy_V, echo=FALSE, eval=TRUE,results=hide >>=
res_wild_moy_V=read.coda(str_c(datawd,"res_wild_VCODAchain1.txt"),str_c(datawd,"res_wild_VCODAindex.txt"))
sigma_wild_m=read.coda(str_c(datawd,"/parameters/sigma_wild_moyCODAchain1.txt"),str_c(datawd,"/parameters/sigma_wild_moyCODAindex.txt"))

res_wild_moy_V_std<-array(NA,c(nrow(res_wild_moy_V),T))

for (t in 1:T){
  for (i in 1:nrow(res_wild_moy_V)){
  
  res_wild_moy_V_std[i,t]<-res_wild_moy_V[i,t]/sigma_wild_m[i]
  }
}
colnames(res_wild_moy_V_std)<-colnames(res_wild_moy_V)
res_wild_moy_V_std<-as.mcmc(res_wild_moy_V_std)


sum=summary(res_wild_moy_V_std, probs=seq(0,1,0.1))
res_wild_moy_V_std_q<-sum$quantiles
mean_res<-cbind(sum$statistics[,"Mean"])


png(filename=str_c(imgwd,"res_wild_moy_V_std.png"),width=800,height=800)

plot(1,1,type="n",axes=FALSE,xlim=c(0,T),xlab="Years",ylim=c(-3,3),ylab="res_wild_moy_V_std")

# trace l'axe des ordonnées
axis(2,at = seq(-3,3,by=0.5),labels= seq(-3,3,by=0.5),cex.axis = 0.9,las = 1,col = "grey55")
# trace l'axe des abscisses
lab1=c(1976,1980,1990,2000,2010,1974+T)
axis(1,at = c(1,5,15,25,35,(T-1)),
		labels=lab1,
		cex.axis = 0.9,las = 1,col = "grey55")

for(i in 1:(T-1)){
	#whiskers
	#95%
	segments(i-0.15,res_wild_moy_V_std_q[i,5],i+0.15,res_wild_moy_V_std_q[i,5])
	segments(i,res_wild_moy_V_std_q[i,4],i,res_wild_moy_V_std_q[i,5])
	#5%
	segments(i-0.15,res_wild_moy_V_std_q[i,1],i+0.15,res_wild_moy_V_std_q[i,1])
	segments(i,res_wild_moy_V_std_q[i,2],i,res_wild_moy_V_std_q[i,1])
	#boxplot
	polygon(c(i-0.3,i+0.3,i+0.3,i-0.3),c(res_wild_moy_V_std_q[i,2],res_wild_moy_V_std_q[i,2],res_wild_moy_V_std_q[i,4],res_wild_moy_V_std_q[i,4]),col="green")
	#mean
	segments(i-0.3,mean_res[i,],i+0.3,mean_res[i,])
}

segments(x0=0,y0=mean(mean_res),y1=mean(mean_res),x1=T,col="red")
mtext(round(mean(mean_res),5),side=4,line=0,at=mean(mean_res),cex = 0.8,col="red",las=1)
dev.off()
@

\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}res_wild_moy_V_std.png}
     \caption{res\_wild\_moy\_V\_std}
     \label{res_wild_moy_V_std} 
\end{figure}

\clearpage


