%====================================
\subsection{res\_juv\_moy}
%====================================

res\_juv\_moy représente les résidus de la densité de juvénile déversés à l'échelle de chacun des secteurs du modèle.

%------------------------------------
\subsubsection{res\_juv\_moy\_Vichy\_standardisé}
%------------------------------------
<< res_juv_moy_V, echo=FALSE, eval=TRUE,results=hide >>=
res_juv_moy_V=read.coda(str_c(datawd,"res_juv_VCODAchain1.txt"),str_c(datawd,"res_juv_VCODAindex.txt"))
sigma_juv_m=read.coda(str_c(datawd,"parameters/sigma_juv_moyCODAchain1.txt"),str_c(datawd,"parameters/sigma_juv_moyCODAindex.txt"))

res_juv_moy_V_std<-array(NA,c(nrow(res_juv_moy_V),(T-1)))

for (t in 1:(T-1)){
  for (i in 1:nrow(res_juv_moy_V)){
  
  res_juv_moy_V_std[i,t]<-res_juv_moy_V[i,t]/sigma_juv_m[i]
  }
}
colnames(res_juv_moy_V_std)<-colnames(res_juv_moy_V)
res_juv_moy_V_std<-as.mcmc(res_juv_moy_V_std)

#On a besoin de récupérer les données depuis Openbugs concernant les I_juv_moy
#pour ne pas les réécrire à la main et risquer de faire des erreurs

library(coda) 
bugs2jags(str_c(datawd,"data.txt"),"data_covariable_2019_12_12.R")
source("data_covariable_2019_12_12.R")
head(I_juv_moy) #ça marche !! :D

sum=summary(res_juv_moy_V_std, probs=seq(0,1,0.1))
res_juv_moy_V_std_q<-sum$quantiles
#Add column to sort
res_juv_moy_V_std_q<-cbind(2:T,res_juv_moy_V_std_q)

#On ne conserve que les lignes quand il y a déversement car sinon = à un tirage
#à blanc
res_juv_moy_V_std_q_dev<-res_juv_moy_V_std_q[I_juv_moy[2:T,1]==1,]

#On récupére les lignes quand I_juv_moy=0 et on met des NA partout
res_juv_moy_V_std_q_ss_dev<-res_juv_moy_V_std_q[I_juv_moy[2:T,1]==0,]
res_juv_moy_V_std_q_ss_dev[,2:6]<-NA

#On fusionne les 2
res_juv_moy_V_std_q_2<-rbind(res_juv_moy_V_std_q_dev,res_juv_moy_V_std_q_ss_dev)
res_juv_moy_V_std_q<-res_juv_moy_V_std_q_2[order(res_juv_moy_V_std_q_2[,1]),2:6]


#On calcule les moyennes pour les années sans dev et on met NA partout
mean_res_na<-cbind(sum$statistics[I_juv_moy[2:T,1]==0,"Mean"])
mean_res_na[,1]<-NA
mean_res<-cbind(sum$statistics[I_juv_moy[2:T,1]==1,"Mean"])
#On ajoute une colonne avec le numéro de ligne récupéré en expression réguliére
mean_res_na<-cbind(as.numeric(gsub("[^0-9]","",gsub(",[0-9]","",row.names(mean_res_na)))),mean_res_na)
mean_res<-cbind(as.numeric(gsub("[^0-9]","",gsub(",[0-9]","",row.names(mean_res)))),mean_res)
#On fusionne les années avec et sans dev
mean_res<-rbind(mean_res,mean_res_na)
mean_res<-as.matrix(mean_res[order(mean_res[,1]),2])


png(filename=str_c(imgwd,"res_juv_moy_V_std.png"),width=800,height=800)

plot(1,1,type="n",axes=FALSE,xlim=c(0,T),xlab="Years",ylim=c(-3,3),ylab="res_juv_moy_V_std")

# trace l'axe des ordonnées
axis(2,at = seq(-3,3,by=0.5),labels=TRUE,cex.axis = 0.9,las = 1,col = "grey55")
# trace l'axe des abscisses
lab1=c(1976,1980,1990,2000,2010,1974+T)
axis(1,at = c(1,5,15,25,35,(T-1)),
		labels=lab1,
		cex.axis = 0.9,las = 1,col = "grey55")

for(i in 1:(T-1)){
	#whiskers
	#95%
	segments(i-0.15,res_juv_moy_V_std_q[i,5],i+0.15,res_juv_moy_V_std_q[i,5])
	segments(i,res_juv_moy_V_std_q[i,4],i,res_juv_moy_V_std_q[i,5])
	#5%
	segments(i-0.15,res_juv_moy_V_std_q[i,1],i+0.15,res_juv_moy_V_std_q[i,1])
	segments(i,res_juv_moy_V_std_q[i,2],i,res_juv_moy_V_std_q[i,1])
	#boxplot
	polygon(c(i-0.3,i+0.3,i+0.3,i-0.3),c(res_juv_moy_V_std_q[i,2],res_juv_moy_V_std_q[i,2],res_juv_moy_V_std_q[i,4],res_juv_moy_V_std_q[i,4]),col="green")
	#mean
	segments(i-0.3,mean_res[i,],i+0.3,mean_res[i,])
}

segments(x0=0,y0=mean(mean_res,na.rm=TRUE),y1=mean(mean_res,na.rm=TRUE),x1=T,col="red")
mtext(round(mean(mean_res,na.rm=TRUE),5),side=4,line=0,at=mean(mean_res,na.rm=TRUE),cex
= 0.8,col="red",las=1) 
dev.off()
@

