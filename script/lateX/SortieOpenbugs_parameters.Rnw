Q_MSL_deval <- data.frame(sta=rep("Q Montjean-sur-Loire dévalaison",length(Q_MSL_deval)),year=1975:(1974+T),Q=Q_MSL_deval)
Q_MSL_mont <- data.frame(sta=rep("Q Montjean-sur-Loire montaison",length(Q_MSL_mont)),year=1975:(1974+T),Q=Q_MSL_mont)
Q_VB_deval <- data.frame(sta=rep("Q Vieille-Brioude dévalaison",length(Q_VB_deval)),year=1975:(1974+T),Q=Q_VB_deval)

Q_surv_serie_bugs<-rbind(Q_MSL_deval,Q_MSL_mont,Q_VB_deval)

Q_surv_serie_bugs$sta <- factor(Q_surv_serie_bugs$sta, levels = c("Q Montjean-sur-Loire montaison", "Q Montjean-sur-Loire dévalaison","Q Vieille-Brioude dévalaison"))

plot_Q_surv <- ggplot(data=Q_surv_serie_bugs,aes(x=year,y=Q))+
