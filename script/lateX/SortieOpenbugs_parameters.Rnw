     \caption{res\_juv\_moy\_L\_std}
     \label{res_juv_moy_L_std} 
\end{figure}

\clearpage

%------------------------------------
\subsubsection{res\_juv\_moy\_Poutes\_standardisé}
%------------------------------------
<< res_juv_moy_P, echo=FALSE, eval=TRUE,results=hide >>=
res_juv_moy_P=read.coda(str_c(datawd,"res_juv_PCODAchain1.txt"),str_c(datawd,"res_juv_PCODAindex.txt"))
sigma_juv_m=read.coda(str_c(datawd,"parameters/sigma_juv_moyCODAchain1.txt"),str_c(datawd,"parameters/sigma_juv_moyCODAindex.txt"))

res_juv_moy_P_std<-array(NA,c(nrow(res_juv_moy_P),(T-12)))

for (t in 1:(T-12)){
  for (i in 1:nrow(res_juv_moy_P)){
  
  res_juv_moy_P_std[i,t]<-res_juv_moy_P[i,t]/sigma_juv_m[i]
  }
}
colnames(res_juv_moy_P_std)<-colnames(res_juv_moy_P)
res_juv_moy_P_std<-as.mcmc(res_juv_moy_P_std)

#On a besoin de récupérer les données depuis Openbugs concernant les I_juv_moy
#pour ne pas les réécrire à la main et risquer de faire des erreurs

library(coda) 
bugs2jags(str_c(datawd,"data.txt"),"data_covariable_2019_12_12.R")
source("data_covariable_2019_12_12.R")
head(I_juv_moy) #ça marche !! :D

sum=summary(res_juv_moy_P_std, probs=seq(0,1,0.1))
res_juv_moy_P_std_q<-sum$quantiles
#Add column to sort
res_juv_moy_P_std_q<-cbind(13:T,res_juv_moy_P_std_q)

#On ne conserve que les lignes quand il y a déversement car sinon = à un tirage
#à blanc
res_juv_moy_P_std_q_dev<-res_juv_moy_P_std_q[I_juv_moy[13:T,4]==1,]

#On récupére les lignes quand I_juv_moy=0 et on met des NA partout
res_juv_moy_P_std_q_ss_dev<-res_juv_moy_P_std_q[I_juv_moy[13:T,4]==0,]
res_juv_moy_P_std_q_ss_dev[,2:6]<-NA

#On fusionne les 2
res_juv_moy_P_std_q_2<-rbind(res_juv_moy_P_std_q_dev,res_juv_moy_P_std_q_ss_dev)
res_juv_moy_P_std_q<-res_juv_moy_P_std_q_2[order(res_juv_moy_P_std_q_2[,1]),2:6]


#On calcule les moyennes pour les années sans dev et on met NA partout
mean_res_na<-cbind(sum$statistics[I_juv_moy[13:T,4]==0,"Mean"])
mean_res_na[,1]<-NA
mean_res<-cbind(sum$statistics[I_juv_moy[13:T,4]==1,"Mean"])
#On ajoute une colonne avec le numéro de ligne récupéré en expression réguliére
mean_res_na<-cbind(as.numeric(gsub("[^0-9]","",gsub(",[0-9]","",row.names(mean_res_na)))),mean_res_na)
mean_res<-cbind(as.numeric(gsub("[^0-9]","",gsub(",[0-9]","",row.names(mean_res)))),mean_res)
#On fusionne les années avec et sans dev
mean_res<-rbind(mean_res,mean_res_na)
mean_res<-as.matrix(mean_res[order(mean_res[,1]),2])

png(filename=str_c(imgwd,"res_juv_moy_P_std.png"),width=800,height=800)

plot(1,1,type="n",axes=FALSE,xlim=c(0,(nrow(res_juv_moy_P_std_q)+1)),xlab="Years",ylim=c(-3,3),ylab="res_juv_moy_P")

# trace l'axe des ordonnées
axis(2,at = seq(-3,3,by=0.5),labels=TRUE,cex.axis = 0.9,las = 1,col = "grey55")
# trace l'axe des abscisses
lab1=c(1987,1990,2000,2010,1974+T)
axis(1,at = c(1,4,14,24,(T-12)),
		labels=lab1,
		cex.axis = 0.9,las = 1,col = "grey55")

for(i in 1:nrow(res_juv_moy_P_std_q)){
	#whiskers
	#95%
	segments(i-0.15,res_juv_moy_P_std_q[i,5],i+0.15,res_juv_moy_P_std_q[i,5])
	segments(i,res_juv_moy_P_std_q[i,4],i,res_juv_moy_P_std_q[i,5])
	#5%
	segments(i-0.15,res_juv_moy_P_std_q[i,1],i+0.15,res_juv_moy_P_std_q[i,1])
	segments(i,res_juv_moy_P_std_q[i,2],i,res_juv_moy_P_std_q[i,1])
	#boxplot
	polygon(c(i-0.3,i+0.3,i+0.3,i-0.3),c(res_juv_moy_P_std_q[i,2],res_juv_moy_P_std_q[i,2],res_juv_moy_P_std_q[i,4],res_juv_moy_P_std_q[i,4]),col="green")
	#mean
	segments(i-0.3,mean_res[i,],i+0.3,mean_res[i,])
}

segments(x0=0,y0=mean(mean_res,na.rm=TRUE),y1=mean(mean_res,na.rm=TRUE),x1=(T-11),col="red")
mtext(round(mean(mean_res,na.rm=TRUE),5),side=4,line=0,at=mean(mean_res,na.rm=TRUE),cex
= 0.8,col="red",las=1) 

dev.off()
@

\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}res_juv_moy_P_std.png}%{a_juv.png}
     \caption{res\_juv\_moy\_P\_std}
     \label{res_juv_moy_P_std} 
\end{figure}

\clearpage


%=================================================================================
\subsection{Corrélations spatiales des résidus de densité de juvéniles sauvages}
%=================================================================================
<< corr_res_wild_moy, echo=FALSE, eval=TRUE,results=hide >>=

res_wild_moy_V=read.coda(str_c(datawd,"res_wild_VCODAchain1.txt"),str_c(datawd,"res_wild_VCODAindex.txt"))
res_wild_moy_A=read.coda(str_c(datawd,"res_wild_ACODAchain1.txt"),str_c(datawd,"res_wild_ACODAindex.txt"))
res_wild_moy_L=read.coda(str_c(datawd,"res_wild_LCODAchain1.txt"),str_c(datawd,"res_wild_LCODAindex.txt"))
res_wild_moy_P=read.coda(str_c(datawd,"res_wild_PCODAchain1.txt"),str_c(datawd,"res_wild_PCODAindex.txt"))

corr_wild <- array(NA,dim=c(10000,6))

for (i in 1:10000) {
		corr_wild[i,1] <- cor(res_wild_moy_V[i,],res_wild_moy_A[i,])
		corr_wild[i,2] <- cor(res_wild_moy_V[i,],res_wild_moy_L[i,])
		corr_wild[i,3] <- cor(res_wild_moy_V[i,12:T],res_wild_moy_P[i,1:(T-11)])
		corr_wild[i,4] <- cor(res_wild_moy_A[i,],res_wild_moy_L[i,])
		corr_wild[i,5] <- cor(res_wild_moy_A[i,12:T],res_wild_moy_P[i,1:(T-11)])
		corr_wild[i,6] <- cor(res_wild_moy_L[i,12:T],res_wild_moy_P[i,1:(T-11)])
}

colnames(corr_wild) <-c("Vichy-Alagnon","Vichy-Langeac","Vichy-Poutès","Alagnon-Langeac","Alagnon-Poutès","Langeac-Poutès")

corr_wild <- stack(as.data.frame(corr_wild))

png(filename=str_c(imgwd,"corr_res_wild.png"),width=800,height=800)
ggplot(corr_wild, aes(x = ind, y = values)) +
		geom_boxplot() +
		geom_hline(yintercept=0, color="red",linewidth=1)+
		labs(title = "Corrélation spatiales des résidus de densités de juvéniles sauvages", x = NULL, y = "Coefficient de corrélation") +
		theme_minimal()

dev.off()


@


\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}corr_res_wild.png}
     \caption{res\_juv\_moy\_P\_std}
     \label{res_juv_moy_P_std} 
\end{figure}

\clearpage

%=================================================================================
\subsection{Corrélations spatiales des résidus de densité de juvéniles élevages}
%=================================================================================
<< corr_res_juv_moy, echo=FALSE, eval=TRUE,results=hide >>=

res_juv_moy_V=read.coda(str_c(datawd,"res_juv_VCODAchain1.txt"),str_c(datawd,"res_juv_VCODAindex.txt"))
res_juv_moy_A=read.coda(str_c(datawd,"res_juv_ACODAchain1.txt"),str_c(datawd,"res_juv_ACODAindex.txt"))
res_juv_moy_L=read.coda(str_c(datawd,"res_juv_LCODAchain1.txt"),str_c(datawd,"res_juv_LCODAindex.txt"))
res_juv_moy_P=read.coda(str_c(datawd,"res_juv_PCODAchain1.txt"),str_c(datawd,"res_juv_PCODAindex.txt"))

#Il faut supprimer les données quand il n'y a pas de déversement car c'est tiré à blanc
head(I_juv_moy) #ça marche !! :D

for (t in 1:(T-1)){
	res_juv_moy_V[,t] <- dplyr::case_when(I_juv_moy[(t+1),1]==1 ~ res_juv_moy_V[,t],
										  TRUE ~ NA)
	res_juv_moy_A[,t] <- dplyr::case_when(I_juv_moy[(t+1),2]==1 ~ res_juv_moy_A[,t],
										  TRUE ~ NA)
	res_juv_moy_L[,t] <- dplyr::case_when(I_juv_moy[(t+1),3]==1 ~ res_juv_moy_L[,t],
										  TRUE ~ NA)
}

for (t in 1:(T-12)){
	res_juv_moy_P[,t] <- dplyr::case_when(I_juv_moy[(t+12),4]==1 ~ res_juv_moy_P[,t],
			TRUE ~ NA)
}

corr_juv <- array(NA,dim=c(10000,6))

for (i in 1:10000) {
	corr_juv[i,1] <- cor(res_juv_moy_V[i,],res_juv_moy_A[i,],use="complete.obs") #use="complete.obs" permet de ne calculer que sur les années où on a des valeurs (=il y a eu des déversements)
	corr_juv[i,2] <- cor(res_juv_moy_V[i,],res_juv_moy_L[i,],use="complete.obs")
	corr_juv[i,3] <- cor(res_juv_moy_V[i,12:(T-1)],res_juv_moy_P[i,1:(T-12)],use="complete.obs")
	corr_juv[i,4] <- cor(res_juv_moy_A[i,],res_juv_moy_L[i,],use="complete.obs")
	corr_juv[i,5] <- cor(res_juv_moy_A[i,12:(T-1)],res_juv_moy_P[i,1:(T-12)],use="complete.obs")
	corr_juv[i,6] <- cor(res_juv_moy_L[i,12:(T-1)],res_juv_moy_P[i,1:(T-12)],use="complete.obs")
}

colnames(corr_juv) <-c("Vichy-Alagnon","Vichy-Langeac","Vichy-Poutès","Alagnon-Langeac","Alagnon-Poutès","Langeac-Poutès")

corr_juv <- stack(as.data.frame(corr_juv))

png(filename=str_c(imgwd,"corr_res_juv.png"),width=800,height=800)
ggplot(corr_juv, aes(x = ind, y = values)) +
		geom_boxplot() +
		geom_hline(yintercept=0, color="red",linewidth=1)+
		labs(title = "Corrélation spatiales des résidus de densités de juvéniles élevages", x = NULL, y = "Coefficient de corrélation") +
		theme_minimal()

dev.off()

@

\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}corr_res_wild.png}
     \caption{res\_juv\_moy\_P\_std}
     \label{res_juv_moy_P_std} 
\end{figure}

\clearpage


