<<adulte_Langeac_Poutes, echo=FALSE, eval=TRUE,results=hide>>=

adulte_langeac<-array(NA,dim=c(10000,T))

for(t in 1:11){
   for(i in 1:10000){
   adulte_langeac[i,t]<-N_langeac[i,t]#Poutès est fermé tous les poissons restent sur Langeac-Poutès
   }
}
for(t in 12:T){
  for(i in 1:10000){
    adulte_langeac[i,t]<-N_langeac[i,t]-adulte_poutes[i,t]
  }
}
adulte_langeac2<-as.mcmc(adulte_langeac[,1:T])

sum=summary(adulte_langeac2, probs=seq(0,1,0.1))
adulte_langeac_q<-sum$quantiles
mean_res<-cbind(sum$statistics[,"Mean"])

#on ajoute les données de comptage quand stations de Langeac et Poutès fonctionnent en même temps
