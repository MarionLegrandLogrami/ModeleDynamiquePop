segments(x0=12,y0=mean(adulte_langeac_q[12:T,3]),y1=mean(adulte_langeac_q[12:T,3]),x1=T+1,col="red")
mtext(round(mean(adulte_langeac_q[12:T,3]),2),side=4,line=0,at=mean(adulte_langeac_q[12:T,3]),cex = 0.8,col="red",las=1)
dev.off()
@

\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}adultes_langeac.png}%{a_juv.png}
     \caption{Adultes restant sur le secteur Langeac-Poutès}
     \label{adultes_langeac_poutes}
\end{figure}

Le nombre d'adultes restant sur le secteur Langeac-Poutès est estimé à partir des effectifs qui sont passés à Vichy mais ne sont pas allés sur l'Alagnon et n'ont pas été capturé par la pisciculture et qui n'ont pas non plus franchi Poutès (on soustrait les effectifs comptés ou estimés à Poutès). Lorsque les stations de Langeac et Poutès ont fonctionné sur la même période on soustrait les effectifs comptés à Poutès à ceux de Langeac (pour rappel, la station de Langeac est considérée comme une station non-exhaustive dans le modèle).

\clearpage

%=================================================================================
\subsubsection{Pourcentage d'adultes dans les différents secteurs}
%=================================================================================

<<pour_adulte_secteur, echo=FALSE, eval=TRUE,results=hide >>=

#N_vichy = adultes total sur l'ensemble de la zone

prop_VL<-array(0,dim=c(10000,T))
prop_A<-array(0,dim=c(10000,T))
prop_LP<-array(0,dim=c(10000,T))
prop_P<-array(0,dim=c(10000,T))
validation<-array(0,dim=c(10000,T))

#On commence par gérer le cas de Poutès qui est le plus compliqué
#Pour poutes on a les comptage entre 1986 et 2020 (avant=0) à partir 2020 il s'agit d'estimation
#Pour Vichy : estimation avant 1997 + en 2004 sinon comptage réel
for (t in 1:11){
  for (i in 1:10000){
    prop_P[i,t]<- 0
  }
}
for (t in 12:22){
  for (i in 1:10000){
    prop_P[i,t]<-adulte_poutes[i,t] / N_vichy[i,t]
  }
}
for (t in 23:29){
  for (i in 1:10000){
    prop_P[i,t]<-adulte_poutes[i,t] / N[t,1]
  }
}

for (t in 30:30){
  for (i in 1:10000){
    prop_P[i,t]<-adulte_poutes[i,t] / N_vichy[i,(t-7)]
  }
}

for (t in 31:46){
  for (i in 1:10000){
    prop_P[i,t]<-adulte_poutes[i,t] / N[t,1]
  }
}
for (t in 47:T){
  for (i in 1:10000){
    prop_P[i,t]<-N_poutes[i,(t-46)] / N[t,1]
  }
}

#On gère les autres secteurs

for (t in 1:22){
  for (i in 1:10000){
      prop_VL[i,t]<-adulte_vichy[i,t] / N_vichy[i,t]
      prop_A[i,t] <- N_alagnon[i,t] / N_vichy[i,t]
      prop_LP[i,t]<- adulte_langeac[i,t] / N_vichy[i,t]
  }
}
for (t in 23:29){
  for (i in 1:10000){
     prop_VL[i,t]<-adulte_vichy[i,t] / N[t,1]
     prop_A[i,t] <- N_alagnon[i,t] / N[t,1]
     prop_LP[i,t]<- adulte_langeac[i,t] / N[t,1]
  }
}

for (t in 30:30){
  for (i in 1:10000){
      prop_VL[i,t]<-adulte_vichy[i,t] / N_vichy[i,(t-7)]
      prop_A[i,t] <- N_alagnon[i,t] / N_vichy[i,(t-7)]
      prop_LP[i,t]<- adulte_langeac[i,t] / N_vichy[i,(t-7)]
  }
}

for (t in 31:T){
  for (i in 1:10000){
     prop_VL[i,t]<-adulte_vichy[i,t] / N[t,1]
     prop_A[i,t] <- N_alagnon[i,t] / N[t,1]
     prop_LP[i,t]<- adulte_langeac[i,t] / N[t,1]
  }
}

#Validation
for (t in 1:T){
  for (i in 1:10000){
    validation[i,t]<-prop_VL[i,t]+prop_A[i,t]+prop_LP[i,t]+prop_P[i,t]
  }
}

prop_VL2<-as.mcmc(prop_VL)
sum=summary(prop_VL2, probs=seq(0,1,0.1))
prop_VL2_q<-sum$quantiles
mean_prop_VL2<-cbind(sum$statistics[,"Mean"])

prop_A2<-as.mcmc(prop_A)
sum=summary(prop_A2, probs=seq(0,1,0.1))
prop_A2_q<-sum$quantiles
mean_prop_A2<-cbind(sum$statistics[,"Mean"])

prop_LP2<-as.mcmc(prop_LP)
sum=summary(prop_LP2, probs=seq(0,1,0.1))
prop_LP2_q<-sum$quantiles
mean_prop_LP2<-cbind(sum$statistics[,"Mean"])

prop_P2<-as.mcmc(prop_P)
sum=summary(prop_P2, probs=seq(0,1,0.1))
prop_P2_q<-sum$quantiles
mean_prop_P2<-cbind(sum$statistics[,"Mean"])

png(filename=str_c(imgwd,"proportion_adultes.png"),width=800,height=800)

par(mfrow=c(4,1))
plot(1,1,type="n",axes=FALSE,xlim=c(0,T),xlab="Years",ylim=c(0,1),ylab="proportion adultes",main="Proportion d'adultes sur le secteur Vichy-Langeac")

# trace l'axe des ordonnées
axis(2,at = seq(0,1,by=0.2),labels=seq(0,1,by=0.2),cex.axis = 0.9,las = 1,col = "grey55")
# trace l'axe des abscisses
lab1=c(1975,1980,1990,2000,2010,1974+T)
axis(1,at = c(1,6,16,26,36,T),
		labels=lab1,
		cex.axis = 0.9,las = 1,col = "grey55")


for(i in 1:T){
	#whiskers
	#95%
	segments(i-0.15,prop_VL2_q[(i),5],i+0.15,prop_VL2_q[(i),5])
