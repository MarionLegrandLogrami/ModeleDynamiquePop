<< d_juv_moy_P, echo=FALSE, eval=TRUE,results=hide >>=
d_juv_moy_P=read.coda(str_c(datawd,"stocking_juv_PCODAchain1.txt"),str_c(datawd,"stocking_juv_PCODAindex.txt"))


#On a besoin de récupérer les données depuis Openbugs concernant les I_juv_moy
#pour ne pas les réécrire à la main et risquer de faire des erreurs

library(coda) 
bugs2jags(str_c(datawd,"data.txt"),"data_covariable_2019_12_12.R")
source("data_covariable_2019_12_12.R")
head(I_juv_moy) #ça marche !! :D

sum=summary(d_juv_moy_P, probs=seq(0,1,0.1))
d_juv_moy_P_q<-sum$quantiles
#Add column to sort
d_juv_moy_P_q<-cbind(13:T,d_juv_moy_P_q)
#On ne conserve que les lignes quand il y a déversement car sinon = à un tirage
#à blanc
d_juv_moy_P_q_dev<-d_juv_moy_P_q[I_juv_moy[13:T,4]==1,]

#On récupére les lignes quand I_juv_moy=0 et on met des NA partout
d_juv_moy_P_q_ss_dev<-d_juv_moy_P_q[I_juv_moy[13:T,4]==0,]
d_juv_moy_P_q_ss_dev[,2:6]<-NA

#On fusionne les 2
d_juv_moy_P_q_2<-rbind(d_juv_moy_P_q_dev,d_juv_moy_P_q_ss_dev)
d_juv_moy_P_q<-d_juv_moy_P_q_2[order(d_juv_moy_P_q_2[,1]),2:6]

#On calcule les moyennes pour les années sans dev et on met NA partout
mean_res_na<-cbind(sum$statistics[I_juv_moy[13:T,4]==0,"Mean"])
mean_res_na[,1]<-NA
mean_res<-cbind(sum$statistics[I_juv_moy[13:T,4]==1,"Mean"])
#On ajoute une colonne avec le numéro de ligne récupéré en expression réguliére
mean_res_na<-cbind(as.numeric(gsub("[^0-9]","",gsub(",[0-9]","",row.names(mean_res_na)))),mean_res_na)
mean_res<-cbind(as.numeric(gsub("[^0-9]","",gsub(",[0-9]","",row.names(mean_res)))),mean_res)
#On fusionne les années avec et sans dev
mean_res<-rbind(mean_res,mean_res_na)
mean_res<-as.matrix(mean_res[order(mean_res[,1]),2])

png(filename=str_c(imgwd,"d_juv_moy_P.png"),width=800,height=800)

plot(1,1,type="n",axes=FALSE,xlim=c(0,nrow(d_juv_moy_P_q)),xlab="Years",ylim=c(0,0.8),ylab="d_juv_moy_P")

# trace l'axe des ordonnées
axis(2,at = seq(0,0.8,by=0.2),labels=c(0,0.2,0.4,0.6,0.8),cex.axis = 0.9,las =
1,col = "grey55") # trace l'axe des abscisses
lab1=c(1987,1990,2000,2010,(1974+T))
axis(1,at = c(1,4,14,24,nrow(d_juv_moy_P_q)),
		labels=lab1,
		cex.axis = 0.9,las = 1,col = "grey55")

for(i in 1:nrow(d_juv_moy_P_q)){
	#whiskers
	#95%
	segments(i-0.15,d_juv_moy_P_q[i,5],i+0.15,d_juv_moy_P_q[i,5])
	segments(i,d_juv_moy_P_q[i,4],i,d_juv_moy_P_q[i,5])
