	segments(i,N_langeac_count_q[i-11,2],i,N_langeac_count_q[i-11,1])
	#boxplot
	polygon(c(i-0.3,i+0.3,i+0.3,i-0.3),c(N_langeac_count_q[i-11,2],N_langeac_count_q[i-11,2],N_langeac_count_q[i-11,4],N_langeac_count_q[i-11,4]),col="green")
	#mean
	segments(i-0.3,mean_res[i-11,],i+0.3,mean_res[i-11,])
}


for(i in 29:34){
	points(x=i,y=min_L[i],pch=16)
}

for(i in 35:41){
	#whiskers
	#95%
	segments(i-0.15,N_langeac_count_q[i-17,5],i+0.15,N_langeac_count_q[i-17,5])
	segments(i,N_langeac_count_q[i-17,4],i,N_langeac_count_q[i-17,5])
