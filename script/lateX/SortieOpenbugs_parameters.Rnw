%=================================================================================
\subsection{res\_p\_alagnon\_standardisé}
%================================================================================
<< res_p_alagnon, echo=FALSE, eval=TRUE,results=hide >>=
res_p_alagnon=read.coda(str_c(datawd,"simulation/res_p_alagnonCODAchain1.txt"),str_c(datawd,"simulation/res_p_alagnonCODAindex.txt"))
sigma_p_alagnon=read.coda(str_c(datawd,"sigma_p_alagnonCODAchain1.txt"),str_c(datawd,"sigma_p_alagnonCODAindex.txt"))

res_p_alagnon_std<-array(NA,c(nrow(res_p_alagnon),T))

for (t in 1:T){
  for (i in 1:nrow(res_p_alagnon)){
  
  res_p_alagnon_std[i,t]<-res_p_alagnon[i,t]/sigma_p_alagnon[i]
  }
}
colnames(res_p_alagnon_std)<-colnames(res_p_alagnon)
res_p_alagnon_std<-as.mcmc(res_p_alagnon_std)

#Pour une raison mystérieuse la fonction quantiles utilisée par Guillaume D ne donne pas les mêmes
#résultats que le summary$quantiles. Après vérif du boxplot sous openbugs, le bon graph est celui utilisant la méthode summary
#Méthode quantiles : res_p_poutes_q=array(0,c(28,5))
#for (t in 1:28){	
#	res_p_langeac_q[t,]=quantile(res_p_langeac[t,],probs=c(0.05,0.25,0.5,0.75,0.95),names=FALSE)
#}

sum=summary(res_p_alagnon_std, probs=seq(0,1,0.1))
res_p_alagnon_std_q<-sum$quantiles
mean_res<-cbind(sum$statistics[,"Mean"])

png(filename=str_c(imgwd,"res_p_alagnon_std.png"),width=800,height=800)

plot(1,1,type="n",axes=FALSE,xlim=c(0,T+1),xlab="Years",ylim=c(-3,3),ylab="res_p_alagnon_std")

# trace l'axe des ordonnées
axis(2,at = seq(-3,3,by=0.5),labels=seq(-3,3,by=0.5),cex.axis = 0.9,las = 1,col = "grey55")
# trace l'axe des abscisses
lab1=c(1975,1980,1990,2000,1974+T)
axis(1,at = c(1,6,16,26,T),
		labels=lab1,
		cex.axis = 0.9,las = 1,col = "grey55")

for(i in 1:T){
	#whiskers
	#97,5%
	segments(i-0.15,res_p_alagnon_std_q[i,5],i+0.15,res_p_alagnon_std_q[i,5])
	segments(i,res_p_alagnon_std_q[i,4],i,res_p_alagnon_std_q[i,5])
	#2,5%
	segments(i-0.15,res_p_alagnon_std_q[i,1],i+0.15,res_p_alagnon_std_q[i,1])
	segments(i,res_p_alagnon_std_q[i,2],i,res_p_alagnon_std_q[i,1])
	#boxplot
	polygon(c(i-0.3,i+0.3,i+0.3,i-0.3),c(res_p_alagnon_std_q[i,2],res_p_alagnon_std_q[i,2],res_p_alagnon_std_q[i,4],res_p_alagnon_std_q[i,4]),col="green")
	#mean
	segments(i-0.3,mean_res[i,],i+0.3,mean_res[i,])
}

segments(x0=0,y0=mean(mean_res),y1=mean(mean_res),x1=T+1,col="red")
mtext(round(mean(mean_res),5),side=4,line=-0.5,at=mean(mean_res),cex = 0.8,col="red",las=1)
dev.off()
@

\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}res_p_alagnon_std.png}%{a_juv.png}
     \caption{res\_p\_alagnon\_std}
     \label{res_p_alagnon_std} 
\end{figure}

res\_p\_alagnon\_standardisé représente les résidus standardisés du paramètre de blocage de la migration pour le secteur Alagnon.

\clearpage



