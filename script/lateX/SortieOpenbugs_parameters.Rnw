beta_Q_MSL_mont_q<-sum$quantiles
#mean_res<-cbind(sum$statistics[,"Mean"])
mean_res<-sum$statistics["Mean"]

tabl<-sum$quantiles
tabl["Mean"]<-sum$statistics["Mean"]
tabl["SD"]<-sum$statistics["SD"]
tabl=rbind(tabl) #pour en faire une table

