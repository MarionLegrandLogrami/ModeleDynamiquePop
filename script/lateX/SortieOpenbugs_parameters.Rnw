\subsubsection{Représentation des séries de débits utilisées dans le modèle}

<<plot_Q, echo=FALSE, eval=TRUE,results=hide >>=

bugs2jags(str_c(datawd,"data.txt"),"data_model.R")
source("data_model.R")

Q_L_mont_A <- data.frame(sta=rep("Q à Lempdes",length(Q_L_mont_A)),year=1975:(1974+T),saison=rep("Automne",length(Q_L_mont_A)),Q=Q_L_mont_A)
Q_L_mont_P <- data.frame(sta=rep("Q à Lempdes",length(Q_L_mont_P)),year=1975:(1974+T),saison=rep("Printemps",length(Q_L_mont_P)),Q=Q_L_mont_P)
Q_VB_mont_A <- data.frame(sta=rep("Q à Vieille-Brioude",length(Q_VB_mont_A)),year=1975:(1974+T),saison=rep("Automne",length(Q_VB_mont_A)),Q=Q_VB_mont_A)
Q_VB_mont_P <- data.frame(sta=rep("Q à Vieille-Brioude",length(Q_VB_mont_P)),year=1975:(1974+T),saison=rep("Printemps",length(Q_VB_mont_P)),Q=Q_VB_mont_P)
Q_P_mont_A <- data.frame(sta=rep("Q à Prades",length(Q_P_mont_A)),year=1975:(1974+T),saison=rep("Automne",length(Q_P_mont_A)),Q=Q_P_mont_A)
Q_P_mont_P <- data.frame(sta=rep("Q à Prades",length(Q_P_mont_P)),year=1975:(1974+T),saison=rep("Printemps",length(Q_P_mont_P)),Q=Q_P_mont_P)

Q_serie_bugs<-rbind(Q_L_mont_A,Q_L_mont_P,Q_VB_mont_A,Q_VB_mont_P,Q_P_mont_A,Q_P_mont_P)

Q_serie_bugs$sta <- factor(Q_serie_bugs$sta, levels = c("Q à Lempdes", "Q à Vieille-Brioude","Q à Prades"))
Q_serie_bugs$saison <- factor(Q_serie_bugs$saison, levels = c("Printemps", "Automne"))

plot_Q <- ggplot(data=Q_serie_bugs,aes(x=year,y=Q))+
		geom_line()+
		facet_grid(sta ~ saison, switch = "y",scales="free_y")+
		theme(strip.text = element_text(face = "bold"))
ggsave(str_c(imgwd,"plot_Q.png"), plot_Q, dpi = 300, width = 4, height = 6)	
@


\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}plot_Q.png}
     \caption{représentation des séries de débits utilisées dans le modèle}
     \label{serie_Q}
\end{figure}

\clearpage

\subsubsection{Corrélogramme des séries de débits utilisées dans le modèle}
<<corrplot_Q, echo=FALSE, eval=TRUE,results=hide>>=

Q_repartition<-pivot_wider(Q_serie_bugs,names_from =c(sta,saison), values_from = Q) #ratio_surv=ratio_surv, p_surv=p_surv, 
Q_repartition <- select(Q_repartition, -year)
colnames(Q_repartition)<-c("Lempdes_Automne","Lempdes_Printemps","VB_Automne","VB_Printemps","Prades_Automne","Prades_Printemps")

png(filename=str_c(imgwd,"corr_Q_rep.png"),width=800,height=800)
corrplot(cor(Q_repartition,use = "complete.obs",method = "pearson"), method = "circle", addCoef.col="black",number.cex = 0.8, order="AOE",type="upper",tl.srt=45)
# corrgram(Q_repartition,lower.panel=panel.shade, upper.panel=panel.pie,order=TRUE)
dev.off()

@

\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}corr_Q_rep.png}%{a_juv.png}
     \caption{Débits utilisés dans le modèle linéaire expliquant la
     répartition des adultes par les débits (Lempdes sur Alagnon pour les
     adultes migrant dans l'Alagnon, Vieille-Brioude pour les adultes migrant
     entre Langeac et Poutès et Prades pour les adultes migrant en amont de
     Poutès)}
     \label{corr_Q_rep} 
\end{figure}


\clearpage

\section{Production des juvéniles (de l'adulte au juvénile)}

%=================================================================================
\subsection{a}
%=================================================================================
<< a, echo=FALSE, eval=TRUE,results=hide >>=
a=read.coda(str_c(datawd,"aCODAchain1.txt"),str_c(datawd,"aCODAindex.txt"))
png(filename=str_c(imgwd,"a.png"),width=800,height=800)
par(mfrow = c(2, 1))
plot(a,density=FALSE,auto.layout=FALSE)
plot(a,trace=FALSE,auto.layout=FALSE)
dev.off()

sum=summary(a, probs=seq(0,1,0.1))

# Pour voir le contenu de l'objet sum = str(sum)
#permet de savoir le nom des colonnes et tous les attributs (longueur, class, etc.) = attributes(sum)

#tabl=cbind(rbind(as.data.frame(sum[c(1)])[1,]),rbind(as.data.frame(sum[c(2)])[1:5,]))
#tabl=cbind(rbind(sum$statistics["Mean"]),rbind(sum$quantiles))

tabl<-sum$quantiles
tabl["Mean"]<-sum$statistics["Mean"]
tabl["SD"]<-sum$statistics["SD"]
tabl=rbind(tabl) #pour en faire une table

tab<-xtable(x=tabl,label="a",caption="Statistiques de a")#,align=c("L",rep("C",5)))

o<-print(tab, file = str_c(tabwd,"a.tex"), 
		table.placement = "htbp",
		caption.placement = "top",
		NA.string = "",
		include.rownames=FALSE
		)

@

\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}a.png}%{a_juv.png}
     \caption{a}
     \label{a} 
\end{figure}

\input{\Sexpr{tabwd}a.tex}
a représente le paramètre de pente de la relation Stock-Recrutement pour le compartiment sauvage, il représente donc le nombre d'oeufs produits par géniteur aux faibles déposes d'oeufs.
\clearpage

