\section{Répartition des adultes}




%====================================
\subsection{N\_Alagnon}
%====================================
<< N_alagnon, echo=FALSE, eval=TRUE,results=hide >>=
N_alagnon <- read_param_coda("N_alagnon", datawd)
q <- param_quantiles(N_alagnon)

# médiane représentée (pas la moyenne, volontairement écartée à l'origine)
boxplot_years_png(imgwd, "N_alagnon",
                   data = q$quantiles, years = 1:T,
                   ylab_txt = "N_alagnon", ylim_range = c(0, 1000), y_at = seq(0, 1000, by = 200),
                   col_box = "green",
                   mean_line = mean(q$mean), mean_line_range = c(0, T + 1))
@

\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}N_alagnon.png}%{a_juv.png}
     \caption{N\_alagnon}
     \label{N_alagnon} 
\end{figure}

N\_Alagnon représente les adultes migrant sur le cours d'eau Alagnon.

\clearpage

%====================================
\subsection{N\_Langeac}
%====================================
<< N_langeac, echo=FALSE, eval=TRUE,results=hide >>=
N_langeac <- read_param_coda("N_langeac", datawd)
q <- param_quantiles(N_langeac)

boxplot_years_png(imgwd, "N_langeac",
                   data = q$quantiles, years = 1:T,
                   ylab_txt = "N_langeac", ylim_range = c(0, 5000), y_at = seq(0, 5000, by = 1000),
                   col_box = "green", center_line = q$mean,
                   points_overlay = list(x = c(30:34, 42:T), y = N_langeac_obs[c(30:34, 42:T)]),
                   mean_line = mean(q$mean), mean_line_range = c(0, T + 1))
@

\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}N_langeac.png}%{a_juv.png}
     \caption{N\_langeac}
     \label{N_langeac} 
\end{figure}

N\_Langeac représente les effectifs d'adultes ayant franchi Langeac. Ils sont calculés en tirant dans une binomiale avec probabilité de franchir Langeac et effectif égal à ce qui est passé à Vichy moins les captures pour la pisciculture moins les poissons qui ont migré sur l'Alagnon. La station de Langeac est considérée comme partielle dans le modèle. Ainsi, même lorsque la station de comptage est en fonctionnement, les effectifs sont estimés. A titre d'indication, les données observées à Langeac sont représentées sous forme de point.

\clearpage

%====================================
\subsection{N\_Poutès}
%====================================
<< N_poutes, echo=FALSE, eval=TRUE,results=hide >>=
N_poutes <- read_param_coda("N_poutes", datawd)
q <- param_quantiles(N_poutes)
N_poutes_tot <- c(N[12:44, 4], q$mean)

# adulte_poutes : compilation des adultes ayant franchi Poutès sur toute la période
# (station fermée avant 1986 -> 0, comptage exhaustif 1986-2018, estimé par le modèle depuis)
adulte_poutes <- matrix(0, nrow = 10000, ncol = T)
adulte_poutes[, 12:44] <- matrix(N[12:44, 4], nrow = 10000, ncol = 33, byrow = TRUE)
adulte_poutes[, 45:T] <- N_poutes[, 1:(T-44)]

boxplot_years_png(imgwd, "N_poutes",
                   data = rbind(matrix(NA, nrow = 44, ncol = 5), q$quantiles), years = 1:T,
                   ylab_txt = "N_poutes", ylim_range = c(0, 200), y_at = seq(0, 200, by = 50),
                   col_box = "green", center_line = c(rep(NA, 44), q$mean),
                   points_overlay = list(x = 12:44, y = N[12:44, 4]),
                   mean_line = mean(N_poutes_tot), mean_line_range = c(0, T + 1),
                   mean_label_digits = 2)
@

\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}N_poutes.png}%{a_juv.png}
     \caption{N\_poutes}
     \label{N_poutes}
\end{figure}

N\_Poutès représente les effectifs de saumon ayant franchi Poutès. Durant la période où la station de comptage a fonctionné, les effectifs comptés sont exhaustifs et représentés par des points noirs. Depuis le démarrage des travaux (2019) et le réaménagement de l'ouvrage (2021), la période de transparence ne permet plus le comptage. Les effectifs sont estimés (boxplot).

\clearpage


%=================================================================================
\subsection{Adultes restant sur les différents secteurs de l'Allier}
%=================================================================================
Les adultes restant sur l'Alagnon correspondent au paramètre N\_alagnon (voir plus haut), et ceux restant en amont de Poutès correspondent au paramètre N\_poutes (voir plus haut). En revenche, pour le secteur Vichy-Langeac et Langeac-Poutès, les effectifs restant sur ces secteurs peuvent être estimés.

%=================================================================================
\subsubsection{Adultes restant sur Vichy-Langeac}
%=================================================================================

<<adulte_Vichy_Langeac, echo=FALSE, eval=TRUE,results=hide>>=
# adulte_vichy : adultes restant sur le secteur Vichy-Langeac = adultes arrivés à
# Vichy (observés 1997-2003 & depuis 2005, estimés sinon) moins ceux partis sur
# l'Alagnon et ceux ayant franchi Langeac
adulte_vichy <- matrix(NA, nrow = 10000, ncol = T)
adulte_vichy[, 1:22]  <- N_vichy[, 1:22] - N_alagnon[, 1:22] - N_langeac[, 1:22]
adulte_vichy[, 23:29] <- matrix(N[23:29, 1], nrow = 10000, ncol = 7, byrow = TRUE) - N_alagnon[, 23:29] - N_langeac[, 23:29]
adulte_vichy[, 30]    <- N_vichy[, 23] - N_alagnon[, 30] - N_langeac[, 30]
adulte_vichy[, 31:T]  <- matrix(N[31:T, 1], nrow = 10000, ncol = T-30, byrow = TRUE) - N_alagnon[, 31:T] - N_langeac[, 31:T]

q <- param_quantiles(as.mcmc(adulte_vichy))

boxplot_years_png(imgwd, "adultes_vichy",
                   data = q$quantiles, years = 1:T,
                   ylab_txt = "adultes restant sur le secteur Vichy-Langeac",
                   ylim_range = c(0, 6000), y_at = seq(0, 6000, by = 1000),
                   col_box = "green", center_line = q$mean,
                   mean_line = mean(q$quantiles[23:T, ]), mean_line_range = c(23, T + 1),
                   mean_label_digits = 2)
@


\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}adultes_vichy.png}%{a_juv.png}
     \caption{Adultes restant sur le secteur Vichy-Langeac}
     \label{adultes_vichy_langeac}
\end{figure}

\clearpage

%=================================================================================
\subsubsection{Adultes restant sur Langeac-Poutès}
%=================================================================================

<<adulte_Langeac_Poutes, echo=FALSE, eval=TRUE,results=hide>>=
# adulte_langeac : adultes restant sur le secteur Langeac-Poutès. Avant 1986 (t=1:11)
# Poutès est fermé donc tous les poissons restent sur le secteur ; ensuite on
# soustrait ceux ayant franchi Poutès (adulte_poutes)
adulte_langeac <- matrix(NA, nrow = 10000, ncol = T)
adulte_langeac[, 1:11] <- N_langeac[, 1:11]
adulte_langeac[, 12:T] <- N_langeac[, 12:T] - adulte_poutes[, 12:T]

q <- param_quantiles(as.mcmc(adulte_langeac))

#on ajoute les données de comptage quand stations de Langeac et Poutès fonctionnent en même temps
comptage<-N_langeac_obs[12:44]-N[12:44,4]
comptage[comptage<0]<-NA

boxplot_years_png(imgwd, "adultes_langeac",
                   data = q$quantiles, years = 1:T,
                   ylab_txt = "adultes restant sur le secteur Langeac-Poutès",
                   ylim_range = c(0, 8000), y_at = seq(0, 8000, by = 500),
                   col_box = "green", center_line = q$mean,
                   points_overlay = list(x = 12:44, y = comptage),
                   mean_line = mean(q$quantiles[12:T, 3]), mean_line_range = c(12, T + 1),
                   mean_label_digits = 2)
@

\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}adultes_langeac.png}%{a_juv.png}
     \caption{Adultes restant sur le secteur Langeac-Poutès}
     \label{adultes_langeac_poutes}
\end{figure}

Le nombre d'adultes restant sur le secteur Langeac-Poutès est estimé à partir des effectifs qui sont passés à Vichy mais ne sont pas allés sur l'Alagnon et n'ont pas été capturé par la pisciculture et qui n'ont pas non plus franchi Poutès (on soustrait les effectifs comptés ou estimés à Poutès). Lorsque les stations de Langeac et Poutès ont fonctionné sur la même période on soustrait les effectifs comptés à Poutès à ceux de Langeac (pour rappel, la station de Langeac est considérée comme une station non-exhaustive dans le modèle).

\clearpage

%=================================================================================
\subsubsection{Pourcentage d'adultes dans les différents secteurs}
%=================================================================================

<<pour_adulte_secteur, echo=FALSE, eval=TRUE,results=hide >>=

#N_vichy = adultes total sur l'ensemble de la zone

# Poutès : fermé avant 1986 (t=1:11 -> 0), comptage exhaustif 1986-2019 (t=12:46,
# hormis 2004 où Vichy est estimé), modèle depuis 2020 (t=47:T)
prop_P <- matrix(0, nrow = 10000, ncol = T)
prop_P[, 12:22] <- adulte_poutes[, 12:22] / N_vichy[, 12:22]
prop_P[, 23:29] <- sweep(adulte_poutes[, 23:29], 2, N[23:29, 1], "/")
prop_P[, 30]    <- adulte_poutes[, 30] / N_vichy[, 23]
prop_P[, 31:46] <- sweep(adulte_poutes[, 31:46], 2, N[31:46, 1], "/")
prop_P[, 47:T]  <- sweep(N_poutes[, 1:(T-46)], 2, N[47:T, 1], "/")

# Autres secteurs : même dénominateur (Vichy estimé avant 1997 et en 2004, sinon
# comptage réel N[,1])
prop_share <- function(x) {
  d <- matrix(NA, nrow = 10000, ncol = T)
  d[, 1:22]  <- x[, 1:22] / N_vichy[, 1:22]
  d[, 23:29] <- sweep(x[, 23:29], 2, N[23:29, 1], "/")
  d[, 30]    <- x[, 30] / N_vichy[, 23]
  d[, 31:T]  <- sweep(x[, 31:T], 2, N[31:T, 1], "/")
  d
}
prop_VL <- prop_share(adulte_vichy)
prop_A  <- prop_share(N_alagnon)
prop_LP <- prop_share(adulte_langeac)

prop_VL_q <- param_quantiles(as.mcmc(prop_VL))
prop_A_q  <- param_quantiles(as.mcmc(prop_A))
prop_LP_q <- param_quantiles(as.mcmc(prop_LP))
prop_P_q  <- param_quantiles(as.mcmc(prop_P))

# affichage secteur amont Poutès : boxplot modélisé seulement pour 12:22 et 47:T
# (comptage exhaustif en points pour 23:46, secteur inaccessible donc masqué avant 1986)
prop_P_display <- prop_P_q$quantiles
prop_P_display[c(1:11, 23:46), ] <- NA
prop_P_center_display <- prop_P_q$mean
prop_P_center_display[c(1:11, 23:46)] <- NA

png(filename = str_c(imgwd, "proportion_adultes.png"), width = 800, height = 800)
par(mfrow = c(4, 1))

custom_plot(data = prop_VL_q$quantiles, years = 1:T,
            main_title = "Proportion d'adultes sur le secteur Vichy-Langeac",
            ylab_txt = "proportion adultes", ylim_range = c(0, 1), y_at = seq(0, 1, by = 0.2),
            col_box = "green", center_line = prop_VL_q$mean,
            mean_line = mean(prop_VL_q$quantiles[, 3]), mean_line_range = c(0, T + 1),
            mean_label_digits = 2)

custom_plot(data = prop_A_q$quantiles, years = 1:T,
            main_title = "Proportion d'adultes sur le secteur Alagnon",
            ylab_txt = "proportion adultes", ylim_range = c(0, 1), y_at = seq(0, 1, by = 0.2),
            col_box = "green", center_line = prop_A_q$mean,
            mean_line = mean(prop_A_q$quantiles[, 3]), mean_line_range = c(1, T + 1),
            mean_label_digits = 2)

custom_plot(data = prop_LP_q$quantiles, years = 1:T,
            main_title = "Proportion d'adultes sur le secteur Langeac-Poutès",
            ylab_txt = "proportion adultes", ylim_range = c(0, 1), y_at = seq(0, 1, by = 0.2),
            col_box = "green", center_line = prop_LP_q$mean,
            mean_line = mean(prop_LP_q$quantiles[, 3]), mean_line_range = c(1, T + 1),
            mean_label_digits = 2)

custom_plot(data = prop_P_display, years = 1:T,
            main_title = "Proportion d'adultes sur le secteur amont Poutès",
            ylab_txt = "proportion adultes", ylim_range = c(0, 1), y_at = seq(0, 1, by = 0.2),
            col_box = "green", center_line = prop_P_center_display,
            points_overlay = list(x = 23:46, y = N[23:46, 4]),
            mean_line = mean(prop_P_q$quantiles[12:T, 3]), mean_line_range = c(12, T + 1),
            mean_label_digits = 2)

dev.off()

@

\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}proportion_adultes.png}%{a_juv.png}
     \caption{proportion des adultes dans les différents secteurs}
     \label{proportion_adultes} 
\end{figure}


Les proportions dans les différents secteurs, sont calculés à partir des saumons estimés (avant 1997) ou comptés à Vichy, ainsi que des adultes estimés dans les différents secteurs du modèle.

\clearpage
