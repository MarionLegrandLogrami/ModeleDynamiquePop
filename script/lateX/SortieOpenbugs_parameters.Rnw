p_Rmax_L_q<-sum$quantiles

#Add column to sort
p_Rmax_L_q<-cbind(as.numeric(gsub("[^0-9]","",gsub(",[0-9]","",row.names(p_Rmax_L_q)))),p_Rmax_L_q)
annee_na<-seq(1,T,1)[!(seq(1,T,1) %in% p_Rmax_L_q[,1])]
p_Rmax_L_q_na<-matrix(c(rep(NA,length(annee_na))),nrow=length(annee_na),ncol=5)
row.names(p_Rmax_L_q_na)<-str_c("p_Rmax[",annee_na,",1]")
p_Rmax_L_q_na<-cbind(annee_na,p_Rmax_L_q_na)
p_Rmax_L_2<-rbind(p_Rmax_L_q_na,p_Rmax_L_q)
p_Rmax_L_q<-p_Rmax_L_2[order(p_Rmax_L_2[,1]),2:6]

mean_calc <-cbind(sum$statistics[,"Mean"])
mean_res <- merge(p_Rmax_L_2,mean_calc,by=0,all.x=TRUE)
mean_res <- mean_res[order(mean_res[,2]),c(1,8)]


png(filename=str_c(imgwd,"p_Rmax_L.png"),width=800,height=800)

plot(1,1,type="n",axes=FALSE,xlim=c(0,T),xlab="Years",ylim=c(0,1),ylab="p_Rmax_L")

# trace l'axe des ordonnées
axis(2,at = seq(0,1,by=0.2),labels=c(0,0.2,0.4,0.6,0.8,1),cex.axis = 0.9,las =1,col = "grey55") # trace l'axe des abscisses
lab1=c(1976,1980,1990,2000,2010,1974+T)
axis(1,at = c(1,5,15,25,35,(T-1)),
		labels=lab1,
		cex.axis = 0.9,las = 1,col = "grey55")

for(i in 1: (T-1)){
	#whiskers
	#95%
	segments(i-0.15,p_Rmax_L_q[i,5],i+0.15,p_Rmax_L_q[i,5])
	segments(i,p_Rmax_L_q[i,4],i,p_Rmax_L_q[i,5])
	#5%
	segments(i-0.15,p_Rmax_L_q[i,1],i+0.15,p_Rmax_L_q[i,1])
	segments(i,p_Rmax_L_q[i,2],i,p_Rmax_L_q[i,1])
	#boxplot
	polygon(c(i-0.3,i+0.3,i+0.3,i-0.3),c(p_Rmax_L_q[i,2],p_Rmax_L_q[i,2],p_Rmax_L_q[i,4],p_Rmax_L_q[i,4]),col="green")
	#mean
	segments(i-0.3,mean_res[i,2],i+0.3,mean_res[i,2])
}

segments(x0=0,y0=mean(mean_res[,2],na.rm=TRUE),y1=mean(mean_res[,2],na.rm=TRUE),x1=T,col="red")
mtext(round(mean(mean_res[,2],na.rm=TRUE),4),side=4,line=0,at=mean(mean_res[,2],na.rm=TRUE),cex = 0.8,col="red",las=1)

dev.off()

@

\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}p_Rmax_L.png}
     \caption{p\_Rmax\_L}
     \label{p_Rmax_L} 
\end{figure}
\clearpage

