@

\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}N_langeac.png}%{a_juv.png}
     \caption{N\_langeac}
     \label{N_langeac} 
\end{figure}

N\_Langeac représente les effectifs d'adultes ayant franchi Langeac. Ils sont calculés en tirant dans une binomiale avec probabilité de franchir Langeac et effectif égal à ce qui est passé à Vichy moins les captures pour la pisciculture moins les poissons qui ont migré sur l'Alagnon. La station de Langeac est considérée comme partielle dans le modèle. Ainsi, même lorsque la station de comptage est en fonctionnement, les effectifs sont estimés. A titre d'indication, les données observées à Langeac sont représentées sous forme de point.

\clearpage

%====================================
\subsection{N\_Poutès}
%====================================
<< N_poutes, echo=FALSE, eval=TRUE,results=hide >>=
N_poutes=read.coda(str_c(datawd,"N_poutesCODAchain1.txt"),str_c(datawd,"N_poutesCODAindex.txt"))

sum=summary(N_poutes, probs=seq(0,1,0.1))
N_poutes_q<-sum$quantiles
mean_res<-cbind(sum$statistics[,"Mean"])
N_poutes_tot<-c(N[12:44,4],as.vector(cbind(sum$statistics[,"Mean"])))

adulte_poutes<-array(NA,dim=c(10000,T))

for (t in 1:11){
  for (i in 1:10000){
    adulte_poutes[i,t]<-0
  }
}
for (t in 12:44){
  for (i in 1:10000){
    adulte_poutes[i,t]<-N[t,4]
  }
}
for (t in 45:T){
  for (i in 1:10000){
    adulte_poutes[i,t]<-N_poutes[i,(t-44)]
  }
}


png(filename=str_c(imgwd,"N_poutes.png"),width=800,height=800)

plot(1,1,type="n",axes=FALSE,xlim=c(0,T),xlab="Years",ylim=c(0,200),ylab="N_poutes")

# trace l'axe des ordonnées
axis(2,at = seq(0,200,by=50),labels=seq(0,200,by=50),cex.axis = 0.9,las = 1,col = "grey55")
# trace l'axe des abscisses
lab1=c(1975,1980,1990,2000,2010,1974+T)
axis(1,at = c(1,6,16,26,36,T),
		labels=lab1,
		cex.axis = 0.9,las = 1,col = "grey55")

points(x=seq(12,44,1),N[12:44,4],pch=16)

for(i in 45:T){
	#whiskers
	#95%
	segments(i-0.15,N_poutes_q[(i-44),5],i+0.15,N_poutes_q[(i-44),5])
	segments(i,N_poutes_q[(i-44),4],i,N_poutes_q[(i-44),5])
	#5%
	segments(i-0.15,N_poutes_q[(i-44),1],i+0.15,N_poutes_q[(i-44),1])
	segments(i,N_poutes_q[(i-44),2],i,N_poutes_q[(i-44),1])
	#boxplot
	polygon(c(i-0.3,i+0.3,i+0.3,i-0.3),c(N_poutes_q[(i-44),2],N_poutes_q[(i-44),2],N_poutes_q[(i-44),4],N_poutes_q[(i-44),4]),col="green")
	#mean
	segments(i-0.3,mean_res[(i-44),],i+0.3,mean_res[(i-44),])
}

segments(x0=0,y0=mean(N_poutes_tot),y1=mean(N_poutes_tot),x1=T+1,col="red")
mtext(round(mean(N_poutes_tot),2),side=4,line=0,at=mean(N_poutes_tot),cex = 0.8,col="red",las=1)
dev.off()
@

\begin{figure}[ht]
     \includegraphics{\Sexpr{imgwd}N_poutes.png}%{a_juv.png}
     \caption{N\_poutes}
     \label{N_poutes}
\end{figure}

N\_Poutès représente les effectifs de saumon ayant franchi Poutès. Durant la période où la station de comptage a fonctionné, les effectifs comptés sont exhaustifs et représentés par des points noirs. Depuis le démarrage des travaux (2019) et le réaménagement de l'ouvrage (2021), la période de transparence ne permet plus le comptage. Les effectifs sont estimés (boxplot).

\clearpage


%=================================================================================
\subsection{Adultes restant sur les différents secteurs de l'Allier}
%=================================================================================
Les adultes restant sur l'Alagnon correspondent au paramètre N\_alagnon (voir plus haut), et ceux restant en amont de Poutès correspondent au paramètre N\_poutes (voir plus haut). En revenche, pour le secteur Vichy-Langeac et Langeac-Poutès, les effectifs restant sur ces secteurs peuvent être estimés.

%=================================================================================
\subsubsection{Adultes restant sur Vichy-Langeac}
%=================================================================================

<<adulte_Vichy_Langeac, echo=FALSE, eval=TRUE,results=hide>>=
#on compile la moyenne des estimations pour les années où on n'a pas la station de Vichy et les données observées quand la station est en fonctionnement
N_vichy_tot<-c(as.vector(mean_res_vichy[1:22]),N[23:29,1],as.vector(mean_res_vichy[23:23]),N[31:T,1])

adulte_vichy<-array(NA,dim=c(10000,T))

for (t in 1:22){
  for (i in 1:10000){
    adulte_vichy[i,t]<-N_vichy[i,t]-N_alagnon[i,t]-N_langeac[i,t]
  }
}
for (t in 23:29){
  for (i in 1:10000){
    adulte_vichy[i,t]<-N[t,1]-N_alagnon[i,t]-N_langeac[i,t]
  }
}
for (t in 30:30){
  for (i in 1:10000){
    adulte_vichy[i,t]<-N_vichy[i,(t-7)]-N_alagnon[i,t]-N_langeac[i,t]
  }
}
for (t in 31:T){
  for (i in 1:10000){
    adulte_vichy[i,t]<-N[t,1]-N_alagnon[i,t]-N_langeac[i,t]
  }
}

adulte_vichy2<-as.mcmc(adulte_vichy)

sum=summary(adulte_vichy2, probs=seq(0,1,0.1))
adulte_vichy_q<-sum$quantiles
mean_res<-cbind(sum$statistics[,"Mean"])

png(filename=str_c(imgwd,"adultes_vichy.png"),width=800,height=800)

plot(1,1,type="n",axes=FALSE,xlim=c(0,T),xlab="Years",ylim=c(0,6000),ylab="adultes restant sur le secteur Vichy-Langeac")

# trace l'axe des ordonnées
axis(2,at = seq(0,6000,by=1000),labels=seq(0,6000,by=1000),cex.axis = 0.9,las = 1,col = "grey55")
# trace l'axe des abscisses
lab1=c(1975,1980,1990,2000,2010,1974+T)
axis(1,at = c(1,6,16,26,36,T),
		labels=lab1,
		cex.axis = 0.9,las = 1,col = "grey55")


#for(i in (1997-1974):T){ #on démarre à l'ouverture de la STACOMI
for(i in 1:T){
	#whiskers
	#95%
	segments(i-0.15,adulte_vichy_q[(i),5],i+0.15,adulte_vichy_q[(i),5])
	segments(i,adulte_vichy_q[(i),4],i,adulte_vichy_q[(i),5])
	#5%
	segments(i-0.15,adulte_vichy_q[(i),1],i+0.15,adulte_vichy_q[(i),1])
	segments(i,adulte_vichy_q[(i),2],i,adulte_vichy_q[(i),1])
	#boxplot
	polygon(c(i-0.3,i+0.3,i+0.3,i-0.3),c(adulte_vichy_q[(i),2],adulte_vichy_q[(i),2],adulte_vichy_q[(i),4],adulte_vichy_q[(i),4]),col="green")
	#mean
	segments(i-0.3,mean_res[(i),],i+0.3,mean_res[(i),])
}

segments(x0=23,y0=mean(adulte_vichy_q[23:T,]),y1=mean(adulte_vichy_q[23:T,]),x1=T+1,col="red")
mtext(round(mean(adulte_vichy_q[23:T,]),2),side=4,line=0,at=mean(adulte_vichy_q[23:T,]),cex = 0.8,col="red",las=1)
dev.off()

