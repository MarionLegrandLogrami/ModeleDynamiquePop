%====================================
<< sigma_p_comptage, echo=FALSE, eval=FALSE,results=hide >>=
tau_p_comptage=read.coda(str_c(datawd,"tau_p_comptageCODAchain1.txt"),str_c(datawd,"tau_p_comptageCODAindex.txt"))
sigma_p_comptage=sqrt(1/tau_p_comptage)
dimnames(sigma_p_comptage)[[2]]<-"sigma_p_comptage" #comme je recalcule sigma_p_comptage à partir de tau_p_comptage il avait gard le nom tau_p_comptage et c'était ce nom qu'il affichait sur le graph. En changeant dimnames ça change le nom du graph

png(filename=str_c(imgwd,"sigma_p_comptage.png"),width=800,height=800)
plot(sigma_p_comptage)
dev.off()

sum=summary(sigma_p_comptage, probs=seq(0,1,0.1))

# Pour voir le contenu de l'objet sum = str(sum)
#permet de savoir le nom des colonnes et tous les attributs (longueur, class, etc.) = attributes(sum)

#tabl=cbind(rbind(as.data.frame(sum[c(1)])[1,]),rbind(as.data.frame(sum[c(2)])[1:5,]))
#tabl=cbind(rbind(sum$statistics["Mean"]),rbind(sum$quantiles))

tabl<-sum$quantiles
tabl["Mean"]<-sum$statistics["Mean"]
tabl["SD"]<-sum$statistics["SD"]
tabl=rbind(tabl) #pour en faire une table

tab<-xtable(x=tabl,label="sigma_p_comptage",caption="Statistiques de sigma\\_p\\comptage")#,align=c("L",rep("C",5)))

o<-print(tab, file = str_c(tabwd,"sigma_p_comptage.tex"), 
		table.placement = "htbp",
		caption.placement = "top",
		NA.string = "",
		include.rownames=FALSE
		)
		
@

