%\section{N\_Langeac_count}
%====================================
<< N_langeac_count, echo=FALSE, eval=FALSE,results=hide >>=
N_langeac_count <- read_param_coda("min_L", datawd)
q <- param_quantiles(N_langeac_count)

# échantillonné pour t=12:28 puis t=35:41 (observé/points ailleurs entre les deux : 29:34 et 42:T)
data_full <- matrix(NA, nrow = T, ncol = 5)
data_full[12:28, ] <- q$quantiles[1:17, ]
data_full[35:41, ] <- q$quantiles[18:24, ]
mean_full <- rep(NA, T)
mean_full[12:28] <- q$mean[1:17]
mean_full[35:41] <- q$mean[18:24]

boxplot_years_png(imgwd, "N_langeac_count",
                   data = data_full, years = 1:T,
                   ylab_txt = "N_langeac_count", ylim_range = c(0, 700), y_at = seq(0, 700, by = 100),
                   col_box = "green", center_line = mean_full,
                   points_overlay = list(x = c(29:34, 42:T), y = min_L[c(29:34, 42:T)]),
                   mean_line = mean(mean_full, na.rm = TRUE), mean_line_range = c(0, T))
@


