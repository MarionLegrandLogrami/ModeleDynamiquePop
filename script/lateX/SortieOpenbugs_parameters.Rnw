<< beta_Q_MSL_mont, echo=FALSE, eval=TRUE,results=hide >>=
beta_Q_MSL_mont=read.coda(str_c(datawd,"beta_Q_MSL_montCODAchain1.txt"),str_c(datawd,"beta_Q_MSL_montCODAindex.txt"))
