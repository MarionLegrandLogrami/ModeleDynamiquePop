legend(15,1,legend=c(expression(p^seuils < 500),expression(p^seuils < 250),expression(p^seuils < 100),expression(p^seuils < 50),expression(p^seuils < 10)),
		pch=c(16,16,16,16,16),col=c("grey45","grey55","grey65","grey75","grey85"),bty="n" )


dev.off()
}
@

Dans ce scénario, les repeuplements sont arrętés et la migration de montaison et
de dévalaison est améliorée ŕ hauteur de 100\% ŕ l'ouvrage de Poutčs. Les
retours d'adultes restent faibles męme si ce scénario est plus favorable que les
deux précédents en terme de réponse de la population de saumons (nombre médian ŕ Vichy sur les 5 derničres années
\Sexpr{round(median(p100_N_vichy[,(T+16):(T+20)]),0)}) (figure
\ref{fig_retour_20ans_poutes100}). La probabilité d'observer moins de
500 individus ŕ Vichy reste toujours importante
(\Sexpr{round(mean(p100_p_under_500_vichy[16:20])*100,1)}\% en moyenne sur les 5
derničres années de la période de projection) et continue ŕ augmenter (figure
\ref{fig_seuil_20ans_poutes100}). Dans la nouvelle configuration ŕ 4 zones, la
seule suppression de l'ouvrage de Poutčs ne serait pas suffisante pour retrouver une population qui se renouvelle
naturellement.

\begin{figure}[ht]
     \includegraphics{100poutes_TotalReturns_proj20years_2016_12_19.pdf}
     \caption[Retours d'adultes ŕ Vichy avec arręt des repeuplements et
     amélioration des conditions ŕ Poutčs de 100\%]{Retours
     d'adultes ŕ Vichy avec arręt des repeuplements et amélioration
     des conditions de migration ŕ la montaison et dévalaison ŕ Poutčs
     ŕ hauteur de 100\%. Une projection des retours d'adultes ŕ 20 ans est
     réalisée.
     Les boxplots indiquent les quantiles 2.5, 25, médiane, 75 et 97.5. Les cercles pleins indiquent les années pour lesquelles la
     station de comptage de Vichy est opérationnelle et fournit le nombre de
     retours d'adultes. Les boxplots orange correspondent aux estimations des
     retours d'adultes ŕ Vichy pour les 20 prochaines années.}
     \label{fig_retour_20ans_poutes100} 
\end{figure}

\begin{figure}[ht]
     \includegraphics{100poutes_Threshold_2016_12_19.pdf}
     \caption[Probabilité d'atteindre certains seuils de nombre
     d'adultes ŕ Vichy avec 100\% d'amélioration ŕ Poutčs]{Evolution de la
     probabilité p\up{seuils} d'atteindre certains seuils arbitraires de nombre
     d'adultes de retours ŕ Vichy sur la période \Sexpr{1974+T+1}--\Sexpr{1974+T+20}, dans le scénario
     d'arręt des repeuplements et d'amélioration des conditions de migration ŕ la montaison et ŕ la
     dévalaison ŕ Poutčs ŕ hauteur de 100\%.}
     \label{fig_seuil_20ans_poutes100} 
\end{figure}

