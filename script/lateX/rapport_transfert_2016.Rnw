plot(1,1,type="n",axes=FALSE,xlim=c(0.5,T+0.5),xlab="Années",ylim=c(0,500000),ylab="",main="nombre estimé de juvéniles dans l'ensemble du systčme")

# trace l'axe des ordonnées
axis(2,at = c(0,100000,200000,300000,400000,500000),
