	pdf(file=str_c(imgwd,"RelationCalibration2_2016_12_19.pdf"),width=5,height=5)
	plot(1,1,type="n",axes=FALSE,xlim=c(0,300),xlab="Nombre de tacons 0+ pęchés en 5 minutes (IA)",ylim=c(0,1.2),ylab="densité (0+ / m-2)",main="")
	
# trace l'axe des ordonnées
	axis(2,at = seq(0,1.2,0.2),cex.axis = 0.8,las = 1,col = "black")
# trace l'axe des abscisses
	axis(1,at = seq(0,300,25),cex.axis = 0.8,las = 1,col = "black")
	
	points(IA_fake,d_fake_q[,3],type="l",col="red",lwd=1.5)
	points(IA_fake,d_fake_q[,1],type="l",col="red",lwd=1.5,lty=2)
	points(IA_fake,d_fake_q[,5],type="l",col="red",lwd=1.5,lty=2)
		
	for(i in 1:17){
		
		#whiskers
		#95%
		segments(IA[i]-4,q.d[i,5],IA[i]+4,q.d[i,5])
		segments(IA[i],q.d[i,4],IA[i],q.d[i,5])
		
		#5%
		segments(IA[i]-4,q.d[i,1],IA[i]+4,q.d[i,1])
		segments(IA[i],q.d[i,2],IA[i],q.d[i,1])
		
		
		#boxplot
		polygon(c(IA[i]-4,IA[i]+4,IA[i]+4,IA[i]-4),c(q.d[i,2],q.d[i,2],q.d[i,4],q.d[i,4]),col="light grey")
		
		#median
		segments(IA[i]-4,q.d[i,3],IA[i]+4,q.d[i,3])
	}
	
	
	dev.off()
}	
@
Le détail des résultats sur les 17 sites échantillonnés sur le double protocole
pęche en 5 minutes et pęche par enlčvements successifs est présenté dans le
tableau \ref{calib}, et la nouvelle relation ŕ la figure \ref{relation_calib2}. Le tableau de conversion des indices tacons 0+ en
5 minutes en densité est présenté ŕ l'Annexe \ref{Annexe4}.
Parmi les 4 points échantillonnés en 2016, deux sites présentaient des
abondances faibles : l'un sur l'Allier (Truchon) et l'autre sur l'Alagnon
(amont pont de Brugeilles). Un site présentait une abondance forte ŕ plus de 150
tacons 0+ par 5 minutes de pęche (camping de Monistrol sur l'Allier). Enfin, un
site présentait une gamme moyenne : Gymnase de Massiac (Alagnon).
Par rapport ŕ
la relation antérieure, ces 4 nouveaux points ne modifient quasiment pas la
vision précédente de cette relation (figure \ref{relation_calib}).

Une derničre campagne de pęche est d'ores et déjŕ prévue pour l'automne 2017
avec la réalisation de 4 nouvelles pęches sur le double protocole pęche IA - pęche
par enlčvements successifs. Ces nouveaux points viendront ainsi compléter les 17 points déjŕ
réalisés afin de renforcer la robustesse de cette relation.

\input{\Sexpr{tabwd}calib.tex}

\begin{figure}
    \includegraphics{RelationCalibration2_2016_12_19.pdf}
    \caption[Relation entre le nombre d'individus capturés en 5 min (IA) et la
    densité de tacons 0+]{Relation entre le nombre d'individus capturés en 5 min
    (IA) et la densité de tacons 0+. Les boxplots indiquent les quantiles ŕ 2.5, 25,
    médiane, 75 et 97.5 pour les 17 points. Les traits pleins et pointillés
    rouges représentent respectivement la médiane et les quantiles 2.5 et 97.5 des
    densités prédites pour les indices d'abondance en 5 minutes.}
    \label{relation_calib2}
\end{figure}

\Floatbarrier

\begin{figure}
    \includegraphics{RelationCalibration_2016_12_19.pdf}
    \caption[Relation entre le nombre d'individus capturés en 5 min (IA) et la
    densité de tacons 0+. Comparaison entre la version ŕ 13 et 17
    points]{Relation entre le nombre d'individus capturés en 5 min (IA) et la
    densité de tacons 0+. Comparaison entre la version ŕ 13 et 17
    points. Les boxplots indiquent les quantiles ŕ 2.5, 25, médiane, 75 et 97.5
    : en gris les 13 points historiques (rivičre Allier), en noir les points réalisés dans la rivičre Allier par LOGRAMI et en bleu les
    points réalisés dans la rivičre Alagnon par LOGRAMI. Les traits pleins et
    pointillés représentent respectivement la médiane et les quantiles 2.5 et 97.5 des densités prédites pour les indices d'abondance en 5 minutes :
    en rouge pour la relation prenant en compte les anciens points plus les 8
    nouveaux (soit 17 points) et en gris la relation établie en 2015 avec les 13
    points.}
    \label{relation_calib}
\end{figure}

\Floatbarrier



