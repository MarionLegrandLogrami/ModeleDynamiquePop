	polygon(c(i-0.3,i+0.3,i+0.3,i-0.3),c(ratio_S_P_q[i,2],ratio_S_P_q[i,2],ratio_S_P_q[i,4],ratio_S_P_q[i,4]),col="darkolivegreen3")
	#median
	segments(i-0.3,ratio_S_P_q[i,3],i+0.3,ratio_S_P_q[i,3])
}
x=seq(23,T,1)
points(x,ratio_S_P_q[23:T,3],pch=16,col="darkolivegreen3")
segments(11.5,S_juv_JP[4,12]/(S_juv_JP[1,12]+S_juv_JP[2,12]+S_juv_JP[3,12]+S_juv_JP[4,12]),23.5,S_juv_JP[4,12]/(S_juv_JP[1,12]+S_juv_JP[2,12]+S_juv_JP[3,12]+S_juv_JP[4,12]),col="grey35",lty=2,lwd=2)
segments(23.5,S_juv_JP[4,24]/(S_juv_JP[1,24]+S_juv_JP[2,24]+S_juv_JP[3,24]+S_juv_JP[4,24]),29.5,S_juv_JP[4,24]/(S_juv_JP[1,24]+S_juv_JP[2,24]+S_juv_JP[3,24]+S_juv_JP[4,24]),col="grey35",lty=2,lwd=2)
segments(29.5,S_juv_JP[4,30]/(S_juv_JP[1,30]+S_juv_JP[2,30]+S_juv_JP[3,30]+S_juv_JP[4,30]),(T+0.5),S_juv_JP[4,30]/(S_juv_JP[1,30]+S_juv_JP[2,30]+S_juv_JP[3,30]+S_juv_JP[4,30]),col="grey35",lty=2,lwd=2)

abline(v=11.5,lty=3)
dev.off()

}
@



La répartition des géniteurs suit sur l'Allier un gradient aval/amont
(figure \ref{fig_repartition_adultes}) avec une majorité de géniteurs dans le
secteur Vichy-Langeac  qui accueille, en moyenne depuis 1986, \Sexpr{round(mean(ratio_S_V[,13:T])*100,1)}\% des géniteurs. Le
secteur Langeac-Poutes reçoit quant ŕ lui en moyenne (depuis 1986)
\Sexpr{round(mean(ratio_S_L[,13:T])*100,1)}\% des géniteurs et le secteur le
plus amont, \Sexpr{round(mean(ratio_S_P[,13:T])*100,1)}\% de géniteurs en
moyenne.
Rapporté ŕ la disponibilité des habitats pour la production de juvéniles, on
constate que le secteur amont de Poutčs est quasiment systématiquement
déficitaire en nombre de géniteurs, que le secteur Langeac-Poutčs est quasiment
chaque année excédentaire et que les géniteurs dans le secteur Vichy-Langeac
suivent relativement bien la disponibilité des habitats, avec une petite
tendance excédentaire en particulier sur les 4 derničres années.

Concernant l'Alagnon, on note que ce secteur ne reçoit que peu de géniteurs
(\Sexpr{round(mean(ratio_S_A[,13:T])*100,1)}\% de la totalité des géniteurs
remontant en amont de Vichy). Tout comme l'amont de Poutčs c'est un secteur oů
le nombre de géniteurs est assez fortement déficitaire par rapport ŕ la quantité
d'habitat disponibles.

\begin{figure}[h]
     \includegraphics[width=0.9\textwidth,keepaspectratio]{SpawnersRedds_GeniteursPotentiels_2016_12_19.pdf}
     \caption[Répartition des adultes dans les différents secteurs]{Répartition
     des adultes dans les différents secteurs. Distribution \textit{a
     posteriori} des abondances annuelles absolues et relatives des géniteurs potentiels dans
     chaque zones du bassin de l'Allier : Vichy-Langeac + Dore (a et e), Alagnon
     (b et f), Langeac-Poutčs (c et g) et Amont de Poutčs (d et h). Les boxplots
     indiquent les quantiles 2.5, 25, médiane, 75 et 97.5. Les lignes pointillées
     horizontales pour d, e, f et g indiquent la disponibilité relative de
     l'habitat potentiel pour les juvéniles. On notera que pour l'amont de Poutčs, il n'y
     a pas d'estimation des abondances absolues car le nombre exact est
     toujours connu (d) et l'abondance relative est connue lorsque les
     comptages ŕ Vichy sont disponibles (h).}
     \label{fig_repartition_adultes} 
\end{figure}


\FloatBarrier


